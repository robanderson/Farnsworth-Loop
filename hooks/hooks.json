{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$HOME/.claude/workflows\" \"$HOME/.claude/agents\" && cp \"${CLAUDE_PLUGIN_ROOT}/.claude/workflows/farnsworth-task.js\" \"${CLAUDE_PLUGIN_ROOT}/.claude/workflows/farnsworth-loop.js\" \"$HOME/.claude/workflows/\" && cp \"${CLAUDE_PLUGIN_ROOT}/.claude/agents/farnsworth-coder.md\" \"${CLAUDE_PLUGIN_ROOT}/.claude/agents/farnsworth-judge.md\" \"${CLAUDE_PLUGIN_ROOT}/.claude/agents/farnsworth-attestor.md\" \"${CLAUDE_PLUGIN_ROOT}/.claude/agents/farnsworth-improver.md\" \"$HOME/.claude/agents/\""
          }
        ]
      }
    ]
  }
}
