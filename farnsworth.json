{
  "workers": [
    {
      "id": "w1",
      "command": [
        "claude",
        "-p",
        "{prompt}",
        "--bare",
        "--model",
        "claude-haiku-4-5",
        "--permission-mode",
        "acceptEdits",
        "--output-format",
        "json"
      ],
      "timeout_seconds": 1800
    }
  ],
  "reviewer": {
    "command": [
      "claude",
      "-p",
      "{prompt}",
      "--bare",
      "--model",
      "claude-opus-4-8",
      "--permission-mode",
      "acceptEdits",
      "--output-format",
      "json"
    ],
    "timeout_seconds": 2700
  },
  "gate": [
    {
      "name": "tests",
      "command": [
        "python3",
        "-m",
        "unittest",
        "discover"
      ]
    }
  ]
}
