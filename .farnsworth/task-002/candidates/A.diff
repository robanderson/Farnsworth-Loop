+    def test_all_gates_run_even_if_first_fails(self):
+        """All gate commands run even if an earlier gate fails."""
+        brief = self._write_brief(name="task-allgates.md", body="all gates")
+        gate = [
+            {
+                "name": "step1",
+                "command": [
+                    "python3",
+                    "-c",
+                    "import sys; sys.stderr.write('step1 fail\\n'); sys.exit(1)",
+                ],
+            },
+            {
+                "name": "step2",
+                "command": ["python3", "-c", "import sys; sys.exit(0)"],
+            },
+        ]
+        # No reviewer (all gates fail -> no candidates pass).
+        cfg_path = os.path.join(self.repo, "farnsworth.json")
+        with open(cfg_path, "w", encoding="utf-8") as fh:
+            json.dump({
+                "workers": [{"id": "w1", "command": ["python3", "-c", FAKE_WORKER_COMMIT_PY, "w1"]}],
+                "gate": gate,
+            }, fh)
+        _git(["add", "-A"], self.repo)
+        _git(["commit", "-m", "allgates config"], self.repo)
+        self._track_workers("task-allgates", ["w1"])
+
+        run_log = run(brief, config_path=cfg_path, cwd=self.repo)
+
+        gate_res = run_log["workers"][0]["gate"]
+        self.assertFalse(gate_res["passed"])
+        # Both gates ran.
+        self.assertEqual(len(gate_res["results"]), 2)
+        self.assertEqual(gate_res["results"][0]["name"], "step1")
+        self.assertEqual(gate_res["results"][0]["exit_code"], 1)
+        self.assertIn("step1 fail", gate_res["results"][0]["autopsy"])
+        self.assertEqual(gate_res["results"][1]["name"], "step2")
+        self.assertEqual(gate_res["results"][1]["exit_code"], 0)
