+    def test_briefing_ordering_and_separator(self):
+        """Review briefing has tips before task text, with literal separator."""
+        tips_path = os.path.join(self.repo, ".code-tips.md")
+        with open(tips_path, "w", encoding="utf-8") as fh:
+            fh.write("# Tips\nSOME_TIP_M2\n")
+        brief = self._write_brief(name="task-brieford.md", body="BRIEF_BODY_M2")
+
+        # Capture the briefing via a worker that writes it to a file.
+        capture_worker_py = (
+            "import sys,pathlib,subprocess;"
+            "prompt=sys.argv[1] if len(sys.argv)>1 else '';"
+            "pathlib.Path('briefing.txt').write_text(prompt);"
+            "subprocess.run(['git','add','-A'],capture_output=True);"
+            "subprocess.run(['git','commit','-m','capture'],capture_output=True);"
+            "print('CAPTURED')"
+        )
+        reviewer_py = (
+            "import sys,json,pathlib,re;"
+            "prompt=sys.argv[1] if len(sys.argv)>1 else '';"
+            "m=re.search(r'\\.farnsworth/([^/]+)/verdict\\.json', prompt);"
+            "task_id=m.group(1) if m else 'task-brieford';"
+            "vdir=pathlib.Path('.farnsworth')/task_id;"
+            "vdir.mkdir(parents=True,exist_ok=True);"
+            "(vdir/'verdict.json').write_text(json.dumps({"
+            "'outcome':'escalate','candidate':None,'reasoning':'ord'}));"
+            "print('REVIEWER_ORD')"
+        )
+        cfg_path = os.path.join(self.repo, "farnsworth.json")
+        with open(cfg_path, "w", encoding="utf-8") as fh:
+            json.dump({
+                "workers": [{"id": "w1", "command": ["python3", "-c", capture_worker_py, "{prompt}"]}],
+                "reviewer": {"command": ["python3", "-c", reviewer_py, "{prompt}"]},
+                "gate": [{"name": "noop", "command": ["python3", "-c", ""]}],
+            }, fh)
+        _git(["add", "-A"], self.repo)
+        _git(["commit", "-m", "ord config"], self.repo)
+        self._track_workers("task-brieford", ["w1"])
+
+        run(brief, config_path=cfg_path, cwd=self.repo)
+
+        wt = os.path.join(self.tmp, "task-brieford-w1")
+        with open(os.path.join(wt, "briefing.txt"), "r", encoding="utf-8") as fh:
+            briefing = fh.read()
+
+        # Tips come first; task text comes second.
+        self.assertIn("SOME_TIP_M2", briefing)
+        self.assertIn("\n\nTASK: ", briefing)
+        self.assertIn("BRIEF_BODY_M2", briefing)
+        tip_idx = briefing.index("SOME_TIP_M2")
+        task_idx = briefing.index("BRIEF_BODY_M2")
+        sep_idx = briefing.index("\n\nTASK: ")
+        self.assertLess(tip_idx, sep_idx)
+        self.assertLess(sep_idx, task_idx)
