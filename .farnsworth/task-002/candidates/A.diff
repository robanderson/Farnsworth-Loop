+class M2TestBase(LoopTestBase):
+    """Extended base with helpers for multi-worker M2 tests."""
+
+    def _track_workers(self, task_id, worker_ids):
+        """Track all worktrees for a multi-worker run."""
+        for wid in worker_ids:
+            wt = os.path.join(self.tmp, "{0}-{1}".format(task_id, wid))
+            self._worktrees.append(wt)
+
+    def _config_multi(self, worker_ids, gate, reviewer_py=None, failing_ids=None):
+        """Write a multi-worker config.
+
+        failing_ids: set of worker ids that should have a failing worker command
+        """
+        failing_ids = failing_ids or set()
+        workers = []
+        for wid in worker_ids:
+            if wid in failing_ids:
+                cmd = ["python3", "-c", FAKE_WORKER_FAIL_PY]
+            else:
+                cmd = ["python3", "-c", FAKE_WORKER_COMMIT_PY, wid]
+            workers.append({"id": wid, "command": cmd})
+
+        cfg = {"workers": workers, "gate": gate}
+
+        if reviewer_py is not None:
+            cfg["reviewer"] = {"command": ["python3", "-c", reviewer_py, "{prompt}"]}
+
+        cfg_path = os.path.join(self.repo, "farnsworth.json")
+        with open(cfg_path, "w", encoding="utf-8") as fh:
+            json.dump(cfg, fh)
+        _git(["add", "-A"], self.repo)
+        _git(["commit", "-m", "add m2 config"], self.repo)
+        return cfg_path
+
