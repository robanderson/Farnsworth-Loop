+def _run_worker(worker_id, command, worktree_abs, briefing, artifact_dir):
+    """Run a single worker in its worktree. Returns a result dict.
+
+    This runs in a thread and is safe to call concurrently across multiple
+    workers. Called from the ThreadPoolExecutor in run().
+    """
+    worker_command = _substitute_prompt(command, briefing)
+    proc = subprocess.run(
+        worker_command,
+        cwd=worktree_abs,
+        capture_output=True,
+        text=True,
+    )
+
+    # Save stdout/stderr to artifact directory.
+    stdout_name = "{0}.stdout".format(worker_id)
+    stderr_name = "{0}.stderr".format(worker_id)
+    with open(os.path.join(artifact_dir, stdout_name), "w", encoding="utf-8") as fh:
+        fh.write(proc.stdout or "")
+    with open(os.path.join(artifact_dir, stderr_name), "w", encoding="utf-8") as fh:
+        fh.write(proc.stderr or "")
+
+    return {
+        "exit_code": proc.returncode,
+        "gate_passed": False,  # Will be set by _run_gate
+        "gate_results": [],  # Will be set by _run_gate
+    }
+
+
+def _generate_labels(count):
+    """Generate a list of unique alphabetic labels: A, B, C, ..., Z, AA, AB, ..."""
+    labels = []
+    for i in range(count):
+        if i < 26:
+            labels.append(chr(ord("A") + i))
+        else:
+            # Beyond Z: AA, AB, AC, ...
+            labels.append(
+                chr(ord("A") + (i // 26) - 1) + chr(ord("A") + (i % 26))
+            )
+    return labels
+
+
+def _build_review_briefing(
+    brief_path, artifact_dir, candidate_labels, worker_results, passing_workers
+):
+    """Build the anonymized briefing for the reviewer.
+
+    Contains the task brief verbatim, candidate labels and diff paths,
+    anonymized autopsies of failures, and the verdict instruction.
+    """
+    with open(brief_path, "r", encoding="utf-8") as fh:
+        brief_text = fh.read()
+
+    lines = [brief_text]
+    lines.append("")
+
+    # List all candidates with their diff paths.
+    lines.append("## Candidates")
+    lines.append("")
+    for spec in passing_workers:
+        worker_id = spec["id"]
+        label = candidate_labels[worker_id]
+        diff_path = os.path.join("candidates", "{0}.diff".format(label))
+        lines.append("- {0}: {1}".format(label, diff_path))
+    lines.append("")
+
+    # List anonymized autopsies of gate failures.
+    failing_workers = [
+        spec
+        for spec in passing_workers
+        if not worker_results[spec["id"]]["gate_passed"]
+    ]
+    if failing_workers:
+        lines.append("## Gate Failures (anonymized)")
+        lines.append("")
+        for spec in failing_workers:
+            worker_id = spec["id"]
+            results = worker_results[worker_id]["gate_results"]
+            for result in results:
+                if result["exit_code"] != 0:
+                    lines.append(
+                        "- a failed candidate: {0}: exit {1}".format(
+                            result["name"], result["exit_code"]
+                        )
+                    )
+        lines.append("")
+
+    # Verdict instruction.
+    lines.append("## Verdict")
+    lines.append("")
+    lines.append(
+        "Write .farnsworth/{0}/verdict.json with schema:".format(
+            os.path.basename(artifact_dir)
+        )
+    )
+    lines.append("")
+    lines.append("```json")
+    lines.append('{"outcome": "adopt" | "synthesize" | "escalate",')
+    lines.append(' "candidate": "A" | null,')
+    lines.append(' "reasoning": "..."}')
+    lines.append("```")
+    lines.append("")
+
+    return "\n".join(lines)
+
+
+def _run_reviewer(reviewer_cfg, briefing, repo_root, artifact_dir, task_id):
+    """Run the reviewer with the anonymized briefing. Returns review_log dict."""
+    reviewer_command = _substitute_prompt(reviewer_cfg["command"], briefing)
+
+    proc = subprocess.run(
+        reviewer_command,
+        cwd=repo_root,
+        capture_output=True,
+        text=True,
+    )
+
+    # Check for verdict.json.
+    verdict_path = os.path.join(artifact_dir, "verdict.json")
+    if not os.path.exists(verdict_path):
+        raise LoopError(
+            "reviewer did not write {0}; cannot proceed".format(verdict_path)
+        )
+
+    with open(verdict_path, "r", encoding="utf-8") as fh:
+        try:
+            verdict = json.load(fh)
+        except json.JSONDecodeError as exc:
+            raise LoopError("verdict.json is not valid JSON: {0}".format(exc))
+
+    # Validate verdict schema.
+    if not isinstance(verdict, dict):
+        raise LoopError("verdict.json root must be an object")
+    outcome = verdict.get("outcome")
+    candidate = verdict.get("candidate")
+    reasoning = verdict.get("reasoning")
+
+    if outcome not in ("adopt", "synthesize", "escalate"):
+        raise LoopError(
+            "verdict outcome must be one of adopt/synthesize/escalate, got: {0}".format(
+                outcome
+            )
+        )
+
+    if outcome == "adopt" and candidate is None:
+        raise LoopError("outcome 'adopt' requires a candidate label")
+    if outcome != "adopt" and candidate is not None:
+        raise LoopError(
+            "outcome '{0}' must have candidate=null, got: {1}".format(outcome, candidate)
+        )
+
+    # Validate candidate label if adopt.
+    if outcome == "adopt":
+        candidates_dir = os.path.join(artifact_dir, "candidates")
+        valid_labels = set()
+        if os.path.exists(candidates_dir):
+            for fname in os.listdir(candidates_dir):
+                if fname.endswith(".diff"):
+                    label = fname[:-5]
+                    valid_labels.add(label)
+        if candidate not in valid_labels:
+            raise LoopError(
+                "candidate label '{0}' not found in valid candidates: {1}".format(
+                    candidate, sorted(valid_labels)
+                )
+            )
+
+    return {
+        "exit_code": proc.returncode,
+        "verdict": {
+            "outcome": outcome,
+            "candidate": candidate,
+            "reasoning": reasoning,
+        },
+    }
