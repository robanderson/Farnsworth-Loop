+# A fake worker that writes a uniquely-named file in the worktree and commits
+# it. Stands in for ``claude``; tests must never invoke the real binary. The
+# {tag} placeholder is filled per worker so diffs differ.
+def _fake_worker(tag):
+    return (
+        "import subprocess,pathlib;"
+        "pathlib.Path('out_{tag}.txt').write_text('hello from {tag}');"
+        "subprocess.run(['git','add','-A']);"
+        "subprocess.run(['git','commit','-m','{tag} change']);"
+        "print('FAKE_WORKER_RAN {tag}')".format(tag=tag)
