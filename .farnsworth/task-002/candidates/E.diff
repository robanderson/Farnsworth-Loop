+# A fake reviewer that echoes its received briefing to a file (for inspection)
+# and writes a fixed verdict.json. Parameterized by outcome/candidate.
+def _fake_reviewer(outcome, candidate):
+    cand_literal = "None" if candidate is None else repr(candidate)
+    return (
+        "import sys,json,pathlib,os;"
+        "pathlib.Path('review_briefing.txt').write_text(sys.argv[1]);"
+        "d=pathlib.Path('.farnsworth')/os.environ['FARN_TASK']/'verdict.json';"
+        "d.parent.mkdir(parents=True,exist_ok=True);"
+        "d.write_text(json.dumps({{'outcome':{outcome!r},"
+        "'candidate':{cand},'reasoning':'because'}}))".format(
+            outcome=outcome, cand=cand_literal
+        )
+    )
+
