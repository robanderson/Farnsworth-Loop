+
+        first = gate_res["results"][0]
+        self.assertEqual(first["name"], "failing-gate")
+        self.assertEqual(first["exit_code"], 1)
+
+        second = gate_res["results"][1]
+        self.assertEqual(second["name"], "passing-gate")
+        self.assertEqual(second["exit_code"], 0)
