+        self.assertIn("SOME_TIP_CONTENT", briefing)
+        self.assertIn("\n\nTASK: ", briefing)
+        self.assertIn("TASK_CONTENT_UNIQUE", briefing)
+        # Tips appear before the task content.
+        self.assertLess(
+            briefing.index("SOME_TIP_CONTENT"),
+            briefing.index("TASK_CONTENT_UNIQUE")
+        )
+        # Literal separator is present.
+        self.assertIn("\n\nTASK: ", briefing)
