+            # Second gate passes.
+            {"name": "passing-gate", "command": ["python3", "-c", "import sys; sys.exit(0)"]},
+        ]
+        # No reviewer needed (all-fail path triggers since gate fails).
+        cfg = self._write_config(workers, gate, reviewer=None)
