@@ -0,0 +1,801 @@
+"""End-to-end tests for the Farnsworth M2 Tournament.
+
+Each test builds a throwaway git repo in a temp dir, runs the loop with
+*fake* worker commands (``python3 -c`` one-liners -- never the real ``claude``
+binary), and asserts the resulting worktrees, gate behavior, review briefing,
+verdict handling, and run.json fields.
+
+The repo under test is wholly contained in a TemporaryDirectory, so nothing
+leaks into this project's tree. Worktrees created by the loop live as siblings
+of the scratch repo (also inside the temp dir) and are removed on teardown.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import subprocess
+import sys
+import tempfile
+import unittest
+
+REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
+if REPO_ROOT not in sys.path:
+    sys.path.insert(0, REPO_ROOT)
+
+from farnsworth import config as cfg_module, gitutil  # noqa: E402
+from farnsworth.loop import LoopError, run, task_id_from_brief  # noqa: E402
+from farnsworth.config import Config, ConfigError  # noqa: E402
+
+
+def _git(args, cwd):
+    proc = subprocess.run(
+        ["git", *args], cwd=cwd, capture_output=True, text=True
+    )
+    if proc.returncode != 0:
+        raise AssertionError(
+            "git {0} failed: {1}".format(" ".join(args), proc.stderr)
+        )
+    return proc
+
+
+# Fake worker that writes a file and commits.
+FAKE_WORKER_PASS = (
+    "import subprocess,pathlib;"
+    "pathlib.Path('worker_output.txt').write_text('hello');"
+    "subprocess.run(['git','add','-A']);"
+    "subprocess.run(['git','commit','-m','fake worker change']);"
+    "print('FAKE_WORKER_PASS')"
+)
+
+# Fake worker that exits 0 but does NOT commit (no file change).
+FAKE_WORKER_NOCOMMIT = "print('FAKE_WORKER_NOCOMMIT')"
+
+# Fake worker that exits nonzero.
+FAKE_WORKER_FAIL = "import sys; sys.exit(1)"
+
+# Gate that always passes.
+GATE_PASS = [{"name": "tests", "command": ["python3", "-c", "import sys; sys.exit(0)"]}]
+
+# Gate that always fails.
+GATE_FAIL = [{"name": "tests", "command": ["python3", "-c", "import sys; sys.exit(1)"]}]
+
+
+class TournamentTestBase(unittest.TestCase):
+    def setUp(self):
+        self._tmp = tempfile.TemporaryDirectory()
+        self.tmp = self._tmp.name
+        self.repo = os.path.join(self.tmp, "scratch-repo")
+        os.makedirs(self.repo)
+        self._init_repo(self.repo)
+        self._worktrees = []
+
+    def tearDown(self):
+        for wt in self._worktrees:
+            subprocess.run(
+                ["git", "worktree", "remove", "--force", wt],
+                cwd=self.repo,
+                capture_output=True,
+                text=True,
+            )
+        self._tmp.cleanup()
+
+    def _init_repo(self, path):
+        _git(["init", "-b", "main"], path)
+        _git(["config", "user.email", "test@example.com"], path)
+        _git(["config", "user.name", "Test Runner"], path)
+        with open(os.path.join(path, "README.md"), "w", encoding="utf-8") as fh:
+            fh.write("# scratch\n")
+        _git(["add", "-A"], path)
+        _git(["commit", "-m", "initial"], path)
+
+    def _write_brief(self, name="task-042.md", body="do the thing"):
+        brief_path = os.path.join(self.repo, name)
+        with open(brief_path, "w", encoding="utf-8") as fh:
+            fh.write("# Brief\n\n" + body + "\n")
+        _git(["add", "-A"], self.repo)
+        _git(["commit", "-m", "add brief"], self.repo)
+        return brief_path
+
+    def _write_config(self, workers, gate, reviewer=None):
+        """Write a farnsworth.json with given workers and gate lists."""
+        cfg = {"workers": workers, "gate": gate}
+        if reviewer is not None:
+            cfg["reviewer"] = reviewer
+        cfg_path = os.path.join(self.repo, "farnsworth.json")
+        with open(cfg_path, "w", encoding="utf-8") as fh:
+            json.dump(cfg, fh)
+        _git(["add", "-A"], self.repo)
+        _git(["commit", "-m", "add config"], self.repo)
+        return cfg_path
+
+    def _track_worktrees(self, task_id, worker_ids):
+        """Register worktrees for teardown."""
+        for wid in worker_ids:
+            wt = os.path.join(self.tmp, "{0}-{1}".format(task_id, wid))
+            self._worktrees.append(wt)
+
+    def _make_fake_reviewer(self, verdict_dict):
+        """Return a reviewer config that writes the given verdict and exits 0."""
+        # The reviewer writes verdict.json to the CWD (.farnsworth/task-id/verdict.json).
+        verdict_json = json.dumps(verdict_dict)
+        # CWD for reviewer is repo root; verdict path is relative.
+        reviewer_py = (
+            "import json,os,sys;"
+            "verdict={verdict_json!r};"
+            "task_id=None;"
+            # Parse --task-id from the prompt or just find the candidates dir.
+            # Actually we need to know the task_id. We'll encode it in a file.
+            # Simpler: search for .farnsworth/ subdir with 'candidates' dir.
+            "base='.farnsworth';"
+            "task_dirs=[d for d in os.listdir(base) if os.path.isdir(os.path.join(base,d,'candidates'))];"
+            "task_id=task_dirs[0];"
+            "path=os.path.join(base,task_id,'verdict.json');"
+            "open(path,'w').write(verdict);"
+            "print('FAKE_REVIEWER_RAN')"
+        ).format(verdict_json=verdict_json)
+        return {"command": ["python3", "-c", reviewer_py]}
+
+    def _make_fake_reviewer_capturing_prompt(self, verdict_dict):
+        """Return a reviewer config that captures its prompt to a file, then writes verdict."""
+        verdict_json = json.dumps(verdict_dict)
+        reviewer_py = (
+            "import json,os,sys;"
+            "prompt=sys.argv[1];"
+            "base='.farnsworth';"
+            "task_dirs=[d for d in os.listdir(base) if os.path.isdir(os.path.join(base,d,'candidates'))];"
+            "task_id=task_dirs[0];"
+            "open(os.path.join(base,task_id,'reviewer_prompt.txt'),'w').write(prompt);"
+            "path=os.path.join(base,task_id,'verdict.json');"
+            "open(path,'w').write({verdict_json!r});"
+            "print('FAKE_REVIEWER_RAN')"
+        ).format(verdict_json=verdict_json)
+        return {"command": ["python3", "-c", reviewer_py, "{prompt}"]}
+
+
+class TestTwoPassOneFailWorker(TournamentTestBase):
+    """Two passing + one gate-failing worker: correct candidate set, labels,
+    diffs, anonymized autopsy."""
+
+    def setUp(self):
+        super().setUp()
+        self.task_id = "task-042"
+        self._track_worktrees(self.task_id, ["w1", "w2", "w3"])
+
+    def _setup(self, verdict):
+        brief = self._write_brief(name="{0}.md".format(self.task_id), body="TASK_BODY_UNIQUE")
+        workers = [
+            {"id": "w1", "command": ["python3", "-c", FAKE_WORKER_PASS]},
+            {"id": "w2", "command": ["python3", "-c", FAKE_WORKER_PASS]},
+            {"id": "w3", "command": ["python3", "-c", FAKE_WORKER_FAIL]},
+        ]
+        # Gate: pass for w1, w2 (they commit a file); fail for w3 (nonzero exit command doesn't matter;
+        # the gate itself exits 0 always, but w3's worker exits nonzero - that's ok, gate runs).
+        # Actually we want w3 to FAIL the gate. Use GATE_FAIL for w3 or use a per-worker gate.
+        # But gate is per-config, same for all workers. So let's differentiate differently:
+        # w3's worker exits nonzero (FAKE_WORKER_FAIL) but the gate runs anyway.
+        # We want ONE of the workers to fail the gate. The easiest way:
+        # Use a gate that checks for a file that only w1/w2 create.
+        gate = [
+            {
+                "name": "check-file",
+                "command": ["python3", "-c",
+                            "import os,sys; sys.exit(0 if os.path.exists('worker_output.txt') else 1)"]
+            }
+        ]
+        reviewer = self._make_fake_reviewer(verdict)
+        cfg = self._write_config(workers, gate, reviewer)
+        return brief, cfg
+
+    def test_two_pass_one_fail(self):
+        verdict = {"outcome": "adopt", "candidate": None, "reasoning": "test"}
+        brief, cfg = self._setup(verdict)
+        # We'll override the verdict after we know the labels.
+        # Instead use a reviewer that adopts the first valid label it finds.
+        # Re-setup with a smarter reviewer.
+
+        verdict_adopt_first = {
+            "outcome": "synthesize",
+            "candidate": None,
+            "reasoning": "both are good, synthesize"
+        }
+        brief_path = os.path.join(self.repo, "task-042.md")
+        workers = [
+            {"id": "w1", "command": ["python3", "-c", FAKE_WORKER_PASS]},
+            {"id": "w2", "command": ["python3", "-c", FAKE_WORKER_PASS]},
+            {"id": "w3", "command": ["python3", "-c", FAKE_WORKER_FAIL]},
+        ]
+        gate = [
+            {
+                "name": "check-file",
+                "command": ["python3", "-c",
+                            "import os,sys; sys.exit(0 if os.path.exists('worker_output.txt') else 1)"]
+            }
+        ]
+        reviewer = self._make_fake_reviewer(verdict_adopt_first)
+        cfg_path = os.path.join(self.repo, "farnsworth.json")
+        cfg_dict = {"workers": workers, "gate": gate, "reviewer": reviewer}
+        with open(cfg_path, "w", encoding="utf-8") as fh:
+            json.dump(cfg_dict, fh)
+        _git(["add", "-A"], self.repo)
+        _git(["commit", "-m", "update config"], self.repo)
+
+        run_log = run(brief_path, config_path=cfg_path, cwd=self.repo)
+
+        workers_log = run_log["workers"]
+        self.assertEqual(len(workers_log), 3)
+
+        # w1 and w2 should have candidate labels, w3 should not.
+        w1 = next(w for w in workers_log if w["id"] == "w1")
+        w2 = next(w for w in workers_log if w["id"] == "w2")
+        w3 = next(w for w in workers_log if w["id"] == "w3")
+
+        self.assertTrue(w1["gate"]["passed"])
+        self.assertTrue(w2["gate"]["passed"])
+        self.assertFalse(w3["gate"]["passed"])
+
+        self.assertIsNotNone(w1["candidate_label"])
+        self.assertIsNotNone(w2["candidate_label"])
+        self.assertIsNone(w3["candidate_label"])
+
+        # Labels should be two distinct letters from A-Z.
+        labels = {w1["candidate_label"], w2["candidate_label"]}
+        self.assertEqual(len(labels), 2)
+        for label in labels:
+            self.assertIn(label, "ABCDEFGHIJKLMNOPQRSTUVWXYZ")
+
+        # Labels must be a permutation of {A, B} (or whichever two).
+        self.assertEqual(sorted(labels), sorted(["A", "B"]))
+
+        # Diff files should exist for each candidate label.
+        candidates_dir = os.path.join(self.repo, ".farnsworth", "task-042", "candidates")
+        for label in labels:
+            diff_path = os.path.join(candidates_dir, "{0}.diff".format(label))
+            self.assertTrue(os.path.exists(diff_path),
+                            "diff file {0}.diff missing".format(label))
+
+        # run.json review field should be present (not None).
+        review = run_log.get("review")
+        self.assertIsNotNone(review)
+        self.assertEqual(review["verdict"]["outcome"], "synthesize")
+
+    def test_anonymized_autopsy_in_review_briefing(self):
+        """Reviewer briefing must contain anonymized autopsies without worker ids."""
+        verdict = {"outcome": "synthesize", "candidate": None, "reasoning": "no good candidate"}
+        # Write the brief first (the body text is asserted below).
+        brief_path = self._write_brief(name="task-042.md", body="TASK_BODY_UNIQUE")
+        workers = [
+            {"id": "w1", "command": ["python3", "-c", FAKE_WORKER_PASS]},
+            {"id": "w2", "command": ["python3", "-c", FAKE_WORKER_FAIL]},
+        ]
+        gate = [
+            {
+                "name": "check-file",
+                "command": ["python3", "-c",
+                            "import os,sys; sys.exit(0 if os.path.exists('worker_output.txt') else 1)"]
+            }
+        ]
+        reviewer = self._make_fake_reviewer_capturing_prompt(verdict)
+        cfg_path = os.path.join(self.repo, "farnsworth.json")
+        cfg_dict = {"workers": workers, "gate": gate, "reviewer": reviewer}
+        with open(cfg_path, "w", encoding="utf-8") as fh:
+            json.dump(cfg_dict, fh)
+        _git(["add", "-A"], self.repo)
+        _git(["commit", "-m", "update config"], self.repo)
+
+        run_log = run(brief_path, config_path=cfg_path, cwd=self.repo)
+
+        # Read the captured reviewer prompt.
+        prompt_path = os.path.join(
+            self.repo, ".farnsworth", "task-042", "reviewer_prompt.txt"
+        )
+        self.assertTrue(os.path.exists(prompt_path))
+        with open(prompt_path, "r", encoding="utf-8") as fh:
+            prompt_text = fh.read()
+
+        # Must contain task brief text.
+        self.assertIn("TASK_BODY_UNIQUE", prompt_text)
+
+        # Must contain candidate label (A, not w1).
+        self.assertIn("A", prompt_text)
+
+        # Must NOT contain worker ids.
+        self.assertNotIn("w1", prompt_text)
+        self.assertNotIn("w2", prompt_text)
+
+        # Must NOT contain the label->worker mapping.
+        self.assertNotIn("candidate-mapping", prompt_text)
+
+        # Must contain anonymized autopsy.
+        self.assertIn("a failed candidate", prompt_text)
+
+
+class TestReviewerBriefingContent(TournamentTestBase):
+    """The briefing passed to the reviewer contains labels and brief text
+    but NOT worker ids and NOT the mapping."""
+
+    def setUp(self):
+        super().setUp()
+        self._track_worktrees("task-042", ["w1", "w2"])
+
+    def test_reviewer_briefing_no_worker_ids(self):
+        brief = self._write_brief(name="task-042.md", body="UNIQUE_BRIEF_CONTENT")
+
+        workers = [
+            {"id": "w1", "command": ["python3", "-c", FAKE_WORKER_PASS]},
+            {"id": "w2", "command": ["python3", "-c", FAKE_WORKER_PASS]},
+        ]
+        gate = GATE_PASS
+
+        # Reviewer captures its prompt to a file.
+        verdict = {"outcome": "adopt", "candidate": "A", "reasoning": "A is best"}
+        # We use a dynamic reviewer: it reads the labels from its prompt, picks the first one.
+        reviewer_py = (
+            "import json,os,sys,re;"
+            "prompt=sys.argv[1];"
+            "base='.farnsworth';"
+            "task_dirs=[d for d in os.listdir(base) if os.path.isdir(os.path.join(base,d,'candidates'))];"
+            "task_id=task_dirs[0];"
+            "open(os.path.join(base,task_id,'reviewer_prompt.txt'),'w').write(prompt);"
+            # Find first candidate label (A or B) in candidates dir.
+            "labels=sorted(os.listdir(os.path.join(base,task_id,'candidates')));"
+            "first_label=labels[0].replace('.diff','') if labels else 'A';"
+            "verdict={'outcome':'adopt','candidate':first_label,'reasoning':'first is best'};"
+            "path=os.path.join(base,task_id,'verdict.json');"
+            "open(path,'w').write(json.dumps(verdict));"
+            "print('REVIEWER_DONE')"
