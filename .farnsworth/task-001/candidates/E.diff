+"""CLI argument parsing and dispatch."""
+import argparse
+import sys
+
+
+def main(argv=None):
+    """Main entry point. Returns exit code."""
+    parser = argparse.ArgumentParser(
+        prog="farnsworth",
+        description="Farnsworth Loop - M1 Skeleton",
+    )
+    subparsers = parser.add_subparsers(dest="subcommand", required=True)
+
+    run_parser = subparsers.add_parser("run", help="Run a task with one worker")
+    run_parser.add_argument("task_brief", help="Path to task brief markdown file")
+    run_parser.add_argument(
+        "--config",
+        default="farnsworth.json",
+        help="Path to config file (default: farnsworth.json in repo root)",
+    )
+
+    args = parser.parse_args(argv)
+
+    if args.subcommand == "run":
+        from farnsworth.runner import run_task
+        return run_task(args.task_brief, args.config)
+
+    parser.print_help()
+    return 1
