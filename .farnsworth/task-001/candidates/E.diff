@@ -0,0 +1,227 @@
+"""Core run logic for the M1 skeleton."""
+import datetime
+import json
+import os
+import subprocess
+import sys
+from pathlib import Path
+from typing import Any
+
+from farnsworth.config import load_config
+
+
+def _utc_now() -> str:
+    """Return current UTC time as ISO-8601 string."""
+    return datetime.datetime.now(datetime.timezone.utc).isoformat()
+
+
+def _run_subprocess(cmd: list[str], cwd: str) -> tuple[int, str, str]:
+    """Run a subprocess; return (exit_code, stdout, stderr)."""
+    result = subprocess.run(
+        cmd,
+        cwd=cwd,
+        capture_output=True,
+        text=True,
+    )
+    return result.returncode, result.stdout, result.stderr
+
+
+def _git(args: list[str], cwd: str) -> tuple[int, str, str]:
+    """Run a git command in the given directory."""
+    return _run_subprocess(["git"] + args, cwd=cwd)
+
+
+def _require_clean_git_repo(repo_root: str) -> str:
+    """Verify CWD is a git repo with clean working tree.
+
+    Returns HEAD commit SHA.
+    Raises SystemExit with a clear message on failure.
+    """
+    # Check it's a git repo
+    rc, out, err = _git(["rev-parse", "--show-toplevel"], cwd=repo_root)
+    if rc != 0:
+        sys.exit(f"ERROR: Not a git repository: {repo_root}")
+
+    # Check clean working tree (index + untracked)
+    rc, out, err = _git(["status", "--porcelain"], cwd=repo_root)
+    if rc != 0:
+        sys.exit(f"ERROR: git status failed: {err.strip()}")
+    if out.strip():
+        sys.exit(
+            "ERROR: Working tree is not clean. Commit or stash changes before running:\n"
+            + out.rstrip()
+        )
+
+    # Get HEAD SHA
+    rc, out, err = _git(["rev-parse", "HEAD"], cwd=repo_root)
+    if rc != 0:
+        sys.exit(f"ERROR: Could not determine HEAD commit: {err.strip()}")
+    return out.strip()
+
+
+def _build_worker_prompt(repo_root: str, task_brief_path: str) -> str:
+    """Build the worker briefing: code-tips + task brief."""
+    parts = []
+
+    tips_path = os.path.join(repo_root, ".code-tips.md")
+    if os.path.exists(tips_path):
+        with open(tips_path, "r", encoding="utf-8") as fh:
+            parts.append(fh.read().rstrip())
+
+    with open(task_brief_path, "r", encoding="utf-8") as fh:
+        brief = fh.read().rstrip()
+
+    if parts:
+        parts.append("\n\nTASK: " + brief)
+    else:
+        parts.append("TASK: " + brief)
+
+    return "".join(parts)
+
+
+def _substitute_prompt(cmd: list[str], prompt: str) -> list[str]:
+    """Replace {prompt} placeholder in command argv elements."""
+    return [arg.replace("{prompt}", prompt) for arg in cmd]
+
+
+def _autopsy(name: str, exit_code: int, stderr: str) -> str:
+    """Produce a one-line autopsy string."""
+    last_line = ""
+    if stderr:
+        lines = [l for l in stderr.strip().splitlines() if l.strip()]
+        if lines:
+            last_line = ": " + lines[-1].strip()
+    return f"{name}: exit {exit_code}{last_line}"
+
+
+def _run_gate(gate_config: list[dict], worktree: str) -> dict[str, Any]:
+    """Run all gate commands; return gate results dict."""
+    results = []
+    all_passed = True
+
+    for entry in gate_config:
+        name = entry["name"]
+        cmd = entry["command"]
+        rc, out, err = _run_subprocess(cmd, cwd=worktree)
+        passed = rc == 0
+        if not passed:
+            all_passed = False
+        results.append({
+            "name": name,
+            "exit_code": rc,
+            "autopsy": _autopsy(name, rc, err),
+        })
+
+    return {"passed": all_passed, "results": results}
+
+
+def run_task(task_brief_arg: str, config_path: str) -> int:
+    """Main loop body: single worker, single gate pass, write run log.
+
+    Returns 0 if all gates passed, 1 otherwise.
+    """
+    # Resolve repo root (CWD when invoked)
+    repo_root = os.path.abspath(os.getcwd())
+
+    # Resolve task brief path
+    task_brief_path = os.path.abspath(task_brief_arg)
+    if not os.path.exists(task_brief_path):
+        sys.exit(f"ERROR: Task brief not found: {task_brief_path}")
+
+    # Derive task_id from file stem
+    task_id = Path(task_brief_path).stem
+
+    # Load config
+    try:
+        config = load_config(config_path)
+    except FileNotFoundError as exc:
+        sys.exit(f"ERROR: {exc}")
+
+    # Validate git state
+    started_at = _utc_now()
+    base_commit = _require_clean_git_repo(repo_root)
+
+    # Determine worktree path and branch
+    worktree_name = f"{task_id}-w1"
+    worktree_path = os.path.abspath(os.path.join(repo_root, "..", worktree_name))
+    branch_name = worktree_name
+
+    # Check branch/path don't already exist
+    rc, out, _ = _git(["branch", "--list", branch_name], cwd=repo_root)
+    if rc == 0 and out.strip():
+        sys.exit(f"ERROR: Branch '{branch_name}' already exists.")
+    if os.path.exists(worktree_path):
+        sys.exit(f"ERROR: Worktree path already exists: {worktree_path}")
+
+    # Create worktree
+    print(f"Creating worktree: {worktree_path} (branch: {branch_name})")
+    rc, out, err = _git(
+        ["worktree", "add", worktree_path, "-b", branch_name],
+        cwd=repo_root,
+    )
+    if rc != 0:
+        sys.exit(f"ERROR: Failed to create worktree:\n{err.strip()}")
+
+    # Build worker prompt
+    prompt = _build_worker_prompt(repo_root, task_brief_path)
+
+    # Build worker command
+    worker_cmd_template = config["worker"]["command"]
+    worker_cmd = _substitute_prompt(worker_cmd_template, prompt)
+
+    # Prepare output directory in main repo
+    artifacts_dir = os.path.join(repo_root, ".farnsworth", task_id)
+    os.makedirs(artifacts_dir, exist_ok=True)
+
+    stdout_file = os.path.join(artifacts_dir, "w1.stdout")
+    stderr_file = os.path.join(artifacts_dir, "w1.stderr")
+
+    # Run worker
+    print(f"Running worker in: {worktree_path}")
+    worker_rc, worker_stdout, worker_stderr = _run_subprocess(worker_cmd, cwd=worktree_path)
+
+    # Save worker output
+    with open(stdout_file, "w", encoding="utf-8") as fh:
+        fh.write(worker_stdout)
+    with open(stderr_file, "w", encoding="utf-8") as fh:
+        fh.write(worker_stderr)
+
+    # Run gate
+    print("Running gate checks...")
+    gate_config = config.get("gate", [])
+    gate_result = _run_gate(gate_config, worktree_path)
+
+    finished_at = _utc_now()
+
+    # Build run log
+    run_log = {
+        "task_id": task_id,
+        "started_at": started_at,
+        "finished_at": finished_at,
+        "base_commit": base_commit,
+        "workers": [
+            {
+                "id": "w1",
+                "branch": branch_name,
+                "worktree": f"../{worktree_name}",
+                "exit_code": worker_rc,
+                "stdout_file": "w1.stdout",
+                "gate": gate_result,
+            }
+        ],
+    }
+
+    run_log_path = os.path.join(artifacts_dir, "run.json")
+    with open(run_log_path, "w", encoding="utf-8") as fh:
+        json.dump(run_log, fh, indent=2)
+
+    # Print summary
+    gate_status = "PASSED" if gate_result["passed"] else "FAILED"
+    print(f"\n--- Gate Summary: {gate_status} ---")
+    for result in gate_result["results"]:
+        status = "OK" if result["exit_code"] == 0 else "FAIL"
+        print(f"  [{status}] {result['autopsy']}")
+    print(f"\nWorktree: {worktree_path}")
+    print(f"Run log:  {run_log_path}")
+
+    return 0 if gate_result["passed"] else 1
