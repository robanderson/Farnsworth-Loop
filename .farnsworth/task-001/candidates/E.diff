+"""Config loading for farnsworth.json."""
+import json
+import os
+from typing import Any
+
+
+DEFAULT_CONFIG = {
+    "worker": {
+        "command": [
+            "claude", "-p", "{prompt}", "--bare", "--model",
+            "claude-haiku-4-5", "--permission-mode", "acceptEdits",
+            "--output-format", "json",
+        ]
+    },
+    "gate": [
+        {"name": "tests", "command": ["python3", "-m", "unittest", "discover"]}
+    ],
+}
+
+
+def load_config(config_path: str) -> dict[str, Any]:
+    """Load and return config from JSON file, falling back to defaults.
+
+    Raises FileNotFoundError if the path is explicitly given but does not exist,
+    except when the path is the default 'farnsworth.json' in which case the
+    default config is returned silently.
+    """
+    is_default = config_path == "farnsworth.json"
+
+    if not os.path.isabs(config_path):
+        # Resolve relative to CWD (which should be the repo root)
+        abs_path = os.path.abspath(config_path)
+    else:
+        abs_path = config_path
+
+    if not os.path.exists(abs_path):
+        if is_default:
+            return dict(DEFAULT_CONFIG)
+        raise FileNotFoundError(f"Config file not found: {abs_path}")
+
+    with open(abs_path, "r", encoding="utf-8") as fh:
+        return json.load(fh)
diff --git a/farnsworth/runner.py b/farnsworth/runner.py
new file mode 100644
index 0000000..c78c237
