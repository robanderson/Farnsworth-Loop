+class TestPromptSubstitution(TestRunnerBase):
+    """The {prompt} placeholder in worker command is replaced with the briefing."""
+
+    def test_prompt_substitution(self):
+        # Worker receives {prompt} as a command-line argument and saves it to a file
+        worker_cmd_with_prompt = [
+            sys.executable, "-c",
+            "import sys, subprocess; "
+            "open('prompt-capture.txt', 'w').write(sys.argv[1]); "
+            "subprocess.run(['git', 'add', 'prompt-capture.txt']); "
+            "subprocess.run(['git', '-c', 'user.email=w@w.com', "
+            "'-c', 'user.name=Worker', 'commit', '-m', 'worker commit'])",
+            "{prompt}",  # This will be substituted with the actual prompt
+        ]
+        # Add a .code-tips.md to verify it appears in prompt
+        tips = os.path.join(self.repo, ".code-tips.md")
+        with open(tips, "w") as fh:
+            fh.write("# Tips\n- tip1\n")
+
+        cfg = _write_config(self.repo, worker_cmd_with_prompt)
+        brief = _write_task_brief(self.repo, "task-prompt")
+
+        # Commit all files so the tree is clean
+        _commit_all(self.repo)
+
+        _run_farnsworth(brief, cfg, self.repo)
+
+        # Check the worktree has prompt-capture.txt with the brief content
+        wt_path = os.path.join(self._tmpdir, "task-prompt-w1")
+        capture_file = os.path.join(wt_path, "prompt-capture.txt")
+        self.assertTrue(os.path.exists(capture_file),
+                        "prompt-capture.txt not found in worktree")
+        with open(capture_file) as fh:
+            content = fh.read()
+        self.assertIn("TASK:", content)
+        self.assertIn("tip1", content)
+
