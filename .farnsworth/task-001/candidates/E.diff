@@ -0,0 +1,400 @@
+"""Tests for farnsworth M1 skeleton.
+
+All tests operate on throwaway git repos in temp directories.
+No side effects in the main repository.
+"""
+import json
+import os
+import subprocess
+import sys
+import tempfile
+import unittest
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+def _git(args, cwd):
+    """Run git in cwd; return (returncode, stdout, stderr)."""
+    result = subprocess.run(
+        ["git"] + args, cwd=cwd, capture_output=True, text=True
+    )
+    return result.returncode, result.stdout, result.stderr
+
+
+def _init_repo(path):
+    """Create a minimal git repo suitable for worktree operations."""
+    os.makedirs(path, exist_ok=True)
+    _git(["init", "-b", "main"], path)
+    _git(["config", "user.email", "test@example.com"], path)
+    _git(["config", "user.name", "Test User"], path)
+    # Initial commit so HEAD exists
+    readme = os.path.join(path, "README.md")
+    with open(readme, "w") as fh:
+        fh.write("# test repo\n")
+    _git(["add", "README.md"], path)
+    _git(["commit", "-m", "init"], path)
+
+
+def _commit_all(repo_path, message="add test files"):
+    """Stage all changes and commit them."""
+    _git(["add", "-A"], repo_path)
+    _git(["-c", "user.email=t@t.com", "-c", "user.name=Test",
+          "commit", "-m", message], repo_path)
+
+
+def _write_config(repo_path, worker_cmd, gate_cmds=None):
+    """Write a farnsworth.json into repo_path and return its path."""
+    if gate_cmds is None:
+        # Default gate: always passes (true is /bin/true on Linux)
+        gate_cmds = [{"name": "always-pass", "command": ["true"]}]
+
+    config = {
+        "worker": {"command": worker_cmd},
+        "gate": gate_cmds,
+    }
+    cfg_path = os.path.join(repo_path, "farnsworth.json")
+    with open(cfg_path, "w") as fh:
+        json.dump(config, fh)
+    return cfg_path
+
+
+def _write_task_brief(repo_path, stem="task-test"):
+    """Write a minimal task brief and return its path."""
+    path = os.path.join(repo_path, f"{stem}.md")
+    with open(path, "w") as fh:
+        fh.write(f"# {stem}\n\nDo something.\n")
+    return path
+
+
+def _fake_worker_cmd():
+    """Return a worker command that creates a commit in the worktree.
+
+    The worker command must be runnable by subprocess with no external deps.
+    We use a Python one-liner that:
+      1. Writes a file.
+      2. Stages and commits it.
+    """
+    script = (
+        "import subprocess, os; "
+        "open('worker-output.txt', 'w').write('done'); "
+        "subprocess.run(['git', 'add', 'worker-output.txt']); "
+        "subprocess.run(['git', '-c', 'user.email=w@w.com', "
+        "'-c', 'user.name=Worker', 'commit', '-m', 'worker commit']); "
+    )
+    return [sys.executable, "-c", script]
+
+
+def _run_farnsworth(task_brief_path, config_path, repo_root):
+    """Invoke farnsworth.runner.run_task directly (not via subprocess).
+
+    We manipulate CWD via os.chdir.  Returns exit code.
+    """
+    old_cwd = os.getcwd()
+    try:
+        os.chdir(repo_root)
+        from farnsworth.runner import run_task
+        return run_task(task_brief_path, config_path)
+    finally:
+        os.chdir(old_cwd)
+
+
+# ---------------------------------------------------------------------------
+# Test cases
+# ---------------------------------------------------------------------------
+
+class TestRunnerBase(unittest.TestCase):
+    """Base class: creates a fresh temp dir and repo for every test."""
+
+    def setUp(self):
+        self._tmpdir = tempfile.mkdtemp(prefix="farnsworth_test_")
+        self.repo = os.path.join(self._tmpdir, "main_repo")
+        _init_repo(self.repo)
+
+    def tearDown(self):
+        # Clean up any worktrees then remove temp dir
+        import shutil
+        # Remove worktrees registered with git
+        rc, out, _ = _git(["worktree", "list", "--porcelain"], self.repo)
+        if rc == 0:
+            current_wt = None
+            for line in out.splitlines():
+                if line.startswith("worktree "):
+                    current_wt = line[len("worktree "):].strip()
+                if line == "" and current_wt and current_wt != self.repo:
+                    # Prune that worktree
+                    _git(["worktree", "remove", "--force", current_wt], self.repo)
+                    current_wt = None
+        shutil.rmtree(self._tmpdir, ignore_errors=True)
+
+
+class TestWorktreeCreated(TestRunnerBase):
+    """Worktree is created on disk and registered with git."""
+
+    def test_worktree_created(self):
+        cfg = _write_config(self.repo, _fake_worker_cmd())
+        brief = _write_task_brief(self.repo, "task-test")
+        _commit_all(self.repo)  # clean tree required
+
+        exit_code = _run_farnsworth(brief, cfg, self.repo)
+
+        expected_wt = os.path.join(self._tmpdir, "task-test-w1")
+        self.assertTrue(
+            os.path.isdir(expected_wt),
+            f"Worktree directory not found: {expected_wt}",
+        )
+        # Verify branch exists
+        rc, out, _ = _git(["branch", "--list", "task-test-w1"], self.repo)
+        self.assertIn("task-test-w1", out)
+
+
+class TestGatePass(TestRunnerBase):
+    """Gate pass: exit code 0, run.json records passed=true."""
+
+    def test_gate_pass(self):
+        cfg = _write_config(
+            self.repo,
+            _fake_worker_cmd(),
+            gate_cmds=[{"name": "always-pass", "command": ["true"]}],
+        )
+        brief = _write_task_brief(self.repo, "task-gpass")
+        _commit_all(self.repo)
+
+        exit_code = _run_farnsworth(brief, cfg, self.repo)
+        self.assertEqual(exit_code, 0)
+
+        run_log_path = os.path.join(
+            self.repo, ".farnsworth", "task-gpass", "run.json"
+        )
+        self.assertTrue(os.path.exists(run_log_path))
+        with open(run_log_path) as fh:
+            data = json.load(fh)
+
+        self.assertTrue(data["workers"][0]["gate"]["passed"])
+        results = data["workers"][0]["gate"]["results"]
+        self.assertEqual(results[0]["name"], "always-pass")
+        self.assertEqual(results[0]["exit_code"], 0)
+
+
+class TestGateFail(TestRunnerBase):
+    """Gate fail: exit code 1, run.json records passed=false."""
+
+    def test_gate_fail(self):
+        cfg = _write_config(
+            self.repo,
+            _fake_worker_cmd(),
+            gate_cmds=[{"name": "always-fail", "command": ["false"]}],
+        )
+        brief = _write_task_brief(self.repo, "task-gfail")
+        _commit_all(self.repo)
+
+        exit_code = _run_farnsworth(brief, cfg, self.repo)
+        self.assertEqual(exit_code, 1)
+
+        run_log_path = os.path.join(
+            self.repo, ".farnsworth", "task-gfail", "run.json"
+        )
+        with open(run_log_path) as fh:
+            data = json.load(fh)
+
+        self.assertFalse(data["workers"][0]["gate"]["passed"])
+        results = data["workers"][0]["gate"]["results"]
+        self.assertEqual(results[0]["exit_code"], 1)
+
+
+class TestRunJsonSchema(TestRunnerBase):
+    """run.json has all required schema fields."""
+
+    def test_run_json_schema(self):
+        cfg = _write_config(
+            self.repo,
+            _fake_worker_cmd(),
+            gate_cmds=[{"name": "tests", "command": ["true"]}],
+        )
+        brief = _write_task_brief(self.repo, "task-schema")
+        _commit_all(self.repo)
+
+        _run_farnsworth(brief, cfg, self.repo)
+
+        run_log_path = os.path.join(
+            self.repo, ".farnsworth", "task-schema", "run.json"
+        )
+        with open(run_log_path) as fh:
+            data = json.load(fh)
+
+        # Top-level fields
+        self.assertEqual(data["task_id"], "task-schema")
+        self.assertIn("started_at", data)
+        self.assertIn("finished_at", data)
+        self.assertIn("base_commit", data)
+        self.assertIsInstance(data["workers"], list)
+        self.assertEqual(len(data["workers"]), 1)
+
+        worker = data["workers"][0]
+        self.assertEqual(worker["id"], "w1")
+        self.assertEqual(worker["branch"], "task-schema-w1")
+        self.assertIn("worktree", worker)
+        self.assertIn("exit_code", worker)
+        self.assertEqual(worker["stdout_file"], "w1.stdout")
+
+        gate = worker["gate"]
+        self.assertIn("passed", gate)
+        self.assertIn("results", gate)
+        result = gate["results"][0]
+        self.assertIn("name", result)
+        self.assertIn("exit_code", result)
+        self.assertIn("autopsy", result)
+
+        # base_commit should be a valid SHA (40 hex chars)
+        self.assertRegex(data["base_commit"], r"^[0-9a-f]{40}$")
+
+
+class TestDirtyTreeRejected(TestRunnerBase):
+    """Dirty working tree is rejected with a clear error."""
+
+    def test_dirty_tree_rejected(self):
+        cfg = _write_config(self.repo, _fake_worker_cmd())
+        brief = _write_task_brief(self.repo, "task-dirty")
+        _commit_all(self.repo)  # Commit all files first
+
+        # Now make the tree dirty AFTER committing
+        dirty_file = os.path.join(self.repo, "dirty.txt")
+        with open(dirty_file, "w") as fh:
+            fh.write("uncommitted\n")
+
+        old_cwd = os.getcwd()
+        try:
+            os.chdir(self.repo)
+            from farnsworth.runner import run_task
+            with self.assertRaises(SystemExit) as ctx:
+                run_task(brief, cfg)
+            # Should exit non-zero
+            self.assertNotEqual(ctx.exception.code, 0)
+            # The exit message should mention the dirty state
+            msg = str(ctx.exception.code)
+            self.assertIn("clean", msg.lower())
+        finally:
+            os.chdir(old_cwd)
+
+
+class TestStdoutStderrFiles(TestRunnerBase):
+    """Worker stdout and stderr are saved to the artifacts dir."""
+
+    def test_stdout_saved(self):
+        # Worker prints something to stdout
+        worker_cmd = [
+            sys.executable, "-c",
+            "import subprocess, os, sys; "
+            "sys.stdout.write('hello from worker'); "
+            "open('worker-output.txt', 'w').write('done'); "
+            "subprocess.run(['git', 'add', 'worker-output.txt']); "
+            "subprocess.run(['git', '-c', 'user.email=w@w.com', "
+            "'-c', 'user.name=Worker', 'commit', '-m', 'worker commit'])"
+        ]
+        cfg = _write_config(self.repo, worker_cmd)
+        brief = _write_task_brief(self.repo, "task-stdout")
+        _commit_all(self.repo)
+
+        _run_farnsworth(brief, cfg, self.repo)
+
+        stdout_path = os.path.join(
+            self.repo, ".farnsworth", "task-stdout", "w1.stdout"
+        )
+        stderr_path = os.path.join(
+            self.repo, ".farnsworth", "task-stdout", "w1.stderr"
+        )
+        self.assertTrue(os.path.exists(stdout_path))
+        self.assertTrue(os.path.exists(stderr_path))
+        with open(stdout_path) as fh:
+            content = fh.read()
+        self.assertIn("hello from worker", content)
