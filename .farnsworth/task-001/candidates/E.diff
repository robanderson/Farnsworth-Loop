+class TestMultipleGatesAllRun(TestRunnerBase):
+    """All gate entries run even if an earlier one fails."""
+
+    def test_all_gates_run(self):
+        gate_cmds = [
+            {"name": "fail-first", "command": ["false"]},
+            {"name": "pass-second", "command": ["true"]},
+        ]
+        cfg = _write_config(self.repo, _fake_worker_cmd(), gate_cmds=gate_cmds)
+        brief = _write_task_brief(self.repo, "task-multi-gate")
+        _commit_all(self.repo)
+
+        exit_code = _run_farnsworth(brief, cfg, self.repo)
+        self.assertEqual(exit_code, 1)  # overall failed
+
+        run_log_path = os.path.join(
+            self.repo, ".farnsworth", "task-multi-gate", "run.json"
+        )
+        with open(run_log_path) as fh:
+            data = json.load(fh)
+
+        results = data["workers"][0]["gate"]["results"]
+        self.assertEqual(len(results), 2)
+        self.assertEqual(results[0]["name"], "fail-first")
+        self.assertEqual(results[0]["exit_code"], 1)
+        self.assertEqual(results[1]["name"], "pass-second")
+        self.assertEqual(results[1]["exit_code"], 0)
+
