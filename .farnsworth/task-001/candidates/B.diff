@@ -0,0 +1,418 @@
+"""Tests for Farnsworth Loop M1 runner."""
+
+import json
+import os
+import shutil
+import subprocess
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+
+
+def setup_scratch_git_repo(base_dir: str) -> str:
+    """Create a minimal git repo inside base_dir/repo and return its path."""
+    repo_path = os.path.join(base_dir, "scratch-repo")
+    os.makedirs(repo_path, exist_ok=True)
+
+    subprocess.run(["git", "init"], cwd=repo_path, check=True,
+                   capture_output=True)
+    subprocess.run(["git", "config", "user.email", "test@example.com"],
+                   cwd=repo_path, check=True, capture_output=True)
+    subprocess.run(["git", "config", "user.name", "Test User"],
+                   cwd=repo_path, check=True, capture_output=True)
+
+    # Create initial commit
+    readme = os.path.join(repo_path, "README.md")
+    with open(readme, "w") as f:
+        f.write("# Test Repo\n")
+
+    subprocess.run(["git", "add", "README.md"], cwd=repo_path, check=True,
+                   capture_output=True)
+    subprocess.run(["git", "commit", "-m", "Initial commit"],
+                   cwd=repo_path, check=True, capture_output=True)
+
+    return repo_path
+
+
+def create_task_brief(base_dir: str, name: str = "task-042") -> str:
+    """Create a task brief file in base_dir (outside the repo) and return its path."""
+    brief_path = os.path.join(base_dir, f"{name}.md")
+    with open(brief_path, "w") as f:
+        f.write(f"# {name}\n\nDo the thing.\n")
+    return brief_path
+
+
+def create_fake_worker_config(
+    base_dir: str,
+    gate_commands: list | None = None,
+    worker_command: list | None = None
+) -> str:
+    """Create a farnsworth.json in base_dir with a fake worker command. Returns path."""
+    if gate_commands is None:
+        # Default: a gate that always passes
+        gate_commands = [
+            {"name": "tests", "command": ["python3", "-c", "import sys; sys.exit(0)"]}
+        ]
+
+    if worker_command is None:
+        # A fake worker: creates a file and commits it in the worktree
+        worker_command = [
+            "python3", "-c",
+            (
+                "import subprocess, os; "
+                "open('worker_output.txt', 'w').write('done'); "
+                "subprocess.run(['git', 'add', 'worker_output.txt'], check=True); "
+                "subprocess.run(['git', 'commit', '-m', 'worker output', "
+                "               '--allow-empty'], check=True)"
+            )
+        ]
+
+    config = {
+        "worker": {"command": worker_command},
+        "gate": gate_commands
+    }
+    config_path = os.path.join(base_dir, "farnsworth.json")
+    with open(config_path, "w") as f:
+        json.dump(config, f)
+    return config_path
+
+
+class TestRunnerBasic(unittest.TestCase):
+    """Basic tests for the run_task function."""
+
+    def setUp(self):
+        # base_dir is the temp dir root; repo is nested one level deeper
+        # so worktrees can be created as siblings of the repo
+        self.base_dir = tempfile.mkdtemp(prefix="farnsworth_test_")
+        self.repo_path = setup_scratch_git_repo(self.base_dir)
+
+    def tearDown(self):
+        # Clean up any worktrees before removing temp dir
+        worktree_path = os.path.join(
+            os.path.dirname(self.repo_path), "task-042-w1"
+        )
+        if os.path.exists(worktree_path):
+            subprocess.run(
+                ["git", "worktree", "remove", "--force", worktree_path],
+                cwd=self.repo_path,
+                capture_output=True
+            )
+            subprocess.run(
+                ["git", "branch", "-D", "task-042-w1"],
+                cwd=self.repo_path,
+                capture_output=True
+            )
+        shutil.rmtree(self.base_dir, ignore_errors=True)
+
+    def test_worktree_created(self):
+        """Worktree should be created at expected path."""
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir)
+
+        from farnsworth.runner import run_task
+        result = run_task(brief_path, config_path, repo_root=self.repo_path)
+
+        expected_worktree = os.path.join(
+            os.path.dirname(self.repo_path), "task-042-w1"
+        )
+        self.assertTrue(
+            os.path.isdir(expected_worktree),
+            f"Expected worktree at {expected_worktree}"
+        )
+
+    def test_gate_pass_returns_0(self):
+        """When all gates pass, run_task returns 0."""
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir, gate_commands=[
+            {"name": "always-pass", "command": ["python3", "-c", "import sys; sys.exit(0)"]}
+        ])
+
+        from farnsworth.runner import run_task
+        result = run_task(brief_path, config_path, repo_root=self.repo_path)
+        self.assertEqual(result, 0)
+
+    def test_gate_fail_returns_1(self):
+        """When a gate fails, run_task returns 1."""
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir, gate_commands=[
+            {"name": "always-fail", "command": ["python3", "-c", "import sys; sys.exit(1)"]}
+        ])
+
+        from farnsworth.runner import run_task
+        result = run_task(brief_path, config_path, repo_root=self.repo_path)
+        self.assertEqual(result, 1)
+
+    def test_run_json_schema(self):
+        """run.json should contain required fields matching the schema."""
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir)
+
+        from farnsworth.runner import run_task
+        run_task(brief_path, config_path, repo_root=self.repo_path)
+
+        run_json_path = os.path.join(
+            self.repo_path, ".farnsworth", "task-042", "run.json"
+        )
+        self.assertTrue(os.path.exists(run_json_path), "run.json should exist")
+
+        with open(run_json_path) as f:
+            data = json.load(f)
+
+        # Top-level fields
+        self.assertIn("task_id", data)
+        self.assertEqual(data["task_id"], "task-042")
+        self.assertIn("started_at", data)
+        self.assertIn("finished_at", data)
+        self.assertIn("base_commit", data)
+        self.assertIn("workers", data)
+
+        # Worker fields
+        self.assertEqual(len(data["workers"]), 1)
+        worker = data["workers"][0]
+        self.assertIn("id", worker)
+        self.assertEqual(worker["id"], "w1")
+        self.assertIn("branch", worker)
+        self.assertEqual(worker["branch"], "task-042-w1")
+        self.assertIn("worktree", worker)
+        self.assertIn("exit_code", worker)
+        self.assertIn("stdout_file", worker)
+        self.assertEqual(worker["stdout_file"], "w1.stdout")
+        self.assertIn("gate", worker)
+
+        # Gate fields
+        gate = worker["gate"]
+        self.assertIn("passed", gate)
+        self.assertIn("results", gate)
+        self.assertIsInstance(gate["results"], list)
+
+        # Gate results per entry
+        for gr in gate["results"]:
+            self.assertIn("name", gr)
+            self.assertIn("exit_code", gr)
+            self.assertIn("autopsy", gr)
+
+    def test_run_json_in_main_repo(self):
+        """run.json should be written in main repo, not in the worktree."""
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir)
+
+        from farnsworth.runner import run_task
+        run_task(brief_path, config_path, repo_root=self.repo_path)
+
+        run_json_path = os.path.join(
+            self.repo_path, ".farnsworth", "task-042", "run.json"
+        )
+        self.assertTrue(os.path.exists(run_json_path))
+
+        # Confirm it's NOT inside the worktree
+        worktree_path = os.path.join(
+            os.path.dirname(self.repo_path), "task-042-w1"
+        )
+        worktree_run_json = os.path.join(
+            worktree_path, ".farnsworth", "task-042", "run.json"
+        )
+        self.assertFalse(os.path.exists(worktree_run_json))
+
+    def test_stdout_stderr_files_created(self):
+        """Worker stdout and stderr files should be created in artifacts dir."""
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir)
+
+        from farnsworth.runner import run_task
+        run_task(brief_path, config_path, repo_root=self.repo_path)
+
+        artifacts_dir = os.path.join(
+            self.repo_path, ".farnsworth", "task-042"
+        )
+        self.assertTrue(os.path.exists(os.path.join(artifacts_dir, "w1.stdout")))
+        self.assertTrue(os.path.exists(os.path.join(artifacts_dir, "w1.stderr")))
+
+    def test_multiple_gates_all_run(self):
+        """All gate entries should run even when an earlier one fails."""
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir, gate_commands=[
+            {"name": "fail-gate", "command": ["python3", "-c", "import sys; sys.exit(1)"]},
+            {"name": "pass-gate", "command": ["python3", "-c", "import sys; sys.exit(0)"]}
+        ])
+
+        from farnsworth.runner import run_task
+        run_task(brief_path, config_path, repo_root=self.repo_path)
+
+        run_json_path = os.path.join(
+            self.repo_path, ".farnsworth", "task-042", "run.json"
+        )
