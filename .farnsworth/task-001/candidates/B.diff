+class TestNoCodeTipsWrite(unittest.TestCase):
+    """Verify that run_task never writes .code-tips.md."""
+
+    def setUp(self):
+        self.base_dir = tempfile.mkdtemp(prefix="farnsworth_notips_")
+        self.repo_path = setup_scratch_git_repo(self.base_dir)
+
+    def tearDown(self):
+        # Cleanup worktree
+        worktree_path = os.path.join(
+            os.path.dirname(self.repo_path), "task-042-w1"
+        )
+        if os.path.exists(worktree_path):
+            subprocess.run(
+                ["git", "worktree", "remove", "--force", worktree_path],
+                cwd=self.repo_path, capture_output=True
+            )
+            subprocess.run(
+                ["git", "branch", "-D", "task-042-w1"],
+                cwd=self.repo_path, capture_output=True
+            )
+        shutil.rmtree(self.base_dir, ignore_errors=True)
+
+    def test_code_tips_not_written(self):
+        """run_task should never create or modify .code-tips.md."""
+        tips_path = os.path.join(self.repo_path, ".code-tips.md")
+        # Record initial state (may or may not exist)
+        initial_exists = os.path.exists(tips_path)
+        initial_content = None
+        if initial_exists:
+            with open(tips_path) as f:
+                initial_content = f.read()
+
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir)
+
+        from farnsworth.runner import run_task
+        run_task(brief_path, config_path, repo_root=self.repo_path)
+
+        # .code-tips.md should be unchanged
+        if initial_exists:
+            self.assertTrue(os.path.exists(tips_path))
+            with open(tips_path) as f:
+                self.assertEqual(f.read(), initial_content)
+        else:
+            self.assertFalse(os.path.exists(tips_path))
+
+
+if __name__ == "__main__":
+    unittest.main()
