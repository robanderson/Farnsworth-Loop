+"""Core runner logic for Farnsworth Loop M1."""
+
+import json
+import os
+import subprocess
+import sys
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any, Optional
+
+from .config import load_config
+from .git_utils import (
+    get_repo_root,
+    get_head_sha,
+    is_working_tree_clean,
+    create_worktree,
+)
+
+
+def build_worker_prompt(repo_root: str, task_brief_path: str) -> str:
+    """Construct the worker briefing from .code-tips.md and task brief contents."""
+    parts = []
+
+    tips_path = os.path.join(repo_root, ".code-tips.md")
+    if os.path.exists(tips_path):
+        with open(tips_path, "r", encoding="utf-8") as f:
+            tips = f.read()
+        parts.append(tips)
+
+    with open(task_brief_path, "r", encoding="utf-8") as f:
+        brief = f.read()
+
+    parts.append("\n\nTASK: " + brief)
+    return "".join(parts)
+
+
+def substitute_prompt(argv: list[str], prompt: str) -> list[str]:
+    """Substitute {prompt} placeholder in command argv with actual prompt."""
+    return [arg.replace("{prompt}", prompt) for arg in argv]
+
+
+def run_worker(
+    worker_command: list[str],
+    worktree_path: str,
+    prompt: str,
+    stdout_file: str,
+    stderr_file: str
+) -> int:
+    """Run the worker command in the worktree. Returns exit code."""
+    cmd = substitute_prompt(worker_command, prompt)
+
+    with open(stdout_file, "w", encoding="utf-8") as fout, \
+         open(stderr_file, "w", encoding="utf-8") as ferr:
+        result = subprocess.run(
+            cmd,
+            cwd=worktree_path,
+            stdout=fout,
+            stderr=ferr
+        )
+
+    return result.returncode
+
+
+def run_gate(
+    gate_entries: list[dict],
+    worktree_path: str
+) -> dict[str, Any]:
+    """Run all gate commands in the worktree. Returns gate result dict."""
+    results = []
+    all_passed = True
+
+    for entry in gate_entries:
+        name = entry["name"]
+        command = entry["command"]
+
+        proc = subprocess.run(
+            command,
+            cwd=worktree_path,
+            capture_output=True,
+            text=True
+        )
+
+        exit_code = proc.returncode
+        passed = exit_code == 0
+
+        if not passed:
+            all_passed = False
+            # Get last line of stderr for autopsy
+            stderr_lines = proc.stderr.strip().splitlines()
+            last_stderr = stderr_lines[-1] if stderr_lines else ""
+            autopsy = f"{name}: exit {exit_code}"
+            if last_stderr:
+                autopsy = f"{autopsy}; {last_stderr}"
+        else:
+            autopsy = f"{name}: exit 0"
+
+        results.append({
+            "name": name,
+            "exit_code": exit_code,
+            "autopsy": autopsy
+        })
+
+    return {
+        "passed": all_passed,
+        "results": results
+    }
+
+
+def run_task(
+    task_brief_path: str,
+    config_path: str,
+    repo_root: Optional[str] = None
+) -> int:
+    """
+    Main run logic. Returns 0 if all gates passed, 1 otherwise.
+    """
+    # Resolve paths
+    task_brief_path = os.path.abspath(task_brief_path)
+    config_path = os.path.abspath(config_path)
+
+    if not os.path.exists(task_brief_path):
+        print(f"Error: Task brief file not found: {task_brief_path}", file=sys.stderr)
+        return 2
+
+    # Determine repo root
+    if repo_root is None:
+        try:
+            repo_root = get_repo_root()
+        except RuntimeError as e:
+            print(f"Error: {e}", file=sys.stderr)
+            return 2
+
+    # Verify clean working tree
+    if not is_working_tree_clean(cwd=repo_root):
+        print(
+            "Error: Working tree is not clean. Commit or stash changes before running Farnsworth.",
+            file=sys.stderr
+        )
+        return 2
+
+    # Load config
+    config = load_config(config_path)
+
+    # Derive task_id from brief filename stem
+    task_id = Path(task_brief_path).stem
+
+    # Define paths
+    worktree_path = os.path.join(os.path.dirname(repo_root), f"{task_id}-w1")
+    branch_name = f"{task_id}-w1"
+    artifacts_dir = os.path.join(repo_root, ".farnsworth", task_id)
+
+    # Record timing
+    started_at = datetime.now(timezone.utc).isoformat()
+
+    # Get base commit SHA
+    base_commit = get_head_sha(cwd=repo_root)
+
+    # Create worktree
+    try:
+        create_worktree(repo_root, worktree_path, branch_name)
+    except RuntimeError as e:
+        print(f"Error: {e}", file=sys.stderr)
+        return 2
+
+    print(f"Worktree created: {worktree_path} (branch: {branch_name})")
+
+    # Create artifacts directory
+    os.makedirs(artifacts_dir, exist_ok=True)
+    stdout_file = os.path.join(artifacts_dir, "w1.stdout")
+    stderr_file = os.path.join(artifacts_dir, "w1.stderr")
+
+    # Build prompt
+    prompt = build_worker_prompt(repo_root, task_brief_path)
+
+    # Run worker
+    print("Running worker...")
+    worker_exit_code = run_worker(
+        config["worker"]["command"],
+        worktree_path,
+        prompt,
+        stdout_file,
+        stderr_file
+    )
+    print(f"Worker finished with exit code: {worker_exit_code}")
+
+    # Run gate
+    print("Running gate checks...")
+    gate_result = run_gate(config.get("gate", []), worktree_path)
+
+    # Record end time
+    finished_at = datetime.now(timezone.utc).isoformat()
+
+    # Build run log
+    run_log = {
+        "task_id": task_id,
+        "started_at": started_at,
+        "finished_at": finished_at,
+        "base_commit": base_commit,
+        "workers": [
+            {
+                "id": "w1",
+                "branch": branch_name,
+                "worktree": os.path.relpath(worktree_path, repo_root),
+                "exit_code": worker_exit_code,
+                "stdout_file": "w1.stdout",
+                "gate": gate_result
+            }
+        ]
+    }
+
+    # Write run log
+    run_log_path = os.path.join(artifacts_dir, "run.json")
+    with open(run_log_path, "w", encoding="utf-8") as f:
+        json.dump(run_log, f, indent=2)
+    print(f"Run log written: {run_log_path}")
+
+    # Print gate summary
+    print("\nGate summary:")
+    for r in gate_result["results"]:
+        status = "PASS" if r["exit_code"] == 0 else "FAIL"
+        print(f"  [{status}] {r['autopsy']}")
+
+    if gate_result["passed"]:
+        print(f"\nAll gates passed. Worktree: {worktree_path}")
+        return 0
+    else:
+        print(f"\nSome gates failed. Worktree: {worktree_path}")
+        return 1
