+class TestCleanTreePrecondition(unittest.TestCase):
+    """Test that dirty working tree causes abort."""
+
+    def setUp(self):
+        self.base_dir = tempfile.mkdtemp(prefix="farnsworth_dirty_")
+        self.repo_path = setup_scratch_git_repo(self.base_dir)
+
+    def tearDown(self):
+        shutil.rmtree(self.base_dir, ignore_errors=True)
+
+    def test_dirty_tree_aborts(self):
+        """Uncommitted changes should cause run_task to return 2."""
+        # Create an uncommitted file to dirty the tree
+        dirty_file = os.path.join(self.repo_path, "dirty.txt")
+        with open(dirty_file, "w") as f:
+            f.write("I am dirty\n")
+
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir)
+
+        from farnsworth.runner import run_task
+        result = run_task(brief_path, config_path, repo_root=self.repo_path)
+        self.assertEqual(result, 2)
+
+    def test_staged_changes_aborts(self):
+        """Staged but uncommitted changes should cause abort."""
+        staged_file = os.path.join(self.repo_path, "staged.txt")
+        with open(staged_file, "w") as f:
+            f.write("staged\n")
+        subprocess.run(["git", "add", "staged.txt"],
+                       cwd=self.repo_path, check=True, capture_output=True)
+
+        brief_path = create_task_brief(self.base_dir, "task-042")
+        config_path = create_fake_worker_config(self.base_dir)
+
+        from farnsworth.runner import run_task
+        result = run_task(brief_path, config_path, repo_root=self.repo_path)
+        self.assertEqual(result, 2)
