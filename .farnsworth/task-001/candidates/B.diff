+class TestPromptBuilding(unittest.TestCase):
+    """Test worker prompt construction."""
+
+    def setUp(self):
+        self.base_dir = tempfile.mkdtemp(prefix="farnsworth_prompt_")
+
+    def tearDown(self):
+        shutil.rmtree(self.base_dir, ignore_errors=True)
+
+    def test_prompt_includes_task_brief(self):
+        """Prompt should include task brief contents."""
+        brief_path = os.path.join(self.base_dir, "task-999.md")
+        with open(brief_path, "w") as f:
+            f.write("Do the secret thing.\n")
+
+        # No .code-tips.md, so prompt should just have the brief
+        from farnsworth.runner import build_worker_prompt
+        prompt = build_worker_prompt(self.base_dir, brief_path)
+        self.assertIn("Do the secret thing.", prompt)
+        self.assertIn("TASK:", prompt)
+
+    def test_prompt_includes_code_tips(self):
+        """Prompt should include .code-tips.md content when present."""
+        tips_path = os.path.join(self.base_dir, ".code-tips.md")
+        with open(tips_path, "w") as f:
+            f.write("## Invariants\n- Never do the bad thing.\n")
+
+        brief_path = os.path.join(self.base_dir, "task-999.md")
+        with open(brief_path, "w") as f:
+            f.write("Do the thing.\n")
+
+        from farnsworth.runner import build_worker_prompt
+        prompt = build_worker_prompt(self.base_dir, brief_path)
+        self.assertIn("Never do the bad thing.", prompt)
+        self.assertIn("Do the thing.", prompt)
+
+    def test_prompt_substitution(self):
+        """The {prompt} placeholder in worker command should be substituted."""
+        from farnsworth.runner import substitute_prompt
+        cmd = ["echo", "{prompt}", "--flag"]
+        result = substitute_prompt(cmd, "hello world")
+        self.assertEqual(result, ["echo", "hello world", "--flag"])
+
+    def test_prompt_no_code_tips(self):
+        """When .code-tips.md is absent, prompt still works."""
+        brief_path = os.path.join(self.base_dir, "task-000.md")
+        with open(brief_path, "w") as f:
+            f.write("Simple task.\n")
+
+        from farnsworth.runner import build_worker_prompt
+        prompt = build_worker_prompt(self.base_dir, brief_path)
+        self.assertNotIn("code-tips", prompt.lower())
+        self.assertIn("Simple task.", prompt)
+
