+"""Entry point for `python3 -m farnsworth`."""
+
+import argparse
+import sys
+import os
+
+from .runner import run_task
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(
+        prog="farnsworth",
+        description="Farnsworth Loop - M1 Skeleton"
+    )
+    subparsers = parser.add_subparsers(dest="subcommand", required=True)
+
+    run_parser = subparsers.add_parser("run", help="Run a task with one worker")
+    run_parser.add_argument(
+        "task_brief",
+        help="Path to the task brief markdown file"
+    )
+    run_parser.add_argument(
+        "--config",
+        default="farnsworth.json",
+        help="Path to config JSON file (default: farnsworth.json in repo root)"
+    )
+
+    args = parser.parse_args()
+
+    if args.subcommand == "run":
+        return run_task(args.task_brief, args.config)
+
+    parser.print_help()
+    return 2
+
+
+if __name__ == "__main__":
+    sys.exit(main())
