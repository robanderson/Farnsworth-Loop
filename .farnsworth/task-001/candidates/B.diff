+"""Git utilities for Farnsworth Loop."""
+
+import subprocess
+import sys
+from typing import Optional
+
+
+def get_repo_root(cwd: Optional[str] = None) -> str:
+    """Return absolute path of git repo root, or raise RuntimeError."""
+    result = subprocess.run(
+        ["git", "rev-parse", "--show-toplevel"],
+        cwd=cwd,
+        capture_output=True,
+        text=True
+    )
+    if result.returncode != 0:
+        raise RuntimeError("Not inside a git repository.")
+    return result.stdout.strip()
+
+
+def get_head_sha(cwd: Optional[str] = None) -> str:
+    """Return the current HEAD commit SHA."""
+    result = subprocess.run(
+        ["git", "rev-parse", "HEAD"],
+        cwd=cwd,
+        capture_output=True,
+        text=True
+    )
+    if result.returncode != 0:
+        raise RuntimeError("Failed to get HEAD SHA.")
+    return result.stdout.strip()
+
+
+def is_working_tree_clean(cwd: Optional[str] = None) -> bool:
+    """Return True if working tree has no uncommitted changes."""
+    result = subprocess.run(
+        ["git", "status", "--porcelain"],
+        cwd=cwd,
+        capture_output=True,
+        text=True
+    )
+    if result.returncode != 0:
+        return False
+    return result.stdout.strip() == ""
+
+
+def create_worktree(repo_root: str, worktree_path: str, branch_name: str) -> None:
+    """Create a new git worktree at worktree_path on a new branch branch_name."""
+    result = subprocess.run(
+        ["git", "worktree", "add", worktree_path, "-b", branch_name],
+        cwd=repo_root,
+        capture_output=True,
+        text=True
+    )
+    if result.returncode != 0:
+        raise RuntimeError(
+            f"Failed to create worktree at '{worktree_path}' on branch '{branch_name}':\n"
+            f"{result.stderr.strip()}"
+        )
+
+
+def remove_worktree(repo_root: str, worktree_path: str) -> None:
+    """Remove a git worktree (for cleanup in tests)."""
+    subprocess.run(
+        ["git", "worktree", "remove", "--force", worktree_path],
+        cwd=repo_root,
+        capture_output=True,
+        text=True
+    )
+
+
+def delete_branch(repo_root: str, branch_name: str) -> None:
+    """Delete a git branch (for cleanup in tests)."""
+    subprocess.run(
+        ["git", "branch", "-D", branch_name],
+        cwd=repo_root,
+        capture_output=True,
+        text=True
+    )
