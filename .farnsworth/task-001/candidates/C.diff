+"""Tests for the CLI."""
+
+import json
+import os
+import shutil
+import subprocess
+import tempfile
+import unittest
+from pathlib import Path
+
+from farnsworth.cli import main, run_task
+
+
+class TestCLI(unittest.TestCase):
+    """Test CLI functionality."""
+
+    def setUp(self):
+        """Set up a temporary git repository for testing."""
+        self.temp_dir = tempfile.mkdtemp()
+        self.repo_path = Path(self.temp_dir) / "test_repo"
+        self.repo_path.mkdir()
+
+        # Initialize git repo
+        subprocess.run(
+            ["git", "init"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "config", "user.email", "test@example.com"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "config", "user.name", "Test User"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "config", "commit.gpgsign", "false"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+
+        # Create initial commit
+        (self.repo_path / "README.md").write_text("# Test Repo\n")
+        subprocess.run(
+            ["git", "add", "README.md"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "commit", "-m", "Initial commit"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+
+        # Save current directory
+        self.orig_cwd = os.getcwd()
+        os.chdir(self.repo_path)
+
+    def tearDown(self):
+        """Clean up temporary directory and worktrees."""
+        # Restore directory
+        os.chdir(self.orig_cwd)
+
+        # Clean up any worktrees
+        try:
+            result = subprocess.run(
+                ["git", "worktree", "list"],
+                cwd=self.repo_path,
+                capture_output=True,
+                text=True,
+                check=True,
+            )
+            for line in result.stdout.split("\n"):
+                if "detached" in line or "task" in line:
+                    parts = line.split()
+                    if parts:
+                        path = parts[0]
+                        if path != str(self.repo_path):
+                            try:
+                                subprocess.run(
+                                    ["git", "worktree", "remove", path, "-f"],
+                                    cwd=self.repo_path,
+                                    capture_output=True,
+                                    timeout=5,
+                                )
+                            except Exception:
+                                pass
+        except Exception:
+            pass
+
+        # Remove temp directory
+        if os.path.exists(self.temp_dir):
+            shutil.rmtree(self.temp_dir)
+
+    def test_run_task_success(self):
+        """Test running a task with all gates passing."""
+        # Create a task brief
+        task_brief = self.repo_path / "task-001.md"
+        task_brief.write_text("# Task 001\n\nTest task brief.\n")
+
+        # Create a config file
+        config_file = self.repo_path / "farnsworth.json"
+        config_file.write_text(json.dumps({
+            "worker": {
+                "command": ["true"],
+            },
+            "gate": [
+                {"name": "test", "command": ["true"]},
+            ],
+        }))
+
+        # Commit the files
+        subprocess.run(
+            ["git", "add", "task-001.md", "farnsworth.json"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "commit", "-m", "Add test files"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+
+        result = run_task(str(task_brief), str(config_file))
+        self.assertEqual(result, 0)
+
+    def test_run_task_gate_failure(self):
+        """Test running a task with a failing gate."""
+        # Create a task brief
