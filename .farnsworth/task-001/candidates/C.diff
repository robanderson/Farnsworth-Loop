+"""Tests for the WorkerRunner."""
+
+import json
+import os
+import shutil
+import subprocess
+import tempfile
+import unittest
+from pathlib import Path
+
+from farnsworth.runner import WorkerRunner
+
+
+class TestWorkerRunner(unittest.TestCase):
+    """Test worktree creation and runner functionality."""
+
+    def setUp(self):
+        """Set up a temporary git repository for testing."""
+        self.temp_dir = tempfile.mkdtemp()
+        self.repo_path = Path(self.temp_dir) / "test_repo"
+        self.repo_path.mkdir()
+
+        # Initialize git repo
+        subprocess.run(
+            ["git", "init"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "config", "user.email", "test@example.com"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "config", "user.name", "Test User"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "config", "commit.gpgsign", "false"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+
+        # Create initial commit
+        (self.repo_path / "README.md").write_text("# Test Repo\n")
+        subprocess.run(
+            ["git", "add", "README.md"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+        subprocess.run(
+            ["git", "commit", "-m", "Initial commit"],
+            cwd=self.repo_path,
+            check=True,
+            capture_output=True,
+        )
+
+    def tearDown(self):
+        """Clean up temporary directory and worktrees."""
+        # Clean up any worktrees
+        try:
+            result = subprocess.run(
+                ["git", "worktree", "list"],
+                cwd=self.repo_path,
+                capture_output=True,
+                text=True,
+                check=True,
+            )
+            for line in result.stdout.split("\n"):
+                if "detached" in line or "task" in line:
+                    parts = line.split()
+                    if parts:
+                        path = parts[0]
+                        if path != str(self.repo_path):
+                            try:
+                                subprocess.run(
+                                    ["git", "worktree", "remove", path, "-f"],
+                                    cwd=self.repo_path,
+                                    capture_output=True,
+                                    timeout=5,
+                                )
+                            except Exception:
+                                pass
+        except Exception:
+            pass
+
+        # Remove temp directory
+        if os.path.exists(self.temp_dir):
+            shutil.rmtree(self.temp_dir)
+
+    def test_worktree_creation(self):
+        """Test that worktree is created successfully."""
+        # Create a task brief
+        task_brief = self.repo_path / "task-001.md"
+        task_brief.write_text("# Task 001\n\nTest task brief.\n")
+
+        # Create a fake worker command that just creates a file
+        config = {
+            "worker": {
+                "command": ["bash", "-c", "echo 'Worker output' > worker.txt"]
+            },
+            "gate": [],
+        }
+
+        runner = WorkerRunner(config, str(self.repo_path))
+        result = runner.run("task-001", str(task_brief), "abc123")
+
+        # Verify worktree was created
+        worktree_path = Path(result["worktree_path"])
+        self.assertTrue(worktree_path.exists())
+
+        # Verify the worker command ran in the worktree
+        self.assertTrue((worktree_path / "worker.txt").exists())
+
+    def test_gate_pass(self):
+        """Test gate passes when all commands succeed."""
+        # Create a task brief
+        task_brief = self.repo_path / "task-001.md"
+        task_brief.write_text("# Task 001\n\nTest task brief.\n")
+
+        # Create a fake worker that just succeeds
+        config = {
+            "worker": {
+                "command": ["true"],
+            },
+            "gate": [
+                {"name": "test_gate", "command": ["true"]},
+            ],
+        }
+
+        runner = WorkerRunner(config, str(self.repo_path))
+        result = runner.run("task-001", str(task_brief), "abc123")
+
+        self.assertTrue(result["gate_passed"])
+        self.assertEqual(len(result["gate_results"]), 1)
+        self.assertEqual(result["gate_results"][0]["exit_code"], 0)
+        self.assertEqual(result["gate_results"][0]["name"], "test_gate")
+
+    def test_gate_fail(self):
+        """Test gate fails when a command fails."""
+        # Create a task brief
+        task_brief = self.repo_path / "task-001.md"
+        task_brief.write_text("# Task 001\n\nTest task brief.\n")
+
+        # Create a fake worker that just succeeds
+        config = {
+            "worker": {
+                "command": ["true"],
+            },
+            "gate": [
+                {"name": "failing_gate", "command": ["false"]},
+            ],
+        }
+
+        runner = WorkerRunner(config, str(self.repo_path))
+        result = runner.run("task-001", str(task_brief), "abc123")
+
+        self.assertFalse(result["gate_passed"])
+        self.assertEqual(len(result["gate_results"]), 1)
+        self.assertEqual(result["gate_results"][0]["exit_code"], 1)
+
+    def test_run_json_schema(self):
+        """Test that run.json is created with correct schema."""
+        # Create a task brief
+        task_brief = self.repo_path / "task-001.md"
+        task_brief.write_text("# Task 001\n\nTest task brief.\n")
+
+        config = {
+            "worker": {
+                "command": ["true"],
+            },
+            "gate": [
+                {"name": "test", "command": ["true"]},
+            ],
+        }
+
+        runner = WorkerRunner(config, str(self.repo_path))
+        result = runner.run("task-001", str(task_brief), "abc123def456")
+
+        # Read the generated run.json
+        run_json_path = self.repo_path / ".farnsworth" / "task-001" / "run.json"
+        self.assertTrue(run_json_path.exists())
+
+        with open(run_json_path) as f:
+            run_log = json.load(f)
+
+        # Verify schema
+        self.assertIn("task_id", run_log)
+        self.assertIn("started_at", run_log)
+        self.assertIn("finished_at", run_log)
+        self.assertIn("base_commit", run_log)
+        self.assertIn("workers", run_log)
+
+        self.assertEqual(run_log["task_id"], "task-001")
+        self.assertEqual(run_log["base_commit"], "abc123def456")
+        self.assertEqual(len(run_log["workers"]), 1)
+
+        worker = run_log["workers"][0]
+        self.assertEqual(worker["id"], "w1")
+        self.assertEqual(worker["branch"], "task-001-w1")
+        self.assertIn("worktree", worker)
+        self.assertIn("exit_code", worker)
+        self.assertIn("stdout_file", worker)
+        self.assertIn("gate", worker)
+
+        gate = worker["gate"]
+        self.assertIn("passed", gate)
+        self.assertIn("results", gate)
+        self.assertEqual(len(gate["results"]), 1)
+
+        gate_result = gate["results"][0]
+        self.assertIn("name", gate_result)
+        self.assertIn("exit_code", gate_result)
+        self.assertIn("autopsy", gate_result)
+
+    def test_multiple_gates(self):
+        """Test multiple gate commands are all executed."""
+        # Create a task brief
+        task_brief = self.repo_path / "task-001.md"
+        task_brief.write_text("# Task 001\n\nTest task brief.\n")
+
+        config = {
+            "worker": {
+                "command": ["true"],
+            },
+            "gate": [
+                {"name": "gate1", "command": ["true"]},
+                {"name": "gate2", "command": ["true"]},
+                {"name": "gate3", "command": ["false"]},
+            ],
+        }
+
+        runner = WorkerRunner(config, str(self.repo_path))
+        result = runner.run("task-001", str(task_brief), "abc123")
+
+        self.assertEqual(len(result["gate_results"]), 3)
+        self.assertEqual(result["gate_results"][0]["name"], "gate1")
+        self.assertEqual(result["gate_results"][1]["name"], "gate2")
+        self.assertEqual(result["gate_results"][2]["name"], "gate3")
+        self.assertFalse(result["gate_passed"])
+
+    def test_worker_stdout_file(self):
+        """Test worker stdout is written to file."""
+        # Create a task brief
+        task_brief = self.repo_path / "task-001.md"
+        task_brief.write_text("# Task 001\n\nTest task brief.\n")
+
+        config = {
+            "worker": {
+                "command": ["echo", "test output"],
