@@ -0,0 +1,212 @@
+"""Worker dispatch and gate execution."""
+
+import json
+import os
+import subprocess
+import sys
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+
+
+class WorkerRunner:
+    """Manages worktree creation, worker dispatch, and gate execution."""
+
+    def __init__(self, config: Dict[str, Any], repo_cwd: str):
+        """Initialize runner with configuration and repo path."""
+        self.config = config
+        self.repo_cwd = repo_cwd
+        self.repo_path = Path(repo_cwd)
+
+    def run(self, task_id: str, task_brief_path: str, base_commit: str) -> Dict[str, Any]:
+        """
+        Run a single worker for a task.
+
+        Returns a dict with:
+        - task_id
+        - started_at
+        - finished_at
+        - base_commit
+        - workers
+        - gate_passed
+        - gate_results
+        - worktree_path
+        """
+        started_at = datetime.now(timezone.utc)
+
+        # Create worktree
+        worktree_id = "w1"
+        branch_name = f"{task_id}-w1"
+        worktree_relpath = f"../{task_id}-w1"
+        worktree_abspath = (self.repo_path.parent / f"{task_id}-w1").absolute()
+
+        try:
+            # Create the worktree
+            subprocess.run(
+                ["git", "worktree", "add", worktree_relpath, "-b", branch_name],
+                cwd=self.repo_cwd,
+                check=True,
+                capture_output=True,
+            )
+        except subprocess.CalledProcessError as e:
+            print(f"Error: failed to create worktree: {e}", file=sys.stderr)
+            return {
+                "task_id": task_id,
+                "started_at": started_at.isoformat(),
+                "finished_at": datetime.now(timezone.utc).isoformat(),
+                "base_commit": base_commit,
+                "workers": [],
+                "gate_passed": False,
+                "gate_results": [],
+                "worktree_path": str(worktree_abspath),
+            }
+
+        # Create .farnsworth directory for logs
+        farnsworth_dir = self.repo_path / ".farnsworth" / task_id
+        farnsworth_dir.mkdir(parents=True, exist_ok=True)
+
+        # Read the task brief
+        with open(task_brief_path, "r") as f:
+            task_brief_content = f.read()
+
+        # Read code-tips if it exists
+        code_tips_path = self.repo_path / ".code-tips.md"
+        code_tips_content = ""
+        if code_tips_path.exists():
+            with open(code_tips_path, "r") as f:
+                code_tips_content = f.read()
+
+        # Prepare the worker briefing
+        briefing = code_tips_content
+        if briefing:
+            briefing += "\n\nTASK: "
+        else:
+            briefing = "TASK: "
+        briefing += task_brief_content
+
+        # Prepare the worker command
+        worker_config = self.config.get("worker", {})
+        worker_command = worker_config.get("command", [])
+
+        # Substitute {prompt} with the briefing
+        substituted_command = [
+            arg.replace("{prompt}", briefing) for arg in worker_command
+        ]
+
+        # Run the worker
+        stdout_file = farnsworth_dir / f"{worktree_id}.stdout"
+        stderr_file = farnsworth_dir / f"{worktree_id}.stderr"
+
+        try:
+            result = subprocess.run(
+                substituted_command,
+                cwd=str(worktree_abspath),
+                capture_output=True,
+                text=True,
+                timeout=None,
+            )
+            worker_exit_code = result.returncode
+            stdout_content = result.stdout
+            stderr_content = result.stderr
+        except subprocess.TimeoutExpired:
+            worker_exit_code = -1
+            stdout_content = ""
+            stderr_content = "Worker command timed out"
+        except Exception as e:
+            worker_exit_code = -1
+            stdout_content = ""
+            stderr_content = str(e)
+
+        # Write stdout and stderr files
+        with open(stdout_file, "w") as f:
+            f.write(stdout_content)
+        with open(stderr_file, "w") as f:
+            f.write(stderr_content)
+
+        # Run the gate
+        gate_results = self._run_gate(worktree_abspath)
+        gate_passed = all(g["exit_code"] == 0 for g in gate_results)
+
+        finished_at = datetime.now(timezone.utc)
+
+        # Create run.json
+        run_log = {
+            "task_id": task_id,
+            "started_at": started_at.isoformat(),
+            "finished_at": finished_at.isoformat(),
+            "base_commit": base_commit,
+            "workers": [
+                {
+                    "id": worktree_id,
+                    "branch": branch_name,
+                    "worktree": worktree_relpath,
+                    "exit_code": worker_exit_code,
+                    "stdout_file": f"{worktree_id}.stdout",
+                    "gate": {
+                        "passed": gate_passed,
+                        "results": gate_results,
+                    },
+                }
+            ],
+        }
+
+        # Write run.json
+        run_json_path = farnsworth_dir / "run.json"
+        with open(run_json_path, "w") as f:
+            json.dump(run_log, f, indent=2)
+
+        return {
+            "task_id": task_id,
+            "started_at": started_at.isoformat(),
+            "finished_at": finished_at.isoformat(),
+            "base_commit": base_commit,
+            "workers": run_log["workers"],
+            "gate_passed": gate_passed,
+            "gate_results": gate_results,
+            "worktree_path": str(worktree_abspath),
+        }
+
+    def _run_gate(self, worktree_path: Path) -> List[Dict[str, Any]]:
+        """Run all gate commands in the worktree."""
+        gate_config = self.config.get("gate", [])
+        results = []
+
+        for gate_entry in gate_config:
+            name = gate_entry.get("name", "unknown")
+            command = gate_entry.get("command", [])
+
+            try:
+                result = subprocess.run(
+                    command,
+                    cwd=str(worktree_path),
+                    capture_output=True,
+                    text=True,
+                    timeout=None,
+                )
+                exit_code = result.returncode
+                stderr_content = result.stderr
+            except subprocess.TimeoutExpired:
+                exit_code = -1
+                stderr_content = "Command timed out"
+            except Exception as e:
+                exit_code = -1
+                stderr_content = str(e)
+
+            # Generate autopsy
+            if exit_code == 0:
+                autopsy = f"{name}: exit 0"
+            else:
+                # Try to get last line of stderr
+                if stderr_content.strip():
+                    last_line = stderr_content.strip().split("\n")[-1]
+                    autopsy = f"{name}: exit {exit_code} ({last_line})"
+                else:
+                    autopsy = f"{name}: exit {exit_code}"
+
+            results.append({
+                "name": name,
+                "exit_code": exit_code,
+                "autopsy": autopsy,
+            })
+
+        return results
