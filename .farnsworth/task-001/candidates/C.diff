+        self.assertTrue(stdout_file.exists())
+        content = stdout_file.read_text()
+        self.assertIn("test output", content)
+
+    def test_gate_autopsy(self):
+        """Test that autopsy is generated for gate failures."""
+        # Create a task brief
+        task_brief = self.repo_path / "task-001.md"
+        task_brief.write_text("# Task 001\n\nTest task brief.\n")
+
+        config = {
+            "worker": {
+                "command": ["true"],
+            },
+            "gate": [
+                {"name": "mytest", "command": ["bash", "-c", "echo error; exit 2"]},
+            ],
+        }
+
+        runner = WorkerRunner(config, str(self.repo_path))
+        result = runner.run("task-001", str(task_brief), "abc123")
+
+        gate_result = result["gate_results"][0]
