+"""Main CLI implementation for Farnsworth Loop."""
+
+import argparse
+import json
+import os
+import subprocess
+import sys
+from datetime import datetime
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+
+from farnsworth.runner import WorkerRunner
+
+
+def load_config(config_path: str) -> Dict[str, Any]:
+    """Load JSON configuration file."""
+    with open(config_path, "r") as f:
+        return json.load(f)
+
+
+def main() -> int:
+    """Main CLI entry point."""
+    parser = argparse.ArgumentParser(
+        description="Farnsworth Loop: M1 skeleton implementation"
+    )
+    parser.add_argument(
+        "command", choices=["run"], help="Command to execute"
+    )
+    parser.add_argument(
+        "task_brief", help="Path to task brief markdown file"
+    )
+    parser.add_argument(
+        "--config",
+        default="farnsworth.json",
+        help="Path to configuration file (default: farnsworth.json)",
+    )
+
+    args = parser.parse_args()
+
+    if args.command == "run":
+        return run_task(args.task_brief, args.config)
+
+    return 1
+
+
+def run_task(task_brief_path: str, config_path: str) -> int:
+    """Run a single task with one worker."""
+    task_brief_path = os.path.abspath(task_brief_path)
+
+    # Verify task brief exists
+    if not os.path.isfile(task_brief_path):
+        print(f"Error: task brief not found: {task_brief_path}", file=sys.stderr)
+        return 1
+
+    # Extract task ID from brief path stem
+    task_id = Path(task_brief_path).stem
+
+    # Load configuration
+    if not os.path.isfile(config_path):
+        print(f"Error: config file not found: {config_path}", file=sys.stderr)
+        return 1
+
+    try:
+        config = load_config(config_path)
+    except json.JSONDecodeError as e:
+        print(f"Error: invalid JSON in config: {e}", file=sys.stderr)
+        return 1
+
+    # Verify current directory is a git repo with clean tree
+    cwd = os.getcwd()
+    try:
+        result = subprocess.run(
+            ["git", "rev-parse", "--git-dir"],
+            cwd=cwd,
+            capture_output=True,
+            text=True,
+            check=False,
+        )
+        if result.returncode != 0:
+            print("Error: current directory is not a git repository", file=sys.stderr)
+            return 1
+
+        # Check working tree is clean
+        result = subprocess.run(
+            ["git", "status", "--porcelain"],
+            cwd=cwd,
+            capture_output=True,
+            text=True,
+            check=False,
+        )
+        if result.stdout.strip():
+            print("Error: git working tree is not clean", file=sys.stderr)
+            return 1
+
+        # Get base commit
+        result = subprocess.run(
+            ["git", "rev-parse", "HEAD"],
+            cwd=cwd,
+            capture_output=True,
+            text=True,
+            check=True,
+        )
+        base_commit = result.stdout.strip()
+    except subprocess.CalledProcessError as e:
+        print(f"Error: git command failed: {e}", file=sys.stderr)
+        return 1
+
+    # Run the task
+    runner = WorkerRunner(config, cwd)
+    result = runner.run(task_id, task_brief_path, base_commit)
+
+    # Print summary
+    if result["gate_passed"]:
+        print(f"✓ All gates passed")
+        print(f"Worktree: {result['worktree_path']}")
+        return 0
+    else:
+        print(f"✗ Gate failed")
+        for gate_result in result["gate_results"]:
+            if gate_result["exit_code"] != 0:
+                autopsy = gate_result.get("autopsy", "unknown")
+                print(f"  - {autopsy}")
+        print(f"Worktree: {result['worktree_path']}")
+        return 1
+
+
+if __name__ == "__main__":
+    sys.exit(main())
