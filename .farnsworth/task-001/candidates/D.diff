+"""Core runner logic for Farnsworth Loop."""
+
+import json
+import os
+import subprocess
+import sys
+from datetime import datetime
+from pathlib import Path
+
+
+class Runner:
+    """Single-worker task runner."""
+
+    def __init__(self, task_brief_path: Path, config_path: Path):
+        """Initialize the runner."""
+        self.task_brief_path = Path(task_brief_path)
+        self.config_path = Path(config_path)
+        self.cwd = Path.cwd()
+
+        # Validate files exist
+        if not self.task_brief_path.exists():
+            raise FileNotFoundError(f"Task brief not found: {self.task_brief_path}")
+        if not self.config_path.exists():
+            raise FileNotFoundError(f"Config not found: {self.config_path}")
+
+        # Load config
+        with open(self.config_path) as f:
+            self.config = json.load(f)
+
+        # Extract task ID from brief path stem
+        self.task_id = self.task_brief_path.stem
+        self.worker_id = "w1"
+        self.branch_name = f"{self.task_id}-w1"
+        self.worktree_path = self.cwd.parent / f"{self.task_id}-w1"
+
+    def run(self) -> bool:
+        """Run the task and return True if all gates pass."""
+        # Step a: Verify git repo with clean working tree
+        self._verify_git_clean()
+
+        # Step b: Create worktree
+        self._create_worktree()
+
+        # Build briefing
+        briefing = self._build_briefing()
+
+        # Step c: Run worker command
+        worker_result = self._run_worker(briefing)
+
+        # Save worker output
+        log_dir = self.cwd / ".farnsworth" / self.task_id
+        log_dir.mkdir(parents=True, exist_ok=True)
+
+        with open(log_dir / f"{self.worker_id}.stdout", "w") as f:
+            f.write(worker_result["stdout"])
+        with open(log_dir / f"{self.worker_id}.stderr", "w") as f:
+            f.write(worker_result["stderr"])
+
+        # Step d: Run gates
+        gate_results = self._run_gates()
+
+        # Step e: Write run log
+        run_log = self._build_run_log(worker_result, gate_results)
+        run_json_path = log_dir / "run.json"
+        with open(run_json_path, "w") as f:
+            json.dump(run_log, f, indent=2)
+
+        # Step f: Print summary
+        gate_passed = all(r["exit_code"] == 0 for r in gate_results)
+        print(f"Worktree: {self.worktree_path}")
+        self._print_gate_summary(gate_results)
+
+        return gate_passed
+
+    def _verify_git_clean(self):
+        """Verify we're in a git repo with clean working tree."""
+        result = subprocess.run(
+            ["git", "status", "--porcelain"],
+            cwd=self.cwd,
+            capture_output=True,
+            text=True
+        )
+        if result.returncode != 0:
+            raise RuntimeError("Not in a git repository")
+        if result.stdout.strip():
+            raise RuntimeError("Working tree is not clean")
+
+    def _create_worktree(self):
+        """Create a git worktree for this task."""
+        # Check if branch or worktree already exists
+        result = subprocess.run(
+            ["git", "show-ref", "--quiet", "--verify", f"refs/heads/{self.branch_name}"],
+            cwd=self.cwd,
+            capture_output=True
+        )
+        if result.returncode == 0:
+            raise RuntimeError(f"Branch {self.branch_name} already exists")
+
+        if self.worktree_path.exists():
+            raise RuntimeError(f"Worktree path {self.worktree_path} already exists")
+
+        # Create the worktree
+        result = subprocess.run(
+            ["git", "worktree", "add", str(self.worktree_path), "-b", self.branch_name],
+            cwd=self.cwd,
+            capture_output=True,
+            text=True
+        )
+        if result.returncode != 0:
+            raise RuntimeError(f"Failed to create worktree: {result.stderr}")
+
+    def _build_briefing(self) -> str:
+        """Build the worker briefing (tips + task brief)."""
+        tips = ""
+        tips_path = self.cwd / ".code-tips.md"
+        if tips_path.exists():
+            with open(tips_path) as f:
+                tips = f.read()
+
+        with open(self.task_brief_path) as f:
+            brief = f.read()
+
+        if tips:
+            return f"{tips}\n\nTASK: {brief}"
+        else:
+            return f"TASK: {brief}"
+
+    def _run_worker(self, briefing: str) -> dict:
+        """Run the worker command."""
+        # Substitute {prompt} in the worker command
+        worker_cmd = self.config["worker"]["command"]
+        worker_cmd = [
+            arg.replace("{prompt}", briefing) for arg in worker_cmd
+        ]
+
+        result = subprocess.run(
+            worker_cmd,
+            cwd=self.worktree_path,
+            capture_output=True,
+            text=True
+        )
+
+        return {
+            "exit_code": result.returncode,
+            "stdout": result.stdout,
+            "stderr": result.stderr
+        }
+
+    def _run_gates(self) -> list:
+        """Run all gate commands."""
+        results = []
+        for gate_config in self.config.get("gate", []):
+            gate_name = gate_config["name"]
+            gate_cmd = gate_config["command"]
+
+            result = subprocess.run(
+                gate_cmd,
+                cwd=self.worktree_path,
+                capture_output=True,
+                text=True
+            )
+
+            # Build autopsy (one-line description)
+            autopsy = f"{gate_name}: exit {result.returncode}"
+            if result.returncode != 0 and result.stderr.strip():
+                # Add last line of stderr if exit failed
+                last_line = result.stderr.strip().split('\n')[-1]
+                autopsy = f"{gate_name}: exit {result.returncode} ({last_line[:50]})"
+
+            results.append({
+                "name": gate_name,
+                "exit_code": result.returncode,
+                "autopsy": autopsy,
+                "stdout": result.stdout,
+                "stderr": result.stderr
+            })
+
+        return results
+
+    def _build_run_log(self, worker_result: dict, gate_results: list) -> dict:
+        """Build the run log structure."""
+        # Get base commit SHA
+        base_commit_result = subprocess.run(
+            ["git", "rev-parse", "HEAD"],
+            cwd=self.cwd,
+            capture_output=True,
+            text=True
+        )
+        base_commit = base_commit_result.stdout.strip()
+
+        now = datetime.utcnow()
+        started_at = now.isoformat() + "Z"
+        finished_at = now.isoformat() + "Z"
+
+        # Build gate results for log
+        gate_log_results = [
+            {
+                "name": r["name"],
+                "exit_code": r["exit_code"],
+                "autopsy": r["autopsy"]
+            }
+            for r in gate_results
+        ]
+
+        gate_passed = all(r["exit_code"] == 0 for r in gate_results)
+
+        worker_log = {
+            "id": self.worker_id,
+            "branch": self.branch_name,
+            "worktree": f"../{self.task_id}-w1",
+            "exit_code": worker_result["exit_code"],
+            "stdout_file": f"{self.worker_id}.stdout",
+            "gate": {
+                "passed": gate_passed,
+                "results": gate_log_results
+            }
+        }
+
+        return {
+            "task_id": self.task_id,
+            "started_at": started_at,
+            "finished_at": finished_at,
+            "base_commit": base_commit,
+            "workers": [worker_log]
+        }
+
+
+    def _print_gate_summary(self, gate_results: list):
+        """Print a summary of gate results."""
+        for result in gate_results:
+            status = "PASS" if result["exit_code"] == 0 else "FAIL"
+            print(f"  {result['name']}: {status}")
