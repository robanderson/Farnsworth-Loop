+"""Tests for the Farnsworth Loop runner."""
+
+import json
+import os
+import shutil
+import subprocess
+import tempfile
+import unittest
+from pathlib import Path
+
+from farnsworth.runner import Runner
+
+
+class TestRunner(unittest.TestCase):
+    """Test the Runner class."""
+
+    def setUp(self):
+        """Create a temporary git repo for each test."""
+        self.temp_dir = tempfile.mkdtemp()
+        self.repo_dir = Path(self.temp_dir) / "test_repo"
+        self.repo_dir.mkdir()
+
+        # Initialize git repo
+        subprocess.run(
+            ["git", "init"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+
+        # Configure git (local to this repo)
+        subprocess.run(
+            ["git", "config", "user.email", "test@example.com"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+        subprocess.run(
+            ["git", "config", "user.name", "Test User"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+
+        # Create initial commit
+        (self.repo_dir / "README.md").write_text("# Test")
+        subprocess.run(
+            ["git", "add", "README.md"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            text=True,
+            check=True
+        )
+        result = subprocess.run(
+            ["git", "commit", "-m", "Initial commit"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            text=True,
+            check=False
+        )
+        if result.returncode != 0:
+            raise RuntimeError(f"Git commit failed: {result.stderr}")
+
+    def tearDown(self):
+        """Clean up temporary directory."""
+        shutil.rmtree(self.temp_dir, ignore_errors=True)
+
+    def _create_config(self, fake_worker_cmd=None):
+        """Create a test config file."""
+        if fake_worker_cmd is None:
+            fake_worker_cmd = ["python3", "-c", "print('worker output')"]
+
+        config = {
+            "worker": {
+                "command": fake_worker_cmd
+            },
+            "gate": [
+                {
+                    "name": "test_gate",
+                    "command": ["python3", "-c", "exit(0)"]
+                }
+            ]
+        }
+
+        config_path = self.repo_dir / "farnsworth.json"
+        with open(config_path, "w") as f:
+            json.dump(config, f)
+
+        # Commit the config file
+        subprocess.run(
+            ["git", "add", "farnsworth.json"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+        subprocess.run(
+            ["git", "commit", "-m", "Add farnsworth.json"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+        return config_path
+
+    def _create_task_brief(self):
+        """Create a test task brief."""
+        brief_path = self.repo_dir / "task-001.md"
+        brief_path.write_text("# Test Task\n\nThis is a test task.")
+
+        # Commit the task brief
+        subprocess.run(
+            ["git", "add", "task-001.md"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+        subprocess.run(
+            ["git", "commit", "-m", "Add task brief"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+        return brief_path
+
+    def test_worktree_created(self):
+        """Test that a worktree is created."""
+        os.chdir(self.repo_dir)
+
+        config_path = self._create_config()
+        brief_path = self._create_task_brief()
+
+        runner = Runner(brief_path, config_path)
+        runner.run()
+
+        # Check that worktree was created
+        worktree_path = self.repo_dir.parent / "task-001-w1"
+        self.assertTrue(worktree_path.exists())
+
+        # Clean up worktree
+        subprocess.run(
+            ["git", "worktree", "remove", str(worktree_path)],
+            cwd=self.repo_dir,
+            capture_output=True
+        )
+
+    def test_branch_created(self):
+        """Test that a branch is created for the worktree."""
+        os.chdir(self.repo_dir)
+
+        config_path = self._create_config()
+        brief_path = self._create_task_brief()
+
+        runner = Runner(brief_path, config_path)
+        runner.run()
+
+        # Check that branch was created
+        result = subprocess.run(
+            ["git", "show-ref", "--quiet", "--verify", "refs/heads/task-001-w1"],
+            cwd=self.repo_dir
+        )
+        self.assertEqual(result.returncode, 0)
+
+        # Clean up
+        worktree_path = self.repo_dir.parent / "task-001-w1"
+        subprocess.run(
+            ["git", "worktree", "remove", str(worktree_path)],
+            cwd=self.repo_dir,
+            capture_output=True
+        )
+
+    def test_gate_pass(self):
+        """Test that gates pass correctly."""
+        os.chdir(self.repo_dir)
+
+        config_path = self._create_config()
+        brief_path = self._create_task_brief()
+
+        runner = Runner(brief_path, config_path)
+        result = runner.run()
+
+        self.assertTrue(result)
+
+        # Clean up
+        worktree_path = self.repo_dir.parent / "task-001-w1"
+        subprocess.run(
+            ["git", "worktree", "remove", str(worktree_path)],
+            cwd=self.repo_dir,
+            capture_output=True
+        )
+
+    def test_gate_fail(self):
+        """Test that gate failures are detected."""
+        os.chdir(self.repo_dir)
+
+        # Create config with failing gate
+        config = {
+            "worker": {
+                "command": ["python3", "-c", "print('worker output')"]
+            },
+            "gate": [
+                {
+                    "name": "failing_gate",
+                    "command": ["python3", "-c", "exit(1)"]
+                }
+            ]
+        }
+        config_path = self.repo_dir / "farnsworth.json"
+        with open(config_path, "w") as f:
+            json.dump(config, f)
+
+        # Commit the config
+        subprocess.run(
+            ["git", "add", "farnsworth.json"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+        subprocess.run(
+            ["git", "commit", "-m", "Add farnsworth.json"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
+
+        brief_path = self._create_task_brief()
+
+        runner = Runner(brief_path, config_path)
+        result = runner.run()
+
+        self.assertFalse(result)
+
+        # Clean up
+        worktree_path = self.repo_dir.parent / "task-001-w1"
+        subprocess.run(
+            ["git", "worktree", "remove", str(worktree_path)],
+            cwd=self.repo_dir,
+            capture_output=True
+        )
+
+    def test_run_log_created(self):
+        """Test that run.json is created with correct schema."""
+        os.chdir(self.repo_dir)
+
+        config_path = self._create_config()
+        brief_path = self._create_task_brief()
+
+        runner = Runner(brief_path, config_path)
+        runner.run()
+
+        # Check that run.json exists
+        run_json_path = self.repo_dir / ".farnsworth" / "task-001" / "run.json"
+        self.assertTrue(run_json_path.exists())
+
+        # Load and validate schema
+        with open(run_json_path) as f:
+            run_log = json.load(f)
+
+        self.assertIn("task_id", run_log)
+        self.assertEqual(run_log["task_id"], "task-001")
+        self.assertIn("started_at", run_log)
+        self.assertIn("finished_at", run_log)
+        self.assertIn("base_commit", run_log)
+        self.assertIn("workers", run_log)
+
+        # Check worker record
+        self.assertEqual(len(run_log["workers"]), 1)
+        worker = run_log["workers"][0]
+        self.assertEqual(worker["id"], "w1")
+        self.assertEqual(worker["branch"], "task-001-w1")
+        self.assertIn("gate", worker)
+        self.assertIn("passed", worker["gate"])
+        self.assertIn("results", worker["gate"])
+
+        # Clean up
+        worktree_path = self.repo_dir.parent / "task-001-w1"
+        subprocess.run(
+            ["git", "worktree", "remove", str(worktree_path)],
+            cwd=self.repo_dir,
+            capture_output=True
+        )
+
+    def test_worker_output_saved(self):
+        """Test that worker stdout/stderr are saved."""
+        os.chdir(self.repo_dir)
+
+        config_path = self._create_config()
+        brief_path = self._create_task_brief()
+
+        runner = Runner(brief_path, config_path)
+        runner.run()
+
+        # Check that output files exist
+        stdout_path = self.repo_dir / ".farnsworth" / "task-001" / "w1.stdout"
+        self.assertTrue(stdout_path.exists())
+
+        # Clean up
+        worktree_path = self.repo_dir.parent / "task-001-w1"
+        subprocess.run(
+            ["git", "worktree", "remove", str(worktree_path)],
+            cwd=self.repo_dir,
+            capture_output=True
+        )
+
+    def test_unclean_tree_rejected(self):
+        """Test that unclean working tree is rejected."""
+        os.chdir(self.repo_dir)
+
+        # Create an uncommitted change
+        (self.repo_dir / "uncommitted.txt").write_text("uncommitted")
+
+        config_path = self._create_config()
+        brief_path = self._create_task_brief()
+
+        runner = Runner(brief_path, config_path)
+        with self.assertRaises(RuntimeError) as cm:
+            runner.run()
+
+        self.assertIn("not clean", str(cm.exception))
+
+    def test_branch_already_exists(self):
+        """Test that existing branch is rejected."""
+        os.chdir(self.repo_dir)
+
+        # Create the branch first
+        subprocess.run(
+            ["git", "checkout", "-b", "task-001-w1"],
+            cwd=self.repo_dir,
+            capture_output=True,
+            check=True
+        )
