+"""Command-line interface for Farnsworth Loop."""
+
+import argparse
+import json
+import sys
+from pathlib import Path
+from farnsworth.runner import Runner
+
+
+def main():
+    """Main entry point for the CLI."""
+    parser = argparse.ArgumentParser(
+        prog="farnsworth",
+        description="Farnsworth Loop: semantic feedback for agent workflows"
+    )
+
+    subparsers = parser.add_subparsers(dest="command", help="Command to run")
+
+    # 'run' subcommand
+    run_parser = subparsers.add_parser("run", help="Run a single task")
+    run_parser.add_argument(
+        "task_brief",
+        type=str,
+        help="Path to task brief markdown file"
+    )
+    run_parser.add_argument(
+        "--config",
+        type=str,
+        default="farnsworth.json",
+        help="Path to config file (default: farnsworth.json)"
+    )
+
+    args = parser.parse_args()
+
+    if args.command == "run":
+        return run_task(args.task_brief, args.config)
+    else:
+        parser.print_help()
+        return 1
+
+
+def run_task(task_brief_path, config_path):
+    """Run a single task with one worker."""
+    try:
+        runner = Runner(Path(task_brief_path), Path(config_path))
+        success = runner.run()
+        return 0 if success else 1
+    except Exception as e:
+        print(f"Error: {e}", file=sys.stderr)
+        return 1
