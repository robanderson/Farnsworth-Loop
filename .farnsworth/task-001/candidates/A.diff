+"""Farnsworth Loop reference implementation.
+
+This package implements Milestone M1 (Skeleton) of the Farnsworth Loop PRD:
+a CLI that runs ONE task with ONE worker -- create a git worktree, run the
+worker command in it, run the mechanical gate, and write a JSON run log.
+"""
+
+__all__ = ["__version__"]
+
+__version__ = "0.1.0"
