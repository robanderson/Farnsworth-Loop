+"""Terminal UI rendering for Word Garden.
+
+Pure rendering functions with no I/O. All functions return strings.
+See SPEC.md sections 9, 10, 18, 20 for display requirements.
+"""
+
+from __future__ import annotations
+
+from .game import GameState, display_word
+
+
+# Growth stage glyphs (SPEC.md section 10).
+_STAGES_EMOJI = {
+    "start": "🌱",
+    "progress": "🌿",
+    "near_win": "🌷",
+    "win": "🌻",
+    "loss": "🥀",
+}
+
+_STAGES_ASCII = {
+    "start": "*",
+    "progress": "*",
+    "near_win": "*",
+    "win": "*",
+    "loss": "*",
+}
+
+# Water and weed glyphs.
+_WATER_EMOJI = "💧"
+_WEED_EMOJI = "🌿"
+_WATER_ASCII = "#"
+_WEED_ASCII = "-"
+
+
+def _get_growth_stage(state: GameState) -> str:
+    """Determine which growth stage the game is in.
+
+    Returns one of: 'start', 'progress', 'near_win', 'win', 'loss'.
+    """
+    if state.won:
+        return "win"
+    if state.remaining_water <= 0 and not state.won:
+        return "loss"
+
+    # Determine progress toward winning based on letters revealed.
+    secret_word = state.secret_word
+    guessed_count = sum(1 for ch in secret_word if ch in state.guessed_letters)
+    total_count = len(secret_word)
+    progress_ratio = guessed_count / total_count if total_count > 0 else 0
+
+    if progress_ratio >= 0.66:
+        return "near_win"
+    elif progress_ratio > 0:
+        return "progress"
+    else:
+        return "start"
+
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the full turn display (SPEC.md section 9).
+
+    Includes: title, growth stage emoji, plant/garden status, masked word,
+    guessed letters, water (label + count + glyphs), weeds (label + count +
+    glyphs), and the previous turn's status message.
+
+    ascii_mode=True uses ASCII fallbacks (no non-ASCII characters).
+    """
+    stages = _STAGES_ASCII if ascii_mode else _STAGES_EMOJI
+    water_glyph = _WATER_ASCII if ascii_mode else _WATER_EMOJI
+    weed_glyph = _WEED_ASCII if ascii_mode else _WEED_EMOJI
+
+    stage = _get_growth_stage(state)
+    stage_emoji = stages[stage]
+
+    # Build the display.
+    lines = []
+
+    # Title with growth stage.
+    lines.append(f"{stage_emoji} Word Garden")
+    lines.append("")
+
+    # Word display.
+    word_display = display_word(state)
+    lines.append(f"Word:      {word_display}")
+
+    # Guessed letters (sorted, space-separated).
+    if state.guessed_letters:
+        guessed_str = " ".join(sorted(state.guessed_letters))
+        lines.append(f"Guessed:   {guessed_str}")
+    else:
+        lines.append("Guessed:")
+
+    # Water with label and count.
+    water_bar = water_glyph * state.remaining_water
+    lines.append(f"Water:     {state.remaining_water}/{state.max_water} {water_bar}")
+
+    # Weeds with label and count.
+    weed_bar = weed_glyph * state.weed_count
+    lines.append(f"Weeds:     {state.weed_count} {weed_bar}")
+
+    lines.append("")
+
+    # Previous turn's status message.
+    if state.status_message:
+        lines.append(state.status_message)
+        lines.append("")
+
+    return "\n".join(lines)
+
