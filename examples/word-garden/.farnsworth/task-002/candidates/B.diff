+"""Tests for word_garden.ui (SPEC.md sections 9, 10, 18, 20).
+
+Tests rendering functions in both emoji and ASCII modes, growth stages,
+win/loss screens, and integration with the main loop.
+"""
+
+import unittest
+from io import StringIO
+
+from word_garden import game, ui
+from word_garden.game import GameState
+
+
+def make_state(
+    secret: str = "GARDEN",
+    water: int = 6,
+    guessed: set[str] | None = None,
+    weeds: int = 0,
+    game_over: bool = False,
+    won: bool = False,
+    status: str = "",
+) -> GameState:
+    """Helper: construct a GameState with known values."""
+    if guessed is None:
+        guessed = set()
+    return GameState(
+        secret_word=secret,
+        guessed_letters=guessed,
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=6,
+        status_message=status,
+        game_over=game_over,
+        won=won,
+    )
+
+
+class RenderEmojiTests(unittest.TestCase):
+    """Test emoji mode rendering (default)."""
+
+    def test_render_initial_state(self):
+        """Test rendering at game start."""
+        state = make_state()
+        output = ui.render(state, ascii_mode=False)
+
+        # Check structure.
+        self.assertIn("🌱 Word Garden", output)
+        self.assertIn("Word:      _ _ _ _ _ _", output)
+        self.assertIn("Guessed:", output)
+        self.assertIn("Water:     6/6 💧💧💧💧💧💧", output)
+        self.assertIn("Weeds:     0", output)
+
+        # Check for emoji labels.
+        self.assertIn("Water:", output)
+        self.assertIn("Weeds:", output)
+
+    def test_render_with_guesses(self):
+        """Test rendering after some guesses."""
+        state = make_state(guessed={"A", "E", "G"}, water=5, weeds=1, status="Good guess!")
+        output = ui.render(state, ascii_mode=False)
+
+        # Word should partially reveal.
+        self.assertIn("G A _ _ E _", output)
+        # Guessed letters should be sorted.
+        self.assertIn("Guessed:   A E G", output)
+        # Water and weeds should update.
+        self.assertIn("Water:     5/6 💧💧💧💧💧", output)
+        self.assertIn("Weeds:     1 🌿", output)
+        # Status message should appear.
+        self.assertIn("Good guess!", output)
+
+    def test_render_growth_stages_emoji(self):
+        """Test that growth stage emoji changes with progress."""
+        # Start: no guesses
+        state = make_state()
+        output = ui.render(state, ascii_mode=False)
+        self.assertIn("🌱 Word Garden", output)
+
+        # Progress: some letters guessed (33%)
+        state = make_state(guessed={"G"})  # 1 of 6 letters
+        output = ui.render(state, ascii_mode=False)
+        self.assertIn("🌿 Word Garden", output)
+
+        # Near win: 66%+ letters guessed
+        state = make_state(guessed={"G", "A", "R", "D"})  # 4 of 6 letters
+        output = ui.render(state, ascii_mode=False)
+        self.assertIn("🌷 Word Garden", output)
+
+        # Win
+        state = make_state(guessed={"G", "A", "R", "D", "E", "N"}, won=True)
+        output = ui.render(state, ascii_mode=False)
+        self.assertIn("🌻 Word Garden", output)
+
+        # Loss
+        state = make_state(water=0, won=False)
+        output = ui.render(state, ascii_mode=False)
+        self.assertIn("🥀 Word Garden", output)
+
+    def test_render_contains_no_non_ascii_in_ascii_mode(self):
+        """Test that ASCII mode has zero non-ASCII characters."""
+        state = make_state(guessed={"A", "E"}, water=3, weeds=2, status="Good guess!")
+        output = ui.render(state, ascii_mode=True)
+
+        # Should not contain any emoji.
+        self.assertNotIn("💧", output)
+        self.assertNotIn("🌿", output)
+        self.assertNotIn("🌱", output)
+        self.assertNotIn("🌻", output)
+        self.assertNotIn("🥀", output)
+
+        # Verify it's pure ASCII.
+        try:
+            output.encode("ascii")
+        except UnicodeEncodeError:
+            self.fail("ASCII mode output contains non-ASCII characters")
+
+    def test_render_ascii_uses_fallback_glyphs(self):
+        """Test that ASCII mode uses ASCII glyphs."""
+        state = make_state(guessed={"A"}, water=5, weeds=2)
+        output = ui.render(state, ascii_mode=True)
+
+        # Should contain ASCII glyphs.
+        self.assertIn("* Word Garden", output)  # asterisk for plant
+        self.assertIn("Water:", output)
+        self.assertIn("Weeds:", output)
+        # Water bar should use ASCII glyph.
+        self.assertIn("#####", output)  # 5 water
+        # Weeds bar should use ASCII glyph.
+        self.assertIn("--", output)  # 2 weeds
