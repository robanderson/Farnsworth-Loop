+"""Main game loop and entry point for Word Garden.
+
+This is the only module that performs I/O (input/print).
+See SPEC.md sections 6, 15, 20.
+"""
+
+from __future__ import annotations
+
+import argparse
+import sys
+from typing import Callable
+
+from .game import GameState, apply_guess, new_game, validate_guess
+from .ui import loss_screen, render, win_screen
+
+
+def main(
+    argv: list[str] | None = None,
+    input_fn: Callable[[str], str] = input,
+    output_fn: Callable[[str], None] = print,
+) -> int:
+    """Run the main game loop.
+
+    Args:
+        argv: Command-line arguments (for testing); defaults to sys.argv[1:].
+        input_fn: Injected input function (defaults to built-in input).
+        output_fn: Injected output function (defaults to built-in print).
+
+    Returns:
+        Exit code (0 for clean exit, including win/loss/EOF/Ctrl-C).
+    """
+    parser = argparse.ArgumentParser(
+        description="Word Garden — a friendly terminal word-guessing game."
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty level (default: normal)",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        help="Use ASCII-only output (no emoji)",
+    )
+
+    try:
+        args = parser.parse_args(argv)
+    except SystemExit:
+        # Gracefully handle argparse errors.
+        return 1
+
+    ascii_mode = args.ascii
+    difficulty = args.difficulty
+
+    # Initialize the game.
+    state = new_game(difficulty=difficulty)
+
+    # Main game loop.
+    try:
+        while not state.game_over:
+            # Render and display the current state.
+            display = render(state, ascii_mode=ascii_mode)
+            output_fn(display)
+
+            # Prompt and read input.
+            try:
+                user_input = input_fn("Guess a letter: ")
+            except EOFError:
+                # Ctrl-D: clean exit.
+                output_fn("\nThanks for playing Word Garden!")
+                return 0
+
+            # Validate input.
+            letter, error_msg = validate_guess(user_input)
+
+            if error_msg:
+                # Invalid input: show message and re-prompt without consuming a turn.
+                output_fn(error_msg)
+                output_fn("")
+                continue
+
+            # Apply the valid guess.
+            state = apply_guess(state, letter)
+
+        # Game over: show final screen.
+        if state.won:
+            output_fn(win_screen(state, ascii_mode=ascii_mode))
+        else:
+            output_fn(loss_screen(state, ascii_mode=ascii_mode))
+
+        return 0
+
+    except KeyboardInterrupt:
+        # Ctrl-C: clean exit.
+        output_fn("\n\nThanks for playing Word Garden!")
+        return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
