+"""Tests for word_garden/game.py — covers SPEC section 16, cases 1–9."""
+
+import dataclasses
+import random
+import unittest
+
+from word_garden.game import (
+    GameState,
+    apply_guess,
+    display_word,
+    is_lost,
+    is_won,
+    new_game,
+    validate_guess,
+)
+from word_garden.words import WORDS
+
+
+# ---------------------------------------------------------------------------
+# Helper: Build a GameState with a fixed word for deterministic testing.
+# ---------------------------------------------------------------------------
+
+def _state(word: str, guessed=None, water: int = 6, weeds: int = 0,
+           game_over: bool = False, won: bool = False) -> GameState:
+    return GameState(
+        secret_word=word.upper(),
+        guessed_letters=set(guessed or []),
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=water,
+        game_over=game_over,
+        won=won,
+    )
+
+
+class TestNewGame(unittest.TestCase):
+    def test_new_game_returns_game_state(self):
+        state = new_game(difficulty="normal")
+        self.assertIsInstance(state, GameState)
+
+    def test_new_game_word_in_wordlist(self):
+        state = new_game(difficulty="normal", rng=random.Random(1))
+        self.assertIn(state.secret_word, WORDS)
+
+    def test_new_game_word_is_uppercase(self):
+        state = new_game(difficulty="normal", rng=random.Random(2))
+        self.assertEqual(state.secret_word, state.secret_word.upper())
+
+    def test_new_game_water_full(self):
+        state = new_game(difficulty="normal")
+        self.assertEqual(state.remaining_water, state.max_water)
+
+    def test_new_game_zero_weeds(self):
+        state = new_game(difficulty="easy")
+        self.assertEqual(state.weed_count, 0)
+
+    def test_new_game_empty_guesses(self):
+        state = new_game()
+        self.assertEqual(len(state.guessed_letters), 0)
+
+    def test_new_game_not_over(self):
+        state = new_game()
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+
+class TestValidateGuess(unittest.TestCase):
+    """SPEC section 14 / section 16 cases 5–6."""
+
+    def test_valid_lowercase_letter(self):
+        """Case 6: Lowercase input is normalised."""
+        letter, msg = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_valid_uppercase_letter(self):
+        letter, msg = validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+    def test_valid_letter_with_whitespace(self):
+        letter, msg = validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(msg, "")
+
+    def test_empty_input_rejected(self):
+        """Case 5: Invalid input is rejected."""
+        letter, msg = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_whitespace_only_rejected(self):
+        letter, msg = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_multiple_chars_rejected(self):
+        letter, msg = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertIn("single", msg.lower())
+
+    def test_digit_rejected(self):
+        letter, msg = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_symbol_rejected(self):
+        letter, msg = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_invalid_returns_none_letter(self):
+        letter, _ = validate_guess("99")
+        self.assertIsNone(letter)
+
+    def test_valid_returns_empty_message(self):
+        _, msg = validate_guess("g")
+        self.assertEqual(msg, "")
+
+
+class TestApplyGuessCorrect(unittest.TestCase):
+    """SPEC section 16, case 1: a correct guess reveals matching letters."""
+
+    def test_correct_guess_adds_letter_to_guessed(self):
+        state = _state("GARDEN")
+        new_state = apply_guess(state, "G")
+        self.assertIn("G", new_state.guessed_letters)
+
+    def test_correct_guess_does_not_change_water(self):
+        state = _state("GARDEN", water=6)
+        new_state = apply_guess(state, "G")
+        self.assertEqual(new_state.remaining_water, 6)
+
+    def test_correct_guess_does_not_change_weeds(self):
+        state = _state("GARDEN", weeds=0)
+        new_state = apply_guess(state, "G")
+        self.assertEqual(new_state.weed_count, 0)
+
+    def test_correct_guess_status_message_is_positive(self):
+        state = _state("GARDEN")
+        new_state = apply_guess(state, "A")
+        self.assertGreater(len(new_state.status_message), 0)
+        # A friendly message — just make sure it's non-empty and doesn't say "weed".
+        self.assertNotIn("weed", new_state.status_message.lower())
+
+
+class TestApplyGuessIncorrect(unittest.TestCase):
+    """SPEC section 16, cases 2–3: wrong guess costs water and adds a weed."""
+
+    def test_wrong_guess_reduces_water_by_one(self):
+        state = _state("GARDEN", water=6)
+        new_state = apply_guess(state, "Z")
+        self.assertEqual(new_state.remaining_water, 5)
+
+    def test_wrong_guess_increases_weed_count_by_one(self):
+        state = _state("GARDEN", weeds=0)
+        new_state = apply_guess(state, "Z")
+        self.assertEqual(new_state.weed_count, 1)
+
+    def test_wrong_guess_letter_recorded_in_guessed(self):
+        state = _state("GARDEN")
+        new_state = apply_guess(state, "Z")
+        self.assertIn("Z", new_state.guessed_letters)
+
+    def test_wrong_guess_has_friendly_message(self):
+        state = _state("GARDEN")
+        new_state = apply_guess(state, "Z")
+        self.assertGreater(len(new_state.status_message), 0)
+
+    def test_wrong_guess_all_three_together(self):
+        """Positive assertion: water -1, weeds +1, letter recorded simultaneously."""
+        state = _state("GARDEN", water=5, weeds=1)
+        new_state = apply_guess(state, "X")
+        self.assertEqual(new_state.remaining_water, 4)
+        self.assertEqual(new_state.weed_count, 2)
+        self.assertIn("X", new_state.guessed_letters)
+
+
+class TestApplyGuessRepeated(unittest.TestCase):
+    """SPEC section 16, case 4: repeated guesses do not cost water."""
+
+    def test_repeated_guess_does_not_reduce_water(self):
+        state = _state("GARDEN", guessed={"G"}, water=6)
+        new_state = apply_guess(state, "G")
+        self.assertEqual(new_state.remaining_water, 6)
+
+    def test_repeated_guess_does_not_increase_weeds(self):
+        state = _state("GARDEN", guessed={"G"}, weeds=0)
+        new_state = apply_guess(state, "G")
+        self.assertEqual(new_state.weed_count, 0)
+
+    def test_repeated_guess_message_mentions_already_guessed(self):
+        state = _state("GARDEN", guessed={"A"})
+        new_state = apply_guess(state, "A")
+        msg = new_state.status_message.lower()
+        self.assertTrue(
+            "already" in msg or "again" in msg,
+            f"Message should mention already guessed, got: {new_state.status_message!r}"
+        )
+
+    def test_repeated_guess_guessed_set_unchanged_size(self):
+        state = _state("GARDEN", guessed={"G", "A"})
+        new_state = apply_guess(state, "G")
+        self.assertEqual(len(new_state.guessed_letters), 2)
+
+
+class TestWinCondition(unittest.TestCase):
+    """SPEC section 16, case 7: game detects a win."""
+
+    def test_is_won_all_letters_guessed(self):
+        state = _state("GO", guessed={"G", "O"})
+        self.assertTrue(is_won(state))
+
+    def test_is_won_partial_guessed_is_false(self):
+        state = _state("GO", guessed={"G"})
+        self.assertFalse(is_won(state))
+
+    def test_apply_guess_triggers_win(self):
+        # Word "GO" — guess G first, then O to win.
+        state = _state("GO", guessed={"G"}, water=4)
+        new_state = apply_guess(state, "O")
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+
+    def test_win_sets_game_over(self):
+        state = _state("GO", guessed={"G"}, water=4)
+        new_state = apply_guess(state, "O")
+        self.assertTrue(new_state.game_over)
+
+    def test_guessing_after_win_is_noop(self):
+        state = _state("GO", guessed={"G", "O"}, water=4, game_over=True, won=True)
+        new_state = apply_guess(state, "Z")
+        self.assertEqual(new_state.remaining_water, 4)
+        self.assertEqual(new_state.weed_count, 0)
+
+
+class TestLossCondition(unittest.TestCase):
+    """SPEC section 16, case 8: game detects a loss."""
+
+    def test_is_lost_water_zero_not_won(self):
+        state = _state("GARDEN", water=0)
+        self.assertTrue(is_lost(state))
+
+    def test_is_lost_positive_water_is_false(self):
+        state = _state("GARDEN", water=1)
+        self.assertFalse(is_lost(state))
+
+    def test_is_lost_water_zero_but_won_is_false(self):
+        # Winning on the last water drop is a win, not a loss.
+        state = _state("GO", guessed={"G", "O"}, water=0)
+        self.assertFalse(is_lost(state))
+
+    def test_apply_guess_triggers_loss(self):
+        # 1 water left, guess wrong → lose.
+        state = _state("GARDEN", guessed={"G", "A", "R", "D", "E"}, water=1)
+        new_state = apply_guess(state, "Z")
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+
+    def test_loss_sets_game_over_not_won(self):
+        state = _state("GARDEN", guessed={"G", "A", "R", "D", "E"}, water=1)
+        new_state = apply_guess(state, "Z")
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+
+
+class TestDisplayWord(unittest.TestCase):
+    """SPEC section 16, case 9: display_word masks unguessed letters."""
+
+    def test_all_unguessed_shows_underscores(self):
+        state = _state("GARDEN")
+        self.assertEqual(display_word(state), "_ _ _ _ _ _")
+
+    def test_all_guessed_shows_full_word(self):
+        state = _state("GARDEN", guessed={"G", "A", "R", "D", "E", "N"})
+        self.assertEqual(display_word(state), "G A R D E N")
+
+    def test_partial_guesses_reveals_correct_positions(self):
+        state = _state("GARDEN", guessed={"G", "R", "E"})
+        self.assertEqual(display_word(state), "G _ R _ E _")
+
+    def test_single_char_word(self):
+        state = _state("A", guessed={"A"})
+        self.assertEqual(display_word(state), "A")
+
+    def test_single_char_word_unguessed(self):
+        state = _state("A")
+        self.assertEqual(display_word(state), "_")
+
+    def test_repeated_letter_in_word_both_revealed(self):
+        state = _state("SEEDLING", guessed={"E"})
+        result = display_word(state)
+        parts = result.split(" ")
+        # SEEDLING: S-E-E-D-L-I-N-G, positions 1 and 2 are E
+        self.assertEqual(parts[1], "E")
+        self.assertEqual(parts[2], "E")
+        self.assertEqual(parts[0], "_")  # S not guessed
+
+    def test_display_word_space_separated(self):
+        state = _state("AB")
+        result = display_word(state)
+        # Space-separated means one space between each character token
+        self.assertEqual(result, "_ _")
+
+
+class TestGameStateFields(unittest.TestCase):
+    """Verify GameState has exactly the fields defined in SPEC section 12."""
+
+    def test_required_fields_present(self):
+        required = {
+            "secret_word", "guessed_letters", "remaining_water",
+            "weed_count", "max_water", "status_message", "game_over", "won",
+        }
+        fields = {f.name for f in dataclasses.fields(GameState)}
+        self.assertEqual(required, fields)
+
+    def test_defaults_for_optional_fields(self):
+        state = GameState(
+            secret_word="TEST",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertEqual(state.status_message, "")
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+
+class TestNoMutation(unittest.TestCase):
+    """apply_guess must return a new object; original must not be mutated."""
+
+    def test_apply_guess_returns_new_object(self):
+        state = _state("GARDEN")
+        new_state = apply_guess(state, "G")
+        self.assertIsNot(state, new_state)
+
+    def test_original_state_unchanged_after_correct_guess(self):
+        state = _state("GARDEN", water=6, weeds=0)
+        original_water = state.remaining_water
+        original_weeds = state.weed_count
+        original_guessed = set(state.guessed_letters)
+        apply_guess(state, "G")
+        self.assertEqual(state.remaining_water, original_water)
+        self.assertEqual(state.weed_count, original_weeds)
+        self.assertEqual(state.guessed_letters, original_guessed)
+
+
+if __name__ == "__main__":
+    unittest.main()
