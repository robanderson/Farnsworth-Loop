+"""Core game logic for Word Garden."""
+
+from __future__ import annotations
+
+import dataclasses
+from typing import Optional
+
+from word_garden import words as _words
+
+
+@dataclasses.dataclass
+class GameState:
+    """Holds the complete mutable state of a Word Garden game."""
+
+    secret_word: str
+    guessed_letters: set[str]
+    remaining_water: int
+    weed_count: int
+    max_water: int
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng=None) -> GameState:
+    """Create and return a fresh GameState for the given difficulty.
+
+    Args:
+        difficulty: "easy", "normal", or "hard".
+        rng: Optional random.Random instance passed to select_word.
+
+    Returns:
+        A GameState ready for the first guess.
+    """
+    word = _words.select_word(difficulty=difficulty, rng=rng).upper()
+    water = _words.water_for(difficulty)
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[Optional[str], str]:
+    """Validate raw user input before applying it to the game state.
+
+    Validation is stateless — it does NOT check whether the letter was
+    already guessed.  That belongs to apply_guess.
+
+    Args:
+        input_text: The raw string entered by the user.
+
+    Returns:
+        (letter, "") on success where letter is trimmed and uppercased.
+        (None, message) on failure with a specific, human-readable message.
+    """
+    stripped = input_text.strip()
+
+    if len(stripped) == 0:
+        return (None, "Please enter a letter.")
+
+    if len(stripped) > 1:
+        return (None, "Please enter a single letter.")
+
+    char = stripped.upper()
+
+    if not char.isalpha():
+        return (None, "That is not a letter.")
+
+    return (char, "")
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a single already-validated uppercase letter to the game state.
+
+    Returns a *new* GameState; the original is not mutated.
+
+    Args:
+        state: The current game state.
+        letter: A validated, uppercase, single alphabetic character.
+
+    Returns:
+        An updated GameState reflecting the result of the guess.
+    """
+    # Guard: no moves after the game has ended.
+    if state.game_over:
+        return dataclasses.replace(
+            state,
+            status_message="The game is already over.",
+        )
+
+    new_guessed = set(state.guessed_letters)
+
+    # Repeated guess — no water/weed change, just a message.
+    if letter in new_guessed:
+        return dataclasses.replace(
+            state,
+            status_message=f"You already guessed {letter}. Try another letter.",
+        )
+
+    new_guessed.add(letter)
+
+    if letter in state.secret_word:
+        # Correct guess — reveal letter, no penalties.
+        new_state = dataclasses.replace(
+            state,
+            guessed_letters=new_guessed,
+            status_message="Good guess! The garden grows.",
+        )
+    else:
+        # Incorrect guess — costs 1 water, gains 1 weed.
+        new_state = dataclasses.replace(
+            state,
+            guessed_letters=new_guessed,
+            remaining_water=state.remaining_water - 1,
+            weed_count=state.weed_count + 1,
+            status_message="No match. A weed appears.",
+        )
+
+    # Check win/loss conditions on the updated state.
+    if is_won(new_state):
+        new_state = dataclasses.replace(
+            new_state,
+            game_over=True,
+            won=True,
+            status_message=(
+                f"You guessed the word: {new_state.secret_word}. "
+                "The garden is thriving!"
+            ),
+        )
+    elif is_lost(new_state):
+        new_state = dataclasses.replace(
+            new_state,
+            game_over=True,
+            won=False,
+            status_message=(
+                f"The garden ran out of water. The word was: {new_state.secret_word}. "
+                "Try again and grow a new garden."
+            ),
+        )
+
+    return new_state
+
+
+def display_word(state: GameState) -> str:
+    """Return a space-separated masked representation of the secret word.
+
+    Guessed letters are shown; others appear as underscore.
+
+    Example:
+        secret_word = "GARDEN", guessed = {"G", "R", "E"}
+        → "G _ R _ E _"
+    """
+    return " ".join(
+        ch if ch in state.guessed_letters else "_"
+        for ch in state.secret_word
+    )
+
+
+def is_won(state: GameState) -> bool:
+    """Return True if every letter in the secret word has been guessed."""
+    return all(ch in state.guessed_letters for ch in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Return True if water has reached zero and the word is not yet won."""
+    return state.remaining_water <= 0 and not is_won(state)
