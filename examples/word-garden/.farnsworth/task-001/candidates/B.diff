+"""Word list and selection logic for Word Garden."""
+
+import random as _random
+
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+_DIFFICULTY_CONFIG = {
+    "easy":   {"water": 8, "min_len": 4, "max_len": 6},
+    "normal": {"water": 6, "min_len": 5, "max_len": 8},
+    "hard":   {"water": 4, "min_len": 7, "max_len": None},
+}
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return starting water level for the given difficulty."""
+    if difficulty not in _DIFFICULTY_CONFIG:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose one of: {', '.join(_DIFFICULTY_CONFIG)}"
+        )
+    return _DIFFICULTY_CONFIG[difficulty]["water"]
+
+
+def select_word(difficulty: str = "normal", rng=None) -> str:
+    """Return a random word from the list filtered by difficulty.
+
+    Args:
+        difficulty: "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic selection.
+             If None, uses the module-level random functions.
+
+    Returns:
+        An uppercase word matching the difficulty constraints.
+
+    Raises:
+        ValueError: If the difficulty is unknown.
+    """
+    if difficulty not in _DIFFICULTY_CONFIG:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose one of: {', '.join(_DIFFICULTY_CONFIG)}"
+        )
+    config = _DIFFICULTY_CONFIG[difficulty]
+    min_len = config["min_len"]
+    max_len = config["max_len"]
+
+    candidates = [
+        w for w in WORDS
+        if len(w) >= min_len and (max_len is None or len(w) <= max_len)
+    ]
+
+    if not candidates:
+        raise ValueError(
+            f"No words match difficulty {difficulty!r} constraints "
+            f"(length {min_len}–{max_len if max_len else '∞'})."
+        )
+
+    if rng is not None:
+        return rng.choice(candidates)
+    return _random.choice(candidates)
