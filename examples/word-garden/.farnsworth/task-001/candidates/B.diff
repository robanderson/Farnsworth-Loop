+"""Tests for word_garden/words.py — SPEC section 16, case 10."""
+
+import random
+import unittest
+
+from word_garden.words import WORDS, select_word, water_for
+
+
+class TestWordList(unittest.TestCase):
+    def test_words_is_nonempty(self):
+        self.assertGreater(len(WORDS), 0)
+
+    def test_words_are_uppercase(self):
+        for w in WORDS:
+            self.assertEqual(w, w.upper(), f"Word {w!r} is not uppercase")
+
+    def test_words_contains_expected_entries(self):
+        expected = {
+            "GARDEN", "FLOWER", "PLANET", "PYTHON", "TERMINAL",
+            "MEADOW", "ORCHARD", "VINEYARD", "SEEDLING", "HARVEST",
+        }
+        self.assertEqual(set(WORDS), expected)
+
+
+class TestWaterFor(unittest.TestCase):
+    def test_easy_water(self):
+        self.assertEqual(water_for("easy"), 8)
+
+    def test_normal_water(self):
+        self.assertEqual(water_for("normal"), 6)
+
+    def test_hard_water(self):
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            water_for("impossible")
+
+
+class TestSelectWord(unittest.TestCase):
+    """SPEC section 16, case 10: word selector returns a valid word for every difficulty."""
+
+    def _fixed_rng(self, seed: int = 42) -> random.Random:
+        return random.Random(seed)
+
+    def test_easy_returns_valid_word(self):
+        word = select_word("easy", rng=self._fixed_rng())
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 4)
+        self.assertLessEqual(len(word), 6)
+
+    def test_normal_returns_valid_word(self):
+        word = select_word("normal", rng=self._fixed_rng())
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 5)
+        self.assertLessEqual(len(word), 8)
+
+    def test_hard_returns_valid_word(self):
+        word = select_word("hard", rng=self._fixed_rng())
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 7)
+
+    def test_select_word_default_difficulty_is_normal(self):
+        # No rng, just verify we get a word back from the WORDS list.
+        word = select_word()
+        self.assertIn(word, WORDS)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            select_word("legendary")
+
+    def test_deterministic_with_rng(self):
+        rng1 = random.Random(99)
+        rng2 = random.Random(99)
+        self.assertEqual(select_word("normal", rng=rng1), select_word("normal", rng=rng2))
+
+    def test_easy_word_lengths(self):
+        """All easy-filtered words must be 4–6 letters."""
+        easy_candidates = [w for w in WORDS if 4 <= len(w) <= 6]
+        self.assertTrue(
+            len(easy_candidates) > 0,
+            "No words match easy length constraints in WORDS list"
+        )
+        for _ in range(20):
+            word = select_word("easy", rng=self._fixed_rng(_ + 1))
+            self.assertIn(word, easy_candidates, f"Word {word!r} doesn't fit easy constraints")
+
+    def test_hard_word_lengths(self):
+        """All hard-filtered words must be 7+ letters."""
+        hard_candidates = [w for w in WORDS if len(w) >= 7]
+        self.assertTrue(
+            len(hard_candidates) > 0,
+            "No words match hard length constraints in WORDS list"
+        )
+        for _ in range(20):
+            word = select_word("hard", rng=self._fixed_rng(_ + 1))
+            self.assertIn(word, hard_candidates, f"Word {word!r} doesn't fit hard constraints")
+
+
+if __name__ == "__main__":
+    unittest.main()
