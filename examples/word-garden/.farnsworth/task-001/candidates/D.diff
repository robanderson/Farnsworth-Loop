+"""Tests for word_garden.game module."""
+
+import unittest
+from word_garden.game import (
+    GameState,
+    new_game,
+    validate_guess,
+    apply_guess,
+    display_word,
+    is_won,
+    is_lost,
+)
+
+
+class TestNewGame(unittest.TestCase):
+    """Tests for new_game() function."""
+
+    def test_new_game_creates_valid_state(self):
+        """Test that new_game creates a valid initial game state."""
+        state = new_game()
+        self.assertIsNotNone(state.secret_word)
+        self.assertEqual(state.guessed_letters, set())
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(state.remaining_water, state.max_water)
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_normal_difficulty(self):
+        """Test new_game with normal difficulty."""
+        state = new_game(difficulty="normal")
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+        # Word length should be 5-8 for normal
+        self.assertGreaterEqual(len(state.secret_word), 5)
+        self.assertLessEqual(len(state.secret_word), 8)
+
+    def test_new_game_easy_difficulty(self):
+        """Test new_game with easy difficulty."""
+        state = new_game(difficulty="easy")
+        self.assertEqual(state.remaining_water, 8)
+        self.assertEqual(state.max_water, 8)
+        # Word length should be 4-6 for easy
+        self.assertGreaterEqual(len(state.secret_word), 4)
+        self.assertLessEqual(len(state.secret_word), 6)
+
+    def test_new_game_hard_difficulty(self):
+        """Test new_game with hard difficulty."""
+        state = new_game(difficulty="hard")
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.max_water, 4)
+        # Word length should be 7+ for hard
+        self.assertGreaterEqual(len(state.secret_word), 7)
+
+
+class TestValidateGuess(unittest.TestCase):
+    """Tests for validate_guess() function."""
+
+    def test_valid_single_letter_lowercase(self):
+        """Test that lowercase single letter is accepted and uppercased."""
+        letter, message = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(message, "")
+
+    def test_valid_single_letter_uppercase(self):
+        """Test that uppercase single letter is accepted."""
+        letter, message = validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(message, "")
+
+    def test_valid_with_whitespace(self):
+        """Test that whitespace is trimmed."""
+        letter, message = validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(message, "")
+
+    def test_empty_input(self):
+        """Test that empty input is rejected."""
+        letter, message = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(message, "Please enter a single letter.")
+
+    def test_whitespace_only_input(self):
+        """Test that whitespace-only input is rejected."""
+        letter, message = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertEqual(message, "Please enter a single letter.")
+
+    def test_multiple_characters(self):
+        """Test that multiple characters are rejected."""
+        letter, message = validate_guess("abc")
+        self.assertIsNone(letter)
+        self.assertEqual(message, "Please enter a single letter.")
+
+    def test_number_input(self):
+        """Test that numbers are rejected."""
+        letter, message = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(message, "That is not a letter.")
+
+    def test_symbol_input(self):
+        """Test that symbols are rejected."""
+        letter, message = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(message, "That is not a letter.")
+
+
+class TestDisplayWord(unittest.TestCase):
+    """Tests for display_word() function."""
+
+    def test_display_word_no_guesses(self):
+        """Test display_word with no guesses yet."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        display = display_word(state)
+        self.assertEqual(display, "_ _ _ _ _ _")
+
+    def test_display_word_partial_guesses(self):
+        """Test display_word with some letters guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "E"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        display = display_word(state)
+        self.assertEqual(display, "G A _ _ E _")
+
+    def test_display_word_all_guessed(self):
+        """Test display_word when all letters are guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        display = display_word(state)
+        self.assertEqual(display, "G A R D E N")
+
+    def test_display_word_extra_guesses(self):
+        """Test display_word when extra letters are guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "E", "Z", "X"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        display = display_word(state)
+        self.assertEqual(display, "G A _ _ E _")
+
+
+class TestApplyGuess(unittest.TestCase):
+    """Tests for apply_guess() function."""
+
+    def test_correct_guess_reveals_letters(self):
+        """Test that correct guess reveals matching letters."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "A")
+        self.assertIn("A", new_state.guessed_letters)
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+        self.assertEqual(new_state.status_message, "Good guess! The garden grows.")
+
+    def test_incorrect_guess_costs_water(self):
+        """Test that incorrect guess reduces water by exactly 1."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "Z")
+        self.assertIn("Z", new_state.guessed_letters)
+        self.assertEqual(new_state.remaining_water, 5)
+        self.assertEqual(new_state.weed_count, 1)
+        self.assertEqual(new_state.status_message, "No match. A weed appears.")
+
+    def test_repeated_guess_no_change(self):
+        """Test that repeated guess doesn't change water or weeds."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"Z"},
+            remaining_water=5,
+            weed_count=1,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "Z")
+        self.assertEqual(new_state.remaining_water, 5)
+        self.assertEqual(new_state.weed_count, 1)
+        self.assertEqual(new_state.guessed_letters, {"Z"})
+        self.assertIn("already guessed", new_state.status_message)
+
+    def test_repeated_guess_message(self):
+        """Test that repeated guess shows appropriate message."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"A"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "A")
+        self.assertIn("already guessed A", new_state.status_message)
+
+    def test_guess_after_game_over(self):
+        """Test that guessing after game is over is a no-op."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+            game_over=True,
+            won=True,
+        )
+        new_state = apply_guess(state, "Z")
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+        self.assertEqual(new_state.guessed_letters, {"G", "A", "R", "D", "E", "N"})
+
+    def test_win_condition(self):
+        """Test that game detects win when word is complete."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "N")
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+
+    def test_loss_condition(self):
+        """Test that game detects loss when water reaches 0."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"Z", "X", "Q", "W", "B"},
+            remaining_water=1,
+            weed_count=5,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "V")
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+
+
+class TestIsWon(unittest.TestCase):
+    """Tests for is_won() function."""
+
+    def test_is_won_false_initially(self):
+        """Test that game is not won initially."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertFalse(is_won(state))
+
+    def test_is_won_partial_guesses(self):
+        """Test that game is not won with partial guesses."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertFalse(is_won(state))
+
+    def test_is_won_all_letters(self):
+        """Test that game is won when all letters are guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertTrue(is_won(state))
+
+
+class TestIsLost(unittest.TestCase):
+    """Tests for is_lost() function."""
+
+    def test_is_lost_false_with_water(self):
+        """Test that game is not lost with water remaining."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=1,
+            weed_count=5,
+            max_water=6,
+        )
+        self.assertFalse(is_lost(state))
+
+    def test_is_lost_at_zero(self):
+        """Test that game is lost when water reaches 0."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=0,
+            weed_count=6,
+            max_water=6,
+        )
+        self.assertTrue(is_lost(state))
+
+
+if __name__ == "__main__":
+    unittest.main()
