+"""Core game logic for Word Garden."""
+
+from dataclasses import dataclass, field
+from . import words
+
+
+@dataclass
+class GameState:
+    """Represents the state of a Word Garden game."""
+
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty="normal", rng=None) -> GameState:
+    """Create a new game with a random word.
+
+    Args:
+        difficulty: "easy", "normal", or "hard"
+        rng: Optional random.Random instance for deterministic testing
+
+    Returns:
+        A new GameState ready to play
+    """
+    secret_word = words.select_word(difficulty, rng)
+    water = words.water_for(difficulty)
+
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text) -> tuple[str | None, str]:
+    """Validate user input as a single letter.
+
+    Args:
+        input_text: Raw input from user
+
+    Returns:
+        Tuple of (letter, message) where letter is None if invalid.
+        letter is uppercase if valid, message explains result.
+    """
+    trimmed = input_text.strip()
+
+    if not trimmed:
+        return (None, "Please enter a single letter.")
+
+    if len(trimmed) > 1:
+        return (None, "Please enter a single letter.")
+
+    if not trimmed.isalpha():
+        return (None, "That is not a letter.")
+
+    return (trimmed.upper(), "")
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word display with revealed letters.
+
+    Args:
+        state: Current game state
+
+    Returns:
+        String like "G _ R _ E _" with guessed letters revealed
+    """
+    result = []
+    for letter in state.secret_word:
+        if letter in state.guessed_letters:
+            result.append(letter)
+        else:
+            result.append("_")
+    return " ".join(result)
+
+
+def is_won(state: GameState) -> bool:
+    """Check if the game is won (all letters guessed).
+
+    Args:
+        state: Current game state
+
+    Returns:
+        True if all letters of secret_word are in guessed_letters
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Check if the game is lost (water reached 0).
+
+    Args:
+        state: Current game state
+
+    Returns:
+        True if remaining_water is 0
+    """
+    return state.remaining_water <= 0
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a validated guess to the game state.
+
+    Args:
+        state: Current game state
+        letter: Single uppercase letter (assumed already validated)
+
+    Returns:
+        New GameState with the guess applied
+    """
+    # Check if game is already over
+    if state.game_over:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="Game is already over.",
+            game_over=True,
+            won=state.won,
+        )
+
+    # Check if letter was already guessed
+    if letter in state.guessed_letters:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=f"You already guessed {letter}. Try another letter.",
+            game_over=state.game_over,
+            won=state.won,
+        )
+
+    # Add letter to guessed set
+    new_guessed = state.guessed_letters.copy()
+    new_guessed.add(letter)
+
+    # Check if guess is correct
+    if letter in state.secret_word:
+        # Correct guess
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="Good guess! The garden grows.",
+            game_over=False,
+            won=False,
+        )
+    else:
+        # Incorrect guess
+        new_remaining = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_remaining,
+            weed_count=new_weeds,
+            max_water=state.max_water,
+            status_message="No match. A weed appears.",
+            game_over=False,
+            won=False,
+        )
+
+    # Check win/loss conditions
+    if is_won(new_state):
+        new_state.game_over = True
+        new_state.won = True
+    elif is_lost(new_state):
+        new_state.game_over = True
+        new_state.won = False
+
+    return new_state
