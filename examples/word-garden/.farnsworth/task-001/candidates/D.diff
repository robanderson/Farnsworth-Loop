+"""Word list and selection for Word Garden."""
+
+import random
+
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+
+def water_for(difficulty="normal") -> int:
+    """Return starting water for the given difficulty level.
+
+    Args:
+        difficulty: "easy", "normal", or "hard"
+
+    Returns:
+        Starting water amount
+
+    Raises:
+        ValueError: If difficulty is not recognized
+    """
+    water_map = {
+        "easy": 8,
+        "normal": 6,
+        "hard": 4,
+    }
+    if difficulty not in water_map:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+    return water_map[difficulty]
+
+
+def select_word(difficulty="normal", rng=None) -> str:
+    """Select a random word filtered by difficulty.
+
+    Args:
+        difficulty: "easy", "normal", or "hard"
+        rng: Optional random.Random instance for deterministic testing.
+             Uses module-level random if None.
+
+    Returns:
+        A word from WORDS list that matches the difficulty criteria
+
+    Raises:
+        ValueError: If difficulty is not recognized
+    """
+    if difficulty not in ("easy", "normal", "hard"):
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    # Difficulty filters by word length
+    length_ranges = {
+        "easy": (4, 6),      # 4-6 letters
+        "normal": (5, 8),    # 5-8 letters
+        "hard": (7, float('inf')),  # 7+ letters
+    }
+
+    min_len, max_len = length_ranges[difficulty]
+    filtered_words = [w for w in WORDS if min_len <= len(w) <= max_len]
+
+    # Use provided RNG or module-level random
+    if rng is None:
+        return random.choice(filtered_words)
+    else:
+        return rng.choice(filtered_words)
