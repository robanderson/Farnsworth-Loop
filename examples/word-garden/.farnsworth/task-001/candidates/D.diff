+"""Tests for word_garden.words module."""
+
+import unittest
+import random
+from word_garden.words import WORDS, select_word, water_for
+
+
+class TestWords(unittest.TestCase):
+    """Tests for words module."""
+
+    def test_words_list_exists(self):
+        """Test that WORDS list is defined and has 10 items."""
+        self.assertEqual(len(WORDS), 10)
+        self.assertIsInstance(WORDS, list)
+
+    def test_words_are_uppercase(self):
+        """Test that all words in WORDS are uppercase."""
+        for word in WORDS:
+            self.assertEqual(word, word.upper())
+
+    def test_words_are_strings(self):
+        """Test that all words are strings."""
+        for word in WORDS:
+            self.assertIsInstance(word, str)
+
+    def test_words_no_duplicates(self):
+        """Test that there are no duplicate words."""
+        self.assertEqual(len(WORDS), len(set(WORDS)))
+
+
+class TestWaterFor(unittest.TestCase):
+    """Tests for water_for() function."""
+
+    def test_water_for_easy(self):
+        """Test water_for returns 8 for easy."""
+        self.assertEqual(water_for("easy"), 8)
+
+    def test_water_for_normal(self):
+        """Test water_for returns 6 for normal."""
+        self.assertEqual(water_for("normal"), 6)
+
+    def test_water_for_hard(self):
+        """Test water_for returns 4 for hard."""
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_water_for_invalid_difficulty(self):
+        """Test that unknown difficulty raises ValueError."""
+        with self.assertRaises(ValueError):
+            water_for("impossible")
+
+
+class TestSelectWord(unittest.TestCase):
+    """Tests for select_word() function."""
+
+    def test_select_word_returns_string(self):
+        """Test that select_word returns a string."""
+        word = select_word()
+        self.assertIsInstance(word, str)
+
+    def test_select_word_returns_from_word_list(self):
+        """Test that select_word returns a word from WORDS."""
+        word = select_word()
+        self.assertIn(word, WORDS)
+
+    def test_select_word_easy_length(self):
+        """Test that easy difficulty returns words of 4-6 letters."""
+        for _ in range(20):  # Multiple attempts to ensure pattern holds
+            word = select_word(difficulty="easy")
+            self.assertGreaterEqual(len(word), 4)
+            self.assertLessEqual(len(word), 6)
+
+    def test_select_word_normal_length(self):
+        """Test that normal difficulty returns words of 5-8 letters."""
+        for _ in range(20):
+            word = select_word(difficulty="normal")
+            self.assertGreaterEqual(len(word), 5)
+            self.assertLessEqual(len(word), 8)
+
+    def test_select_word_hard_length(self):
+        """Test that hard difficulty returns words of 7+ letters."""
+        for _ in range(20):
+            word = select_word(difficulty="hard")
+            self.assertGreaterEqual(len(word), 7)
+
+    def test_select_word_invalid_difficulty(self):
+        """Test that unknown difficulty raises ValueError."""
+        with self.assertRaises(ValueError):
+            select_word(difficulty="nightmare")
+
+    def test_select_word_with_rng(self):
+        """Test that select_word accepts and uses injected RNG."""
+        rng1 = random.Random(42)
+        rng2 = random.Random(42)
+        word1 = select_word(difficulty="normal", rng=rng1)
+        word2 = select_word(difficulty="normal", rng=rng2)
+        # Same seed should produce same word
+        self.assertEqual(word1, word2)
+
+    def test_select_word_deterministic_with_same_seed(self):
+        """Test that different seeds produce potentially different words."""
+        words_set = set()
+        for seed in range(100):
+            rng = random.Random(seed)
+            word = select_word(difficulty="normal", rng=rng)
+            words_set.add(word)
+        # Should get some variety across different seeds
+        self.assertGreater(len(words_set), 1)
+
+
+if __name__ == "__main__":
+    unittest.main()
