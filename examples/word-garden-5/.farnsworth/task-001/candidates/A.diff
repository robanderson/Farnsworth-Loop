+"""Tests for word_garden.game module."""
+
+import unittest
+from word_garden.game import (
+    GameState,
+    new_game,
+    validate_guess,
+    apply_guess,
+    display_word,
+    is_won,
+    is_lost,
+    MSG_CORRECT_GUESS,
+    MSG_WRONG_GUESS,
+    MSG_ALREADY_GUESSED,
+    MSG_EMPTY_INPUT,
+    MSG_NOT_A_LETTER,
+    MSG_MULTIPLE_CHARS,
+    MSG_GAME_OVER,
+    MSG_WIN,
+    MSG_LOSS,
+)
+from word_garden import words
+
+
+class TestValidateGuess(unittest.TestCase):
+    """Test input validation."""
+
+    def test_valid_lowercase_letter(self):
+        """A lowercase letter should be normalized to uppercase."""
+        letter, msg = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_valid_uppercase_letter(self):
+        """An uppercase letter should be accepted."""
+        letter, msg = validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+    def test_valid_with_whitespace(self):
+        """Whitespace should be trimmed."""
+        letter, msg = validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(msg, "")
+
+    def test_empty_input(self):
+        """Empty input should be rejected."""
+        letter, msg = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_EMPTY_INPUT)
+
+    def test_empty_input_whitespace(self):
+        """Whitespace-only input should be rejected."""
+        letter, msg = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_EMPTY_INPUT)
+
+    def test_multiple_characters(self):
+        """Multiple characters should be rejected."""
+        letter, msg = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_MULTIPLE_CHARS)
+
+    def test_number(self):
+        """A number should be rejected."""
+        letter, msg = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_NOT_A_LETTER)
+
+    def test_special_character(self):
+        """A special character should be rejected."""
+        letter, msg = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_NOT_A_LETTER)
+
+
+class TestDisplayWord(unittest.TestCase):
+    """Test the word display function."""
+
+    def test_no_guesses_all_blank(self):
+        """With no guesses, all letters should be blank."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        result = display_word(state)
+        self.assertEqual(result, "_ _ _ _ _ _")
+
+    def test_partial_guesses(self):
+        """Guessed letters should be revealed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "E"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        result = display_word(state)
+        self.assertEqual(result, "G A _ _ E _")
+
+    def test_all_guesses_word_complete(self):
+        """With all letters guessed, the word should be complete."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        result = display_word(state)
+        self.assertEqual(result, "G A R D E N")
+
+
+class TestIsWon(unittest.TestCase):
+    """Test win condition."""
+
+    def test_not_won_no_guesses(self):
+        """Fresh game should not be won."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertFalse(is_won(state))
+
+    def test_not_won_partial_guesses(self):
+        """Partial guesses should not result in a win."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertFalse(is_won(state))
+
+    def test_won_all_letters_guessed(self):
+        """All letters guessed should be a win."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertTrue(is_won(state))
+
+    def test_won_extra_letters_guessed(self):
+        """Extra guessed letters should not prevent a win."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N", "X", "Y", "Z"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertTrue(is_won(state))
+
+
+class TestIsLost(unittest.TestCase):
+    """Test loss condition."""
+
+    def test_not_lost_full_water(self):
+        """Full water should not be a loss."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertFalse(is_lost(state))
+
+    def test_not_lost_some_water(self):
+        """Partial water should not be a loss."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"X"},
+            remaining_water=1,
+            weed_count=1,
+            max_water=6,
+        )
+        self.assertFalse(is_lost(state))
+
+    def test_lost_zero_water_not_won(self):
+        """Zero water and not won should be a loss."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"X", "Y", "Z"},
+            remaining_water=0,
+            weed_count=3,
+            max_water=6,
+        )
+        self.assertTrue(is_lost(state))
+
+    def test_not_lost_zero_water_but_won(self):
+        """Zero water but won should not be a loss."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=0,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertFalse(is_lost(state))
+
+
+class TestApplyGuess(unittest.TestCase):
+    """Test applying a guess to the game state."""
+
+    def test_correct_guess(self):
+        """A correct guess should reveal letters without cost."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "G")
+        self.assertIn("G", new_state.guessed_letters)
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+        self.assertEqual(new_state.status_message, MSG_CORRECT_GUESS)
+        self.assertFalse(new_state.game_over)
+
+    def test_wrong_guess(self):
+        """A wrong guess should cost water and add weeds."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "X")
+        self.assertIn("X", new_state.guessed_letters)
+        self.assertEqual(new_state.remaining_water, 5)
+        self.assertEqual(new_state.weed_count, 1)
+        self.assertEqual(new_state.status_message, MSG_WRONG_GUESS)
+        self.assertFalse(new_state.game_over)
+
+    def test_repeated_guess(self):
+        """A repeated guess should not change water or weeds."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "G")
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+        self.assertIn("already guessed", new_state.status_message.lower())
+
+    def test_win_condition(self):
+        """Guessing the last letter should trigger a win."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "N")
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+        self.assertIn("GARDEN", new_state.status_message)
+        self.assertIn("thriving", new_state.status_message)
+
+    def test_loss_condition(self):
+        """Running out of water should trigger a loss."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"X", "Y", "Z"},
+            remaining_water=1,
+            weed_count=3,
+            max_water=6,
+        )
+        new_state = apply_guess(state, "Q")
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+        self.assertIn("GARDEN", new_state.status_message)
+        self.assertIn("grow a new garden", new_state.status_message.lower())
+
+    def test_guess_after_game_over(self):
+        """Guessing after game over should be a no-op with a message."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+            game_over=True,
+            won=True,
+        )
+        new_state = apply_guess(state, "X")
+        self.assertTrue(new_state.game_over)
+        self.assertEqual(new_state.status_message, MSG_GAME_OVER)
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+
+
+class TestNewGame(unittest.TestCase):
+    """Test game creation."""
+
+    def test_new_game_normal_difficulty(self):
+        """A new normal game should have 6 water."""
+        state = new_game(difficulty="normal")
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(len(state.guessed_letters), 0)
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_easy_difficulty(self):
+        """A new easy game should have 8 water."""
+        state = new_game(difficulty="easy")
+        self.assertEqual(state.remaining_water, 8)
+        self.assertEqual(state.max_water, 8)
+
+    def test_new_game_hard_difficulty(self):
+        """A new hard game should have 4 water."""
+        state = new_game(difficulty="hard")
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.max_water, 4)
+
+    def test_new_game_word_in_wordlist(self):
+        """The secret word should come from the word list."""
+        state = new_game(difficulty="normal")
+        self.assertIn(state.secret_word, words.WORDS)
+
+    def test_new_game_deterministic_with_rng(self):
+        """Using the same RNG seed should produce the same word."""
+        import random
+        rng1 = random.Random(42)
+        rng2 = random.Random(42)
+        state1 = new_game(difficulty="normal", rng=rng1)
+        state2 = new_game(difficulty="normal", rng=rng2)
+        self.assertEqual(state1.secret_word, state2.secret_word)
+
+
+if __name__ == "__main__":
+    unittest.main()
