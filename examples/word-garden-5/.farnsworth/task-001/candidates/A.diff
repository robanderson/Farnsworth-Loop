+"""Word list and selection for Word Garden."""
+
+import random
+
+# The 10-word list from SPEC.md section 8
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+
+def water_for(difficulty="normal") -> int:
+    """Return starting water for the given difficulty level."""
+    difficulty_table = {
+        "easy": 8,
+        "normal": 6,
+        "hard": 4,
+    }
+    if difficulty not in difficulty_table:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+    return difficulty_table[difficulty]
+
+
+def select_word(difficulty="normal", rng=None) -> str:
+    """
+    Select a random word filtered by difficulty constraints.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Injectable random.Random instance; uses module-level random if None.
+
+    Returns:
+        A random word matching the difficulty constraints.
+
+    Raises:
+        ValueError: If difficulty is unknown or no words match the constraints.
+    """
+    if rng is None:
+        rng = random
+
+    # Difficulty table: (water, min_length, max_length)
+    constraints = {
+        "easy": (8, 4, 6),
+        "normal": (6, 5, 8),
+        "hard": (4, 7, float('inf')),
+    }
+
+    if difficulty not in constraints:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    _, min_len, max_len = constraints[difficulty]
+
+    # Filter words by length
+    filtered = [w for w in WORDS if min_len <= len(w) <= max_len]
+
+    if not filtered:
+        raise ValueError(f"No words available for difficulty: {difficulty}")
+
+    return rng.choice(filtered)
