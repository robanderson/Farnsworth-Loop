+"""Main game loop and CLI entry point for Word Garden."""
+
+import argparse
+import sys
+from .game import new_game, validate_guess, apply_guess
+from .ui import render
+
+
+def main(argv=None, input_fn=input, output_fn=print) -> int:
+    """
+    Main game loop and CLI entry point.
+
+    Args:
+        argv: Command-line arguments (None uses sys.argv[1:]).
+        input_fn: Function to read user input (default: built-in input).
+        output_fn: Function to write output (default: built-in print).
+
+    Returns:
+        Exit code (0 for success).
+    """
+    # Parse arguments
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description="Word Garden - A friendly word-guessing game.",
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Difficulty level (default: normal)",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        help="Use ASCII symbols instead of emoji",
+    )
+
+    try:
+        args = parser.parse_args(argv)
+    except SystemExit as e:
+        # Let argparse handle --help (exits 0) and usage errors (exits 2)
+        raise
+
+    # Create a new game
+    game_state = new_game(difficulty=args.difficulty)
+
+    # Game loop
+    try:
+        while not game_state.game_over:
+            # Render and display the current state
+            screen = render(game_state, ascii_mode=args.ascii)
+            output_fn(screen)
+            output_fn("")
+
+            # Prompt for input
+            try:
+                user_input = input_fn("Guess a letter: ")
+            except EOFError:
+                output_fn("Goodbye!")
+                return 0
+            except KeyboardInterrupt:
+                output_fn("\nGoodbye!")
+                return 0
+
+            # Validate the guess
+            letter, error_msg = validate_guess(user_input)
+
+            # If validation failed, show message and continue (no state change)
+            if letter is None:
+                output_fn(f"\n{error_msg}\n")
+                continue
+
+            # Apply the validated guess
+            game_state = apply_guess(game_state, letter)
+            output_fn("")
+
+        # Game is over: display final screen
+        screen = render(game_state, ascii_mode=args.ascii)
+        output_fn(screen)
+        output_fn("")
+
+        return 0
+
+    except EOFError:
+        output_fn("Goodbye!")
+        return 0
+    except KeyboardInterrupt:
+        output_fn("\nGoodbye!")
+        return 0
