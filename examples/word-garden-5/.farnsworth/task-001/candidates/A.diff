@@ -0,0 +1,100 @@
+"""Terminal UI rendering for Word Garden."""
+
+from .game import GameState, display_word
+
+
+# Emoji and ASCII growth stages
+GROWTH_STAGES = {
+    "start": ("🌱", "*"),
+    "progress": ("🌿", "*"),
+    "near_win": ("🌷", "*"),
+    "win": ("🌻", "*"),
+    "loss": ("🥀", "*"),
+}
+
+# Water and weed symbols
+WATER_EMOJI = "💧"
+WATER_ASCII = "~"
+WEED_EMOJI = "🌿"
+WEED_ASCII = "-"
+
+
+def _get_growth_stage(state: GameState) -> str:
+    """
+    Determine the growth stage based on letters revealed.
+
+    Stages:
+    - start: no letters revealed
+    - progress: some letters revealed
+    - near_win: most letters revealed but not won
+    - win: game won
+    - loss: game lost
+    """
+    if state.won:
+        return "win"
+    if state.game_over and not state.won:  # lost
+        return "loss"
+
+    # Fraction of distinct letters revealed
+    secret_letters = set(state.secret_word)
+    if not secret_letters:
+        return "start"
+
+    fraction = len(state.guessed_letters & secret_letters) / len(secret_letters)
+
+    if fraction == 0:
+        return "start"
+    elif fraction < 0.5:
+        return "progress"
+    else:  # >= 0.5 and not won
+        return "near_win"
+
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """
+    Render the full game screen.
+
+    Args:
+        state: Current game state.
+        ascii_mode: If True, use ASCII symbols instead of emoji.
+
+    Returns:
+        Complete rendered screen as a string.
+    """
+    stage = _get_growth_stage(state)
+    emoji, ascii_sym = GROWTH_STAGES[stage]
+    plant_glyph = ascii_sym if ascii_mode else emoji
+
+    water_sym = WATER_ASCII if ascii_mode else WATER_EMOJI
+    weed_sym = WEED_ASCII if ascii_mode else WEED_EMOJI
+
+    lines = []
+
+    # Title with growth glyph
+    lines.append(f"{plant_glyph} Word Garden")
+    lines.append("")
+
+    # Word display
+    word_display = display_word(state)
+    lines.append(f"Word:      {word_display}")
+
+    # Guessed letters (sorted, space-separated)
+    guessed_sorted = " ".join(sorted(state.guessed_letters))
+    lines.append(f"Guessed:   {guessed_sorted}")
+
+    # Water line: n/max_water + symbols
+    water_line = f"Water:     {state.remaining_water}/{state.max_water} "
+    water_line += water_sym * state.remaining_water
+    lines.append(water_line)
+
+    # Weeds line: count + symbols
+    weed_line = f"Weeds:     {state.weed_count} "
+    weed_line += weed_sym * state.weed_count
+    lines.append(weed_line)
+
+    # Status message block (omit if empty)
+    if state.status_message:
+        lines.append("")
+        lines.append(state.status_message)
+
+    return "\n".join(lines)
