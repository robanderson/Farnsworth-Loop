+"""Tests for word_garden.ui module."""
+
+import unittest
+from word_garden.ui import render, _get_growth_stage
+from word_garden.game import GameState
+
+
+class TestGrowthStage(unittest.TestCase):
+    """Test growth stage selection."""
+
+    def test_stage_start(self):
+        """With no guesses, stage should be start."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertEqual(_get_growth_stage(state), "start")
+
+    def test_stage_progress(self):
+        """With < 50% of letters revealed, stage should be progress."""
