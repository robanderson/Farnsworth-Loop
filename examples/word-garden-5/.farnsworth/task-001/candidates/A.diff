+"""Tests for word_garden.main module and end-to-end integration."""
+
+import unittest
+import random
+from io import StringIO
+from word_garden.main import main
+from word_garden import words, game
+
+
+class TestMainCLI(unittest.TestCase):
+    """Test the main CLI entry point."""
+
+    def test_help_exit_code_zero(self):
+        """--help should exit with code 0."""
+        output = StringIO()
+        try:
+            exit_code = main(["--help"], output_fn=output.write)
+            # Should raise SystemExit, not return
+            self.fail("Expected SystemExit")
+        except SystemExit as e:
+            self.assertEqual(e.code, 0)
+
+    def test_invalid_arg_exit_code_two(self):
+        """Invalid arguments should exit with code 2."""
+        output = StringIO()
+        try:
+            exit_code = main(["--bogus"], output_fn=output.write)
+            self.fail("Expected SystemExit")
+        except SystemExit as e:
+            self.assertEqual(e.code, 2)
+
+    def test_eof_graceful_exit(self):
+        """EOF should exit gracefully with code 0."""
+        def input_fn(prompt):
+            raise EOFError()
+
+        output_lines = []
+        exit_code = main(
+            [],
+            input_fn=input_fn,
+            output_fn=lambda s: output_lines.append(s)
+        )
+        self.assertEqual(exit_code, 0)
+        output_text = "\n".join(output_lines)
+        self.assertIn("Goodbye", output_text)
+
+    def test_keyboard_interrupt_graceful_exit(self):
+        """KeyboardInterrupt should exit gracefully with code 0."""
+        def input_fn(prompt):
+            raise KeyboardInterrupt()
+
+        output_lines = []
+        exit_code = main(
+            [],
+            input_fn=input_fn,
+            output_fn=lambda s: output_lines.append(s)
+        )
+        self.assertEqual(exit_code, 0)
+        output_text = "\n".join(output_lines)
+        self.assertIn("Goodbye", output_text)
+
+
+class TestMainGameFlow(unittest.TestCase):
+    """Test full game flow scenarios."""
+
+    def test_win_scenario(self):
+        """A full win game should return 0."""
+        # Monkeypatch select_word to always pick "PYTHON"
+        original_select = words.select_word
+        words.select_word = lambda difficulty="normal", rng=None: "PYTHON"
+
+        try:
+            # Input sequence: P Y T H O N (correct letters to win)
+            input_sequence = ["p", "y", "t", "h", "o", "n"]
+            input_index = [0]
+
+            def input_fn(prompt):
+                if input_index[0] >= len(input_sequence):
+                    raise EOFError()
+                result = input_sequence[input_index[0]]
+                input_index[0] += 1
+                return result
+
+            output_lines = []
+            exit_code = main(
+                [],
+                input_fn=input_fn,
+                output_fn=lambda s: output_lines.append(s)
+            )
+
+            self.assertEqual(exit_code, 0)
+            output_text = "\n".join(output_lines)
+            # Should see the win screen
+            self.assertIn("PYTHON", output_text)
+            self.assertIn("thriving", output_text)
+
+        finally:
+            words.select_word = original_select
+
+    def test_loss_scenario(self):
+        """A full loss game should return 0."""
+        original_select = words.select_word
+        words.select_word = lambda difficulty="normal", rng=None: "PYTHON"
+
+        try:
+            # Input sequence: 6 wrong letters (costs 6 water) -> loss
+            input_sequence = ["a", "b", "c", "d", "e", "f"]
+            input_index = [0]
+
+            def input_fn(prompt):
+                if input_index[0] >= len(input_sequence):
+                    raise EOFError()
+                result = input_sequence[input_index[0]]
+                input_index[0] += 1
+                return result
+
+            output_lines = []
+            exit_code = main(
+                [],
+                input_fn=input_fn,
+                output_fn=lambda s: output_lines.append(s)
+            )
+
+            self.assertEqual(exit_code, 0)
+            output_text = "\n".join(output_lines)
+            # Should see the loss screen
+            self.assertIn("PYTHON", output_text)
+
+        finally:
+            words.select_word = original_select
+
+    def test_invalid_input_no_state_change(self):
+        """Invalid input should not cost a guess."""
+        original_select = words.select_word
+        words.select_word = lambda difficulty="normal", rng=None: "PYTHON"
+
+        try:
+            # Input: invalid, then valid win sequence
+            input_sequence = ["!", "p", "y", "t", "h", "o", "n"]
+            input_index = [0]
+
+            def input_fn(prompt):
+                if input_index[0] >= len(input_sequence):
+                    raise EOFError()
+                result = input_sequence[input_index[0]]
+                input_index[0] += 1
+                return result
+
+            output_lines = []
+            exit_code = main(
+                [],
+                input_fn=input_fn,
+                output_fn=lambda s: output_lines.append(s)
+            )
+
+            self.assertEqual(exit_code, 0)
+            output_text = "\n".join(output_lines)
+            # Should still see a win (invalid input didn't cost)
+            self.assertIn("PYTHON", output_text)
+            self.assertIn("thriving", output_text)
+
+        finally:
+            words.select_word = original_select
+
+    def test_repeated_guess_no_cost(self):
+        """Repeated guess should not cost water or weeds."""
+        original_select = words.select_word
+        words.select_word = lambda difficulty="normal", rng=None: "PYTHON"
+
+        try:
+            # Input: P twice, then other letters to win
+            input_sequence = ["p", "p", "y", "t", "h", "o", "n"]
+            input_index = [0]
+
+            def input_fn(prompt):
+                if input_index[0] >= len(input_sequence):
+                    raise EOFError()
+                result = input_sequence[input_index[0]]
+                input_index[0] += 1
+                return result
+
+            output_lines = []
+            exit_code = main(
+                [],
+                input_fn=input_fn,
+                output_fn=lambda s: output_lines.append(s)
+            )
+
+            self.assertEqual(exit_code, 0)
+            output_text = "\n".join(output_lines)
+            # Should see message about already guessing
+            self.assertIn("already guessed", output_text.lower())
+
+        finally:
+            words.select_word = original_select
+
+    def test_ascii_mode_full_game(self):
+        """--ascii should produce entirely ASCII output."""
+        original_select = words.select_word
+        words.select_word = lambda difficulty="normal", rng=None: "PYTHON"
+
+        try:
+            input_sequence = ["p", "y", "t", "h", "o", "n"]
+            input_index = [0]
+
+            def input_fn(prompt):
+                if input_index[0] >= len(input_sequence):
+                    raise EOFError()
+                result = input_sequence[input_index[0]]
+                input_index[0] += 1
+                return result
+
+            output_lines = []
+            exit_code = main(
+                ["--ascii"],
+                input_fn=input_fn,
+                output_fn=lambda s: output_lines.append(s)
+            )
+
+            self.assertEqual(exit_code, 0)
+            output_text = "\n".join(output_lines)
+            # Should not contain emoji
+            emoji_chars = "💧🌿🌱🌷🌻🥀"
+            for emoji in emoji_chars:
+                self.assertNotIn(emoji, output_text)
+
+        finally:
+            words.select_word = original_select
+
+    def test_difficulty_easy(self):
+        """--difficulty easy should start with 8 water."""
+        original_select = words.select_word
+
+        try:
+            words.select_word = lambda difficulty="normal", rng=None: "GARDEN"
+
+            input_sequence = ["!"]  # Invalid, just to trigger one iteration
+            input_index = [0]
+
+            def input_fn(prompt):
+                raise EOFError()
+
+            output_lines = []
+            exit_code = main(
+                ["--difficulty", "easy"],
+                input_fn=input_fn,
+                output_fn=lambda s: output_lines.append(s)
+            )
+
+            self.assertEqual(exit_code, 0)
+            output_text = "\n".join(output_lines)
+            # Should see 8 water
+            self.assertIn("8/8", output_text)
+
+        finally:
+            words.select_word = original_select
+
+    def test_five_growth_stages(self):
+        """Should observe five distinct growth stages across a game."""
+        original_select = words.select_word
+        words.select_word = lambda difficulty="normal", rng=None: "GARDEN"
+
+        try:
+            # Craft a sequence to hit all 5 stages
+            # GARDEN has 6 distinct letters: G, A, R, D, E, N
+            # Stage 1: start (0/6 = 0%)
+            # Stage 2: progress (1/6 = 16.7%)
+            # Stage 3: near_win (3/6 = 50%, 4/6 = 66.7%)
+            # Stage 4: win (6/6 = 100%)
+            # Stage 5: loss (if water reaches 0 before win)
+
+            # Use: G (progress), A (progress), R (near_win), D (near_win), E (near_win), N (win)
+            input_sequence = ["g", "a", "r", "d", "e", "n"]
+            input_index = [0]
+
+            def input_fn(prompt):
+                if input_index[0] >= len(input_sequence):
+                    raise EOFError()
+                result = input_sequence[input_index[0]]
+                input_index[0] += 1
+                return result
+
+            output_lines = []
+            exit_code = main(
+                [],
+                input_fn=input_fn,
+                output_fn=lambda s: output_lines.append(s)
+            )
+
+            self.assertEqual(exit_code, 0)
+            output_text = "\n".join(output_lines)
+            # Just check we can observe growth emoji
+            self.assertIn("🌱", output_text)  # start
+            self.assertIn("🌻", output_text)  # win
+
+        finally:
+            words.select_word = original_select
+
+
+if __name__ == "__main__":
+    unittest.main()
