+"""Game state management for Word Garden."""
+
+from dataclasses import dataclass, field
+from . import words
+
+
+# Message constants
+MSG_CORRECT_GUESS = "Good guess! The garden grows."
+MSG_WRONG_GUESS = "No match. A weed appears."
+MSG_ALREADY_GUESSED = "You already guessed {letter}. Try another letter."
+MSG_EMPTY_INPUT = "Please enter a single letter."
+MSG_NOT_A_LETTER = "That is not a letter."
+MSG_MULTIPLE_CHARS = "Please enter a single letter."
+MSG_GAME_OVER = "The game is over. You already know the answer."
+MSG_WIN = "You guessed the word: {word}\nThe garden is thriving."
+MSG_LOSS = "The word was: {word}\nTry again and grow a new garden."
+
+
+@dataclass
+class GameState:
+    """Complete game state at any point."""
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty="normal", rng=None) -> GameState:
+    """Create a new game with a random word for the given difficulty."""
+    word = words.select_word(difficulty=difficulty, rng=rng)
+    water = words.water_for(difficulty=difficulty)
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[str | None, str]:
+    """
+    Validate user input and return (letter, message).
+
+    Args:
+        input_text: Raw user input.
+
+    Returns:
+        (letter, "") for valid single letter, or (None, error_message) for invalid input.
+    """
+    text = input_text.strip().upper()
+
+    if not text:
+        return None, MSG_EMPTY_INPUT
+
+    if len(text) > 1:
+        return None, MSG_MULTIPLE_CHARS
+
+    if not text.isalpha():
+        return None, MSG_NOT_A_LETTER
+
+    return text, ""
+
+
+def display_word(state: GameState) -> str:
+    """Return the display version of the secret word with guesses revealed."""
+    result = []
+    for char in state.secret_word:
+        if char in state.guessed_letters:
+            result.append(char)
+        else:
+            result.append("_")
+    return " ".join(result)
+
+
+def is_won(state: GameState) -> bool:
+    """Check if all letters of the secret word have been guessed."""
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Check if the game is lost (water at 0 and word not won)."""
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """
+    Apply a validated letter guess and return a new game state.
+
+    Args:
+        state: Current game state.
+        letter: A single uppercase letter (already validated).
+
+    Returns:
+        Updated GameState.
+    """
+    # If game is already over, no-op with a message.
+    if state.game_over:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=MSG_GAME_OVER,
+            game_over=True,
+            won=state.won,
+        )
+
+    # If already guessed, just update the message.
+    if letter in state.guessed_letters:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=MSG_ALREADY_GUESSED.format(letter=letter),
+            game_over=state.game_over,
+            won=state.won,
+        )
+
+    # Add the letter to guessed set.
+    new_guessed = state.guessed_letters | {letter}
+
+    # Determine if correct.
+    is_correct = letter in state.secret_word
+
+    if is_correct:
+        status_msg = MSG_CORRECT_GUESS
+        new_water = state.remaining_water
+        new_weeds = state.weed_count
+    else:
+        status_msg = MSG_WRONG_GUESS
+        new_water = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+
+    # Create new state.
+    new_state = GameState(
+        secret_word=state.secret_word,
+        guessed_letters=new_guessed,
+        remaining_water=new_water,
+        weed_count=new_weeds,
+        max_water=state.max_water,
+        status_message=status_msg,
+        game_over=False,
+        won=False,
+    )
+
+    # Check for win/loss after this guess.
+    if is_won(new_state):
+        new_state.game_over = True
+        new_state.won = True
+        new_state.status_message = MSG_WIN.format(word=state.secret_word)
+    elif is_lost(new_state):
+        new_state.game_over = True
+        new_state.won = False
+        new_state.status_message = MSG_LOSS.format(word=state.secret_word)
+
+    return new_state
