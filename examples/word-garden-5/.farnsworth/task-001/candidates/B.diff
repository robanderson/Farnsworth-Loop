@@ -0,0 +1,72 @@
+"""Command-line entry point and game loop for Word Garden.
+
+This is the ONLY module that touches stdin/stdout, and it does so only via
+the injected ``input_fn`` / ``output_fn`` callables so the whole game can
+be driven hermetically in tests.
+"""
+
+from __future__ import annotations
+
+import argparse
+
+from . import game, ui
+
+PROMPT = "Guess a letter: "
+GOODBYE = "Goodbye! Come back and tend your garden soon."
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description=(
+            "Word Garden — a friendly terminal word-guessing game. "
+            "Guess the hidden word before the garden runs out of water."
+        ),
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Difficulty level (default: normal).",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        dest="ascii_mode",
+        help="Use ASCII-only output instead of emoji.",
+    )
+    return parser
+
+
+def main(argv=None, input_fn=input, output_fn=print) -> int:
+    """Run a full Word Garden session.
+
+    Returns the process exit code. ``--help`` exits 0 and a usage error
+    exits 2 (``SystemExit`` from argparse is intentionally NOT caught).
+    ``EOFError`` and ``KeyboardInterrupt`` produce a friendly goodbye and
+    return 0 with no traceback.
+    """
+    parser = _build_parser()
+    args = parser.parse_args(argv)
+
+    state = game.new_game(args.difficulty)
+    ascii_mode = args.ascii_mode
+
+    try:
+        while not state.game_over:
+            output_fn(ui.render(state, ascii_mode))
+            output_fn("")
+            raw = input_fn(PROMPT)
+            letter, message = game.validate_guess(raw)
+            if letter is None:
+                # Invalid input never mutates game state.
+                state.status_message = message
+                continue
+            game.apply_guess(state, letter)
+
+        output_fn(ui.render_end(state, ascii_mode))
+        return 0
+    except (EOFError, KeyboardInterrupt):
+        output_fn("")
+        output_fn(GOODBYE)
+        return 0
diff --git a/word_garden/ui.py b/word_garden/ui.py
