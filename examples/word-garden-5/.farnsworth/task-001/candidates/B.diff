index 0000000..96ded5e
--- /dev/null
+++ b/word_garden/words.py
@@ -0,0 +1,86 @@
+"""Word list and difficulty-aware word selection.
+
+This module performs no terminal I/O. Randomness is injectable via an
+optional ``rng`` (a ``random.Random`` instance); when ``None`` the
+module-level ``random`` functions are used.
+"""
+
+from __future__ import annotations
+
+import random
+
+# The built-in word list from SPEC.md section 8, uppercased.
+WORDS: list[str] = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty table from SPEC.md section 7.
+#   water: starting water level for the difficulty.
+#   min_length / max_length: inclusive word-length bounds (None == unbounded).
+_DIFFICULTY = {
+    "easy": {"water": 8, "min_length": 4, "max_length": 6},
+    "normal": {"water": 6, "min_length": 5, "max_length": 8},
+    "hard": {"water": 4, "min_length": 7, "max_length": None},
+}
+
+
+def _difficulty_config(difficulty: str) -> dict:
+    """Return the config row for ``difficulty`` or raise ``ValueError``."""
+    try:
+        return _DIFFICULTY[difficulty]
+    except KeyError:
+        valid = ", ".join(sorted(_DIFFICULTY))
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}; expected one of: {valid}."
+        )
+
+
+def _words_for(difficulty: str) -> list[str]:
+    """Return words matching the difficulty's length bounds.
+
+    Raises ``ValueError`` for an unknown difficulty, or if the filtered
+    pool is empty (never silently falls back to the full list).
+    """
+    config = _difficulty_config(difficulty)
+    min_length = config["min_length"]
+    max_length = config["max_length"]
+    pool = [
+        word
+        for word in WORDS
+        if len(word) >= min_length
+        and (max_length is None or len(word) <= max_length)
+    ]
+    if not pool:
+        raise ValueError(
+            f"No words available for difficulty {difficulty!r}."
+        )
+    return pool
+
+
+def select_word(difficulty: str = "normal", rng: random.Random | None = None) -> str:
+    """Return a random word filtered by ``difficulty``.
+
+    ``rng`` is an injectable ``random.Random`` for deterministic tests;
+    when ``None`` the module-level ``random`` functions are used. Raises
+    ``ValueError`` for an unknown difficulty or an empty filtered pool.
+    """
+    pool = _words_for(difficulty)
+    chooser = rng if rng is not None else random
+    return chooser.choice(pool)
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return the starting water level for ``difficulty``.
+
+    Raises ``ValueError`` for an unknown difficulty.
+    """
+    return _difficulty_config(difficulty)["water"]
