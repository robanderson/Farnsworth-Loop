index 0000000..00cbd26
--- /dev/null
+++ b/word_garden/ui.py
@@ -0,0 +1,158 @@
+"""Pure rendering for Word Garden.
+
+Every function returns a string and performs no I/O: this module never
+calls ``print`` or ``input``. Pass ``ascii_mode=True`` to swap every emoji
+for its SPEC.md section 10 ASCII fallback so a whole session can run as
+pure ASCII.
+"""
+
+from __future__ import annotations
+
+from .game import GameState, display_word
+
+# --- Glyph tables ----------------------------------------------------------
+#
+# Growth stages from SPEC.md section 10. Each stage has an emoji and an
+# ASCII fallback. The five stages are observable and distinct.
+GROWTH_EMOJI = {
+    "start": "\U0001F331",     # 🌱
+    "progress": "\U0001F33F",  # 🌿
+    "near_win": "\U0001F337",  # 🌷
+    "win": "\U0001F33B",       # 🌻
+    "loss": "\U0001F940",      # 🥀
+}
+GROWTH_ASCII = {
+    "start": "*",
+    "progress": "*",
+    "near_win": "*",
+    "win": "*",
+    "loss": "x",
+}
+
+# Resource symbols. Water uses a droplet; weeds use an herb.
+WATER_EMOJI = "\U0001F4A7"  # 💧
+WEED_EMOJI = "\U0001F33F"   # 🌿
+WATER_ASCII_FULL = "*"
+WATER_ASCII_EMPTY = "-"
+WEED_ASCII = "-"
+
+TITLE = "Word Garden"
+
+# Win / loss screen text (SPEC.md sections 6.6–6.7).
+WIN_HEADER = "Bloom!"
+WIN_THRIVING = "The garden is thriving."
+LOSS_HEADER = "The garden ran out of water."
+LOSS_RETRY = "Try again and grow a new garden."
+
+
+def _growth_stage(state: GameState) -> str:
+    """Return the growth-stage key for ``state``.
+
+    Win and loss come straight from the terminal flags. Otherwise the
+    stage is driven by the fraction of *distinct* secret letters revealed:
+    none -> start, some -> progress, almost all -> near_win.
+    """
+    if state.won:
+        return "win"
+    if state.game_over and not state.won:
+        return "loss"
+
+    distinct = set(state.secret_word)
+    revealed = {ltr for ltr in distinct if ltr in state.guessed_letters}
+    if not distinct:
+        return "start"
+    fraction = len(revealed) / len(distinct)
+    if fraction <= 0.0:
+        return "start"
+    if fraction >= 0.75:
+        return "near_win"
+    return "progress"
+
+
+def _growth_glyph(state: GameState, ascii_mode: bool) -> str:
+    stage = _growth_stage(state)
+    table = GROWTH_ASCII if ascii_mode else GROWTH_EMOJI
+    return table[stage]
+
+
+def _water_line(state: GameState, ascii_mode: bool) -> str:
+    """Water line: numeric ``count/max`` plus symbols (SPEC.md section 18)."""
+    count = max(state.remaining_water, 0)
+    numeric = f"{count}/{state.max_water}"
+    if ascii_mode:
+        empty = max(state.max_water - count, 0)
+        symbols = "[" + WATER_ASCII_FULL * count + WATER_ASCII_EMPTY * empty + "]"
+    else:
+        symbols = WATER_EMOJI * count
+    return f"Water: {numeric} {symbols}".rstrip()
+
+
+def _weeds_line(state: GameState, ascii_mode: bool) -> str:
+    """Weeds line: standalone numeric count plus symbols (SPEC.md section 18)."""
+    count = max(state.weed_count, 0)
+    if ascii_mode:
+        symbols = "[" + WEED_ASCII * count + "]"
+    else:
+        symbols = WEED_EMOJI * count
+    return f"Weeds: {count} {symbols}".rstrip()
+
+
+def _guessed_line(state: GameState) -> str:
+    """Already-guessed letters, sorted and space-separated."""
+    letters = " ".join(sorted(state.guessed_letters))
+    return f"Guessed: {letters}".rstrip()
+
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the main game screen (SPEC.md section 9).
+
+    Fields in order: title (with growth glyph), masked word, guessed
+    letters (sorted, space-separated), water, weeds, then the previous
+    turn's status message. The message block is omitted when empty.
+    """
+    glyph = _growth_glyph(state, ascii_mode)
+    lines = [
+        f"{glyph} {TITLE}",
+        "",
+        f"Word:    {display_word(state)}",
+        _guessed_line(state),
+        _water_line(state, ascii_mode),
+        _weeds_line(state, ascii_mode),
+    ]
+    if state.status_message:
+        lines.append("")
+        lines.append(state.status_message)
+    return "\n".join(lines)
+
+
+def render_win(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the win screen (SPEC.md section 6.6)."""
+    glyph = GROWTH_ASCII["win"] if ascii_mode else GROWTH_EMOJI["win"]
+    return "\n".join(
+        [
+            f"{glyph} {WIN_HEADER}",
+            "",
+            f"You guessed the word: {state.secret_word}",
+            WIN_THRIVING,
+        ]
+    )
+
+
+def render_loss(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the loss screen (SPEC.md section 6.7)."""
+    glyph = GROWTH_ASCII["loss"] if ascii_mode else GROWTH_EMOJI["loss"]
+    return "\n".join(
+        [
+            f"{glyph} {LOSS_HEADER}",
+            "",
+            f"The word was: {state.secret_word}",
+            LOSS_RETRY,
+        ]
+    )
+
+
+def render_end(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the appropriate end screen based on the terminal flags."""
+    if state.won:
+        return render_win(state, ascii_mode)
+    return render_loss(state, ascii_mode)
