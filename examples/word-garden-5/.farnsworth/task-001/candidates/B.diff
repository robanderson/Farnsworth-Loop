+"""Tests for word selection and difficulty filtering."""
+
+import random
+import unittest
+
+from word_garden import words
+
+
+class SelectWordTests(unittest.TestCase):
+    def test_select_word_each_difficulty_respects_length_bounds(self):
+        rng = random.Random(1234)
+        bounds = {
+            "easy": (4, 6),
+            "normal": (5, 8),
+            "hard": (7, None),
+        }
+        for difficulty, (lo, hi) in bounds.items():
+            with self.subTest(difficulty=difficulty):
+                # Sample repeatedly to exercise the whole filtered pool.
+                seen = set()
+                for _ in range(200):
+                    word = words.select_word(difficulty, rng=rng)
+                    self.assertIn(word, words.WORDS)
+                    self.assertEqual(word, word.upper())
+                    self.assertGreaterEqual(len(word), lo)
+                    if hi is not None:
+                        self.assertLessEqual(len(word), hi)
+                    seen.add(word)
+                # The pool actually contains the words we expect.
+                expected = {
+                    w
+                    for w in words.WORDS
+                    if len(w) >= lo and (hi is None or len(w) <= hi)
+                }
+                self.assertEqual(seen, expected)
+                self.assertTrue(expected, "difficulty pool must be non-empty")
+
+    def test_select_word_is_deterministic_with_seeded_rng(self):
+        a = words.select_word("normal", rng=random.Random(42))
+        b = words.select_word("normal", rng=random.Random(42))
+        self.assertEqual(a, b)
+
+    def test_select_word_returns_valid_word_default_rng(self):
+        # SPEC section 16, case 10: selector returns a valid word.
+        word = words.select_word()
+        self.assertIn(word, words.WORDS)
+        self.assertEqual(word, word.upper())
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            words.select_word("impossible")
+
+    def test_empty_pool_raises_when_forced(self):
+        # Force the filtered pool empty by shrinking WORDS, and assert the
+        # raising path is taken (not a silent fallback to the full list).
+        saved = words.WORDS
+        try:
+            words.WORDS = ["CAT"]  # too short for any difficulty bound
+            with self.assertRaises(ValueError):
+                words.select_word("hard")
+        finally:
+            words.WORDS = saved
+        # After restore, selection works again.
+        self.assertIn(words.select_word("hard"), words.WORDS)
+
+
+class WaterForTests(unittest.TestCase):
+    def test_water_for_each_difficulty(self):
+        self.assertEqual(words.water_for("easy"), 8)
+        self.assertEqual(words.water_for("normal"), 6)
+        self.assertEqual(words.water_for("hard"), 4)
+
+    def test_water_for_default_is_normal(self):
+        self.assertEqual(words.water_for(), 6)
+
+    def test_water_for_unknown_raises(self):
+        with self.assertRaises(ValueError):
+            words.water_for("nope")
+
+
+if __name__ == "__main__":
+    unittest.main()
