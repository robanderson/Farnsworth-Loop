+"""Tests for pure rendering (ui.py)."""
+
+import unittest
+
+from word_garden import ui
+from word_garden.game import GameState, MSG_CORRECT
+from word_garden.ui import (
+    GROWTH_ASCII,
+    GROWTH_EMOJI,
+    LOSS_HEADER,
+    LOSS_RETRY,
+    TITLE,
+    WIN_HEADER,
+    WIN_THRIVING,
+    render,
+    render_loss,
+    render_win,
+)
+
+
+def make_state(secret="GARDEN", guessed=None, water=6, weeds=0, max_water=6,
+               message="", game_over=False, won=False):
+    return GameState(
+        secret_word=secret,
+        guessed_letters=set(guessed or ()),
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=max_water,
+        status_message=message,
+        game_over=game_over,
+        won=won,
+    )
+
+
+class RenderFieldsTests(unittest.TestCase):
+    def test_render_contains_required_fields_in_order(self):
+        state = make_state("GARDEN", guessed={"A", "E", "G", "R"},
+                           water=4, weeds=2, message=MSG_CORRECT)
+        out = render(state)
+        self.assertIn(TITLE, out)
+        # Title appears before the word line, etc. (order check).
+        idx_title = out.index(TITLE)
+        idx_word = out.index("Word:")
+        idx_guessed = out.index("Guessed:")
+        idx_water = out.index("Water:")
+        idx_weeds = out.index("Weeds:")
+        idx_msg = out.index(MSG_CORRECT)
+        self.assertLess(idx_title, idx_word)
+        self.assertLess(idx_word, idx_guessed)
+        self.assertLess(idx_guessed, idx_water)
+        self.assertLess(idx_water, idx_weeds)
+        self.assertLess(idx_weeds, idx_msg)
+
+    def test_guessed_letters_sorted(self):
+        state = make_state("GARDEN", guessed={"R", "A", "G"})
+        out = render(state)
+        self.assertIn("Guessed: A G R", out)
+
+    def test_water_line_shows_count_max_and_symbols(self):
+        # SPEC section 18: numeric count/max AND symbols, text label present.
+        state = make_state("GARDEN", water=4, max_water=6)
+        out = render(state)
+        self.assertIn("Water: 4/6", out)
+        self.assertIn(ui.WATER_EMOJI * 4, out)
+
+    def test_weeds_line_shows_count_and_symbols(self):
+        # SPEC section 18: standalone count AND symbols.
+        state = make_state("GARDEN", weeds=2)
+        out = render(state)
+        self.assertIn("Weeds: 2", out)
+        self.assertIn(ui.WEED_EMOJI * 2, out)
+
+    def test_message_block_omitted_when_empty(self):
+        state = make_state("GARDEN", message="")
+        out = render(state)
+        # No trailing message; the render ends with the weeds line.
+        self.assertTrue(out.rstrip().endswith(render(state).splitlines()[-1]))
+        self.assertNotIn("\n\n\n", out)
+
+
+class GrowthStageTests(unittest.TestCase):
+    """Five distinct, observable growth stages."""
+
+    def test_five_stages_are_distinct_glyphs(self):
+        glyphs = {
+            "start": GROWTH_EMOJI["start"],
+            "progress": GROWTH_EMOJI["progress"],
+            "near_win": GROWTH_EMOJI["near_win"],
+            "win": GROWTH_EMOJI["win"],
+            "loss": GROWTH_EMOJI["loss"],
+        }
+        self.assertEqual(len(set(glyphs.values())), 5)
+
+    def test_start_stage_glyph(self):
+        state = make_state("GARDEN")  # nothing revealed
+        self.assertTrue(render(state).startswith(GROWTH_EMOJI["start"]))
+
+    def test_progress_stage_glyph(self):
+        state = make_state("GARDEN", guessed={"G"})  # some revealed
+        self.assertTrue(render(state).startswith(GROWTH_EMOJI["progress"]))
+
+    def test_near_win_stage_glyph(self):
+        # GARDEN distinct letters: G A R D E N (6). Reveal 5/6 = 0.833 >= 0.75.
+        state = make_state("GARDEN", guessed={"G", "A", "R", "D", "E"})
+        self.assertTrue(render(state).startswith(GROWTH_EMOJI["near_win"]))
+
+    def test_win_stage_glyph(self):
+        state = make_state("GARDEN", guessed=set("GARDEN"),
+                           game_over=True, won=True)
+        self.assertTrue(render(state).startswith(GROWTH_EMOJI["win"]))
+
+    def test_loss_stage_glyph(self):
+        state = make_state("GARDEN", guessed={"G"}, water=0,
+                           game_over=True, won=False)
+        self.assertTrue(render(state).startswith(GROWTH_EMOJI["loss"]))
+
+
+class EndScreenTests(unittest.TestCase):
+    def test_win_screen_names_word_and_is_cheerful(self):
+        state = make_state("GARDEN", guessed=set("GARDEN"),
+                           game_over=True, won=True)
+        out = render_win(state)
+        self.assertIn(WIN_HEADER, out)
+        self.assertIn("You guessed the word: GARDEN", out)
+        self.assertIn(WIN_THRIVING, out)
+        self.assertTrue(out.startswith(GROWTH_EMOJI["win"]))
+
+    def test_loss_screen_keeps_water_sense_and_names_word(self):
+        state = make_state("GARDEN", guessed={"G"}, water=0,
+                           game_over=True, won=False)
+        out = render_loss(state)
+        self.assertIn(LOSS_HEADER, out)
+        self.assertIn("ran out of water", out)
+        self.assertIn("The word was: GARDEN", out)
+        self.assertIn(LOSS_RETRY, out)
+        self.assertTrue(out.startswith(GROWTH_EMOJI["loss"]))
+
+
+class AsciiModeTests(unittest.TestCase):
+    def test_render_ascii_is_pure_ascii(self):
+        state = make_state("GARDEN", guessed={"G", "Z"}, water=5, weeds=1,
+                           message=MSG_CORRECT)
+        out = render(state, ascii_mode=True)
+        out.encode("ascii")  # raises if any non-ASCII slipped through
+        self.assertIn(GROWTH_ASCII["progress"], out)
+        self.assertIn("Water: 5/6", out)
+        self.assertIn("[", out)
+
+    def test_win_loss_screens_ascii_pure(self):
+        won = make_state("GARDEN", guessed=set("GARDEN"),
+                         game_over=True, won=True)
+        lost = make_state("GARDEN", guessed={"G"}, water=0,
+                          game_over=True, won=False)
+        render_win(won, ascii_mode=True).encode("ascii")
+        render_loss(lost, ascii_mode=True).encode("ascii")
+
+
+if __name__ == "__main__":
+    unittest.main()
