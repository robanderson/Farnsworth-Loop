+"""Tests for game state, validation, and rules."""
+
+import random
+import unittest
+
+from word_garden import game, words
+from word_garden.game import (
+    GameState,
+    MSG_ALREADY_OVER,
+    MSG_CORRECT,
+    MSG_EMPTY,
+    MSG_INCORRECT,
+    MSG_NOT_LETTER,
+    MSG_TOO_MANY,
+    apply_guess,
+    display_word,
+    is_lost,
+    is_won,
+    msg_repeated,
+    new_game,
+    validate_guess,
+)
+
+
+def make_state(secret="GARDEN", guessed=None, water=6, weeds=0, max_water=6):
+    """Construct a GameState directly with pinned values (no random factory)."""
+    return GameState(
+        secret_word=secret,
+        guessed_letters=set(guessed or ()),
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=max_water,
+    )
+
+
+class NewGameTests(unittest.TestCase):
+    def test_new_game_fields(self):
+        state = new_game("normal", rng=random.Random(7))
+        self.assertIn(state.secret_word, words.WORDS)
+        self.assertEqual(state.secret_word, state.secret_word.upper())
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(state.guessed_letters, set())
+        self.assertEqual(state.status_message, "")
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_water_per_difficulty(self):
+        for difficulty, water in (("easy", 8), ("normal", 6), ("hard", 4)):
+            state = new_game(difficulty, rng=random.Random(3))
+            self.assertEqual(state.remaining_water, water)
+            self.assertEqual(state.max_water, water)
+
+    def test_new_game_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            new_game("legendary")
+
+
+class ValidateGuessTests(unittest.TestCase):
+    def test_valid_lowercase_normalized(self):
+        # SPEC section 16 case 6: lowercase input is normalized.
+        letter, message = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(message, "")
+
+    def test_valid_trims_whitespace(self):
+        letter, message = validate_guess("  z  ")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(message, "")
+
+    def test_empty_input_rejected(self):
+        letter, message = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_EMPTY)
+
+    def test_whitespace_only_rejected(self):
+        letter, message = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_EMPTY)
+
+    def test_multiple_chars_rejected(self):
+        letter, message = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_TOO_MANY)
+
+    def test_number_rejected(self):
+        letter, message = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_NOT_LETTER)
+
+    def test_symbol_rejected(self):
+        letter, message = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_NOT_LETTER)
+
+    def test_validation_does_not_consult_state(self):
+        # validate_guess takes only text; repeated detection is elsewhere.
+        letter, message = validate_guess("A")
+        self.assertEqual((letter, message), ("A", ""))
+
+
+class ApplyGuessTests(unittest.TestCase):
+    def test_correct_guess_reveals_without_cost(self):
+        # SPEC section 16 case 1 + positive combined assertion.
+        state = make_state("GARDEN")
+        apply_guess(state, "A")
+        self.assertIn("A", state.guessed_letters)
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(state.status_message, MSG_CORRECT)
+        self.assertEqual(display_word(state), "_ A _ _ _ _")
+
+    def test_incorrect_guess_costs_one_water_and_one_weed(self):
+        # SPEC section 16 cases 2 + 3, asserted together positively.
+        state = make_state("GARDEN", water=6, weeds=0)
+        apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, 5)  # down by exactly 1
+        self.assertEqual(state.weed_count, 1)       # up by exactly 1
+        self.assertIn("Z", state.guessed_letters)   # recorded
+        self.assertEqual(state.status_message, MSG_INCORRECT)
+        self.assertFalse(state.game_over)
+
+    def test_repeated_guess_changes_only_message(self):
+        # SPEC section 16 case 4: repeated guess does not reduce water.
+        state = make_state("GARDEN", guessed={"Z"}, water=5, weeds=1)
+        apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, 5)
+        self.assertEqual(state.weed_count, 1)
+        self.assertEqual(state.guessed_letters, {"Z"})
+        self.assertEqual(state.status_message, msg_repeated("Z"))
+
+    def test_guess_after_game_over_is_noop(self):
+        state = make_state("AB", guessed={"A"})
+        apply_guess(state, "B")  # this win ends the game
+        self.assertTrue(state.game_over)
+        water_before = state.remaining_water
+        apply_guess(state, "C")
+        self.assertEqual(state.status_message, MSG_ALREADY_OVER)
+        self.assertEqual(state.remaining_water, water_before)
+        self.assertNotIn("C", state.guessed_letters)
+
+    def test_winning_guess_sets_terminal_message_and_flags(self):
+        # Tip 1: terminal message overwrites the mid-game message.
+        state = make_state("GO", guessed={"G"})
+        apply_guess(state, "O")
+        self.assertTrue(state.won)
+        self.assertTrue(state.game_over)
+        self.assertNotEqual(state.status_message, MSG_CORRECT)
+        self.assertIn("GO", state.status_message)
+        self.assertIn("guessed the word", state.status_message)
+
+    def test_losing_guess_sets_terminal_message_and_flags(self):
+        # One water left, wrong guess drops to zero -> loss.
+        state = make_state("GARDEN", water=1, weeds=5)
+        apply_guess(state, "Z")
+        self.assertFalse(state.won)
+        self.assertTrue(state.game_over)
+        self.assertEqual(state.remaining_water, 0)
+        self.assertNotEqual(state.status_message, MSG_INCORRECT)
+        self.assertIn("ran out of water", state.status_message)
+        self.assertIn("GARDEN", state.status_message)
+
+
+class DisplayWordTests(unittest.TestCase):
+    def test_masks_unguessed_letters(self):
+        # SPEC section 16 case 9.
+        state = make_state("GARDEN", guessed={"G", "R", "E"})
+        self.assertEqual(display_word(state), "G _ R _ E _")
+
+    def test_no_guesses_all_masked(self):
+        state = make_state("GARDEN")
+        self.assertEqual(display_word(state), "_ _ _ _ _ _")
+
+
+class PredicateTests(unittest.TestCase):
+    """Each predicate exercised DIRECTLY on terminal/boundary states."""
+
+    def test_is_won_true_when_all_revealed(self):
+        state = make_state("GARDEN", guessed=set("GARDEN"))
+        self.assertTrue(is_won(state))
+
+    def test_is_won_false_when_partial(self):
+        state = make_state("GARDEN", guessed={"G", "A"})
+        self.assertFalse(is_won(state))
+
+    def test_is_lost_true_at_zero_water_not_won(self):
+        # SPEC section 16 case 8.
+        state = make_state("GARDEN", guessed={"G"}, water=0)
+        self.assertTrue(is_lost(state))
+
+    def test_is_lost_false_when_water_remains(self):
+        state = make_state("GARDEN", guessed={"G"}, water=3)
+        self.assertFalse(is_lost(state))
+
+    def test_is_lost_false_when_won_at_zero_water(self):
+        # Boundary: fully revealed at exactly zero water is a WIN, not a
+        # loss. is_lost must return False on its own, with no caller
+        # checking is_won first (tip 10).
+        state = make_state("GARDEN", guessed=set("GARDEN"), water=0)
+        self.assertTrue(is_won(state))
+        self.assertFalse(is_lost(state))
+
+
+if __name__ == "__main__":
+    unittest.main()
