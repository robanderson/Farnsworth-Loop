+"""Core game state and rules for Word Garden.
+
+This module performs no terminal I/O: it never reads stdin or writes
+stdout. All logic is fully testable without a terminal. Randomness is
+injected through :func:`word_garden.words.select_word`.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+import random
+
+from . import words
+
+# --- User-facing message strings (defined once, imported everywhere) -------
+
+MSG_CORRECT = "Good guess! The garden grows."
+MSG_INCORRECT = "No match. A weed appears."
+
+
+def msg_repeated(letter: str) -> str:
+    """Message shown when ``letter`` was already guessed."""
+    return f"You already guessed {letter}. Try another letter."
+
+
+MSG_ALREADY_OVER = "The game is over. Start a new garden to play again."
+
+# Validation messages (SPEC.md sections 6.2 and 14).
+MSG_EMPTY = "Please enter a single letter."
+MSG_TOO_MANY = "Please enter a single letter."
+MSG_NOT_LETTER = "That is not a letter."
+
+
+@dataclass
+class GameState:
+    """Mutable state for a single Word Garden session (SPEC.md section 12)."""
+
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng: random.Random | None = None) -> GameState:
+    """Create a fresh :class:`GameState` for ``difficulty``.
+
+    Picks the word via :func:`words.select_word`, uppercases it, fills
+    water to the difficulty maximum, and zeroes the weed count. Raises
+    ``ValueError`` for an unknown difficulty.
+    """
+    secret_word = words.select_word(difficulty, rng=rng).upper()
+    water = words.water_for(difficulty)
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[str | None, str]:
+    """Validate raw guess input.
+
+    Returns ``(letter, "")`` for valid input — trimmed, uppercased, and
+    exactly one alphabetic character — or ``(None, message)`` with a
+    specific, helpful message (SPEC.md section 14). Validation does NOT
+    consult game state; repeated-guess detection belongs to
+    :func:`apply_guess`.
+    """
+    text = (input_text or "").strip()
+    if not text:
+        return None, MSG_EMPTY
+    if len(text) > 1:
+        return None, MSG_TOO_MANY
+    if not text.isalpha():
+        return None, MSG_NOT_LETTER
+    return text.upper(), ""
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word, space-separated, e.g. ``G _ R _ E _``."""
+    return " ".join(
+        letter if letter in state.guessed_letters else "_"
+        for letter in state.secret_word
+    )
+
+
+def is_won(state: GameState) -> bool:
+    """Return True if every distinct letter of the secret word is guessed.
+
+    Correct for every reachable state on its own — it does not depend on
+    a caller checking anything first.
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Return True if water is exhausted before the word is fully revealed.
+
+    A standalone predicate: it includes its own not-won guard, so it
+    returns the correct answer even for a state where every letter is
+    revealed at exactly zero water (that is a win, not a loss), and even
+    when called directly rather than after :func:`is_won`.
+    """
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply one already-validated uppercase ``letter`` to ``state``.
+
+    Implements SPEC.md sections 6.3–6.5. Mutates and returns ``state``.
+    Guessing after ``game_over`` is a no-op apart from the message. The
+    end-of-game message overwrites the turn message when the guess ends
+    the game.
+    """
+    if state.game_over:
+        state.status_message = MSG_ALREADY_OVER
+        return state
+
+    if letter in state.guessed_letters:
+        # Repeated guess: nothing changes but the message.
+        state.status_message = msg_repeated(letter)
+        return state
+
+    state.guessed_letters.add(letter)
+
+    if letter in state.secret_word:
+        # Correct guess: reveal, no water/weed change.
+        state.status_message = MSG_CORRECT
+    else:
+        # Incorrect guess: costs one water, grows one weed.
+        state.remaining_water -= 1
+        state.weed_count += 1
+        state.status_message = MSG_INCORRECT
+
+    # Resolve end-of-game state. Win takes precedence over loss when the
+    # final letter is revealed at zero water.
+    if is_won(state):
+        state.won = True
+        state.game_over = True
+        state.status_message = _win_message(state)
+    elif is_lost(state):
+        state.won = False
+        state.game_over = True
+        state.status_message = _loss_message(state)
+
+    return state
+
+
+def _win_message(state: GameState) -> str:
+    """Terminal status line for a win (names the word)."""
+    return f"You guessed the word: {state.secret_word}"
+
+
+def _loss_message(state: GameState) -> str:
+    """Terminal status line for a loss (keeps the out-of-water sense)."""
+    return f"The garden ran out of water. The word was: {state.secret_word}"
