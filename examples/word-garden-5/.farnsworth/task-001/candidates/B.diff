+"""End-to-end tests for the CLI entry point and game loop."""
+
+import unittest
+
+from word_garden import game, main, words
+from word_garden.ui import (
+    LOSS_HEADER,
+    LOSS_RETRY,
+    WIN_HEADER,
+    WIN_THRIVING,
+)
+
+
+class ScriptedInput:
+    """An input_fn that returns queued lines, then raises EOFError."""
+
+    def __init__(self, lines):
+        self._lines = list(lines)
+
+    def __call__(self, prompt=""):
+        if not self._lines:
+            raise EOFError
+        return self._lines.pop(0)
+
+
+class Recorder:
+    """An output_fn that records everything printed."""
+
+    def __init__(self):
+        self.lines = []
+
+    def __call__(self, *args):
+        self.lines.append(" ".join(str(a) for a in args))
+
+    @property
+    def text(self):
+        return "\n".join(self.lines)
+
+
+def pin_word(word):
+    """Monkeypatch words.select_word to always return ``word``.
+
+    Returns a restore callable for use in try/finally.
+    """
+    saved = words.select_word
+    words.select_word = lambda difficulty="normal", rng=None: word
+    return saved
+
+
+class WinSessionTests(unittest.TestCase):
+    def test_full_win_session_shows_win_screen(self):
+        saved = pin_word("GO")
+        try:
+            inp = ScriptedInput(["g", "o"])
+            out = Recorder()
+            code = main.main(["--difficulty", "normal"],
+                             input_fn=inp, output_fn=out)
+        finally:
+            words.select_word = saved
+        self.assertEqual(code, 0)
+        # The win artifact actually appeared (forced scenario, not exit-0 only).
+        self.assertIn(WIN_HEADER, out.text)
+        self.assertIn("You guessed the word: GO", out.text)
+        self.assertIn(WIN_THRIVING, out.text)
+        self.assertNotIn(LOSS_HEADER, out.text)
+
+
+class LossSessionTests(unittest.TestCase):
+    def test_full_loss_session_shows_loss_screen(self):
+        # Normal water = 6; six wrong guesses exhaust it. Use letters not
+        # in "GO": B C D F H J each cost one water.
+        saved = pin_word("GO")
+        try:
+            inp = ScriptedInput(["b", "c", "d", "f", "h", "j"])
+            out = Recorder()
+            code = main.main(["--difficulty", "normal"],
+                             input_fn=inp, output_fn=out)
+        finally:
+            words.select_word = saved
+        self.assertEqual(code, 0)
+        self.assertIn(LOSS_HEADER, out.text)
+        self.assertIn("The word was: GO", out.text)
+        self.assertIn(LOSS_RETRY, out.text)
+        self.assertNotIn(WIN_HEADER, out.text)
+
+
+class NoCostPathTests(unittest.TestCase):
+    def test_invalid_input_costs_nothing(self):
+        # Invalid inputs interleaved must not consume water; win still
+        # reached with exactly the correct letters.
+        saved = pin_word("GO")
+        try:
+            inp = ScriptedInput(["", "7", "!!", "apple", "g", "o"])
+            out = Recorder()
+            code = main.main([], input_fn=inp, output_fn=out)
+        finally:
+            words.select_word = saved
+        self.assertEqual(code, 0)
+        # Reached a win despite the invalid inputs.
+        self.assertIn(WIN_HEADER, out.text)
+        # A validation message appeared for the invalid input.
+        self.assertIn(game.MSG_NOT_LETTER, out.text)
+
+    def test_repeated_wrong_guess_costs_nothing(self):
+        # Guess "B" (wrong) once -> water 5. Repeat "B" -> still 5. Then
+        # win. We assert the loss screen never appears (water was not
+        # double-charged) and the win is reached.
+        saved = pin_word("GO")
+        try:
+            inp = ScriptedInput(["b", "b", "g", "o"])
+            out = Recorder()
+            code = main.main([], input_fn=inp, output_fn=out)
+        finally:
+            words.select_word = saved
+        self.assertEqual(code, 0)
+        self.assertIn(WIN_HEADER, out.text)
+        self.assertIn("already guessed B", out.text)
+
+
+class AsciiSessionTests(unittest.TestCase):
+    def test_whole_win_session_is_ascii(self):
+        saved = pin_word("GO")
+        try:
+            inp = ScriptedInput(["b", "g", "o"])  # one wrong, then win
+            out = Recorder()
+            code = main.main(["--ascii"], input_fn=inp, output_fn=out)
+        finally:
+            words.select_word = saved
+        self.assertEqual(code, 0)
+        # The ENTIRE session output is ASCII.
+        out.text.encode("ascii")
+        self.assertIn(WIN_HEADER, out.text)
+
+    def test_whole_loss_session_is_ascii(self):
+        saved = pin_word("GO")
+        try:
+            inp = ScriptedInput(["b", "c", "d", "f", "h", "j"])
+            out = Recorder()
+            code = main.main(["--ascii"], input_fn=inp, output_fn=out)
+        finally:
+            words.select_word = saved
+        self.assertEqual(code, 0)
+        out.text.encode("ascii")
+        self.assertIn(LOSS_HEADER, out.text)
+
+
+class ExitPathTests(unittest.TestCase):
+    def test_eof_exits_zero_with_goodbye(self):
+        inp = ScriptedInput([])  # immediate EOFError
+        out = Recorder()
+        code = main.main([], input_fn=inp, output_fn=out)
+        self.assertEqual(code, 0)
+        self.assertIn(main.GOODBYE, out.text)
+
+    def test_eof_ascii_exits_zero_with_goodbye(self):
+        inp = ScriptedInput([])
+        out = Recorder()
+        code = main.main(["--ascii"], input_fn=inp, output_fn=out)
+        self.assertEqual(code, 0)
+        self.assertIn(main.GOODBYE, out.text)
+        out.text.encode("ascii")
+
+    def test_keyboard_interrupt_exits_zero_with_goodbye(self):
+        def interrupting_input(prompt=""):
+            raise KeyboardInterrupt
+
+        out = Recorder()
+        code = main.main([], input_fn=interrupting_input, output_fn=out)
+        self.assertEqual(code, 0)
+        self.assertIn(main.GOODBYE, out.text)
+
+
+class CliArgTests(unittest.TestCase):
+    def test_help_exits_zero(self):
+        with self.assertRaises(SystemExit) as ctx:
+            main.main(["--help"], input_fn=lambda p="": "", output_fn=lambda *a: None)
+        self.assertEqual(ctx.exception.code, 0)
+
+    def test_bogus_flag_exits_two(self):
+        with self.assertRaises(SystemExit) as ctx:
+            main.main(["--bogus"], input_fn=lambda p="": "", output_fn=lambda *a: None)
+        self.assertEqual(ctx.exception.code, 2)
+
+    def test_bad_difficulty_exits_two(self):
+        with self.assertRaises(SystemExit) as ctx:
+            main.main(["--difficulty", "extreme"],
+                      input_fn=lambda p="": "", output_fn=lambda *a: None)
+        self.assertEqual(ctx.exception.code, 2)
+
+
+if __name__ == "__main__":
+    unittest.main()
