+"""Tests for word_garden.game — engine, state, predicates.
+
+SPEC section 16 items 1–9 are all covered here.
+"""
+
+import unittest
+
+from word_garden.game import (
+    GameState,
+    apply_guess,
+    display_word,
+    is_lost,
+    is_won,
+    new_game,
+    validate_guess,
+    MSG_CORRECT_GUESS,
+    MSG_WRONG_GUESS,
+    MSG_ALREADY_GUESSED,
+    MSG_GAME_OVER_ATTEMPT,
+    MSG_INVALID_EMPTY,
+    MSG_INVALID_MULTIPLE,
+    MSG_INVALID_NOT_ALPHA,
+    MSG_WIN_BODY,
+    MSG_LOSS_BODY,
+)
+
+
+def _state(secret="GARDEN", water=6, guessed=None, weeds=0):
+    """Build a GameState directly with pinned values (tip #8)."""
+    return GameState(
+        secret_word=secret,
+        guessed_letters=set(guessed) if guessed else set(),
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=water,
+    )
+
+
+class TestDisplayWord(unittest.TestCase):
+    """SPEC section 16 item 9: displayed word masks unguessed letters."""
+
+    def test_fully_masked(self):
+        state = _state(secret="GARDEN")
+        self.assertEqual(display_word(state), "_ _ _ _ _ _")
+
+    def test_partial_reveal(self):
+        state = _state(secret="GARDEN", guessed=["G", "R"])
+        self.assertEqual(display_word(state), "G _ R _ _ _")
+
+    def test_full_reveal(self):
+        state = _state(secret="GARDEN", guessed=list("GARDEN"))
+        self.assertEqual(display_word(state), "G A R D E N")
+
+    def test_single_letter_word(self):
+        state = _state(secret="A", guessed=["A"])
+        self.assertEqual(display_word(state), "A")
+
+
+class TestIsWon(unittest.TestCase):
+    """SPEC section 16 item 7: game detects win."""
+
+    def test_not_won_on_start(self):
+        self.assertFalse(is_won(_state()))
+
+    def test_not_won_partial(self):
+        self.assertFalse(is_won(_state(guessed=["G", "A"])))
+
+    def test_won_all_letters(self):
+        state = _state(secret="GARDEN", guessed=list("GARDEN"))
+        self.assertTrue(is_won(state))
+
+    def test_won_with_duplicate_letters(self):
+        # SEEDLING has repeated E
+        state = _state(secret="SEEDLING", guessed=list("SEEDLING"))
+        self.assertTrue(is_won(state))
+
+    def test_predicate_directly_on_won_state(self):
+        """Predicate must work on a terminal won state (tip #10)."""
+        state = _state(secret="FLOWER", guessed=list("FLOWER"))
+        state.game_over = True
+        state.won = True
+        self.assertTrue(is_won(state))
+
+
+class TestIsLost(unittest.TestCase):
+    """SPEC section 16 item 8: game detects loss."""
+
+    def test_not_lost_on_start(self):
+        self.assertFalse(is_lost(_state()))
+
+    def test_not_lost_with_water(self):
+        self.assertFalse(is_lost(_state(water=1)))
+
+    def test_lost_when_water_zero(self):
+        state = _state(water=0)
+        self.assertTrue(is_lost(state))
+
+    def test_win_takes_priority_over_loss(self):
+        """Win beats loss — is_lost must return False even if water == 0 when
+        the word is fully guessed (tip #10 standalone-predicate contract)."""
+        state = _state(secret="A", water=0, guessed=["A"])
+        self.assertTrue(is_won(state))
+        self.assertFalse(is_lost(state))
+
+    def test_predicate_directly_on_lost_state(self):
+        """Predicate must work on a terminal loss state (tip #10)."""
+        state = _state(water=0)
+        state.game_over = True
+        state.won = False
+        self.assertTrue(is_lost(state))
+
+
+class TestValidateGuess(unittest.TestCase):
+    """SPEC section 16 items 5–6: invalid input is rejected; lowercase
+    normalised."""
+
+    def test_valid_lowercase(self):
+        letter, err = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(err, "")
+
+    def test_valid_uppercase(self):
+        letter, err = validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(err, "")
+
+    def test_valid_with_spaces(self):
+        letter, err = validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(err, "")
+
+    def test_empty_input(self):
+        letter, err = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(err, MSG_INVALID_EMPTY)
+
+    def test_whitespace_only(self):
+        letter, err = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertEqual(err, MSG_INVALID_EMPTY)
+
+    def test_multiple_chars(self):
+        letter, err = validate_guess("ab")
+        self.assertIsNone(letter)
+        self.assertEqual(err, MSG_INVALID_MULTIPLE)
+
+    def test_number_input(self):
+        letter, err = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(err, MSG_INVALID_NOT_ALPHA)
+
+    def test_symbol_input(self):
+        letter, err = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(err, MSG_INVALID_NOT_ALPHA)
+
+    def test_word_input(self):
+        letter, err = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertEqual(err, MSG_INVALID_MULTIPLE)
+
+    def test_does_not_consult_state(self):
+        """validate_guess must not accept game state as a parameter."""
+        import inspect
+        sig = inspect.signature(validate_guess)
+        self.assertEqual(list(sig.parameters.keys()), ["input_text"])
+
+
+class TestApplyGuess(unittest.TestCase):
+    """Core apply_guess behaviour."""
+
+    def test_correct_guess_reveals_letter(self):
+        """SPEC item 1: correct guess reveals matching letters."""
+        state = _state(secret="GARDEN")
+        apply_guess(state, "G")
+        self.assertIn("G", state.guessed_letters)
+        self.assertEqual(display_word(state), "G _ _ _ _ _")
+
+    def test_correct_guess_message(self):
+        state = _state(secret="GARDEN")
+        apply_guess(state, "G")
+        self.assertEqual(state.status_message, MSG_CORRECT_GUESS)
+
+    def test_correct_guess_no_water_change(self):
+        state = _state(secret="GARDEN", water=6)
+        apply_guess(state, "G")
+        self.assertEqual(state.remaining_water, 6)
+
+    def test_correct_guess_no_weed_change(self):
+        state = _state(secret="GARDEN", water=6, weeds=0)
+        apply_guess(state, "G")
+        self.assertEqual(state.weed_count, 0)
+
+    def test_wrong_guess_costs_water(self):
+        """SPEC item 2: incorrect guess reduces water by one."""
+        state = _state(secret="GARDEN", water=6)
+        apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, 5)
+
+    def test_wrong_guess_adds_weed(self):
+        """SPEC item 3: incorrect guess increases weed count by one."""
+        state = _state(secret="GARDEN", weeds=0)
+        apply_guess(state, "Z")
+        self.assertEqual(state.weed_count, 1)
+
+    def test_wrong_guess_records_letter(self):
+        state = _state(secret="GARDEN")
+        apply_guess(state, "Z")
+        self.assertIn("Z", state.guessed_letters)
+
+    def test_wrong_guess_message(self):
+        state = _state(secret="GARDEN")
+        apply_guess(state, "Z")
+        self.assertEqual(state.status_message, MSG_WRONG_GUESS)
+
+    def test_repeated_guess_no_water_change(self):
+        """SPEC item 4: repeated guesses do not reduce water."""
+        state = _state(secret="GARDEN", water=6, guessed=["Z"])
+        apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, 6)
+
+    def test_repeated_guess_no_weed_change(self):
+        state = _state(secret="GARDEN", weeds=2, guessed=["Z"])
+        apply_guess(state, "Z")
+        self.assertEqual(state.weed_count, 2)
+
+    def test_repeated_guess_message(self):
+        state = _state(secret="GARDEN", guessed=["A"])
+        apply_guess(state, "A")
+        self.assertEqual(
+            state.status_message,
+            MSG_ALREADY_GUESSED.format(letter="A"),
+        )
+
+    def test_win_sets_game_over_and_won(self):
+        # All letters except N already guessed
+        state = _state(secret="GARDEN", guessed=list("GARDE"))
+        apply_guess(state, "N")
+        self.assertTrue(state.game_over)
+        self.assertTrue(state.won)
+
+    def test_win_sets_terminal_message(self):
+        """Tip #1: terminal message must be set on game-over, not just flags."""
+        state = _state(secret="GARDEN", guessed=list("GARDE"))
+        apply_guess(state, "N")
+        expected = MSG_WIN_BODY.format(word="GARDEN")
+        self.assertEqual(state.status_message, expected)
+
+    def test_loss_sets_game_over_not_won(self):
+        state = _state(secret="GARDEN", water=1)
+        apply_guess(state, "Z")
+        self.assertTrue(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_loss_sets_terminal_message(self):
+        """Tip #1: terminal message must be set on game-over."""
+        state = _state(secret="GARDEN", water=1)
+        apply_guess(state, "Z")
+        expected = MSG_LOSS_BODY.format(word="GARDEN")
+        self.assertEqual(state.status_message, expected)
+
+    def test_guessing_after_game_over_is_noop(self):
+        state = _state(secret="GARDEN", water=1)
+        apply_guess(state, "Z")  # triggers loss
+        water_before = state.remaining_water
+        weeds_before = state.weed_count
+        guessed_before = set(state.guessed_letters)
+        apply_guess(state, "G")
+        self.assertEqual(state.remaining_water, water_before)
+        self.assertEqual(state.weed_count, weeds_before)
+        self.assertEqual(state.guessed_letters, guessed_before)
+        self.assertEqual(state.status_message, MSG_GAME_OVER_ATTEMPT)
+
+    def test_apply_guess_invalid_letter_raises(self):
+        """apply_guess must raise on contract violation."""
+        state = _state()
+        with self.assertRaises(ValueError):
+            apply_guess(state, "a")  # lowercase
+        with self.assertRaises(ValueError):
+            apply_guess(state, "")
+        with self.assertRaises(ValueError):
+            apply_guess(state, "AB")
+
+
+class TestNewGame(unittest.TestCase):
+    def test_new_game_has_zero_weeds(self):
+        import random
+        rng = random.Random(0)
+        state = new_game(rng=rng)
+        self.assertEqual(state.weed_count, 0)
+
+    def test_new_game_water_matches_difficulty(self):
+        from word_garden.words import water_for
+        import random
+        for diff in ("easy", "normal", "hard"):
+            rng = random.Random(0)
+            state = new_game(difficulty=diff, rng=rng)
+            self.assertEqual(state.remaining_water, water_for(diff))
+            self.assertEqual(state.max_water, water_for(diff))
+
+    def test_new_game_word_uppercase(self):
+        import random
+        state = new_game(rng=random.Random(42))
+        self.assertEqual(state.secret_word, state.secret_word.upper())
+
+    def test_new_game_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            new_game(difficulty="insane")
+
+
+if __name__ == "__main__":
+    unittest.main()
