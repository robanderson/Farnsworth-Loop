+"""End-to-end tests for word_garden.main — full game sessions via injection."""
+
+import io
+import unittest
+
+import word_garden.words as words_mod
+from word_garden.main import main
+from word_garden.game import (
+    MSG_WIN_BODY,
+    MSG_LOSS_BODY,
+    MSG_ALREADY_GUESSED,
+    MSG_CORRECT_GUESS,
+    MSG_WRONG_GUESS,
+    MSG_INVALID_EMPTY,
+    MSG_INVALID_NOT_ALPHA,
+)
+
+
+def _run(inputs: list[str], argv: list[str] | None = None) -> tuple[int, str]:
+    """Run main() with scripted input, capture all output, return (rc, output).
+
+    argv defaults to [] (not None) so argparse does not fall back to sys.argv
+    (which contains the test-runner arguments and would cause parse failures).
+    """
+    if argv is None:
+        argv = []
+    it = iter(inputs)
+    captured: list[str] = []
+
+    def fake_input(_prompt=""):
+        try:
+            return next(it)
+        except StopIteration:
+            raise EOFError
+
+    def fake_print(*args, **kwargs):
+        sep = kwargs.get("sep", " ")
+        end = kwargs.get("end", "\n")
+        captured.append(sep.join(str(a) for a in args) + end)
+
+    rc = main(argv=argv, input_fn=fake_input, output_fn=fake_print)
+    return rc, "".join(captured)
+
+
+def _force_word(word: str):
+    """Context manager: monkey-patch select_word in word_garden.game to always
+    return *word*.  We patch the name in game's namespace because game.py
+    imports the function directly (``from .words import select_word``).
+    """
+    import contextlib
+    import word_garden.game as game_mod
+
+    @contextlib.contextmanager
+    def _ctx():
+        original = game_mod.select_word
+        try:
+            game_mod.select_word = lambda difficulty="normal", rng=None: word
+            yield
+        finally:
+            game_mod.select_word = original
+
+    return _ctx()
+
+
+class TestEOFAndInterrupt(unittest.TestCase):
+    def test_eof_exits_0(self):
+        """printf '' | python3 -m word_garden should exit 0 with goodbye."""
+        with _force_word("GARDEN"):
+            rc, out = _run([], argv=[])
+        self.assertEqual(rc, 0)
+        self.assertIn("Goodbye", out)
+
+    def test_eof_ascii_exits_0(self):
+        with _force_word("GARDEN"):
+            rc, out = _run([], argv=["--ascii"])
+        self.assertEqual(rc, 0)
+        self.assertIn("Goodbye", out)
+
+
+class TestHelpAndBadArgs(unittest.TestCase):
+    def test_help_exits_0(self):
+        """--help must exit 0 (not swallowed by try/except)."""
+        with self.assertRaises(SystemExit) as cm:
+            main(argv=["--help"], input_fn=lambda _="": "", output_fn=lambda *a, **k: None)
+        self.assertEqual(cm.exception.code, 0)
+
+    def test_bogus_flag_exits_2(self):
+        """Unknown flag must exit 2."""
+        with self.assertRaises(SystemExit) as cm:
+            main(argv=["--bogus"], input_fn=lambda _="": "", output_fn=lambda *a, **k: None)
+        self.assertEqual(cm.exception.code, 2)
+
+
+class TestWinSession(unittest.TestCase):
+    """End-to-end win: force a known word, play all correct letters.
+
+    Tip #3: must assert the win artifact actually appeared.
+    """
+
+    def test_win_session_exits_0_with_win_screen(self):
+        # PYTHON has letters P,Y,T,H,O,N — all unique
+        with _force_word("PYTHON"):
+            rc, out = _run(["P", "Y", "T", "H", "O", "N"], argv=["--difficulty", "normal"])
+        self.assertEqual(rc, 0)
+        expected_fragment = "You guessed the word: PYTHON"
+        self.assertIn(expected_fragment, out)
+        self.assertIn("thriving", out)
+
+    def test_win_session_shows_bloom_glyph(self):
+        with _force_word("PYTHON"):
+            _rc, out = _run(["P", "Y", "T", "H", "O", "N"])
+        self.assertIn("🌻", out)
+
+
+class TestLossSession(unittest.TestCase):
+    """End-to-end loss: exhaust water on wrong guesses."""
+
+    def test_loss_session_exits_0_with_loss_screen(self):
+        # PYTHON on normal = 6 water; guess 6 wrong letters
+        with _force_word("PYTHON"):
+            rc, out = _run(["A", "B", "C", "D", "E", "F"])
+        self.assertEqual(rc, 0)
+        expected_fragment = "The word was: PYTHON"
+        self.assertIn(expected_fragment, out)
+        self.assertIn("ran out of water", out)
+
+    def test_loss_session_shows_loss_glyph(self):
+        with _force_word("PYTHON"):
+            _rc, out = _run(["A", "B", "C", "D", "E", "F"])
+        self.assertIn("🥀", out)
+
+
+class TestNoCostPaths(unittest.TestCase):
+    """Invalid input and repeated wrong guess cost nothing."""
+
+    def test_invalid_input_does_not_cost_water(self):
+        """Give invalid input then EOF; water must not decrease."""
+        with _force_word("GARDEN"):
+            _rc, out = _run(["7"])  # invalid, then EOF
+        # Water should not decrease — 6/6 should still appear somewhere
+        self.assertIn("6/6", out)
+
+    def test_repeated_wrong_guess_costs_nothing_extra(self):
+        """Guess Z (wrong), then Z again — water drops only once."""
+        with _force_word("GARDEN"):
+            _rc, out = _run(["Z", "Z"])  # Z wrong, Z repeated, then EOF
+        # Water line should show 5/6, not 4/6
+        self.assertIn("5/6", out)
+        self.assertNotIn("4/6", out)
+
+    def test_invalid_empty_message_shown(self):
+        with _force_word("GARDEN"):
+            _rc, out = _run([""])  # empty → message → EOF
+        self.assertIn(MSG_INVALID_EMPTY, out)
+
+    def test_invalid_non_alpha_message_shown(self):
+        with _force_word("GARDEN"):
+            _rc, out = _run(["!"])
+        self.assertIn(MSG_INVALID_NOT_ALPHA, out)
+
+    def test_repeated_guess_message_shown(self):
+        with _force_word("GARDEN"):
+            _rc, out = _run(["Z", "Z"])
+        self.assertIn(MSG_ALREADY_GUESSED.format(letter="Z"), out)
+
+
+class TestAsciiSession(unittest.TestCase):
+    """Whole-session ASCII purity under --ascii."""
+
+    def _is_all_ascii(self, text: str) -> bool:
+        try:
+            text.encode("ascii")
+            return True
+        except UnicodeEncodeError:
+            return False
+
+    def test_eof_session_is_ascii(self):
+        with _force_word("GARDEN"):
+            _rc, out = _run([], argv=["--ascii"])
+        self.assertTrue(self._is_all_ascii(out), f"Non-ASCII in --ascii session:\n{out!r}")
+
+    def test_win_session_is_ascii(self):
+        with _force_word("PYTHON"):
+            _rc, out = _run(["P", "Y", "T", "H", "O", "N"], argv=["--ascii"])
+        self.assertTrue(self._is_all_ascii(out), f"Non-ASCII in --ascii win:\n{out!r}")
+
+    def test_loss_session_is_ascii(self):
+        with _force_word("PYTHON"):
+            _rc, out = _run(["A", "B", "C", "D", "E", "F"], argv=["--ascii"])
+        self.assertTrue(self._is_all_ascii(out), f"Non-ASCII in --ascii loss:\n{out!r}")
+
+
+class TestDifficultyOption(unittest.TestCase):
+    def test_easy_difficulty_sets_water_8(self):
+        with _force_word("MEADOW"):
+            _rc, out = _run([], argv=["--difficulty", "easy"])
+        self.assertIn("8/8", out)
+
+    def test_hard_difficulty_sets_water_4(self):
+        with _force_word("TERMINAL"):
+            _rc, out = _run([], argv=["--difficulty", "hard"])
+        self.assertIn("4/4", out)
+
+
+if __name__ == "__main__":
+    unittest.main()
