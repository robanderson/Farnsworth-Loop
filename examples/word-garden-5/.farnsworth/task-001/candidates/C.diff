+"""Entry point for Word Garden — the only module that touches stdin/stdout."""
+
+from __future__ import annotations
+
+import argparse
+import sys
+from typing import Callable
+
+from .game import new_game, validate_guess, apply_guess
+from .ui import render
+
+
+def main(
+    argv: list[str] | None = None,
+    input_fn: Callable[..., str] = input,
+    output_fn: Callable[..., None] = print,
+) -> int:
+    """Run one complete game session.
+
+    Parameters
+    ----------
+    argv:
+        Argument list (defaults to sys.argv[1:] when None).
+    input_fn:
+        Injectable replacement for ``input``.
+    output_fn:
+        Injectable replacement for ``print``.
+
+    Returns
+    -------
+    int
+        Exit code — always 0 for a normal exit (win, loss, EOF, interrupt).
+    """
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description="Word Garden — guess the hidden word before the garden runs out of water.",
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty (default: normal).",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        dest="ascii_mode",
+        help="Use ASCII fallback symbols instead of emoji.",
+    )
+
+    # Do NOT wrap in try/except SystemExit — --help must exit 0, bad args must
+    # exit 2 (per SPEC and code-tips entry 4).
+    args = parser.parse_args(argv)
+
+    try:
+        state = new_game(difficulty=args.difficulty)
+    except ValueError as exc:
+        output_fn(f"Error: {exc}")
+        return 1
+
+    ascii_mode: bool = args.ascii_mode
+
+    try:
+        while not state.game_over:
+            output_fn(render(state, ascii_mode=ascii_mode))
+            output_fn("")  # blank line before prompt
+
+            try:
+                raw = input_fn("Guess a letter: ")
+            except EOFError:
+                output_fn("\nGoodbye! Thanks for playing Word Garden.")
+                return 0
+
+            letter, err = validate_guess(raw)
+            if letter is None:
+                # Invalid input — do not mutate state; just show the message
+                state.status_message = err
+                continue
+
+            apply_guess(state, letter)
+
+        # Game is now over — show the final screen
+        output_fn(render(state, ascii_mode=ascii_mode))
+
+    except KeyboardInterrupt:
+        output_fn("\nGoodbye! Thanks for playing Word Garden.")
+        return 0
+
+    return 0
