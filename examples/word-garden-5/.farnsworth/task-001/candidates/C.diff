+"""Tests for word_garden.ui — rendering and growth stages."""
+
+import unittest
+
+from word_garden.game import GameState, apply_guess
+from word_garden.ui import render
+
+
+def _state(secret="GARDEN", water=6, guessed=None, weeds=0,
+           game_over=False, won=False, status_message=""):
+    """Build a GameState directly with pinned values (tip #8)."""
+    return GameState(
+        secret_word=secret,
+        guessed_letters=set(guessed) if guessed else set(),
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=water,
+        status_message=status_message,
+        game_over=game_over,
+        won=won,
+    )
+
+
+class TestRenderFields(unittest.TestCase):
+    """Verify that all required fields appear in the rendered output."""
+
+    def test_title_present(self):
+        out = render(_state())
+        self.assertIn("Word Garden", out)
+
+    def test_masked_word_present(self):
+        out = render(_state(secret="GARDEN"))
+        self.assertIn("_ _ _ _ _ _", out)
+
+    def test_partial_word_present(self):
+        out = render(_state(secret="GARDEN", guessed=["G", "R"]))
+        self.assertIn("G _ R _ _ _", out)
+
+    def test_guessed_letters_sorted(self):
+        out = render(_state(secret="GARDEN", guessed=["R", "A", "G"]))
+        self.assertIn("A G R", out)
+
+    def test_water_line_shows_count_and_max(self):
+        out = render(_state(water=4))
+        # Must show n/max per SPEC section 18
+        self.assertIn("4/4", out)
+
+    def test_water_line_shows_symbols(self):
+        out = render(_state(water=3))
+        self.assertIn("💧💧💧", out)
+
+    def test_weeds_line_shows_count(self):
+        out = render(_state(water=6, weeds=2))
+        # Must show standalone count
+        self.assertIn("2", out)
+
+    def test_weeds_line_shows_symbols(self):
+        out = render(_state(water=6, weeds=2))
+        self.assertIn("🌿🌿", out)
+
+    def test_status_message_included_when_set(self):
+        out = render(_state(status_message="Good guess! The garden grows."))
+        self.assertIn("Good guess! The garden grows.", out)
+
+    def test_status_message_omitted_when_empty(self):
+        out = render(_state(status_message=""))
+        # No trailing blank block — just check no spurious newlines at end
+        # (we simply verify no extra blank lines appear for a clean state)
+        lines = out.splitlines()
+        # Last non-empty line should be a weeds line
+        self.assertTrue(any("Weeds" in ln for ln in lines))
+
+    def test_water_after_wrong_guess(self):
+        state = _state(secret="GARDEN", water=6)
+        apply_guess(state, "Z")
+        out = render(state)
+        # Water should now be 5/6
+        self.assertIn("5/6", out)
+
+
+class TestGrowthStages(unittest.TestCase):
+    """Five distinct growth stages must be observable (SPEC section 10)."""
+
+    def test_stage_start_glyph(self):
+        """No letters revealed → 🌱"""
+        out = render(_state())
+        self.assertIn("🌱", out)
+
+    def test_stage_progress_glyph(self):
+        """Some letters revealed but < 2/3 → 🌿"""
+        # GARDEN has 6 distinct letters; 1/6 revealed = progress
+        out = render(_state(secret="GARDEN", guessed=["G"]))
+        self.assertIn("🌿", out)
+
+    def test_stage_near_win_glyph(self):
+        """≥ 2/3 of distinct letters revealed, not won → 🌷"""
+        # GARDEN: 6 distinct; need ≥4 revealed
+        out = render(_state(secret="GARDEN", guessed=["G", "A", "R", "D"]))
+        self.assertIn("🌷", out)
+
+    def test_stage_win_glyph(self):
+        """game_over AND won → 🌻"""
+        state = _state(secret="GARDEN", guessed=list("GARDEN"), game_over=True, won=True)
+        out = render(state)
+        self.assertIn("🌻", out)
+
+    def test_stage_loss_glyph(self):
+        """game_over AND not won → 🥀"""
+        state = _state(secret="GARDEN", water=0, game_over=True, won=False)
+        out = render(state)
+        self.assertIn("🥀", out)
+
+    def test_five_stages_are_distinct(self):
+        """Each stage must produce a different glyph — no two stages share a symbol."""
+        start  = render(_state())
+        prog   = render(_state(secret="GARDEN", guessed=["G"]))
+        near   = render(_state(secret="GARDEN", guessed=["G", "A", "R", "D"]))
+        win    = render(_state(secret="GARDEN", guessed=list("GARDEN"), game_over=True, won=True))
+        loss   = render(_state(secret="GARDEN", water=0, game_over=True, won=False))
+
+        # Extract the first line (title) of non-terminal renders or first line of terminal
+        def leading_glyph(s):
+            return s.splitlines()[0]
+
+        glyphs = {leading_glyph(start), leading_glyph(prog), leading_glyph(near),
+                  leading_glyph(win), leading_glyph(loss)}
+        self.assertEqual(len(glyphs), 5, f"Not five distinct stage glyphs: {glyphs}")
+
+
+class TestWinLossScreens(unittest.TestCase):
+    def test_win_screen_contains_word(self):
+        state = _state(secret="GARDEN", game_over=True, won=True)
+        out = render(state)
+        self.assertIn("GARDEN", out)
+        self.assertIn("Bloom!", out)
+        self.assertIn("thriving", out)
+
+    def test_loss_screen_contains_word(self):
+        state = _state(secret="GARDEN", water=0, game_over=True, won=False)
+        out = render(state)
+        self.assertIn("GARDEN", out)
+        self.assertIn("ran out of water", out)
+
+
+class TestAsciiMode(unittest.TestCase):
+    """--ascii output must be entirely ASCII (SPEC section 10)."""
+
+    def _is_all_ascii(self, text: str) -> bool:
+        try:
+            text.encode("ascii")
+            return True
+        except UnicodeEncodeError:
+            return False
+
+    def test_render_normal_state_ascii_only(self):
+        state = _state(secret="GARDEN", water=4, weeds=2)
+        out = render(state, ascii_mode=True)
+        self.assertTrue(self._is_all_ascii(out), f"Non-ASCII found:\n{out!r}")
+
+    def test_render_win_screen_ascii_only(self):
+        state = _state(secret="GARDEN", game_over=True, won=True)
+        out = render(state, ascii_mode=True)
+        self.assertTrue(self._is_all_ascii(out), f"Non-ASCII found:\n{out!r}")
+
+    def test_render_loss_screen_ascii_only(self):
+        state = _state(secret="GARDEN", water=0, game_over=True, won=False)
+        out = render(state, ascii_mode=True)
+        self.assertTrue(self._is_all_ascii(out), f"Non-ASCII found:\n{out!r}")
+
+    def test_each_growth_stage_ascii_only(self):
+        states = [
+            _state(),
+            _state(secret="GARDEN", guessed=["G"]),
+            _state(secret="GARDEN", guessed=["G", "A", "R", "D"]),
+            _state(secret="GARDEN", game_over=True, won=True),
+            _state(secret="GARDEN", water=0, game_over=True, won=False),
+        ]
+        for s in states:
+            out = render(s, ascii_mode=True)
+            self.assertTrue(
+                self._is_all_ascii(out),
+                f"Non-ASCII in ascii_mode for state {s!r}:\n{out!r}",
+            )
+
+
+if __name__ == "__main__":
+    unittest.main()
