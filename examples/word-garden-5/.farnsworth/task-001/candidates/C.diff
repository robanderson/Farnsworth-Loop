+"""Core game logic for Word Garden — no I/O, fully testable."""
+
+from __future__ import annotations
+
+import random as _random
+from dataclasses import dataclass, field
+
+from .words import select_word, water_for
+
+# ---------------------------------------------------------------------------
+# User-facing message constants (SPEC sections 6.3–6.7, 14).
+# Import these in tests; never re-type the literal text.
+# ---------------------------------------------------------------------------
+
+MSG_CORRECT_GUESS: str = "Good guess! The garden grows."
+MSG_WRONG_GUESS: str = "No match. A weed appears."
+MSG_ALREADY_GUESSED: str = "You already guessed {letter}. Try another letter."
+MSG_GAME_OVER_ATTEMPT: str = "The game is already over."
+
+# Win / loss terminal messages
+MSG_WIN_TITLE: str = "Bloom!"
+MSG_WIN_BODY: str = "You guessed the word: {word}\nThe garden is thriving."
+MSG_LOSS_TITLE: str = "The garden ran out of water."
+MSG_LOSS_BODY: str = "The word was: {word}\nTry again and grow a new garden."
+
+# Validation messages
+MSG_INVALID_EMPTY: str = "Please enter a single letter."
+MSG_INVALID_MULTIPLE: str = "Please enter a single letter."
+MSG_INVALID_NOT_ALPHA: str = "That is not a letter."
+
+
+# ---------------------------------------------------------------------------
+# GameState
+# ---------------------------------------------------------------------------
+
+@dataclass
+class GameState:
+    """Complete state of one Word Garden game session."""
+
+    secret_word: str
+    guessed_letters: set[str]
+    remaining_water: int
+    weed_count: int
+    max_water: int
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+# ---------------------------------------------------------------------------
+# Public API
+# ---------------------------------------------------------------------------
+
+def new_game(difficulty: str = "normal", rng: _random.Random | None = None) -> GameState:
+    """Create a fresh GameState for the given difficulty.
+
+    Raises ValueError (via words.select_word / words.water_for) for unknown
+    or unsatisfiable difficulties.
+    """
+    word = select_word(difficulty=difficulty, rng=rng).upper()
+    water = water_for(difficulty)
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[str | None, str]:
+    """Validate raw user input without consulting game state.
+
+    Returns
+    -------
+    (letter, "")
+        *letter* is the trimmed, uppercased single alphabetic character.
+    (None, message)
+        Input is invalid; *message* is a specific, helpful string.
+    """
+    stripped = input_text.strip()
+
+    if len(stripped) == 0:
+        return (None, MSG_INVALID_EMPTY)
+
+    if len(stripped) > 1:
+        return (None, MSG_INVALID_MULTIPLE)
+
+    if not stripped.isalpha():
+        return (None, MSG_INVALID_NOT_ALPHA)
+
+    return (stripped.upper(), "")
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply an already-validated uppercase letter to *state*.
+
+    The returned object IS *state* (mutated in place) — callers should
+    use the return value for clarity but do not need to replace the
+    reference.
+
+    Contract violations
+    -------------------
+    - Calling after game_over is a no-op with MSG_GAME_OVER_ATTEMPT.
+    - *letter* must be a single uppercase alphabetic character; otherwise
+      raises ValueError loudly.
+    """
+    # --- contract: letter must be a valid single uppercase alpha ---------
+    if not (isinstance(letter, str) and len(letter) == 1 and letter.isalpha() and letter.isupper()):
+        raise ValueError(
+            f"apply_guess expects a single uppercase letter; got {letter!r}"
+        )
+
+    # --- already finished ------------------------------------------------
+    if state.game_over:
+        state.status_message = MSG_GAME_OVER_ATTEMPT
+        return state
+
+    # --- repeated guess --------------------------------------------------
+    if letter in state.guessed_letters:
+        state.status_message = MSG_ALREADY_GUESSED.format(letter=letter)
+        return state
+
+    # --- record the letter -----------------------------------------------
+    state.guessed_letters.add(letter)
+
+    # --- correct / incorrect ---------------------------------------------
+    if letter in state.secret_word:
+        state.status_message = MSG_CORRECT_GUESS
+    else:
+        state.remaining_water -= 1
+        state.weed_count += 1
+        state.status_message = MSG_WRONG_GUESS
+
+    # --- check terminal conditions ---------------------------------------
+    if is_won(state):
+        state.game_over = True
+        state.won = True
+        state.status_message = MSG_WIN_BODY.format(word=state.secret_word)
+    elif is_lost(state):
+        state.game_over = True
+        state.won = False
+        state.status_message = MSG_LOSS_BODY.format(word=state.secret_word)
+
+    return state
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word with spaces, e.g. ``G _ R _ E _``."""
+    return " ".join(
+        ch if ch in state.guessed_letters else "_"
+        for ch in state.secret_word
+    )
+
+
+def is_won(state: GameState) -> bool:
+    """Return True iff every letter of the secret word has been guessed."""
+    return all(ch in state.guessed_letters for ch in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Return True iff water is exhausted AND the word has not been won.
+
+    Standalone predicate: correct for EVERY reachable state, including
+    simultaneous win/loss boundary states (win takes priority).
+    """
+    return state.remaining_water <= 0 and not is_won(state)
