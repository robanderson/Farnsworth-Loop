@@ -0,0 +1,84 @@
+"""Word list and selection logic for Word Garden."""
+
+import random as _random
+
+# The canonical 10-word list from SPEC.md section 8.
+WORDS: list[str] = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty → (max_word_length_or_None, min_word_length, starting_water)
+# easy: water 8, length 4–6
+# normal: water 6, length 5–8
+# hard: water 4, length 7+
+_DIFFICULTY_CONFIG: dict[str, tuple[int, int, int | None]] = {
+    #          water  min_len  max_len (None = no upper bound)
+    "easy":   (8,     4,       6),
+    "normal": (6,     5,       8),
+    "hard":   (4,     7,       None),
+}
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return the starting water level for the given difficulty.
+
+    Raises ValueError for unknown difficulty names.
+    """
+    if difficulty not in _DIFFICULTY_CONFIG:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose one of: {sorted(_DIFFICULTY_CONFIG)}"
+        )
+    water, _min_len, _max_len = _DIFFICULTY_CONFIG[difficulty]
+    return water
+
+
+def select_word(difficulty: str = "normal", rng: _random.Random | None = None) -> str:
+    """Return a random word filtered by difficulty constraints.
+
+    Parameters
+    ----------
+    difficulty:
+        One of 'easy', 'normal', or 'hard'.  Raises ValueError for anything
+        else.
+    rng:
+        An injectable ``random.Random`` instance for deterministic tests.
+        When None the module-level ``random`` functions are used.
+
+    Raises
+    ------
+    ValueError
+        If *difficulty* is unknown, or if no word in WORDS satisfies the
+        length constraint for that difficulty (empty pool).
+    """
+    if difficulty not in _DIFFICULTY_CONFIG:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
