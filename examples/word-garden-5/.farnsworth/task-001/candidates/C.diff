index 0000000..9adf1b5
--- /dev/null
+++ b/word_garden/ui.py
@@ -0,0 +1,133 @@
+"""Pure rendering for Word Garden — no I/O, every function returns a string."""
+
+from __future__ import annotations
+
+from .game import GameState, display_word, is_won, is_lost
+
+# ---------------------------------------------------------------------------
+# Emoji / ASCII symbol sets
+# ---------------------------------------------------------------------------
+
+_EMOJI = {
+    "stage_start":    "🌱",
+    "stage_progress": "🌿",
+    "stage_near_win": "🌷",
+    "stage_win":      "🌻",
+    "stage_loss":     "🥀",
+    "water_drop":     "💧",
+    "weed":           "🌿",
+}
+
+_ASCII = {
+    "stage_start":    "*",
+    "stage_progress": "+",
+    "stage_near_win": "@",
+    "stage_win":      "X",
+    "stage_loss":     "~",
+    "water_drop":     "~",
+    "weed":           "-",
+}
+
+
+# ---------------------------------------------------------------------------
+# Growth stage
+# ---------------------------------------------------------------------------
+
+def _growth_glyph(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the single glyph that represents the current growth stage.
+
+    Five observable, distinct stages (per SPEC section 10):
+      - loss   → 🥀 / ~
+      - win    → 🌻 / X
+      - near-win (≥ 2/3 of distinct secret letters revealed) → 🌷 / @
+      - progress (any letter revealed but not near-win)       → 🌿 / +
+      - start  (no letters revealed yet)                      → 🌱 / *
+    """
+    syms = _ASCII if ascii_mode else _EMOJI
+
+    if state.game_over and not state.won:
+        return syms["stage_loss"]
+    if state.won or state.game_over:
+        return syms["stage_win"]
+
+    distinct = set(state.secret_word)
+    revealed = distinct & state.guessed_letters
+    fraction = len(revealed) / len(distinct) if distinct else 0.0
+
+    if fraction == 0.0:
+        return syms["stage_start"]
+    if fraction >= 2 / 3:
+        return syms["stage_near_win"]
+    return syms["stage_progress"]
+
+
+# ---------------------------------------------------------------------------
+# Win / loss screens
+# ---------------------------------------------------------------------------
+
+def _win_screen(state: GameState, ascii_mode: bool = False) -> str:
+    syms = _ASCII if ascii_mode else _EMOJI
+    glyph = syms["stage_win"]
+    title = f"{glyph} Bloom!"
+    body = f"You guessed the word: {state.secret_word}\nThe garden is thriving."
+    return f"{title}\n\n{body}"
+
+
+def _loss_screen(state: GameState, ascii_mode: bool = False) -> str:
+    syms = _ASCII if ascii_mode else _EMOJI
+    glyph = syms["stage_loss"]
+    title = f"{glyph} The garden ran out of water."
+    body = f"The word was: {state.secret_word}\nTry again and grow a new garden."
+    return f"{title}\n\n{body}"
+
+
+# ---------------------------------------------------------------------------
+# Main render
+# ---------------------------------------------------------------------------
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the full game display as a single string.
+
+    Field order per SPEC section 9:
+      title (with growth glyph), masked word, guessed letters,
+      water, weeds, status message (omitted when empty).
+
+    Accessibility (SPEC section 18):
+      Water: ``count/max_water`` + symbols
+      Weeds: standalone count + symbols
+    """
+    syms = _ASCII if ascii_mode else _EMOJI
+
+    # Terminal screens
+    if state.game_over:
+        if state.won:
+            return _win_screen(state, ascii_mode)
+        else:
+            return _loss_screen(state, ascii_mode)
+
+    glyph = _growth_glyph(state, ascii_mode)
+    title = f"{glyph} Word Garden"
+
+    masked = display_word(state)
+    guessed_str = " ".join(sorted(state.guessed_letters))
+
+    water_symbols = syms["water_drop"] * state.remaining_water
+    water_line = f"Water:    {state.remaining_water}/{state.max_water} {water_symbols}".rstrip()
+
+    weed_symbols = syms["weed"] * state.weed_count
+    weeds_line = f"Weeds:    {state.weed_count} {weed_symbols}".rstrip()
+
+    lines = [
+        title,
+        "",
+        f"Word:      {masked}",
+        f"Guessed:   {guessed_str}",
+        water_line,
+        weeds_line,
+    ]
+
+    if state.status_message:
+        lines.append("")
+        lines.append(state.status_message)
+
+    return "\n".join(lines)
