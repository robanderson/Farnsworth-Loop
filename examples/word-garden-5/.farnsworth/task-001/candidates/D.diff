+"""Main entry point and game loop for Word Garden."""
+
+import argparse
+import sys
+
+from . import game
+from . import ui
+
+
+def main(argv=None, input_fn=input, output_fn=print) -> int:
+    """Run the Word Garden game.
+
+    Per the hard requirements, this signature is EXACT and CLOSED:
+    no additional parameters, input_fn and output_fn are positional.
+
+    Args:
+        argv: Command-line arguments (defaults to sys.argv[1:]).
+        input_fn: Function for reading user input (defaults to input).
+        output_fn: Function for printing output (defaults to print).
+
+    Returns:
+        Exit code: 0 for success, 2 for usage error.
+    """
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description="Word Garden - a friendly terminal word-guessing game.",
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty (default: normal)",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        help="Use ASCII output instead of emoji",
+    )
+
+    try:
+        args = parser.parse_args(argv)
+    except SystemExit as e:
+        # Let argparse handle --help (exit 0) and usage errors (exit 2)
+        # Do NOT swallow SystemExit per code-tip 4
+        raise
+
+    ascii_mode = args.ascii
+    difficulty = args.difficulty
+
+    # Start a new game
+    current_state = game.new_game(difficulty=difficulty)
+
+    # Game loop
+    try:
+        while not current_state.game_over:
+            # Render and display the current game state
+            screen = ui.render(current_state, ascii_mode=ascii_mode)
+            output_fn(screen)
+            output_fn("")
+
+            # Prompt for input
+            try:
+                user_input = input_fn("Guess a letter: ")
+            except EOFError:
+                # Friendly goodbye on EOF
+                output_fn("Thanks for playing! Goodbye.")
+                return 0
+            except KeyboardInterrupt:
+                # Friendly goodbye on interrupt
+                output_fn("\nThanks for playing! Goodbye.")
+                return 0
+
+            # Validate the guess
+            letter, error_message = game.validate_guess(user_input)
+
+            if letter is None:
+                # Invalid input: show message, don't consume a guess
+                output_fn(error_message)
+                output_fn("")
+                continue
+
+            # Apply the guess
+            current_state = game.apply_guess(current_state, letter)
+
+        # Game is over; show final screen
+        if current_state.won:
+            final_screen = ui.render_win_screen(current_state, ascii_mode=ascii_mode)
+        else:
+            final_screen = ui.render_loss_screen(current_state, ascii_mode=ascii_mode)
+
+        output_fn(final_screen)
+        return 0
+
+    except EOFError:
+        # Friendly goodbye
+        output_fn("Thanks for playing! Goodbye.")
+        return 0
+    except KeyboardInterrupt:
+        # Friendly goodbye
+        output_fn("\nThanks for playing! Goodbye.")
+        return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
