+"""Word list and selection logic for Word Garden."""
+
+import random
+
+# The 10-word list from SPEC.md section 8, uppercase
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty configuration per SPEC.md section 7
+_DIFFICULTY_CONFIG = {
+    "easy": {"water": 8, "min_length": 4, "max_length": 6},
+    "normal": {"water": 6, "min_length": 5, "max_length": 8},
+    "hard": {"water": 4, "min_length": 7, "max_length": float("inf")},
+}
+
+
+def water_for(difficulty="normal") -> int:
+    """Return the starting water for the given difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+
+    Returns:
+        The starting water count for that difficulty.
+
+    Raises:
+        ValueError: If difficulty is unknown.
+    """
+    if difficulty not in _DIFFICULTY_CONFIG:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+    return _DIFFICULTY_CONFIG[difficulty]["water"]
+
+
+def select_word(difficulty="normal", rng=None) -> str:
+    """Select a random word from the list filtered by difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard". Defaults to "normal".
+        rng: An injectable random.Random instance for deterministic tests.
+             If None, uses the module-level random functions.
+
+    Returns:
+        An uppercase word matching the difficulty constraints.
+
+    Raises:
+        ValueError: If difficulty is unknown or no words match the difficulty.
+    """
+    if difficulty not in _DIFFICULTY_CONFIG:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    config = _DIFFICULTY_CONFIG[difficulty]
+    min_len = config["min_length"]
+    max_len = config["max_length"]
+
+    # Filter words by length
+    candidates = [w for w in WORDS if min_len <= len(w) <= max_len]
+
+    if not candidates:
+        raise ValueError(f"No words available for difficulty: {difficulty}")
+
+    if rng is None:
+        return random.choice(candidates)
+    else:
+        return rng.choice(candidates)
