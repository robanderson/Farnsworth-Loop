+"""Core game logic and state for Word Garden."""
+
+from dataclasses import dataclass, field
+import random
+
+from . import words
+
+# Message constants per code-tip 7
+MSG_CORRECT_GUESS = "Good guess! The garden grows."
+MSG_WRONG_GUESS = "No match. A weed appears."
+MSG_REPEAT_GUESS = "You already guessed {letter}. Try another letter."
+MSG_INVALID_INPUT = "Please enter a single letter."
+MSG_NOT_A_LETTER = "That is not a letter."
+MSG_EMPTY_INPUT = "Please enter a single letter."
+MSG_GUESSING_AFTER_GAME_OVER = "The game is over. Start a new game to play again."
+MSG_WIN = "You guessed the word: {word}\nThe garden is thriving."
+MSG_LOSS = "The word was: {word}\nTry again and grow a new garden."
+
+
+@dataclass
+class GameState:
+    """Represents the complete state of a Word Garden game.
+
+    Per SPEC.md section 12, exactly these fields:
+    """
+
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty="normal", rng=None) -> GameState:
+    """Create a new game with a random word at the given difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard". Defaults to "normal".
+        rng: An injectable random.Random instance. If None, uses module-level random.
+
+    Returns:
+        A fresh GameState ready to play.
+
+    Raises:
+        ValueError: If difficulty is unknown.
+    """
+    secret_word = words.select_word(difficulty=difficulty, rng=rng)
+    max_water = words.water_for(difficulty=difficulty)
+
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=set(),
+        remaining_water=max_water,
+        weed_count=0,
+        max_water=max_water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text) -> tuple[str | None, str]:
+    """Validate and normalize a single letter guess.
+
+    Validation rules per SPEC.md section 14:
+    - Trim whitespace
+    - Convert to uppercase
+    - Must be exactly one alphabetic character
+
+    Args:
+        input_text: Raw user input.
+
+    Returns:
+        Tuple of (letter, message). If valid, returns (uppercase_letter, "").
+        If invalid, returns (None, helpful_message).
+    """
+    trimmed = input_text.strip()
+
+    if not trimmed:
+        return None, MSG_EMPTY_INPUT
+
+    if len(trimmed) > 1:
+        return None, MSG_INVALID_INPUT
+
+    if not trimmed.isalpha():
+        return None, MSG_NOT_A_LETTER
+
+    return trimmed.upper(), ""
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a validated guess to the game state.
+
+    Per SPEC.md sections 6.3-6.5:
+    - Correct guess: reveal letters, show positive message
+    - Wrong guess: cost 1 water, add 1 weed, show warning
+    - Repeated guess: no state change, show message
+    - Guessing after game over: no-op with appropriate message
+
+    Args:
+        state: The current game state.
+        letter: An uppercase letter, already validated.
+
+    Returns:
+        Updated GameState with new status_message, and game_over/won flags
+        if the game ends this turn.
+    """
+    # Make a shallow copy; we'll modify fields
+    new_state = GameState(
+        secret_word=state.secret_word,
+        guessed_letters=state.guessed_letters.copy(),
+        remaining_water=state.remaining_water,
+        weed_count=state.weed_count,
+        max_water=state.max_water,
+        status_message="",
+        game_over=state.game_over,
+        won=state.won,
+    )
+
+    # If already game over, no-op with message
+    if state.game_over:
+        new_state.status_message = MSG_GUESSING_AFTER_GAME_OVER
+        new_state.game_over = True
+        new_state.won = state.won
+        return new_state
+
+    # If letter already guessed, no state change
+    if letter in state.guessed_letters:
+        new_state.guessed_letters = state.guessed_letters.copy()
+        new_state.status_message = MSG_REPEAT_GUESS.format(letter=letter)
+        return new_state
+
+    # Record the guess
+    new_state.guessed_letters.add(letter)
+
+    # Check if correct
+    if letter in state.secret_word:
+        new_state.status_message = MSG_CORRECT_GUESS
+    else:
+        # Wrong guess: cost water and weeds
+        new_state.remaining_water = state.remaining_water - 1
+        new_state.weed_count = state.weed_count + 1
+        new_state.status_message = MSG_WRONG_GUESS
+
+    # After applying the guess, check win/loss
+    if is_won(new_state):
+        new_state.game_over = True
+        new_state.won = True
+        new_state.status_message = MSG_WIN.format(word=state.secret_word)
+    elif is_lost(new_state):
+        new_state.game_over = True
+        new_state.won = False
+        new_state.status_message = MSG_LOSS.format(word=state.secret_word)
+
+    return new_state
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word with guessed letters revealed.
+
+    Format: space-separated letters and underscores, e.g. "G _ R _ E _"
+
+    Args:
+        state: The current game state.
+
+    Returns:
+        The masked word string.
+    """
+    revealed = [
+        letter if letter in state.guessed_letters else "_"
+        for letter in state.secret_word
+    ]
+    return " ".join(revealed)
+
+
+def is_won(state: GameState) -> bool:
+    """Check if the player has won.
+
+    Per code-tip 10: this predicate must return the correct answer for
+    EVERY reachable state, including states where is_lost is also true
+    (which should not happen in normal play, but the predicate must be
+    self-contained).
+
+    Win condition: all letters of the secret word are in guessed_letters.
+
+    Args:
+        state: The game state to check.
+
+    Returns:
+        True if all secret letters have been guessed.
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Check if the player has lost.
+
+    Per code-tip 10: this predicate must return the correct answer for
+    EVERY reachable state. Loss condition: water at 0 AND not won.
+
+    Args:
+        state: The game state to check.
+
+    Returns:
+        True if water is 0 and the game is not won.
+    """
+    return state.remaining_water <= 0 and not is_won(state)
