+"""Tests for the core game logic."""
+
+import unittest
+import random
+
+from word_garden import game
+from word_garden.game import GameState
+
+
+class TestGameState(unittest.TestCase):
+    """Test GameState dataclass structure."""
+
+    def test_gamestate_fields_exist(self):
+        """GameState has all required fields per SPEC.md section 12."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+            status_message="",
+            game_over=False,
+            won=False,
+        )
+        self.assertEqual(state.secret_word, "GARDEN")
+        self.assertEqual(state.guessed_letters, set())
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(state.max_water, 6)
+        self.assertEqual(state.status_message, "")
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+
+class TestNewGame(unittest.TestCase):
+    """Test new_game function."""
+
+    def test_new_game_normal(self):
+        """new_game creates a valid normal difficulty game."""
+        state = game.new_game(difficulty="normal")
+        self.assertIsNotNone(state.secret_word)
+        self.assertTrue(state.secret_word.isupper())
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(state.guessed_letters, set())
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_easy(self):
+        """new_game with easy difficulty."""
+        state = game.new_game(difficulty="easy")
+        self.assertEqual(state.remaining_water, 8)
+        self.assertEqual(state.max_water, 8)
+
+    def test_new_game_hard(self):
+        """new_game with hard difficulty."""
+        state = game.new_game(difficulty="hard")
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.max_water, 4)
+
+    def test_new_game_invalid_difficulty(self):
+        """new_game raises ValueError for unknown difficulty."""
+        with self.assertRaises(ValueError):
+            game.new_game(difficulty="impossible")
+
+    def test_new_game_with_seeded_rng(self):
+        """new_game is deterministic with seeded RNG."""
+        rng1 = random.Random(42)
+        rng2 = random.Random(42)
+        state1 = game.new_game(difficulty="normal", rng=rng1)
+        state2 = game.new_game(difficulty="normal", rng=rng2)
+        self.assertEqual(state1.secret_word, state2.secret_word)
+
+
+class TestValidateGuess(unittest.TestCase):
+    """Test validate_guess function."""
+
+    def test_valid_uppercase_letter(self):
+        """Valid uppercase letter is accepted."""
+        letter, msg = game.validate_guess("A")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_valid_lowercase_letter(self):
+        """Lowercase letter is normalized to uppercase."""
+        letter, msg = game.validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_valid_letter_with_spaces(self):
+        """Spaces are trimmed."""
+        letter, msg = game.validate_guess("  z  ")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+    def test_empty_input(self):
+        """Empty input is rejected."""
+        letter, msg = game.validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, game.MSG_EMPTY_INPUT)
+
+    def test_multiple_letters(self):
+        """Multiple letters are rejected."""
+        letter, msg = game.validate_guess("abc")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, game.MSG_INVALID_INPUT)
+
+    def test_non_letter_character(self):
+        """Non-letter characters are rejected."""
+        letter, msg = game.validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, game.MSG_NOT_A_LETTER)
+
+    def test_symbol_rejected(self):
+        """Symbols are rejected."""
+        letter, msg = game.validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, game.MSG_NOT_A_LETTER)
+
+
+class TestApplyGuess(unittest.TestCase):
+    """Test apply_guess function."""
+
+    def test_correct_guess_reveals_letter(self):
+        """Correct guess adds letter to guessed_letters."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "A")
+        self.assertIn("A", new_state.guessed_letters)
+        self.assertEqual(new_state.status_message, game.MSG_CORRECT_GUESS)
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+
+    def test_wrong_guess_costs_water(self):
+        """Wrong guess costs 1 water (SPEC.md section 6.4)."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "Z")
+        self.assertIn("Z", new_state.guessed_letters)
+        self.assertEqual(new_state.remaining_water, 5)
+        self.assertEqual(new_state.weed_count, 1)
+        self.assertEqual(new_state.status_message, game.MSG_WRONG_GUESS)
+
+    def test_wrong_guess_adds_weed(self):
+        """Wrong guess increases weed count by 1 (SPEC.md section 6.4)."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "X")
+        self.assertEqual(new_state.weed_count, 1)
+
+    def test_repeated_guess_no_change(self):
+        """Repeated guess doesn't change water or weeds (SPEC.md section 6.5)."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"A"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "A")
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+        self.assertIn("A", new_state.guessed_letters)
+        self.assertEqual(new_state.status_message, game.MSG_REPEAT_GUESS.format(letter="A"))
+
+    def test_guess_after_game_over_no_op(self):
+        """Guessing after game_over is a no-op."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+            game_over=True,
+            won=True,
+        )
+        new_state = game.apply_guess(state, "Z")
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+        self.assertTrue(new_state.game_over)
+
+    def test_win_sets_flags_and_message(self):
+        """Guessing the last letter sets game_over=True and won=True."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "N")
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+        self.assertIn("GARDEN", new_state.status_message)
+        self.assertIn("thriving", new_state.status_message)
+
+    def test_loss_sets_flags_and_message(self):
+        """Running out of water sets game_over=True and won=False."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"X"},
+            remaining_water=1,
+            weed_count=1,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "Y")
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+        self.assertIn("GARDEN", new_state.status_message)
+        self.assertIn("Try again", new_state.status_message)
+
+    def test_original_state_unchanged(self):
+        """apply_guess does not mutate the original state."""
+        original = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        original_guessed = original.guessed_letters.copy()
+        original_water = original.remaining_water
+
+        new_state = game.apply_guess(original, "Z")
+
+        # Original should be unchanged
+        self.assertEqual(original.guessed_letters, original_guessed)
+        self.assertEqual(original.remaining_water, original_water)
+        self.assertFalse(original.game_over)
+
+
+class TestDisplayWord(unittest.TestCase):
+    """Test display_word function."""
+
+    def test_no_guesses(self):
+        """With no guesses, all letters are masked."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        display = game.display_word(state)
+        self.assertEqual(display, "_ _ _ _ _ _")
+
+    def test_partial_guesses(self):
+        """Guessed letters are revealed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        display = game.display_word(state)
+        self.assertEqual(display, "G A R D E _")
+
+    def test_all_guesses(self):
+        """All guessed letters reveal the word."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        display = game.display_word(state)
+        self.assertEqual(display, "G A R D E N")
+
+
+class TestIsWon(unittest.TestCase):
+    """Test is_won predicate."""
+
+    def test_not_won_no_guesses(self):
+        """Game not won with no guesses."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
