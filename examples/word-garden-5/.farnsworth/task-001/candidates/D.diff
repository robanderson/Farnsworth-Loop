+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertFalse(game.is_won(state))
+
+    def test_won_all_letters(self):
+        """Game won when all letters guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        self.assertTrue(game.is_won(state))
+
+    def test_won_with_extra_letters(self):
+        """Game won even with extra wrong letters guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N", "Z", "X"},
+            remaining_water=4,
+            weed_count=2,
+            max_water=6,
+        )
+        self.assertTrue(game.is_won(state))
+
+    def test_won_with_zero_water(self):
+        """Game won even if water is 0 (all letters guessed first)."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=0,
+            weed_count=6,
+            max_water=6,
+        )
+        self.assertTrue(game.is_won(state))
+
+
+class TestIsLost(unittest.TestCase):
