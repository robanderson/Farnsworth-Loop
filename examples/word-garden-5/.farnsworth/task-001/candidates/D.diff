+        output = []
+        input_calls = iter([""])  # EOF on first prompt
+
+        def mock_output(text):
+            output.append(text)
+
+        def mock_input(prompt):
+            return next(input_calls)
+
+        try:
+            main.main(
+                argv=["--difficulty", "easy"],
+                input_fn=mock_input,
+                output_fn=mock_output,
