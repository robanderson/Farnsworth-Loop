+class TestGameIntegration(unittest.TestCase):
+    """Integration tests for full game flow."""
+
+    def test_full_win_scenario(self):
+        """Full game win scenario with pinned word."""
+        # Use a seeded RNG to ensure we get a specific word
+        rng = random.Random(42)
+        state = game.new_game(difficulty="normal", rng=rng)
+        word = state.secret_word
+
+        # Guess all letters one by one
+        for letter in word:
+            state = game.apply_guess(state, letter)
+            if game.is_won(state):
+                break
+
+        self.assertTrue(state.game_over)
+        self.assertTrue(state.won)
+        self.assertEqual(set(state.guessed_letters), set(word))
+
+    def test_full_loss_scenario(self):
+        """Full game loss scenario with pinned word."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=1,
+            weed_count=0,
+            max_water=6,
+        )
+
+        # Make a wrong guess to run out of water
+        state = game.apply_guess(state, "X")
+
+        self.assertTrue(state.game_over)
+        self.assertFalse(state.won)
+        self.assertEqual(state.remaining_water, 0)
+
+    def test_multiple_wrong_guesses_accumulate(self):
+        """Multiple wrong guesses accumulate water/weed costs."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        state = game.apply_guess(state, "X")
+        self.assertEqual(state.remaining_water, 5)
+        self.assertEqual(state.weed_count, 1)
+
+        state = game.apply_guess(state, "Y")
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.weed_count, 2)
+
+        state = game.apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, 3)
+        self.assertEqual(state.weed_count, 3)
+
+
+if __name__ == "__main__":
+    unittest.main()
