+"""Terminal UI rendering for Word Garden."""
+
+from . import game
+
+
+def _get_growth_stage(state: game.GameState) -> str:
+    """Determine the growth stage emoji based on revealed letters.
+
+    Per SPEC.md section 10, five stages driven by the fraction of distinct
+    secret letters revealed:
+    - Start: 🌱
+    - Progress: 🌿
+    - Near win: 🌷
+    - Win: 🌻
+    - Loss: 🥀
+
+    Args:
+        state: The game state.
+
+    Returns:
+        The emoji glyph for the current stage.
+    """
+    if state.won:
+        return "🌻"
+    if game.is_lost(state):
+        return "🥀"
+
+    # Fraction of secret letters revealed
+    unique_secret_letters = set(state.secret_word)
+    revealed_count = len(unique_secret_letters & state.guessed_letters)
+    total_unique = len(unique_secret_letters)
+
+    if total_unique == 0:
+        fraction = 0
+    else:
+        fraction = revealed_count / total_unique
+
+    if fraction == 0:
+        return "🌱"
+    elif fraction < 0.5:
+        return "🌿"
+    elif fraction < 1.0:
+        return "🌷"
+    else:
+        return "🌻"
+
+
+def _get_growth_stage_ascii(state: game.GameState) -> str:
+    """Return ASCII fallback for growth stage.
+
+    Args:
+        state: The game state.
+
+    Returns:
+        ASCII representation of the growth stage.
+    """
+    if state.won:
+        return "***"
+    if game.is_lost(state):
+        return "###"
+
+    unique_secret_letters = set(state.secret_word)
+    revealed_count = len(unique_secret_letters & state.guessed_letters)
+    total_unique = len(unique_secret_letters)
+
+    if total_unique == 0:
+        fraction = 0
+    else:
+        fraction = revealed_count / total_unique
+
+    if fraction == 0:
+        return "*"
+    elif fraction < 0.5:
+        return "**"
+    elif fraction < 1.0:
+        return "***"
+    else:
+        return "****"
+
+
+def render(state: game.GameState, ascii_mode: bool = False) -> str:
+    """Render the complete game display.
+
+    Per SPEC.md section 9, displays in order:
+    1. Title with growth glyph
+    2. Masked word
+    3. Guessed letters (sorted, space-separated)
+    4. Water (with count/max and symbols)
+    5. Weeds (with count and symbols)
+    6. Previous turn's status message (if not empty)
+
+    Per SPEC.md section 18 accessibility: text labels and numeric counts
+    alongside symbols.
+
+    Args:
+        state: The game state to render.
+        ascii_mode: If True, use ASCII fallbacks instead of emoji.
+
+    Returns:
+        A complete, ready-to-print game screen.
+    """
+    lines = []
+
+    # Title with growth glyph
+    if ascii_mode:
+        growth = _get_growth_stage_ascii(state)
+        lines.append(f"{growth} Word Garden")
+    else:
+        growth = _get_growth_stage(state)
+        lines.append(f"{growth} Word Garden")
+
+    lines.append("")
+
+    # Masked word
+    word_display = game.display_word(state)
+    lines.append(f"Word:     {word_display}")
+
+    # Guessed letters (sorted, space-separated)
+    if state.guessed_letters:
+        guessed = " ".join(sorted(state.guessed_letters))
+        lines.append(f"Guessed:  {guessed}")
+    else:
+        lines.append("Guessed:")
+
+    # Water with count/max and symbols
+    if ascii_mode:
+        water_symbols = "[" + "*" * state.remaining_water + "]"
+        lines.append(f"Water:   {state.remaining_water}/{state.max_water} {water_symbols}")
+    else:
+        water_symbols = "💧" * state.remaining_water
+        lines.append(f"Water:   {state.remaining_water}/{state.max_water} {water_symbols}")
+
+    # Weeds with count and symbols
+    if ascii_mode:
+        weed_symbols = "[" + "-" * state.weed_count + "]"
+        lines.append(f"Weeds:   {state.weed_count} {weed_symbols}")
+    else:
+        weed_symbols = "🌿" * state.weed_count
+        lines.append(f"Weeds:   {state.weed_count} {weed_symbols}")
+
+    # Previous turn's status message (if not empty)
+    if state.status_message:
+        lines.append("")
+        lines.append(state.status_message)
+
+    return "\n".join(lines)
+
+
+def render_win_screen(state: game.GameState, ascii_mode: bool = False) -> str:
+    """Render the win screen.
+
+    Per SPEC.md section 6.6.
+
+    Args:
+        state: The game state (assumed to be won).
+        ascii_mode: If True, use ASCII fallback.
+
+    Returns:
+        The win screen.
+    """
+    if ascii_mode:
+        glyph = "***"
+    else:
+        glyph = "🌻"
+
+    lines = [
+        f"{glyph} Bloom!",
+        "",
+        state.status_message,
+    ]
+    return "\n".join(lines)
+
+
+def render_loss_screen(state: game.GameState, ascii_mode: bool = False) -> str:
+    """Render the loss screen.
+
+    Per SPEC.md section 6.7.
+
+    Args:
+        state: The game state (assumed to be lost).
+        ascii_mode: If True, use ASCII fallback.
+
+    Returns:
+        The loss screen.
+    """
+    if ascii_mode:
+        glyph = "###"
+    else:
+        glyph = "🥀"
+
+    lines = [
+        f"{glyph} The garden ran out of water.",
+        "",
+        state.status_message,
+    ]
+    return "\n".join(lines)
