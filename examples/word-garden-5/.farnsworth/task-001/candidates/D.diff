+"""Tests for word selection and difficulty."""
+
+import unittest
+import random
+
+from word_garden import words
+
+
+class TestWordList(unittest.TestCase):
+    """Test the word list."""
+
+    def test_words_list_exists(self):
+        """WORDS list exists and has 10 words."""
+        self.assertEqual(len(words.WORDS), 10)
+
+    def test_words_are_uppercase(self):
+        """All words are uppercase."""
+        for word in words.WORDS:
+            self.assertTrue(word.isupper())
+
+    def test_words_are_strings(self):
+        """All words are strings."""
+        for word in words.WORDS:
+            self.assertIsInstance(word, str)
+
+    def test_no_duplicate_words(self):
+        """No duplicate words in the list."""
+        self.assertEqual(len(words.WORDS), len(set(words.WORDS)))
+
+
+class TestSelectWord(unittest.TestCase):
+    """Test word selection by difficulty."""
+
+    def test_select_word_normal(self):
+        """select_word returns a valid word for normal difficulty."""
+        word = words.select_word(difficulty="normal")
+        self.assertIn(word, words.WORDS)
+        self.assertTrue(5 <= len(word) <= 8)
+
+    def test_select_word_easy(self):
+        """select_word returns a valid word for easy difficulty."""
+        word = words.select_word(difficulty="easy")
+        self.assertIn(word, words.WORDS)
+        self.assertTrue(4 <= len(word) <= 6)
+
+    def test_select_word_hard(self):
+        """select_word returns a valid word for hard difficulty."""
+        word = words.select_word(difficulty="hard")
+        self.assertIn(word, words.WORDS)
+        self.assertTrue(len(word) >= 7)
+
+    def test_select_word_invalid_difficulty(self):
+        """select_word raises ValueError for unknown difficulty."""
+        with self.assertRaises(ValueError) as cm:
+            words.select_word(difficulty="impossible")
+        self.assertIn("Unknown difficulty", str(cm.exception))
+
+    def test_select_word_with_seeded_rng(self):
+        """select_word is deterministic with seeded RNG."""
+        rng1 = random.Random(42)
+        rng2 = random.Random(42)
+        word1 = words.select_word(difficulty="normal", rng=rng1)
+        word2 = words.select_word(difficulty="normal", rng=rng2)
+        self.assertEqual(word1, word2)
+
+    def test_select_word_different_seeds_vary(self):
+        """select_word varies with different RNG seeds."""
+        rng1 = random.Random(1)
+        rng2 = random.Random(2)
+        # It's theoretically possible both return the same word,
+        # but extremely unlikely with 10 words
+        word1 = words.select_word(difficulty="normal", rng=rng1)
+        word2 = words.select_word(difficulty="normal", rng=rng2)
+        # Don't assert they're different (flaky test), just that both are valid
+        self.assertIn(word1, words.WORDS)
+        self.assertIn(word2, words.WORDS)
+
+    def test_select_word_each_difficulty_covers_words(self):
+        """Each difficulty level can select from at least some words."""
+        easy_words = [w for w in words.WORDS if 4 <= len(w) <= 6]
+        normal_words = [w for w in words.WORDS if 5 <= len(w) <= 8]
+        hard_words = [w for w in words.WORDS if len(w) >= 7]
+
+        self.assertTrue(len(easy_words) > 0, "No easy words available")
+        self.assertTrue(len(normal_words) > 0, "No normal words available")
+        self.assertTrue(len(hard_words) > 0, "No hard words available")
+
+
+class TestWaterFor(unittest.TestCase):
+    """Test difficulty water configuration."""
+
+    def test_water_for_easy(self):
+        """water_for returns 8 for easy."""
+        self.assertEqual(words.water_for("easy"), 8)
+
+    def test_water_for_normal(self):
+        """water_for returns 6 for normal."""
+        self.assertEqual(words.water_for("normal"), 6)
+
+    def test_water_for_hard(self):
+        """water_for returns 4 for hard."""
+        self.assertEqual(words.water_for("hard"), 4)
+
+    def test_water_for_invalid_difficulty(self):
+        """water_for raises ValueError for unknown difficulty."""
+        with self.assertRaises(ValueError) as cm:
+            words.water_for("impossible")
+        self.assertIn("Unknown difficulty", str(cm.exception))
+
+    def test_water_for_default(self):
+        """water_for defaults to normal."""
+        self.assertEqual(words.water_for(), 6)
+
+
+if __name__ == "__main__":
+    unittest.main()
