  "reviewer": {
    "command": [
      "claude", "-p", "{prompt}", "--bare",
      "--model", "claude-opus-4-8",
      "--permission-mode", "acceptEdits",
      "--output-format", "json"
    ],
    "timeout_seconds": 3600
  },
  "gate": [
    {
      "name": "tests",
      "command": ["python3", "-m", "unittest", "discover", "-s", "tests"]
    },
    {
      "name": "compiles",
      "command": ["python3", "-m", "compileall", "-q", "word_garden"]
    },
    {
      "name": "plays-eof",
      "command": ["sh", "-c", "printf '' | python3 -m word_garden"]
    },
    {
      "name": "plays-ascii",
      "command": ["sh", "-c", "printf '' | python3 -m word_garden --ascii"]
    },
    {
      "name": "help",
      "command": ["sh", "-c", "python3 -m word_garden --help > /dev/null"]
    },
    {
      "name": "usage-error",
      "command": ["sh", "-c", "python3 -m word_garden --bogus 2> /dev/null; test $? -eq 2"]
    }
  ],
