+"""Terminal rendering for Word Garden (pure functions, no I/O).
+
+All functions return strings; nothing here calls print() or input().
+"""
+
+from __future__ import annotations
+
+from word_garden.game import GameState, display_word, is_won, is_lost
+
+# ---------------------------------------------------------------------------
+# User-facing message constants for UI screens (SPEC.md sections 6.6, 6.7)
+# ---------------------------------------------------------------------------
+
+TITLE = "Word Garden"
+
+# Win screen labels (SPEC 6.6)
+WIN_HEADER = "Bloom!"
+WIN_LINE2 = "You guessed the word: {word}"
+WIN_LINE3 = "The garden is thriving."
+
+# Loss screen labels (SPEC 6.7)
+LOSS_HEADER = "The garden ran out of water."
+LOSS_LINE2 = "The word was: {word}"
+LOSS_LINE3 = "Try again and grow a new garden."
+
+# Field labels (SPEC 18 accessibility: text label AND count, never symbols alone)
+LABEL_WORD = "Word:    "
+LABEL_GUESSED = "Guessed: "
+LABEL_WATER = "Water: "
+LABEL_WEEDS = "Weeds: "
+
+# Emoji glyphs (SPEC section 10)
+_STAGE_EMOJI = {
+    "start":    "🌱",
+    "progress": "🌿",
+    "near_win": "🌷",
+    "win":      "🌻",
+    "loss":     "🥀",
+}
+
+# ASCII fallback glyphs (SPEC section 10)
+_STAGE_ASCII = {
+    "start":    "*",
+    "progress": "~",
+    "near_win": "@",
+    "win":      "#",
+    "loss":     "X",
+}
+
+_WATER_EMOJI = "💧"
+_WEED_EMOJI = "🌿"
+_WATER_ASCII = "*"
+_WEED_ASCII = "-"
+
+
+# ---------------------------------------------------------------------------
+# Internal helpers
+# ---------------------------------------------------------------------------
+
+def _growth_stage(state: GameState) -> str:
+    """Determine the current growth stage label from state.
+
+    Stages (SPEC section 10):
+      loss     — game is over and not won
+      win      — game is over and won
+      near_win — at least 2/3 of unique letters in word revealed
+      progress — at least one letter revealed
+      start    — no letters revealed yet
+    """
+    if state.game_over and not state.won:
+        return "loss"
+    if state.game_over and state.won:
+        return "win"
+
+    # Count how many *unique* letters of the word have been guessed
+    unique_letters = set(state.secret_word)
+    revealed = unique_letters & state.guessed_letters
+    ratio = len(revealed) / len(unique_letters) if unique_letters else 0.0
+
+    if ratio >= 2 / 3:
+        return "near_win"
+    if revealed:
+        return "progress"
+    return "start"
+
+
+def _plant_glyph(stage: str, ascii_mode: bool) -> str:
+    """Return the plant glyph for the given stage."""
+    return _STAGE_ASCII[stage] if ascii_mode else _STAGE_EMOJI[stage]
+
+
+def _water_symbols(remaining: int, total: int, ascii_mode: bool) -> str:
+    """Return labeled water display: 'Water: N/M <symbols>'."""
+    if ascii_mode:
+        symbols = _WATER_ASCII * remaining
+        return f"{LABEL_WATER}{remaining}/{total} [{symbols}]"
+    else:
+        symbols = _WATER_EMOJI * remaining
+        return f"{LABEL_WATER}{remaining}/{total} {symbols}"
+
+
+def _weed_symbols(count: int, ascii_mode: bool) -> str:
+    """Return labeled weed display: 'Weeds: N <symbols>'."""
+    if ascii_mode:
+        symbols = _WEED_ASCII * count
+        if count:
+            return f"{LABEL_WEEDS}{count} [{symbols}]"
+        return f"{LABEL_WEEDS}0"
+    else:
+        symbols = _WEED_EMOJI * count
+        if count:
+            return f"{LABEL_WEEDS}{count} {symbols}"
+        return f"{LABEL_WEEDS}0"
+
+
+# ---------------------------------------------------------------------------
+# Public API
+# ---------------------------------------------------------------------------
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the full turn display as a string (SPEC sections 9, 10, 18).
+
+    Order (SPEC section 9):
+      1. Title with plant/growth glyph
+      2. (blank line)
+      3. Masked word
+      4. Guessed letters (sorted, space-separated)
+      5. Water (label + count + symbols)
+      6. Weeds (label + count + symbols)
+      7. (blank line)
+      8. status_message (previous turn's feedback)
+
+    ascii_mode=True: no non-ASCII characters anywhere in output.
+    """
+    stage = _growth_stage(state)
+    glyph = _plant_glyph(stage, ascii_mode)
+
+    if ascii_mode:
+        title_line = f"[{glyph}] {TITLE}"
+    else:
+        title_line = f"{glyph} {TITLE}"
+
+    word_line = f"{LABEL_WORD}{display_word(state)}"
+
+    guessed_sorted = " ".join(sorted(state.guessed_letters))
+    guessed_line = f"{LABEL_GUESSED}{guessed_sorted}"
+
+    water_line = _water_symbols(state.remaining_water, state.max_water, ascii_mode)
+    weed_line = _weed_symbols(state.weed_count, ascii_mode)
+
+    parts = [
+        title_line,
+        "",
+        word_line,
+        guessed_line,
+        water_line,
+        weed_line,
+    ]
+
+    if state.status_message:
+        parts.append("")
+        parts.append(state.status_message)
+
+    return "\n".join(parts)
+
+
+def win_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the win screen (SPEC section 6.6).
+
+    ascii_mode=True: no non-ASCII characters anywhere.
+    """
+    glyph = _plant_glyph("win", ascii_mode)
+    if ascii_mode:
+        header = f"[{glyph}] {WIN_HEADER}"
+    else:
+        header = f"{glyph} {WIN_HEADER}"
+
+    lines = [
+        header,
+        "",
+        WIN_LINE2.format(word=state.secret_word),
+        WIN_LINE3,
+    ]
+    return "\n".join(lines)
+
+
+def loss_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the loss screen (SPEC section 6.7), revealing the secret word.
+
+    ascii_mode=True: no non-ASCII characters anywhere.
+    """
+    glyph = _plant_glyph("loss", ascii_mode)
+    if ascii_mode:
+        header = f"[{glyph}] {LOSS_HEADER}"
+    else:
+        header = f"{glyph} {LOSS_HEADER}"
+
+    lines = [
+        header,
+        "",
+        LOSS_LINE2.format(word=state.secret_word),
+        LOSS_LINE3,
+    ]
+    return "\n".join(lines)
