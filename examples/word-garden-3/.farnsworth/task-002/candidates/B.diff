+# ---------------------------------------------------------------------------
+# main() — invalid input re-prompts without consuming water
+# ---------------------------------------------------------------------------
+
+class TestMainInvalidInput(unittest.TestCase):
+    """Invalid input must re-prompt without consuming a turn (SPEC 6.2/14)."""
+
+    def _run_with_inputs(self, inputs, secret_word="GO", water=6):
+        def fixed_new_game(difficulty="normal"):
+            return _state(secret_word=secret_word, remaining_water=water, max_water=water)
+
+        input_iter = iter(inputs)
+
+        def input_fn(prompt=""):
+            return next(input_iter)
+
+        output_lines = []
+
+        def output_fn(line=""):
+            output_lines.append(str(line))
+
+        exit_code = main(
+            argv=["--difficulty", "normal"],
+            input_fn=input_fn,
+            output_fn=output_fn,
+            new_game_fn=fixed_new_game,
+        )
+        return exit_code, output_lines
+
+    def test_invalid_input_then_win(self):
+        """After invalid input, the game continues and win is still reachable."""
+        # Invalid inputs: "7", "" then valid guesses to win GO: "g", "o"
+        code, lines = self._run_with_inputs(["7", "", "g", "o"], secret_word="GO")
+        all_output = "\n".join(lines)
+        self.assertEqual(code, 0)
+        self.assertIn(WIN_HEADER, all_output)
+
+    def test_invalid_input_water_not_consumed(self):
+        """Invalid input must not consume water.
+
+        We force water=1 for GARDEN. If invalid inputs cost water, a wrong
+        guess would become the loss-trigger and the game would end with
+        the loss screen. But the win should still appear after valid guesses.
+        """
+        # water=1 for word "AB" — invalid inputs "!", then guess "a" then "b" to win
+        code, lines = self._run_with_inputs(
+            ["!", "99", "a", "b"],
+            secret_word="AB",
+            water=1,
+        )
+        all_output = "\n".join(lines)
+        self.assertEqual(code, 0)
+        # If invalid inputs consumed water, we'd run out before winning.
+        self.assertIn(WIN_HEADER, all_output)
+
+
+# ---------------------------------------------------------------------------
+# main() — EOF and KeyboardInterrupt handling
+# ---------------------------------------------------------------------------
+
+class TestMainEOF(unittest.TestCase):
+    """EOF and KeyboardInterrupt exit cleanly with a friendly message (code 0)."""
+
+    def _run_eof(self, use_keyboard_interrupt=False):
+        def fixed_new_game(difficulty="normal"):
+            return _state(secret_word="GARDEN")
+
+        def input_fn(prompt=""):
+            if use_keyboard_interrupt:
+                raise KeyboardInterrupt
+            raise EOFError
+
+        output_lines = []
+
+        def output_fn(line=""):
+            output_lines.append(str(line))
+
+        exit_code = main(
+            argv=["--difficulty", "normal"],
+            input_fn=input_fn,
+            output_fn=output_fn,
+            new_game_fn=fixed_new_game,
+        )
+        return exit_code, output_lines
+
+    def test_eof_exit_code_zero(self):
+        code, _ = self._run_eof()
+        self.assertEqual(code, 0)
+
+    def test_eof_goodbye_message(self):
+        """Friendly goodbye message must appear on EOF."""
+        _, lines = self._run_eof()
+        all_output = "\n".join(lines)
+        self.assertIn(MSG_GOODBYE, all_output)
+
+    def test_keyboard_interrupt_exit_code_zero(self):
+        code, _ = self._run_eof(use_keyboard_interrupt=True)
+        self.assertEqual(code, 0)
+
+    def test_keyboard_interrupt_goodbye_message(self):
+        """Friendly goodbye message must appear on KeyboardInterrupt."""
+        _, lines = self._run_eof(use_keyboard_interrupt=True)
+        all_output = "\n".join(lines)
+        self.assertIn(MSG_GOODBYE, all_output)
+
+
+# ---------------------------------------------------------------------------
+# main() — module-level constants
+# ---------------------------------------------------------------------------
+
+class TestMainConstants(unittest.TestCase):
+    def test_msg_goodbye_defined(self):
+        self.assertIsInstance(MSG_GOODBYE, str)
+        self.assertTrue(MSG_GOODBYE)
+
+
+if __name__ == "__main__":
+    unittest.main()
