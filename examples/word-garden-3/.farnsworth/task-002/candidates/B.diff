+# ---------------------------------------------------------------------------
+# End-to-end main() — scripted win
+#
+# Per .code-tips.md: force a known scenario (inject new_game_fn returning
+# a fixed state), script guesses to actually win, assert the win artifact.
+# ---------------------------------------------------------------------------
+
+class TestMainWin(unittest.TestCase):
+    """Scripted E2E win through main()."""
+
+    def _run_main(self, inputs, secret_word="GO", difficulty="normal", ascii_mode=False):
+        """Run main() with a fixed word, collecting output."""
+        from word_garden.game import new_game as real_new_game
+
+        # new_game_fn ignores difficulty param; always returns fixed state
+        def fixed_new_game(difficulty=difficulty):
+            import random as _r
+            # Build a fresh GameState with our known word directly via new_game
+            # but we override via the fixed state fixture
+            return _state(
+                secret_word=secret_word,
+                remaining_water=6,
+                max_water=6,
+            )
+
+        input_iter = iter(inputs)
+
+        def input_fn(prompt=""):
+            return next(input_iter)
+
+        output_lines = []
+
+        def output_fn(line=""):
+            output_lines.append(str(line))
+
+        argv = ["--difficulty", difficulty]
+        if ascii_mode:
+            argv.append("--ascii")
+
+        exit_code = main(
+            argv=argv,
+            input_fn=input_fn,
+            output_fn=output_fn,
+            new_game_fn=fixed_new_game,
+        )
+        return exit_code, output_lines
+
+    def test_win_exit_code_zero(self):
+        # GO: guess G then O to win
+        code, _ = self._run_main(["g", "o"], secret_word="GO")
+        self.assertEqual(code, 0)
+
+    def test_win_screen_displayed(self):
+        """Assert the win screen (WIN_HEADER) appeared — positive assertion."""
+        code, lines = self._run_main(["g", "o"], secret_word="GO")
+        all_output = "\n".join(lines)
+        self.assertIn(WIN_HEADER, all_output)
+
+    def test_win_screen_contains_word(self):
+        """Win screen must show the guessed word."""
+        _, lines = self._run_main(["g", "o"], secret_word="GO")
+        all_output = "\n".join(lines)
+        self.assertIn("GO", all_output)
+
+    def test_win_screen_ascii_mode(self):
+        """ASCII mode win: no non-ASCII in the final output."""
+        code, lines = self._run_main(["g", "o"], secret_word="GO", ascii_mode=True)
+        all_output = "\n".join(lines)
+        self.assertIn(WIN_HEADER, all_output)
+        for ch in all_output:
+            self.assertLess(ord(ch), 128, f"Non-ASCII char {ch!r} in ascii win output")
+
+    def test_win_longer_word(self):
+        """Win with a multi-letter word guessing each letter."""
+        # Word: CAT — guess C, A, T
+        code, lines = self._run_main(["c", "a", "t"], secret_word="CAT")
+        all_output = "\n".join(lines)
+        self.assertEqual(code, 0)
+        self.assertIn(WIN_HEADER, all_output)
+
