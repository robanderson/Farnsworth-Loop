+"""Entry point and main game loop for Word Garden.
+
+This is the ONLY module that performs I/O (stdin/stdout). All I/O is
+injected through input_fn and output_fn for testability.
+"""
+
+from __future__ import annotations
+
+import argparse
+import sys
+
+from word_garden.game import (
+    new_game,
+    validate_guess,
+    apply_guess,
+)
+from word_garden.ui import render, win_screen, loss_screen
+
+# ---------------------------------------------------------------------------
+# Friendly exit message
+# ---------------------------------------------------------------------------
+
+MSG_GOODBYE = "Thanks for playing Word Garden! Goodbye."
+
+
+# ---------------------------------------------------------------------------
+# Main
+# ---------------------------------------------------------------------------
+
+def main(
+    argv: list[str] | None = None,
+    input_fn=input,
+    output_fn=print,
+    new_game_fn=None,
+) -> int:
+    """Run one full game of Word Garden, returning exit code 0.
+
+    Parameters
+    ----------
+    argv:
+        Command-line arguments; uses sys.argv[1:] when None.
+    input_fn:
+        Callable that reads one line of input (injectable for tests).
+        Default: built-in input().
+    output_fn:
+        Callable that outputs a line (injectable for tests).
+        Default: built-in print().
+    new_game_fn:
+        Callable(difficulty) -> GameState; injectable for deterministic tests.
+        Default: None (uses word_garden.game.new_game).
+
+    Returns
+    -------
+    int
+        Always 0 on clean exit (win, loss, or EOF/interrupt).
+    """
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description="Word Garden — a friendly terminal word-guessing game.",
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty: easy (8 water, 4-6 letter words), "
+             "normal (6 water, 5-8 letter words), "
+             "hard (4 water, 7+ letter words). Default: normal.",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        default=False,
+        help="Use ASCII-only output (no emoji). Useful for terminals that "
+             "do not render emoji correctly.",
+    )
+
+    # NOTE: Do NOT wrap parse_args in try/except SystemExit — per .code-tips.md.
+    # --help must exit 0, bad args must exit 2. Let argparse handle those.
+    args = parser.parse_args(argv)
+
+    ascii_mode: bool = args.ascii
+    difficulty: str = args.difficulty
+
+    _new_game = new_game_fn if new_game_fn is not None else new_game
+
+    try:
+        state = _new_game(difficulty=difficulty)
+    except ValueError as exc:
+        output_fn(f"Error starting game: {exc}")
+        return 1
+
+    try:
+        while not state.game_over:
+            # Render and display current state
+            output_fn(render(state, ascii_mode=ascii_mode))
+            output_fn("")  # blank line before prompt
+
+            # Input loop: re-prompt on invalid input without consuming a turn
+            while True:
+                raw = input_fn("Guess a letter: ")
+                letter, err = validate_guess(raw)
+                if letter is None:
+                    # Invalid input: show message and re-prompt (SPEC 6.2/14)
+                    output_fn(err)
+                    continue
+                break
+
+            # Apply the valid guess
+            state = apply_guess(state, letter)
+
+        # Game is over — show final screen
+        if state.won:
+            output_fn(win_screen(state, ascii_mode=ascii_mode))
+        else:
+            output_fn(loss_screen(state, ascii_mode=ascii_mode))
+
+    except EOFError:
+        output_fn("")
+        output_fn(MSG_GOODBYE)
+        return 0
+    except KeyboardInterrupt:
+        output_fn("")
+        output_fn(MSG_GOODBYE)
+        return 0
+
+    return 0
+
+
+if __name__ == "__main__":  # pragma: no cover
+    sys.exit(main())
