+"""Terminal UI rendering for Word Garden (no I/O)."""
+
+from word_garden.game import GameState, display_word, is_won, is_lost
+
+
+def _growth_stage(state: GameState) -> tuple[str, str]:
+    """Return (emoji_glyph, ascii_glyph) for current garden growth stage.
+
+    Stages (per SPEC.md section 10):
+    - start: 🌱 / *
+    - progress: 🌿 / *
+    - near-win: 🌷 / *
+    - win: 🌻 / *
+    - loss: 🥀 / *
+
+    Stage determination:
+    - loss: is_lost(state)
+    - win: is_won(state)
+    - near-win: more than 75% of letters revealed (remaining letters <= 25% of total)
+    - progress: more than 0 letters revealed
+    - start: no letters revealed
+    """
+    if is_lost(state):
+        return "🥀", "*"
+    if is_won(state):
+        return "🌻", "*"
+
+    # Calculate progress toward win
+    total_letters = len(set(state.secret_word))
+    guessed_correct = sum(1 for ch in state.secret_word if ch in state.guessed_letters)
+    remaining = total_letters - guessed_correct
+
+    # Near-win: 75% or more revealed (≤25% remaining)
+    if remaining > 0 and remaining <= max(1, total_letters // 4):
+        return "🌷", "*"
+    # Progress: at least one correct guess
+    if guessed_correct > 0:
+        return "🌿", "*"
+    # Start: no guesses yet
+    return "🌱", "*"
+
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the current game state as a string.
+
+    Per SPEC.md section 9, in order:
+    1. Title with growth stage emoji/ascii
+    2. Masked word (display_word)
+    3. Guessed letters (sorted, space-separated)
+    4. Water (label + count, plus symbols)
+    5. Weeds (label + count, plus symbols)
+    6. Status message (from previous turn)
+
+    Accessibility (SPEC.md section 18): water and weeds always carry a text
+    label AND a count, never symbols alone.
+
+    Parameters
+    ----------
+    state : GameState
+        Current game state.
+    ascii_mode : bool
+        If True, use ASCII characters; if False, use emoji.
+
+    Returns
+    -------
+    str
+        The rendered display (no trailing newline).
+    """
+    emoji_stage, ascii_stage = _growth_stage(state)
+    stage_glyph = ascii_stage if ascii_mode else emoji_stage
+
+    lines = []
+
+    # Title
+    lines.append(f"{stage_glyph} Word Garden")
+    lines.append("")
+
+    # Word
+    word = display_word(state)
+    lines.append(f"Word:     {word}")
+
+    # Guessed letters (sorted)
+    if state.guessed_letters:
+        guessed_str = " ".join(sorted(state.guessed_letters))
+        lines.append(f"Guessed:  {guessed_str}")
+    else:
+        lines.append("Guessed:")
+
+    # Water with label and count
+    if ascii_mode:
+        water_symbols = "[" + "*" * state.remaining_water + "]"
+    else:
+        water_symbols = "💧" * state.remaining_water
+    lines.append(f"Water:    {state.remaining_water}/{state.max_water} {water_symbols}")
+
+    # Weeds with label and count
+    if ascii_mode:
+        weed_symbols = "[" + "-" * state.weed_count + "]"
+    else:
+        weed_symbols = "🌿" * state.weed_count
+    lines.append(f"Weeds:    {state.weed_count} {weed_symbols}")
+
+    # Status message (if any)
+    if state.status_message:
+        lines.append("")
+        lines.append(state.status_message)
+
+    return "\n".join(lines)
+
+
+def win_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the win screen per SPEC.md section 6.6.
+
+    Parameters
+    ----------
+    state : GameState
+        A game state with won=True.
+    ascii_mode : bool
+        If True, use ASCII characters; if False, use emoji.
+
+    Returns
+    -------
+    str
+        The win screen (no trailing newline).
+    """
+    glyph = "*" if ascii_mode else "🌻"
+    lines = [
+        f"{glyph} Bloom!",
+        "",
+        f"You guessed the word: {state.secret_word}",
+        "The garden is thriving.",
+    ]
+    return "\n".join(lines)
+
+
+def loss_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the loss screen per SPEC.md section 6.7.
+
+    Shows the secret word so the player knows what they missed.
+
+    Parameters
+    ----------
+    state : GameState
+        A game state with won=False and remaining_water <= 0.
+    ascii_mode : bool
+        If True, use ASCII characters; if False, use emoji.
+
+    Returns
+    -------
+    str
+        The loss screen (no trailing newline).
+    """
+    glyph = "*" if ascii_mode else "🥀"
+    lines = [
+        f"{glyph} The garden ran out of water.",
+        "",
+        f"The word was: {state.secret_word}",
+        "Try again and grow a new garden.",
+    ]
+    return "\n".join(lines)
