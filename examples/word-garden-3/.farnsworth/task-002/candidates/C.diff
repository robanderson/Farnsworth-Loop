+class TestMainEndToEndWin(unittest.TestCase):
+    """End-to-end test of main() with a scripted win."""
+
+    def test_main_end_to_end_win(self):
+        """Play a full game that ends in a win; verify win screen appears."""
+        # Force a win by pinning the word and guessing its letters.
+        # Use GARDEN (6 unique letters: G, A, R, D, E, N).
+        # On normal difficulty with 6 water, we can afford 0 wrong guesses,
+        # so we must guess only the letters in GARDEN.
+        import unittest.mock as mock
+        from word_garden import words
+
+        # Monkeypatch select_word to always return "GARDEN"
+        original_select = words.select_word
+        words.select_word = lambda difficulty="normal", rng=None: "GARDEN"
+
+        try:
+            # Input the unique letters of GARDEN in sorted order
+            inputs = list("ADENRG")  # Sorted unique letters of GARDEN
+            input_iter = iter(inputs)
+
+            def mock_input(prompt=""):
+                try:
+                    return next(input_iter)
+                except StopIteration:
+                    raise EOFError()
+
+            outputs = []
+
+            def mock_output(text=""):
+                outputs.append(text)
+
+            exit_code = main(
+                argv=["--difficulty", "normal"],
+                input_fn=mock_input,
+                output_fn=mock_output,
+            )
+
+            # Assertions per .code-tips.md:
+            # - Exit code is 0
+            self.assertEqual(exit_code, 0)
+
+            # - Win screen appeared (final output should contain "Bloom!")
+            final_output = "\n".join(outputs)
+            self.assertIn("Bloom!", final_output)
+            # - Word should be revealed in win screen
+            self.assertIn("GARDEN", final_output)
+        finally:
+            # Restore original function
+            words.select_word = original_select
+
