+"""Main game loop and entry point for Word Garden."""
+
+import argparse
+import sys
+
+from word_garden.game import (
+    GameState,
+    new_game,
+    validate_guess,
+    apply_guess,
+    is_won,
+    is_lost,
+)
+from word_garden.ui import render, win_screen, loss_screen
+
+
+def main(argv=None, input_fn=input, output_fn=print) -> int:
+    """Run the Word Garden game loop.
+
+    Per SPEC.md section 5, 9, 10, 15, 18, 20:
+    1. Parse arguments (--difficulty, --ascii).
+    2. Create new game with selected difficulty.
+    3. Loop: render state, prompt for guess, validate (re-prompt on invalid),
+       apply guess, repeat until game over.
+    4. Show win/loss screen.
+    5. Exit with code 0.
+
+    Handle EOF (Ctrl-D) and KeyboardInterrupt gracefully with friendly exit.
+
+    Parameters
+    ----------
+    argv : list[str] | None
+        Command-line arguments; defaults to sys.argv[1:].
+    input_fn : callable
+        Injectable input function (default: built-in input).
+    output_fn : callable
+        Injectable print function (default: built-in print).
+
+    Returns
+    -------
+    int
+        Exit code (0 on success).
+    """
+    # Parse arguments
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description="Word Garden — a friendly terminal word-guessing game.",
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty (default: normal)",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        help="Use ASCII-only output (no emoji)",
+    )
+
+    args = parser.parse_args(argv)
+
+    # Create new game
+    state = new_game(difficulty=args.difficulty)
+    ascii_mode = args.ascii
+
+    # Main game loop
+    try:
+        while not state.game_over:
+            # Render current state
+            output_fn(render(state, ascii_mode=ascii_mode))
+            output_fn("")
+
+            # Prompt for guess (re-prompt on invalid input)
+            while True:
+                try:
+                    user_input = input_fn("Guess a letter: ")
+                except EOFError:
+                    # User pressed Ctrl-D; exit gracefully
+                    output_fn("\nThanks for playing!")
+                    return 0
+                except KeyboardInterrupt:
+                    # User pressed Ctrl-C; exit gracefully
+                    output_fn("\nThanks for playing!")
+                    return 0
+
+                # Validate input
+                letter, error_msg = validate_guess(user_input)
+                if letter is None:
+                    # Invalid input; show message and re-prompt
+                    output_fn(error_msg)
+                    continue
+                break
+
+            # Apply validated guess
+            state = apply_guess(state, letter)
+            output_fn("")
+
+        # Game is over; show appropriate screen
+        if is_won(state):
+            output_fn(win_screen(state, ascii_mode=ascii_mode))
+        elif is_lost(state):
+            output_fn(loss_screen(state, ascii_mode=ascii_mode))
+
+    except KeyboardInterrupt:
+        # Catch any remaining KeyboardInterrupt from output operations
+        output_fn("\nThanks for playing!")
+        return 0
+
+    return 0
