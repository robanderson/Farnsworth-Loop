+class TestMainEndToEndLoss(unittest.TestCase):
+    """End-to-end test of main() with a scripted loss."""
+
+    def test_main_end_to_end_loss(self):
+        """Play a game designed to lose; verify loss screen appears."""
+        # On normal difficulty, water=6. Guess 6 or more wrong letters to lose.
+        # Use a long list of unlikely letters to ensure we hit water=0.
+        inputs = ["Z", "X", "Q", "K", "J", "W", "B", "V"]  # More than 6 wrong guesses
+        input_iter = iter(inputs)
+
+        def mock_input(prompt=""):
+            try:
+                return next(input_iter)
+            except StopIteration:
+                raise EOFError()
+
+        outputs = []
+
+        def mock_output(text=""):
+            outputs.append(text)
+
+        exit_code = main(
+            argv=["--difficulty", "normal"],
+            input_fn=mock_input,
+            output_fn=mock_output,
+        )
+
+        # Assertions:
+        # - Exit code is 0
+        self.assertEqual(exit_code, 0)
+
+        # - Loss screen appeared (final output should contain "ran out of water")
+        final_output = "\n".join(outputs)
+        self.assertIn("ran out of water", final_output)
+        # - Word should be revealed in loss screen
