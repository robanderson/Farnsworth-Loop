+"""Word list and selection logic for Word Garden."""
+
+import random
+from typing import Optional
+
+# The 10-word list from SPEC.md section 8, uppercase
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty filter criteria: (water, min_length, max_length)
+DIFFICULTY_TABLE = {
+    "easy": (8, 4, 6),
+    "normal": (6, 5, 8),
+    "hard": (4, 7, float("inf")),
+}
+
+
+def select_word(difficulty: str = "normal", rng: Optional[random.Random] = None) -> str:
+    """
+    Select a random word filtered by difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic tests.
+             If None, uses module-level random functions.
+
+    Returns:
+        A word from WORDS (uppercase) matching the difficulty filter.
+
+    Raises:
+        ValueError: If difficulty is unknown or no words match the filter.
+    """
+    if difficulty not in DIFFICULTY_TABLE:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    _water, min_len, max_len = DIFFICULTY_TABLE[difficulty]
+
+    # Filter words by length
+    filtered = [w for w in WORDS if min_len <= len(w) <= max_len]
+
+    if not filtered:
+        raise ValueError(f"No words available for difficulty: {difficulty}")
+
+    if rng is None:
+        return random.choice(filtered)
+    else:
+        return rng.choice(filtered)
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """
+    Return the starting water level for a given difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+
+    Returns:
+        Starting water amount.
+
+    Raises:
+        ValueError: If difficulty is unknown.
+    """
+    if difficulty not in DIFFICULTY_TABLE:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    water, _, _ = DIFFICULTY_TABLE[difficulty]
+    return water
