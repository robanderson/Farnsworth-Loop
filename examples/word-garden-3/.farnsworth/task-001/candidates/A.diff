+"""Unit tests for Word Garden game logic."""
+
+import unittest
+import random
+from word_garden import game
+from word_garden.game import (
+    GameState,
+    MSG_CORRECT_GUESS,
+    MSG_WRONG_GUESS,
+    MSG_REPEATED_GUESS,
+    MSG_INVALID_INPUT,
+    MSG_NOT_A_LETTER,
+    MSG_WIN,
+    MSG_LOSS,
+    MSG_ALREADY_WON,
+    MSG_ALREADY_LOST,
+)
+
+
+class TestCorrectGuess(unittest.TestCase):
+    """Test that a correct guess reveals matching letters."""
+
+    def test_correct_guess_reveals_letter(self):
+        """Correct guess should reveal all matching letters in the word."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "A")
+
+        # Assert positive outcomes
+        self.assertIn("A", new_state.guessed_letters)
+        self.assertEqual(new_state.remaining_water, 6)  # No water lost
+        self.assertEqual(new_state.weed_count, 0)  # No weeds added
+        self.assertEqual(new_state.status_message, MSG_CORRECT_GUESS)
+        self.assertFalse(new_state.game_over)
+
+
+class TestIncorrectGuess(unittest.TestCase):
+    """Test that an incorrect guess reduces water and increases weeds."""
+
+    def test_wrong_guess_costs_water(self):
+        """Wrong guess should reduce water by exactly 1."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "Z")
+
+        # Assert positive outcomes: water -1, weeds +1, letter recorded
+        self.assertEqual(new_state.remaining_water, 5)
+        self.assertEqual(new_state.weed_count, 1)
+        self.assertIn("Z", new_state.guessed_letters)
+        self.assertEqual(new_state.status_message, MSG_WRONG_GUESS)
+        self.assertFalse(new_state.game_over)
+
+    def test_wrong_guess_increases_weeds(self):
+        """Wrong guess should increase weeds by exactly 1."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "X")
+
+        self.assertEqual(new_state.weed_count, 1)
+        self.assertIn("X", new_state.guessed_letters)
+
+    def test_multiple_wrong_guesses(self):
+        """Multiple wrong guesses should accumulate water loss and weeds."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        state = game.apply_guess(state, "Z")
+        state = game.apply_guess(state, "X")
+
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.weed_count, 2)
+
+
+class TestRepeatedGuess(unittest.TestCase):
+    """Test that repeated guesses don't change water or weeds."""
+
+    def test_repeated_guess_no_penalty(self):
+        """Repeated guess should not change water or weeds."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"A"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "A")
+
+        # Assert no change to resources, but message explains it
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+        self.assertIn("already guessed", new_state.status_message)
+        self.assertFalse(new_state.game_over)
+
+    def test_repeated_guess_message(self):
+        """Repeated guess message should reference the letter."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"B"},
+            remaining_water=5,
+            weed_count=1,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "B")
+
+        self.assertEqual(new_state.status_message, MSG_REPEATED_GUESS.format(letter="B"))
+
+
+class TestInvalidInput(unittest.TestCase):
+    """Test that invalid input is rejected without changing state."""
+
+    def test_empty_input(self):
+        """Empty input should be rejected."""
+        letter, msg = game.validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_INVALID_INPUT)
+
+    def test_multiple_characters(self):
+        """Multiple characters should be rejected."""
+        letter, msg = game.validate_guess("abc")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_INVALID_INPUT)
+
+    def test_number_input(self):
+        """Numbers should be rejected as not a letter."""
+        letter, msg = game.validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_NOT_A_LETTER)
+
+    def test_symbol_input(self):
+        """Symbols should be rejected as not a letter."""
+        letter, msg = game.validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_NOT_A_LETTER)
+
+    def test_invalid_input_no_state_mutation(self):
+        """Invalid input should not mutate game state."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        letter, msg = game.validate_guess("abc")
+
+        # Invalid guess should return None, message
+        self.assertIsNone(letter)
+        # State unchanged
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+
+
+class TestLowercaseNormalization(unittest.TestCase):
+    """Test that lowercase input is normalized to uppercase."""
+
+    def test_lowercase_to_uppercase(self):
+        """Lowercase input should be converted to uppercase."""
+        letter, msg = game.validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_lowercase_with_spaces(self):
+        """Lowercase with spaces should be trimmed and uppercased."""
+        letter, msg = game.validate_guess("  z  ")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+
+class TestWinCondition(unittest.TestCase):
+    """Test that the game detects a win."""
+
+    def test_is_won_all_letters_guessed(self):
+        """Game should detect win when all letters are guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=3,
+            weed_count=1,
+            max_water=6,
+            game_over=False,
+            won=False,
+        )
+
+        self.assertTrue(game.is_won(state))
+
+    def test_win_sets_game_over_and_won_flags(self):
+        """Winning guess should set game_over and won flags."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E"},
+            remaining_water=3,
+            weed_count=1,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "N")
+
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+        self.assertEqual(new_state.status_message, MSG_WIN)
+
+    def test_win_with_minimal_water(self):
+        """Should be able to win even with water nearly depleted."""
+        state = GameState(
+            secret_word="CAT",
+            guessed_letters={"C", "A"},
+            remaining_water=1,
+            weed_count=5,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "T")
+
+        self.assertTrue(new_state.won)
+        self.assertTrue(new_state.game_over)
+
+
+class TestLossCondition(unittest.TestCase):
+    """Test that the game detects a loss."""
+
+    def test_is_lost_at_zero_water(self):
+        """Game should detect loss when water is at 0."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"X", "Y", "Z"},
+            remaining_water=0,
+            weed_count=3,
+            max_water=6,
+        )
+
+        self.assertTrue(game.is_lost(state))
+
+    def test_loss_sets_game_over_flag(self):
+        """Losing guess (last water) should set game_over and won=False."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"X"},
+            remaining_water=1,
+            weed_count=1,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "Y")
+
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+        self.assertEqual(new_state.status_message, MSG_LOSS)
+
+    def test_cannot_guess_after_loss(self):
+        """Guessing after water depleted should have no effect."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"X"},
+            remaining_water=0,
+            weed_count=1,
+            max_water=6,
+            game_over=True,
+            won=False,
+        )
+
+        new_state = game.apply_guess(state, "A")
+
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+        self.assertEqual(new_state.status_message, MSG_ALREADY_LOST)
+
+
+class TestDisplayWord(unittest.TestCase):
+    """Test that the displayed word masks unguessed letters."""
+
+    def test_display_word_all_masked(self):
+        """Unguessed word should be all underscores."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        displayed = game.display_word(state)
+
+        self.assertEqual(displayed, "_ _ _ _ _ _")
+
+    def test_display_word_partial_reveal(self):
+        """Partially guessed word should show correct letters."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "E"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        displayed = game.display_word(state)
+
+        self.assertEqual(displayed, "G A R _ E _")
+
+    def test_display_word_fully_guessed(self):
+        """Fully guessed word should show all letters."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        displayed = game.display_word(state)
+
+        self.assertEqual(displayed, "G A R D E N")
+
+
+class TestNewGame(unittest.TestCase):
+    """Test that new_game creates a valid initial state."""
+
+    def test_new_game_returns_game_state(self):
+        """new_game should return a GameState instance."""
+        state = game.new_game(difficulty="normal")
+        self.assertIsInstance(state, GameState)
+
+    def test_new_game_has_valid_word(self):
+        """new_game should select a word from the word list."""
+        from word_garden import words
+
+        state = game.new_game(difficulty="normal")
+
+        self.assertIn(state.secret_word, words.WORDS)
+
+    def test_new_game_empty_guessed_letters(self):
+        """new_game should start with no guessed letters."""
+        state = game.new_game(difficulty="normal")
+
+        self.assertEqual(state.guessed_letters, set())
+
+    def test_new_game_full_water(self):
+        """new_game should start with full water for difficulty."""
+        state = game.new_game(difficulty="normal")
+
+        self.assertEqual(state.remaining_water, state.max_water)
+
+    def test_new_game_zero_weeds(self):
+        """new_game should start with zero weeds."""
+        state = game.new_game(difficulty="normal")
+
+        self.assertEqual(state.weed_count, 0)
+
+    def test_new_game_not_game_over(self):
+        """new_game should start with game_over=False."""
+        state = game.new_game(difficulty="normal")
+
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_with_rng(self):
+        """new_game should accept deterministic rng for testing."""
+        rng = random.Random(42)
+        state = game.new_game(difficulty="normal", rng=rng)
+
+        self.assertIsInstance(state, GameState)
+        self.assertIn(state.secret_word, ["GARDEN", "FLOWER", "PLANET", "PYTHON",
+                                           "TERMINAL", "MEADOW", "ORCHARD",
+                                           "VINEYARD", "SEEDLING", "HARVEST"])
+
+
+class TestGameOverMessageUpdate(unittest.TestCase):
+    """Test that game_over updates both flags AND status message."""
+
+    def test_win_updates_all_state(self):
+        """Winning must set game_over, won, AND status message."""
+        state = GameState(
+            secret_word="CAT",
+            guessed_letters={"C", "A"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "T")
+
+        # Assert all three together
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+        self.assertEqual(new_state.status_message, MSG_WIN)
+
+    def test_loss_updates_all_state(self):
+        """Losing must set game_over, won=False, AND status message."""
+        state = GameState(
+            secret_word="PYTHON",
+            guessed_letters={"Z"},
+            remaining_water=1,
+            weed_count=0,
+            max_water=6,
+        )
+
+        new_state = game.apply_guess(state, "X")
+
+        # Assert all three together
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+        self.assertEqual(new_state.status_message, MSG_LOSS)
+
+
+if __name__ == "__main__":
+    unittest.main()
