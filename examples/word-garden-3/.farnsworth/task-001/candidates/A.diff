+"""Core game logic for Word Garden."""
+
+from dataclasses import dataclass, field
+from typing import Optional
+import random
+
+from . import words
+
+# Status messages as module-level constants
+MSG_CORRECT_GUESS = "Good guess! The garden grows."
+MSG_WRONG_GUESS = "No match. A weed appears."
+MSG_REPEATED_GUESS = "You already guessed {letter}. Try another letter."
+MSG_ALREADY_WON = "You have already won!"
+MSG_ALREADY_LOST = "The garden has run out of water."
+MSG_INVALID_INPUT = "Please enter a single letter."
+MSG_NOT_A_LETTER = "That is not a letter."
+MSG_WIN = "You guessed the word! The garden is thriving."
+MSG_LOSS = "The garden ran out of water."
+
+
+@dataclass
+class GameState:
+    """Game state for Word Garden.
+
+    Attributes:
+        secret_word: The word to be guessed (uppercase).
+        guessed_letters: Set of letters already guessed (uppercase).
+        remaining_water: Current water remaining.
+        weed_count: Current number of weeds.
+        max_water: Maximum water at game start.
+        status_message: Friendly message from the last action.
+        game_over: True if the game has ended.
+        won: True if the game was won (all letters guessed).
+    """
+
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng: Optional[random.Random] = None) -> GameState:
+    """Create a new game with a random word at the given difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic tests.
+
+    Returns:
+        A fresh GameState ready to play.
+    """
+    secret_word = words.select_word(difficulty=difficulty, rng=rng)
+    max_water = words.water_for(difficulty=difficulty)
+
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=set(),
+        remaining_water=max_water,
+        weed_count=0,
+        max_water=max_water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[Optional[str], str]:
+    """Validate a single letter guess from user input.
+
+    Args:
+        input_text: Raw user input.
+
+    Returns:
+        A tuple (letter, message):
+        - If valid: (uppercase_letter, "")
+        - If invalid: (None, helpful_error_message)
+
+    Note:
+        Validation does NOT check game state or repeated guesses.
+        Those are handled by apply_guess.
+    """
+    # Trim whitespace
+    trimmed = input_text.strip()
+
+    # Check for empty input
+    if not trimmed:
+        return (None, MSG_INVALID_INPUT)
+
+    # Check for exactly one character
+    if len(trimmed) != 1:
+        return (None, MSG_INVALID_INPUT)
+
+    # Check for alphabetic character
+    if not trimmed.isalpha():
+        return (None, MSG_NOT_A_LETTER)
+
+    # Return uppercase letter and empty message (valid)
+    return (trimmed.upper(), "")
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a validated uppercase letter guess to the game state.
+
+    Args:
+        state: Current GameState.
+        letter: A single uppercase letter (assumed already validated).
+
+    Returns:
+        Updated GameState with:
+        - guessed_letters updated
+        - water/weeds adjusted if wrong guess
+        - status_message set appropriately
+        - game_over/won set if the game ends
+
+    Behavior:
+        - Correct guess: Reveal letter, no water/weed cost, winning check.
+        - Wrong guess: Cost 1 water, +1 weed, loss check.
+        - Repeated guess: No water/weed change, friendly reminder.
+        - Guess after game over: No-op with status message.
+    """
+    # Import here to avoid circular dependency
+    from dataclasses import replace
+
+    # Check if game is already over
+    if state.game_over:
+        new_state = replace(state, status_message=MSG_ALREADY_WON if state.won else MSG_ALREADY_LOST)
+        return new_state
+
+    # Check for repeated guess
+    if letter in state.guessed_letters:
+        new_state = replace(state, status_message=MSG_REPEATED_GUESS.format(letter=letter))
+        return new_state
+
+    # Add letter to guessed set
+    new_guessed = state.guessed_letters | {letter}
+
+    # Check if letter is in the secret word
+    if letter in state.secret_word:
+        # Correct guess
+        new_state = replace(
+            state,
+            guessed_letters=new_guessed,
+            status_message=MSG_CORRECT_GUESS,
+        )
+    else:
+        # Wrong guess: cost water, add weed
+        new_water = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+        new_state = replace(
+            state,
+            guessed_letters=new_guessed,
+            remaining_water=new_water,
+            weed_count=new_weeds,
+            status_message=MSG_WRONG_GUESS,
+        )
+
+    # Check win/loss conditions after the guess
+    if is_won(new_state):
+        new_state = replace(
+            new_state,
+            game_over=True,
+            won=True,
+            status_message=MSG_WIN,
+        )
+    elif is_lost(new_state):
+        new_state = replace(
+            new_state,
+            game_over=True,
+            won=False,
+            status_message=MSG_LOSS,
+        )
+
+    return new_state
+
+
+def display_word(state: GameState) -> str:
+    """Display the secret word with guessed letters revealed and others masked.
+
+    Args:
+        state: Current GameState.
+
+    Returns:
+        Space-separated string, e.g. "G _ R _ E _"
+    """
+    displayed = [
+        letter if letter in state.guessed_letters else "_"
+        for letter in state.secret_word
+    ]
+    return " ".join(displayed)
+
+
+def is_won(state: GameState) -> bool:
+    """Check if all letters in the secret word have been guessed.
+
+    Args:
+        state: Current GameState.
+
+    Returns:
+        True if all letters are in guessed_letters, False otherwise.
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Check if the game is lost (water at 0 before word is complete).
+
+    Args:
+        state: Current GameState.
+
+    Returns:
+        True if water is 0 or less, False otherwise.
+    """
+    return state.remaining_water <= 0
