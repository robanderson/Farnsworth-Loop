+"""Unit tests for Word Garden word selection."""
+
+import unittest
+import random
+from word_garden import words
+
+
+class TestSelectWordDifficulties(unittest.TestCase):
+    """Test that word selection respects difficulty filters."""
+
+    def test_select_word_easy(self):
+        """Easy difficulty should select words of length 4-6."""
+        rng = random.Random(123)
+        word = words.select_word(difficulty="easy", rng=rng)
+
+        self.assertIn(word, words.WORDS)
+        self.assertGreaterEqual(len(word), 4)
+        self.assertLessEqual(len(word), 6)
+
+    def test_select_word_normal(self):
+        """Normal difficulty should select words of length 5-8."""
+        rng = random.Random(456)
+        word = words.select_word(difficulty="normal", rng=rng)
+
+        self.assertIn(word, words.WORDS)
+        self.assertGreaterEqual(len(word), 5)
+        self.assertLessEqual(len(word), 8)
+
+    def test_select_word_hard(self):
+        """Hard difficulty should select words of length 7+."""
+        rng = random.Random(789)
+        word = words.select_word(difficulty="hard", rng=rng)
+
+        self.assertIn(word, words.WORDS)
+        self.assertGreaterEqual(len(word), 7)
+
+    def test_select_word_deterministic(self):
+        """Same seed should produce same word."""
+        rng1 = random.Random(999)
+        word1 = words.select_word(difficulty="normal", rng=rng1)
+
+        rng2 = random.Random(999)
+        word2 = words.select_word(difficulty="normal", rng=rng2)
+
+        self.assertEqual(word1, word2)
+
+    def test_select_word_default_uses_module_random(self):
+        """select_word with rng=None should use module-level random."""
+        # Call without rng multiple times to verify it doesn't error
+        word1 = words.select_word(difficulty="normal", rng=None)
+        word2 = words.select_word(difficulty="normal", rng=None)
+
+        # Both should be valid words
+        self.assertIn(word1, words.WORDS)
+        self.assertIn(word2, words.WORDS)
+
+    def test_select_word_unknown_difficulty_raises(self):
+        """Unknown difficulty should raise ValueError."""
+        with self.assertRaises(ValueError) as context:
+            words.select_word(difficulty="impossible")
+
+        self.assertIn("Unknown difficulty", str(context.exception))
+
+
+class TestWaterFor(unittest.TestCase):
+    """Test that water_for returns correct values per difficulty."""
+
+    def test_water_for_easy(self):
+        """Easy should return 8 water."""
+        water = words.water_for(difficulty="easy")
+        self.assertEqual(water, 8)
+
+    def test_water_for_normal(self):
+        """Normal should return 6 water."""
+        water = words.water_for(difficulty="normal")
+        self.assertEqual(water, 6)
+
+    def test_water_for_hard(self):
+        """Hard should return 4 water."""
+        water = words.water_for(difficulty="hard")
+        self.assertEqual(water, 4)
+
+    def test_water_for_default(self):
+        """Default difficulty should be normal (6 water)."""
+        water = words.water_for()
+        self.assertEqual(water, 6)
+
+    def test_water_for_unknown_difficulty_raises(self):
+        """Unknown difficulty should raise ValueError."""
+        with self.assertRaises(ValueError) as context:
+            words.water_for(difficulty="unknown")
+
+        self.assertIn("Unknown difficulty", str(context.exception))
+
+
+class TestWordList(unittest.TestCase):
+    """Test that the word list is correct."""
+
+    def test_words_constant_exists(self):
+        """WORDS should be defined."""
+        self.assertTrue(hasattr(words, "WORDS"))
+
+    def test_words_has_ten_items(self):
+        """WORDS should have 10 items per SPEC section 8."""
+        self.assertEqual(len(words.WORDS), 10)
+
+    def test_words_are_uppercase(self):
+        """All words should be uppercase."""
+        for word in words.WORDS:
+            self.assertEqual(word, word.upper())
+
+    def test_words_are_strings(self):
+        """All words should be strings."""
+        for word in words.WORDS:
+            self.assertIsInstance(word, str)
+
+    def test_words_from_spec(self):
+        """Words should match the list in SPEC.md section 8."""
+        expected = [
+            "GARDEN",
+            "FLOWER",
+            "PLANET",
+            "PYTHON",
+            "TERMINAL",
+            "MEADOW",
+            "ORCHARD",
+            "VINEYARD",
+            "SEEDLING",
+            "HARVEST",
+        ]
+        self.assertEqual(words.WORDS, expected)
+
+
+if __name__ == "__main__":
+    unittest.main()
