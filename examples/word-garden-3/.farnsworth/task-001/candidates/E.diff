+"""Tests for word_garden/words.py (SPEC.md section 16, case 10)."""
+
+import random
+import unittest
+
+from word_garden.words import WORDS, select_word, water_for
+
+
+class TestWaterFor(unittest.TestCase):
+    """water_for returns the correct starting water per difficulty."""
+
+    def test_easy_water(self):
+        self.assertEqual(water_for("easy"), 8)
+
+    def test_normal_water(self):
+        self.assertEqual(water_for("normal"), 6)
+
+    def test_hard_water(self):
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            water_for("legendary")
+
+
+class TestSelectWord(unittest.TestCase):
+    """select_word returns a valid word for each difficulty (case 10)."""
+
+    def test_easy_word_in_list_and_correct_length(self):
+        rng = random.Random(42)
+        word = select_word("easy", rng=rng)
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 4)
+        self.assertLessEqual(len(word), 6)
+
+    def test_normal_word_in_list_and_correct_length(self):
+        rng = random.Random(42)
+        word = select_word("normal", rng=rng)
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 5)
+        self.assertLessEqual(len(word), 8)
+
+    def test_hard_word_in_list_and_correct_length(self):
+        rng = random.Random(42)
+        word = select_word("hard", rng=rng)
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 7)
+
+    def test_unknown_difficulty_raises(self):
+        """Unknown difficulty must raise ValueError, not silently return a word."""
+        with self.assertRaises(ValueError):
+            select_word("insane")
+
+    def test_deterministic_with_seeded_rng(self):
+        """Two calls with the same seed must return the same word."""
+        word_a = select_word("normal", rng=random.Random(7))
+        word_b = select_word("normal", rng=random.Random(7))
+        self.assertEqual(word_a, word_b)
+
+    def test_all_difficulties_return_words(self):
+        """Every recognised difficulty must succeed without error."""
+        for diff in ("easy", "normal", "hard"):
+            with self.subTest(difficulty=diff):
+                word = select_word(diff, rng=random.Random(0))
+                self.assertIn(word, WORDS)
