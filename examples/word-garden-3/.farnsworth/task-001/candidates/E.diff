+"""Core game logic for Word Garden (no I/O, no terminal dependency)."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+
+from word_garden import words as _words
+
+# ---------------------------------------------------------------------------
+# User-facing message strings (SPEC.md sections 6.3–6.7, 14)
+# Defined once here; tests import these constants directly.
+# ---------------------------------------------------------------------------
+
+MSG_CORRECT_GUESS: str = "Good guess! The garden grows."
+MSG_WRONG_GUESS: str = "No match. A weed appears."
+MSG_ALREADY_GUESSED: str = "You already guessed {letter}. Try another letter."
+MSG_WIN: str = "You guessed the word: {word}\nThe garden is thriving."
+MSG_LOSS: str = "The word was: {word}\nTry again and grow a new garden."
+MSG_GAME_OVER: str = "The game is already over."
+
+# Validation messages (SPEC.md section 14)
+MSG_INVALID_EMPTY: str = "Please enter a single letter."
+MSG_INVALID_MULTIPLE: str = "Please enter a single letter."
+MSG_INVALID_NOT_ALPHA: str = "That is not a letter."
+
+
+# ---------------------------------------------------------------------------
+# Game state
+# ---------------------------------------------------------------------------
+
+@dataclass
+class GameState:
+    """All mutable state for a single game of Word Garden (SPEC.md section 12)."""
+
+    secret_word: str
+    guessed_letters: set[str]
+    remaining_water: int
+    weed_count: int
+    max_water: int
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+# ---------------------------------------------------------------------------
+# Public API
+# ---------------------------------------------------------------------------
+
+def new_game(difficulty: str = "normal", rng=None) -> GameState:
+    """Start a fresh game for *difficulty*, picking a word via :mod:`words`.
+
+    Parameters
+    ----------
+    difficulty:
+        Passed straight through to :func:`words.select_word` and
+        :func:`words.water_for`.
+    rng:
+        Injectable :class:`random.Random` for deterministic tests.
+    """
+    word = _words.select_word(difficulty=difficulty, rng=rng).upper()
+    water = _words.water_for(difficulty=difficulty)
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[str | None, str]:
+    """Validate raw player input.
+
+    Trims whitespace and uppercases the input, then checks that it is
+    exactly one alphabetic character.
+
+    Returns
+    -------
+    ``(letter, "")``
+        When the input is valid.
+    ``(None, message)``
+        When the input is invalid; *message* describes the problem.
+
+    This function does **not** consult game state — repeated-guess detection
+    belongs to :func:`apply_guess`.
+    """
+    stripped = input_text.strip().upper()
+
+    if len(stripped) == 0:
+        return None, MSG_INVALID_EMPTY
+
+    if len(stripped) > 1:
+        return None, MSG_INVALID_MULTIPLE
+
+    if not stripped.isalpha():
+        return None, MSG_INVALID_NOT_ALPHA
+
+    return stripped, ""
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a single already-validated uppercase *letter* to *state*.
+
+    Handles correct, incorrect, and repeated guesses per SPEC.md sections
+    6.3–6.5.  Win and loss are detected and ``game_over``/``won`` set
+    accordingly.
+
+    Guessing after ``game_over`` is a no-op (state unchanged except for the
+    status message).
+
+    Returns a **new** :class:`GameState` — the original is not mutated.
+    """
+    if state.game_over:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=set(state.guessed_letters),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=MSG_GAME_OVER,
+            game_over=True,
+            won=state.won,
+        )
+
+    # Repeated guess — no state change except message
+    if letter in state.guessed_letters:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=set(state.guessed_letters),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=MSG_ALREADY_GUESSED.format(letter=letter),
+            game_over=False,
+            won=False,
+        )
+
+    new_guessed = set(state.guessed_letters) | {letter}
+
+    if letter in state.secret_word:
+        # Correct guess
+        new_water = state.remaining_water
+        new_weeds = state.weed_count
+
+        if _all_revealed(state.secret_word, new_guessed):
+            return GameState(
+                secret_word=state.secret_word,
+                guessed_letters=new_guessed,
+                remaining_water=new_water,
+                weed_count=new_weeds,
+                max_water=state.max_water,
+                status_message=MSG_WIN.format(word=state.secret_word),
+                game_over=True,
+                won=True,
+            )
+
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_water,
+            weed_count=new_weeds,
+            max_water=state.max_water,
+            status_message=MSG_CORRECT_GUESS,
+            game_over=False,
+            won=False,
+        )
+
+    else:
+        # Wrong guess
+        new_water = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+
+        if new_water <= 0:
+            return GameState(
+                secret_word=state.secret_word,
+                guessed_letters=new_guessed,
+                remaining_water=new_water,
+                weed_count=new_weeds,
+                max_water=state.max_water,
+                status_message=MSG_LOSS.format(word=state.secret_word),
+                game_over=True,
+                won=False,
+            )
+
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_water,
+            weed_count=new_weeds,
+            max_water=state.max_water,
+            status_message=MSG_WRONG_GUESS,
+            game_over=False,
+            won=False,
+        )
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word with revealed letters, space-separated.
+
+    Example: ``"G _ R _ E _"`` when G, R, E are guessed for ``"GARDEN"``.
+    """
+    return " ".join(
+        letter if letter in state.guessed_letters else "_"
+        for letter in state.secret_word
+    )
+
+
+def is_won(state: GameState) -> bool:
+    """Return True when all letters of the secret word have been guessed."""
+    return _all_revealed(state.secret_word, state.guessed_letters)
+
+
+def is_lost(state: GameState) -> bool:
+    """Return True when water has reached zero without a win."""
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+# ---------------------------------------------------------------------------
+# Internal helpers
+# ---------------------------------------------------------------------------
+
+def _all_revealed(secret_word: str, guessed: set[str]) -> bool:
+    """Return True if every letter in *secret_word* is in *guessed*."""
+    return all(letter in guessed for letter in secret_word)
