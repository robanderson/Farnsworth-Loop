+++ b/word_garden/game.py
@@ -0,0 +1,158 @@
+"""Core game logic for Word Garden.
+
+Pure, stdlib-only. No ``input()``, no ``print()``, no main loop. Every
+function here is a pure transformation over :class:`GameState`, so the engine
+is fully testable without a terminal (SPEC.md section 16). The UI (task-002)
+builds on these functions and imports the message constants below rather than
+re-typing them.
+"""
+
+from __future__ import annotations
+
+import random
+from dataclasses import dataclass, field
+
+from . import words
+
+# --- User-facing message constants (defined once; imported by UI and tests) ---
+
+# Turn feedback (SPEC.md sections 6.3-6.5).
+MSG_CORRECT = "Good guess! The garden grows."
+MSG_WRONG = "No match. A weed appears."
+# Repeated-guess and validation messages take the offending letter, so they are
+# templates formatted with ``.format(letter=...)``.
+MSG_ALREADY_GUESSED = "You already guessed {letter}. Try another letter."
+
+# Terminal messages (SPEC.md sections 6.6-6.7). These MUST be set as the
+# status_message when the game ends, not only the boolean flags.
+MSG_WIN = "Bloom! You guessed the word: {word}. The garden is thriving."
+MSG_LOSS = (
+    "The garden ran out of water. The word was: {word}. "
+    "Try again and grow a new garden."
+)
+MSG_GAME_OVER = "The game is over. Start a new garden to keep playing."
+
+# Validation messages (SPEC.md section 14). Returned by ``validate_guess``.
+MSG_EMPTY = "Please enter a single letter."
+MSG_TOO_LONG = "Please enter just one letter."
+MSG_NOT_LETTER = "That is not a letter. Please enter a letter A-Z."
+
+
+@dataclass
+class GameState:
+    """Mutable game state (SPEC.md section 12).
+
+    Field names and order match the spec exactly so downstream code can rely
+    on the contract. ``apply_guess`` mutates and returns the same instance for
+    convenience.
+    """
+
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng: random.Random | None = None) -> GameState:
+    """Create a fresh :class:`GameState` for ``difficulty``.
+
+    Picks the secret word via :func:`words.select_word` (uppercased), fills
+    water to the difficulty maximum, and starts with zero weeds and no guesses.
+    ``rng`` is forwarded for deterministic word selection. Raises ``ValueError``
+    for an unknown difficulty.
+    """
+    secret = words.select_word(difficulty, rng=rng).upper()
+    water = words.water_for(difficulty)
+    return GameState(
+        secret_word=secret,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[str | None, str]:
+    """Validate raw guess input without consulting game state.
+
+    Returns ``(letter, "")`` for valid input -- trimmed, uppercased, exactly
+    one alphabetic character -- or ``(None, message)`` with a specific, helpful
+    message (SPEC.md section 14). Repeated-guess detection is NOT done here; it
+    belongs to :func:`apply_guess`.
+    """
+    if input_text is None:
+        return None, MSG_EMPTY
+    trimmed = input_text.strip()
+    if not trimmed:
+        return None, MSG_EMPTY
+    if len(trimmed) > 1:
+        return None, MSG_TOO_LONG
+    if not trimmed.isalpha():
+        return None, MSG_NOT_LETTER
+    return trimmed.upper(), ""
+
+
+def is_won(state: GameState) -> bool:
+    """Return True when every letter of the secret word has been guessed."""
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Return True when water has run out before the word was completed."""
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word, space-separated (e.g. ``G _ R _ E _``)."""
+    return " ".join(
+        letter if letter in state.guessed_letters else "_"
+        for letter in state.secret_word
+    )
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply one already-validated uppercase ``letter`` to ``state``.
+
+    Implements SPEC.md sections 6.3-6.5. A correct guess reveals letters with
+    no water/weed change; a wrong guess costs 1 water and adds 1 weed; a
+    repeated guess changes nothing but the message. Sets ``status_message`` and,
+    when the guess ends the game, the terminal message plus ``game_over``/
+    ``won``. Guessing after ``game_over`` is a no-op with a message. Mutates and
+    returns the same ``state`` instance.
+    """
+    if state.game_over:
+        state.status_message = MSG_GAME_OVER
+        return state
+
+    if letter in state.guessed_letters:
+        # Repeated guess: nothing changes but the message (SPEC.md 6.5).
+        state.status_message = MSG_ALREADY_GUESSED.format(letter=letter)
+        return state
+
+    state.guessed_letters.add(letter)
+
+    if letter in state.secret_word:
+        # Correct guess (SPEC.md 6.3): reveal, no resource change.
+        state.status_message = MSG_CORRECT
+    else:
+        # Incorrect guess (SPEC.md 6.4): lose water, gain a weed.
+        state.remaining_water -= 1
+        state.weed_count += 1
+        state.status_message = MSG_WRONG
+
+    # A win takes precedence over a loss: revealing the final letter wins even
+    # if it was the move that would otherwise be checked for water.
+    if is_won(state):
+        state.won = True
+        state.game_over = True
+        state.status_message = MSG_WIN.format(word=state.secret_word)
+    elif is_lost(state):
+        state.won = False
+        state.game_over = True
+        state.status_message = MSG_LOSS.format(word=state.secret_word)
+
+    return state
