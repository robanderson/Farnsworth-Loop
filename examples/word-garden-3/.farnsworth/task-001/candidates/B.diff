@@ -0,0 +1,97 @@
+"""Word list and word selection for Word Garden.
+
+Pure, stdlib-only. No I/O. All randomness is injectable via an optional
+``random.Random`` instance so callers (and tests) can be deterministic.
+"""
+
+from __future__ import annotations
+
+import random
+
+# The built-in word list (SPEC.md section 8), uppercase. Easy to extend or
+# replace: keep entries uppercase, alphabetic, and free of the qualities the
+# spec warns against (offensive, obscure, ambiguous, proper nouns, too short).
+WORDS: list[str] = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty table (SPEC.md section 7). Each entry pins the starting water and
+# an inclusive length window ``(min_len, max_len)``; ``None`` means unbounded.
+DIFFICULTIES: dict[str, dict[str, object]] = {
+    "easy": {"water": 8, "min_len": 4, "max_len": 6},
+    "normal": {"water": 6, "min_len": 5, "max_len": 8},
+    "hard": {"water": 4, "min_len": 7, "max_len": None},
+}
+
+# User-facing / error message templates, defined once (see .code-tips.md).
+UNKNOWN_DIFFICULTY_MSG = (
+    "Unknown difficulty {difficulty!r}. Expected one of: {choices}."
+)
+EMPTY_POOL_MSG = (
+    "No words match difficulty {difficulty!r} (length window {window})."
+)
+
+
+def _difficulty_config(difficulty: str) -> dict[str, object]:
+    """Return the config row for ``difficulty`` or raise ``ValueError``."""
+    try:
+        return DIFFICULTIES[difficulty]
+    except KeyError:
+        choices = ", ".join(sorted(DIFFICULTIES))
+        raise ValueError(
+            UNKNOWN_DIFFICULTY_MSG.format(difficulty=difficulty, choices=choices)
+        ) from None
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return the starting water for ``difficulty`` (SPEC.md section 7).
+
+    Raises ``ValueError`` for an unknown difficulty.
+    """
+    config = _difficulty_config(difficulty)
+    return int(config["water"])
+
+
+def words_for(difficulty: str = "normal") -> list[str]:
+    """Return the words eligible for ``difficulty``, filtered by length.
+
+    Raises ``ValueError`` for an unknown difficulty or an empty pool. Never
+    falls back to the unfiltered list (see .code-tips.md).
+    """
+    config = _difficulty_config(difficulty)
+    min_len = config["min_len"]
+    max_len = config["max_len"]
+
+    eligible = [
+        word
+        for word in WORDS
+        if (min_len is None or len(word) >= min_len)
+        and (max_len is None or len(word) <= max_len)
+    ]
+    if not eligible:
+        window = f"{min_len}-{'inf' if max_len is None else max_len}"
+        raise ValueError(
+            EMPTY_POOL_MSG.format(difficulty=difficulty, window=window)
+        )
+    return eligible
+
+
+def select_word(difficulty: str = "normal", rng: random.Random | None = None) -> str:
+    """Return a random uppercase word valid for ``difficulty``.
+
+    ``rng`` is an injectable ``random.Random`` for deterministic selection;
+    when ``None`` the module-level ``random`` functions are used. Raises
+    ``ValueError`` for an unknown difficulty or an empty pool.
+    """
+    eligible = words_for(difficulty)
+    chooser = random.choice if rng is None else rng.choice
+    return chooser(eligible).upper()
