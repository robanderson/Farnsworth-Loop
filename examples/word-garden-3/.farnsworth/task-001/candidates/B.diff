+"""Tests for word_garden.game.
+
+Covers SPEC.md section 16 cases (UI-free): correct/incorrect guesses, repeats,
+invalid input, lowercase normalization, win, loss, display masking. Fixtures
+are built by constructing GameState directly with pinned values (per
+.code-tips.md) -- never by calling the random factory and overwriting.
+Message assertions import the module-level constants.
+"""
+
+import random
+import unittest
+
+from word_garden import words
+from word_garden.game import (
+    MSG_ALREADY_GUESSED,
+    MSG_CORRECT,
+    MSG_EMPTY,
+    MSG_GAME_OVER,
+    MSG_LOSS,
+    MSG_NOT_LETTER,
+    MSG_TOO_LONG,
+    MSG_WIN,
+    MSG_WRONG,
+    GameState,
+    apply_guess,
+    display_word,
+    is_lost,
+    is_won,
+    new_game,
+    validate_guess,
+)
+
+
+def make_state(
+    secret="GARDEN",
+    guessed=None,
+    water=6,
+    weeds=0,
+    max_water=6,
+    status="",
+    game_over=False,
+    won=False,
+):
+    """Construct a GameState directly with pinned values (no random factory)."""
+    return GameState(
+        secret_word=secret,
+        guessed_letters=set(guessed or ()),
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=max_water,
+        status_message=status,
+        game_over=game_over,
+        won=won,
+    )
+
+
+class NewGameTests(unittest.TestCase):
+    def test_new_game_initial_state(self):
+        state = new_game("normal", rng=random.Random(42))
+        self.assertIn(state.secret_word, words.words_for("normal"))
+        self.assertTrue(state.secret_word.isupper())
+        self.assertEqual(state.guessed_letters, set())
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_water_follows_difficulty(self):
+        easy = new_game("easy", rng=random.Random(1))
+        hard = new_game("hard", rng=random.Random(1))
+        self.assertEqual(easy.remaining_water, 8)
+        self.assertEqual(easy.max_water, 8)
+        self.assertEqual(hard.remaining_water, 4)
+
+    def test_new_game_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            new_game("bogus", rng=random.Random(1))
+
+
+class ValidateGuessTests(unittest.TestCase):
+    def test_valid_lowercase_is_normalized(self):
+        # SPEC.md section 16 case 6: lowercase input normalized.
+        letter, message = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(message, "")
+
+    def test_valid_strips_whitespace(self):
+        letter, message = validate_guess("  z  ")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(message, "")
+
+    def test_empty_input_rejected(self):
+        letter, message = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_EMPTY)
+
+    def test_whitespace_only_rejected(self):
+        letter, message = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_EMPTY)
+
+    def test_multiple_characters_rejected(self):
+        letter, message = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_TOO_LONG)
+
+    def test_number_rejected(self):
+        letter, message = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_NOT_LETTER)
+
+    def test_symbol_rejected(self):
+        letter, message = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(message, MSG_NOT_LETTER)
+
+    def test_validation_does_not_consult_state(self):
+        # validate_guess takes only text; an already-guessed letter still
+        # validates fine here (repeat detection is apply_guess's job).
+        letter, message = validate_guess("A")
+        self.assertEqual((letter, message), ("A", ""))
+
+
+class ApplyGuessCorrectTests(unittest.TestCase):
+    def test_correct_guess_reveals_and_keeps_resources(self):
+        # SPEC.md section 16 case 1: correct guess reveals matching letters.
+        state = make_state(secret="GARDEN", water=6, weeds=0)
+        apply_guess(state, "G")
+        self.assertIn("G", state.guessed_letters)
+        self.assertEqual(state.remaining_water, 6)  # unchanged
+        self.assertEqual(state.weed_count, 0)  # unchanged
+        self.assertEqual(state.status_message, MSG_CORRECT)
+        self.assertFalse(state.game_over)
+        # Reveal shows the letter in every matching position.
+        self.assertEqual(display_word(state), "G _ _ _ _ _")
+
+
+class ApplyGuessWrongTests(unittest.TestCase):
+    def test_wrong_guess_costs_water_and_adds_weed_and_records_letter(self):
+        # SPEC.md section 16 cases 2 & 3, positive combined assertion.
+        state = make_state(secret="GARDEN", water=6, weeds=0)
+        apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, 5)  # down by exactly 1
+        self.assertEqual(state.weed_count, 1)  # up by exactly 1
+        self.assertIn("Z", state.guessed_letters)  # letter recorded
+        self.assertEqual(state.status_message, MSG_WRONG)
+        self.assertFalse(state.game_over)
+
+
+class ApplyGuessRepeatTests(unittest.TestCase):
+    def test_repeat_guess_changes_nothing_but_message(self):
+        # SPEC.md section 16 case 4: repeated guesses do not reduce water.
+        state = make_state(secret="GARDEN", guessed={"Z"}, water=5, weeds=1)
+        apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, 5)  # unchanged
+        self.assertEqual(state.weed_count, 1)  # unchanged
+        self.assertEqual(state.guessed_letters, {"Z"})  # unchanged
+        self.assertEqual(
+            state.status_message, MSG_ALREADY_GUESSED.format(letter="Z")
+        )
+        self.assertIn("Z", state.status_message)
+
+
+class DisplayWordTests(unittest.TestCase):
+    def test_display_masks_unguessed_letters(self):
+        # SPEC.md section 16 case 9.
+        state = make_state(secret="GARDEN", guessed={"G", "R", "E"})
+        self.assertEqual(display_word(state), "G _ R _ E _")
+
+    def test_display_all_masked_initially(self):
+        state = make_state(secret="GARDEN")
+        self.assertEqual(display_word(state), "_ _ _ _ _ _")
+
+    def test_display_fully_revealed(self):
+        state = make_state(secret="GARDEN", guessed=set("GARDEN"))
+        self.assertEqual(display_word(state), "G A R D E N")
+
+
+class WinTests(unittest.TestCase):
+    def test_win_detected_and_terminal_message_set(self):
+        # SPEC.md section 16 case 7: detect a win. Last letter completes word.
+        state = make_state(
+            secret="SUN", guessed={"S", "U"}, water=6, weeds=0
+        )
+        self.assertFalse(is_won(state))
+        apply_guess(state, "N")
+        self.assertTrue(is_won(state))
+        self.assertTrue(state.won)
+        self.assertTrue(state.game_over)
+        # Terminal message replaces mid-game feedback (.code-tips.md).
+        self.assertEqual(state.status_message, MSG_WIN.format(word="SUN"))
+        self.assertIn("SUN", state.status_message)
+        self.assertNotEqual(state.status_message, MSG_CORRECT)
+
+    def test_win_via_full_play_through(self):
+        # End-to-end success path: force a known scenario and assert the win
+        # artifact actually appeared (.code-tips.md).
+        state = make_state(secret="VINE", water=6, weeds=0, max_water=6)
+        for letter in ("V", "I", "N", "E"):
+            apply_guess(state, letter)
+        self.assertTrue(state.won)
+        self.assertTrue(state.game_over)
+        self.assertEqual(display_word(state), "V I N E")
+        self.assertEqual(state.status_message, MSG_WIN.format(word="VINE"))
+
+
+class LossTests(unittest.TestCase):
+    def test_loss_detected_and_terminal_message_set(self):
+        # SPEC.md section 16 case 8: detect a loss when last water is spent.
+        state = make_state(secret="GARDEN", guessed={"X", "Y"}, water=1, weeds=2)
+        self.assertFalse(is_lost(state))
+        apply_guess(state, "Z")  # wrong -> water hits 0
+        self.assertEqual(state.remaining_water, 0)
+        self.assertEqual(state.weed_count, 3)
+        self.assertTrue(is_lost(state))
+        self.assertTrue(state.game_over)
+        self.assertFalse(state.won)
+        self.assertEqual(state.status_message, MSG_LOSS.format(word="GARDEN"))
+        self.assertIn("GARDEN", state.status_message)
+        self.assertNotEqual(state.status_message, MSG_WRONG)
+
+    def test_win_takes_precedence_over_water_zero(self):
+        # Revealing the final letter wins even though it is unrelated to water;
+        # guard the win/loss ordering.
+        state = make_state(secret="GO", guessed={"G"}, water=1, weeds=5)
+        apply_guess(state, "O")  # correct, completes word, no water change
+        self.assertTrue(state.won)
+        self.assertTrue(state.game_over)
+        self.assertEqual(state.status_message, MSG_WIN.format(word="GO"))
+
+
+class GameOverNoOpTests(unittest.TestCase):
+    def test_guess_after_game_over_is_noop_with_message(self):
+        state = make_state(
+            secret="GARDEN",
+            guessed=set("GARDEN"),
+            water=4,
+            weeds=2,
+            game_over=True,
+            won=True,
+            status=MSG_WIN.format(word="GARDEN"),
+        )
+        apply_guess(state, "Q")
+        self.assertEqual(state.remaining_water, 4)  # unchanged
+        self.assertEqual(state.weed_count, 2)  # unchanged
+        self.assertNotIn("Q", state.guessed_letters)  # not recorded
+        self.assertEqual(state.status_message, MSG_GAME_OVER)
+
+
+if __name__ == "__main__":
+    unittest.main()
