+"""Tests for word_garden.words (word list, difficulty filtering, selection)."""
+
+import random
+import unittest
+
+from word_garden import words
+from word_garden.words import (
+    EMPTY_POOL_MSG,
+    UNKNOWN_DIFFICULTY_MSG,
+    WORDS,
+    select_word,
+    water_for,
+    words_for,
+)
+
+
+class WordListTests(unittest.TestCase):
+    def test_word_list_matches_spec(self):
+        # SPEC.md section 8: exactly these ten words, uppercase.
+        expected = [
+            "GARDEN",
+            "FLOWER",
+            "PLANET",
+            "PYTHON",
+            "TERMINAL",
+            "MEADOW",
+            "ORCHARD",
+            "VINEYARD",
+            "SEEDLING",
+            "HARVEST",
+        ]
+        self.assertEqual(WORDS, expected)
+        self.assertTrue(all(w.isupper() and w.isalpha() for w in WORDS))
+
+
+class WaterForTests(unittest.TestCase):
+    def test_water_per_difficulty(self):
+        # SPEC.md section 7 table.
+        self.assertEqual(water_for("easy"), 8)
+        self.assertEqual(water_for("normal"), 6)
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_default_is_normal(self):
+        self.assertEqual(water_for(), 6)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError) as ctx:
+            water_for("nightmare")
+        self.assertIn("nightmare", str(ctx.exception))
+
+
+class WordsForTests(unittest.TestCase):
+    def test_easy_pool_is_length_4_to_6(self):
+        pool = words_for("easy")
+        self.assertTrue(pool)
+        self.assertTrue(all(4 <= len(w) <= 6 for w in pool))
+        # GARDEN (6) qualifies; SEEDLING (8) and VINEYARD (8) do not.
+        self.assertIn("GARDEN", pool)
+        self.assertNotIn("SEEDLING", pool)
+
+    def test_normal_pool_is_length_5_to_8(self):
+        pool = words_for("normal")
+        self.assertTrue(pool)
+        self.assertTrue(all(5 <= len(w) <= 8 for w in pool))
+
+    def test_hard_pool_is_length_7_plus(self):
+        pool = words_for("hard")
+        self.assertTrue(pool)
+        self.assertTrue(all(len(w) >= 7 for w in pool))
+        # GARDEN (6) is excluded; TERMINAL (8) is included.
+        self.assertNotIn("GARDEN", pool)
+        self.assertIn("TERMINAL", pool)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            words_for("medium")
+
+
+class SelectWordTests(unittest.TestCase):
+    def test_select_returns_valid_word_for_every_difficulty(self):
+        # SPEC.md section 16 case 10: selector returns a valid word.
+        rng = random.Random(1234)
+        for difficulty in ("easy", "normal", "hard"):
+            word = select_word(difficulty, rng=rng)
+            self.assertIn(word, words_for(difficulty))
+            self.assertTrue(word.isupper())
+
+    def test_select_is_deterministic_with_injected_rng(self):
+        a = select_word("normal", rng=random.Random(7))
+        b = select_word("normal", rng=random.Random(7))
+        self.assertEqual(a, b)
+        self.assertIn(a, words_for("normal"))
+
+    def test_select_uses_module_random_when_rng_none(self):
+        # Default path returns a real, valid normal-difficulty word.
+        word = select_word("normal")
+        self.assertIn(word, words_for("normal"))
+
+    def test_select_respects_difficulty_filter(self):
+        # Every selection under "hard" must be a length-7+ word, across many
+        # draws, proving the filter is applied (not a silent unfiltered fallback).
+        rng = random.Random(99)
+        for _ in range(50):
+            word = select_word("hard", rng=rng)
+            self.assertGreaterEqual(len(word), 7)
+
+    def test_select_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            select_word("impossible", rng=random.Random(0))
+
+    def test_message_constants_used_by_source(self):
+        # Guard against message-template rot: the raised text comes from the
+        # module-level constants, not a re-typed literal.
+        self.assertIn("{difficulty", UNKNOWN_DIFFICULTY_MSG)
+        self.assertIn("{difficulty", EMPTY_POOL_MSG)
+
+
+if __name__ == "__main__":
+    unittest.main()
