+"""Word Garden -- a friendly terminal word-guessing game.
+
+This package holds the pure game engine. ``words`` provides the word list and
+difficulty-aware selection; ``game`` provides the state model and guess logic.
+Neither module performs I/O, so the engine is fully testable without a terminal.
+"""
+
+from . import game, words
+from .game import (
+    MSG_ALREADY_GUESSED,
+    MSG_CORRECT,
+    MSG_EMPTY,
+    MSG_GAME_OVER,
+    MSG_LOSS,
+    MSG_NOT_LETTER,
+    MSG_TOO_LONG,
+    MSG_WIN,
+    MSG_WRONG,
+    GameState,
+    apply_guess,
+    display_word,
+    is_lost,
+    is_won,
+    new_game,
+    validate_guess,
+)
+from .words import WORDS, select_word, water_for, words_for
+
+__all__ = [
+    "game",
+    "words",
+    "GameState",
+    "new_game",
+    "validate_guess",
+    "apply_guess",
+    "display_word",
+    "is_won",
+    "is_lost",
+    "WORDS",
+    "select_word",
+    "water_for",
+    "words_for",
+    "MSG_CORRECT",
+    "MSG_WRONG",
+    "MSG_ALREADY_GUESSED",
+    "MSG_WIN",
+    "MSG_LOSS",
+    "MSG_GAME_OVER",
+    "MSG_EMPTY",
+    "MSG_TOO_LONG",
+    "MSG_NOT_LETTER",
+]
