+class TestGameState(unittest.TestCase):
+    """Test GameState dataclass."""
+
+    def test_gamestate_creation(self):
+        """GameState should be creatable with required fields."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+            status_message="",
+            game_over=False,
+            won=False,
+        )
+        self.assertEqual(state.secret_word, "GARDEN")
+        self.assertEqual(state.guessed_letters, set())
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(state.max_water, 6)
+
+    def test_gamestate_field_names(self):
+        """GameState should have exactly the fields from SPEC section 12."""
+        expected_fields = {
+            "secret_word",
+            "guessed_letters",
+            "remaining_water",
+            "weed_count",
+            "max_water",
+            "status_message",
+            "game_over",
+            "won",
+        }
+        actual_fields = {f.name for f in game.GameState.__dataclass_fields__.values()}
+        self.assertEqual(actual_fields, expected_fields)
+
