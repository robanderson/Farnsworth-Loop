+class TestValidateGuess(unittest.TestCase):
+    """Test validate_guess function."""
+
+    def test_valid_lowercase_letter(self):
+        """Lowercase letter should be valid and uppercased."""
+        letter, message = game.validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(message, "")
+
+    def test_valid_uppercase_letter(self):
+        """Uppercase letter should be valid."""
+        letter, message = game.validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(message, "")
+
+    def test_valid_letter_with_whitespace(self):
+        """Letter with leading/trailing whitespace should be trimmed and valid."""
+        letter, message = game.validate_guess("  a  ")
+        self.assertEqual(letter, "A")
+        self.assertEqual(message, "")
+
+    def test_invalid_empty_input(self):
+        """Empty input should be invalid."""
+        letter, message = game.validate_guess("")
+        self.assertIsNone(letter)
+        self.assertNotEqual(message, "")
+
+    def test_invalid_empty_input_with_spaces(self):
+        """Input with only spaces should be treated as empty."""
+        letter, message = game.validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertNotEqual(message, "")
+
+    def test_invalid_multiple_characters(self):
+        """Multiple characters should be invalid."""
+        letter, message = game.validate_guess("ab")
+        self.assertIsNone(letter)
+        self.assertNotEqual(message, "")
+
+    def test_invalid_number(self):
+        """Numbers should be invalid."""
+        letter, message = game.validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertNotEqual(message, "")
+
+    def test_invalid_symbol(self):
+        """Symbols should be invalid."""
+        letter, message = game.validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertNotEqual(message, "")
+
+    def test_invalid_word(self):
+        """Words should be invalid."""
+        letter, message = game.validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertNotEqual(message, "")
