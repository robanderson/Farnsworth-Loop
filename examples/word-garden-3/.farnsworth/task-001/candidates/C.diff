+        self.assertTrue(new_state.game_over)
+
+
+class TestEndToEndScenarios(unittest.TestCase):
+    """Test complete game scenarios."""
+
+    def test_complete_win_game(self):
+        """Complete scenario: start game and win by guessing all letters."""
+        # Use a fixed word for determinism
+        state = game.GameState(
+            secret_word="CAT",
+            guessed_letters=set(),
+            remaining_water=8,
+            weed_count=0,
+            max_water=8,
+        )
+
+        # Guess C (correct)
+        state = game.apply_guess(state, "C")
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+        # Guess A (correct)
+        state = game.apply_guess(state, "A")
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+        # Guess T (correct, should win)
+        state = game.apply_guess(state, "T")
+        self.assertTrue(state.game_over)
+        self.assertTrue(state.won)
+
+    def test_complete_loss_game(self):
+        """Complete scenario: start game and lose by running out of water."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=2,
+            weed_count=0,
+            max_water=2,
+        )
+
+        # Guess X (wrong)
+        state = game.apply_guess(state, "X")
+        self.assertEqual(state.remaining_water, 1)
+        self.assertFalse(state.game_over)
+
+        # Guess Y (wrong)
+        state = game.apply_guess(state, "Y")
+        self.assertEqual(state.remaining_water, 0)
+        self.assertTrue(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_game_with_mixed_guesses(self):
+        """Complete scenario with mix of correct and incorrect guesses."""
+        state = game.GameState(
+            secret_word="DOG",
+            guessed_letters=set(),
+            remaining_water=5,
+            weed_count=0,
+            max_water=5,
+        )
+
+        # Guess D (correct)
+        state = game.apply_guess(state, "D")
+        self.assertEqual(state.remaining_water, 5)
+        self.assertEqual(state.weed_count, 0)
+
+        # Guess X (wrong)
+        state = game.apply_guess(state, "X")
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.weed_count, 1)
+
+        # Guess O (correct)
+        state = game.apply_guess(state, "O")
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.weed_count, 1)
+
+        # Guess D again (repeat)
+        state = game.apply_guess(state, "D")
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.weed_count, 1)
+
+        # Guess G (correct, should win)
+        state = game.apply_guess(state, "G")
+        self.assertTrue(state.won)
+        self.assertTrue(state.game_over)
+
+
+if __name__ == "__main__":
+    unittest.main()
