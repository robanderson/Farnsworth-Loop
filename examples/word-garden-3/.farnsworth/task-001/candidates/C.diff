+class TestDisplayWord(unittest.TestCase):
+    """Test display_word function."""
+
+    def test_display_word_no_guesses(self):
+        """With no guesses, all letters should be masked."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
