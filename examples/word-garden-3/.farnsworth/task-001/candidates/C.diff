@@ -0,0 +1,88 @@
+"""Word list and selection logic for Word Garden."""
+
+import random
+from typing import Optional
+
+# Word list from SPEC.md section 8
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty settings per SPEC.md section 7
+DIFFICULTY_SETTINGS = {
+    "easy": {"water": 8, "min_length": 4, "max_length": 6},
+    "normal": {"water": 6, "min_length": 5, "max_length": 8},
+    "hard": {"water": 4, "min_length": 7, "max_length": float("inf")},
+}
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return starting water for the given difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+
+    Returns:
+        Starting water amount for the difficulty.
+
+    Raises:
+        ValueError: If difficulty is not recognized.
+    """
+    if difficulty not in DIFFICULTY_SETTINGS:
+        raise ValueError(
+            f"Unknown difficulty: {difficulty}. "
+            f"Must be one of {list(DIFFICULTY_SETTINGS.keys())}."
+        )
+    return DIFFICULTY_SETTINGS[difficulty]["water"]
+
+
+def select_word(difficulty: str = "normal", rng: Optional[random.Random] = None) -> str:
+    """Select a random word filtered by difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic testing.
+             If None, uses module-level random functions.
+
+    Returns:
+        A randomly selected word matching the difficulty constraints.
+
+    Raises:
+        ValueError: If difficulty is not recognized or no words match the criteria.
+    """
+    if difficulty not in DIFFICULTY_SETTINGS:
+        raise ValueError(
+            f"Unknown difficulty: {difficulty}. "
+            f"Must be one of {list(DIFFICULTY_SETTINGS.keys())}."
+        )
+
+    settings = DIFFICULTY_SETTINGS[difficulty]
+    min_len = settings["min_length"]
+    max_len = settings["max_length"]
+
+    # Filter words by length constraints
+    filtered_words = [
+        word for word in WORDS
+        if min_len <= len(word) <= max_len
+    ]
+
+    if not filtered_words:
+        raise ValueError(
+            f"No words available for difficulty {difficulty} "
+            f"with length {min_len}-{max_len}."
+        )
+
+    # Use provided rng or module-level random
+    if rng is None:
+        return random.choice(filtered_words)
+    else:
+        return rng.choice(filtered_words)
