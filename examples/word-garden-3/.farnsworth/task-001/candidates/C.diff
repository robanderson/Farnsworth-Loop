@@ -0,0 +1,219 @@
+"""Core game logic for Word Garden."""
+
+import random
+from dataclasses import dataclass, field
+from typing import Optional
+
+from . import words
+
+# Status message constants
+MSG_CORRECT_GUESS = "Good guess! The garden grows."
+MSG_INCORRECT_GUESS = "No match. A weed appears."
+MSG_REPEAT_GUESS = "You already guessed {letter}. Try another letter."
+MSG_INVALID_INPUT = "Please enter a single letter."
+MSG_NOT_A_LETTER = "That is not a letter."
+MSG_EMPTY_INPUT = "Please enter a single letter."
+MSG_GAME_ALREADY_OVER = "The game is over. Start a new game to play again."
+MSG_WON = "You guessed the word! The garden is thriving."
+MSG_LOST = "The garden ran out of water. The word was: {word}. Try again and grow a new garden."
+
+
+@dataclass
+class GameState:
+    """Represents the state of a Word Garden game."""
+
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng: Optional[random.Random] = None) -> GameState:
+    """Create a new game with the given difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic testing.
+
+    Returns:
+        A new GameState with a random word and starting conditions.
+
+    Raises:
+        ValueError: If difficulty is not recognized.
+    """
+    secret_word = words.select_word(difficulty=difficulty, rng=rng)
+    max_water = words.water_for(difficulty=difficulty)
+
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=set(),
+        remaining_water=max_water,
+        weed_count=0,
+        max_water=max_water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[Optional[str], str]:
+    """Validate user input and return a letter and optional error message.
+
+    Args:
+        input_text: Raw user input string.
+
+    Returns:
+        (letter, "") for valid input (single alphabetic character, uppercased).
+        (None, message) for invalid input.
+    """
+    # Trim whitespace
+    trimmed = input_text.strip()
+
+    # Check if empty
+    if not trimmed:
+        return None, MSG_EMPTY_INPUT
+
+    # Check if single character
+    if len(trimmed) != 1:
+        return None, MSG_INVALID_INPUT
+
+    # Check if alphabetic
+    if not trimmed.isalpha():
+        return None, MSG_NOT_A_LETTER
+
+    # Return uppercase letter
+    return trimmed.upper(), ""
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word display with guessed letters revealed.
+
+    Args:
+        state: Current game state.
+
+    Returns:
+        Space-separated masked word (e.g., "G _ R _ E _").
+    """
+    displayed = []
+    for letter in state.secret_word:
+        if letter in state.guessed_letters:
+            displayed.append(letter)
+        else:
+            displayed.append("_")
+    return " ".join(displayed)
+
+
+def is_won(state: GameState) -> bool:
+    """Check if the player has won.
+
+    A player wins when all letters of the secret word are in guessed_letters.
+
+    Args:
+        state: Current game state.
+
+    Returns:
+        True if the word is fully revealed, False otherwise.
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Check if the player has lost.
+
+    A player loses when remaining_water reaches 0 while the word is not fully revealed.
+
+    Args:
+        state: Current game state.
+
+    Returns:
+        True if water is 0 and the word is not fully revealed, False otherwise.
+    """
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a validated guess to the game state.
+
+    Args:
+        state: Current game state.
+        letter: A single uppercase alphabetic character.
+
+    Returns:
+        Updated GameState with the guess applied and appropriate status message.
+    """
+    # If game is already over, no-op with message
+    if state.game_over:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=MSG_GAME_ALREADY_OVER,
+            game_over=True,
+            won=state.won,
+        )
+
+    # Check if letter was already guessed
+    if letter in state.guessed_letters:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=MSG_REPEAT_GUESS.format(letter=letter),
+            game_over=state.game_over,
+            won=state.won,
+        )
+
+    # Add letter to guessed_letters
+    new_guessed_letters = state.guessed_letters.copy()
+    new_guessed_letters.add(letter)
+
+    # Check if guess is correct
+    is_correct = letter in state.secret_word
+
+    if is_correct:
+        # Correct guess: no water/weed change
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=MSG_CORRECT_GUESS,
+            game_over=False,
+            won=False,
+        )
+    else:
+        # Incorrect guess: costs 1 water, adds 1 weed
+        new_remaining_water = max(0, state.remaining_water - 1)
+        new_weed_count = state.weed_count + 1
+
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed_letters,
+            remaining_water=new_remaining_water,
+            weed_count=new_weed_count,
+            max_water=state.max_water,
+            status_message=MSG_INCORRECT_GUESS,
+            game_over=False,
+            won=False,
+        )
+
+    # Check for win/loss after the guess
+    if is_won(new_state):
+        new_state.game_over = True
+        new_state.won = True
+        new_state.status_message = MSG_WON
+    elif is_lost(new_state):
+        new_state.game_over = True
+        new_state.won = False
+        new_state.status_message = MSG_LOST.format(word=state.secret_word)
+
+    return new_state
