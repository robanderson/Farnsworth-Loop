+class TestNewGame(unittest.TestCase):
+    """Test new_game function."""
+
+    def test_new_game_creates_state(self):
+        """new_game should return a GameState."""
+        state = game.new_game()
+        self.assertIsInstance(state, game.GameState)
+
+    def test_new_game_default_difficulty(self):
+        """new_game with default difficulty should use normal."""
+        state = game.new_game()
+        # Normal difficulty: 5-8 letter words, 6 water
+        self.assertGreaterEqual(len(state.secret_word), 5)
+        self.assertLessEqual(len(state.secret_word), 8)
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+
+    def test_new_game_easy_difficulty(self):
+        """new_game with easy difficulty should have 8 water."""
+        state = game.new_game("easy")
+        self.assertEqual(state.remaining_water, 8)
+        self.assertEqual(state.max_water, 8)
+
+    def test_new_game_hard_difficulty(self):
+        """new_game with hard difficulty should have 4 water."""
+        state = game.new_game("hard")
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.max_water, 4)
+
+    def test_new_game_secret_word_uppercase(self):
+        """Secret word should be uppercase."""
+        state = game.new_game()
+        self.assertEqual(state.secret_word, state.secret_word.upper())
+
+    def test_new_game_initial_guessed_letters_empty(self):
