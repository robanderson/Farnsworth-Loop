+"""Main game loop and entry point for Word Garden.
+
+This is the only module that touches stdin/stdout. All output goes through
+output_fn and all input through input_fn so the loop is fully testable.
+"""
+
+import argparse
+
+from .game import apply_guess, new_game, validate_guess
+from .ui import loss_screen, render, win_screen
+
+GOODBYE_MESSAGE = "\nGoodbye! Come back soon to tend your garden."
+
+
+def main(argv=None, input_fn=input, output_fn=print) -> int:
+    """Run one complete game session. Returns 0 on clean exit."""
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description="Word Garden — a friendly terminal word-guessing game.",
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty (default: normal)",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        help="ASCII-only output — no emoji",
+    )
+    args = parser.parse_args(argv)
+
+    state = new_game(difficulty=args.difficulty)
+
+    try:
+        while not state.game_over:
+            output_fn(render(state, ascii_mode=args.ascii))
+
+            # Inner loop: re-prompt on invalid input without re-rendering the board.
+            while True:
+                raw = input_fn("Guess a letter: ")
+                letter, error = validate_guess(raw)
+                if letter is not None:
+                    break
+                output_fn(error)
+
+            state = apply_guess(state, letter)
+
+        if state.won:
+            output_fn(win_screen(state, ascii_mode=args.ascii))
+        else:
+            output_fn(loss_screen(state, ascii_mode=args.ascii))
+
+    except (EOFError, KeyboardInterrupt):
+        output_fn(GOODBYE_MESSAGE)
+
+    return 0
