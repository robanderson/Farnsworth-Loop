+import unittest
+from unittest.mock import patch
+
+from word_garden.game import GameState, MSG_CORRECT, MSG_INCORRECT
+from word_garden.main import GOODBYE_MESSAGE, main
+from word_garden.ui import (
+    LOSS_BODY,
+    LOSS_HEADER_ASCII,
+    LOSS_HEADER_EMOJI,
+    LOSS_WORD_PREFIX,
+    TITLE_ASCII,
+    TITLE_EMOJI,
+    WIN_BODY,
+    WIN_HEADER_ASCII,
+    WIN_HEADER_EMOJI,
+    WIN_WORD_PREFIX,
+    loss_screen,
+    render,
+    win_screen,
+)
+
+
+def _make_state(**kwargs) -> GameState:
+    """Build a GameState with sensible defaults, overridden by kwargs."""
+    defaults = dict(
+        secret_word="GARDEN",
+        guessed_letters=set(),
+        remaining_water=6,
+        weed_count=0,
+        max_water=6,
+    )
+    defaults.update(kwargs)
+    return GameState(**defaults)
+
+
+# ---------------------------------------------------------------------------
+# render — emoji mode
+# ---------------------------------------------------------------------------
+
+class TestRenderEmojiMode(unittest.TestCase):
+    def test_contains_title(self):
+        state = _make_state()
+        output = render(state)
+        self.assertIn(TITLE_EMOJI, output)
+
+    def test_water_line_has_label_count_and_symbols(self):
+        state = _make_state(remaining_water=4, max_water=6)
+        output = render(state)
+        self.assertIn("Water:", output)
+        self.assertIn("4/6", output)
+        self.assertIn("💧💧💧💧", output)
+
+    def test_weed_line_has_label_count_and_symbols(self):
+        state = _make_state(weed_count=2)
+        output = render(state)
+        self.assertIn("Weeds:", output)
+        self.assertIn("2", output)
+        self.assertIn("🌿🌿", output)
+
+    def test_weed_line_shows_zero_when_no_weeds(self):
+        state = _make_state(weed_count=0)
+        output = render(state)
+        self.assertIn("Weeds:    0", output)
+
+    def test_guessed_letters_sorted_space_separated(self):
+        state = _make_state(guessed_letters={"E", "A", "R"})
+        output = render(state)
+        self.assertIn("A E R", output)
+
+    def test_masked_word_shown(self):
+        state = _make_state(secret_word="CAT", guessed_letters={"A"})
+        output = render(state)
+        self.assertIn("_ A _", output)
+
+    def test_status_message_included_when_present(self):
+        state = _make_state(status_message=MSG_CORRECT)
+        output = render(state)
+        self.assertIn(MSG_CORRECT, output)
+
+    def test_no_status_message_when_empty(self):
+        state = _make_state(status_message="")
+        output = render(state)
+        self.assertNotIn(MSG_CORRECT, output)
+        self.assertNotIn(MSG_INCORRECT, output)
+
+    def test_output_order(self):
+        state = _make_state(
+            secret_word="CAT",
+            guessed_letters={"A"},
+            remaining_water=4,
+            max_water=6,
+            weed_count=2,
+            status_message=MSG_CORRECT,
+        )
+        output = render(state)
+        title_pos = output.index(TITLE_EMOJI)
+        word_pos = output.index("Word:")
+        guessed_pos = output.index("Guessed:")
+        water_pos = output.index("Water:")
+        weed_pos = output.index("Weeds:")
+        msg_pos = output.index(MSG_CORRECT)
+        self.assertLess(title_pos, word_pos)
+        self.assertLess(word_pos, guessed_pos)
+        self.assertLess(guessed_pos, water_pos)
+        self.assertLess(water_pos, weed_pos)
+        self.assertLess(weed_pos, msg_pos)
+
+
+# ---------------------------------------------------------------------------
+# render — ASCII mode
+# ---------------------------------------------------------------------------
+
+class TestRenderAsciiMode(unittest.TestCase):
+    def test_title_is_ascii(self):
+        state = _make_state()
+        output = render(state, ascii_mode=True)
+        self.assertIn(TITLE_ASCII, output)
+        self.assertNotIn(TITLE_EMOJI, output)
+
+    def test_output_contains_no_non_ascii(self):
+        state = _make_state(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A"},
+            remaining_water=4,
+            max_water=6,
+            weed_count=2,
+            status_message=MSG_INCORRECT,
+        )
+        output = render(state, ascii_mode=True)
+        self.assertTrue(
+            output.isascii(),
+            f"Non-ASCII characters found in ASCII render output:\n{output!r}",
+        )
+
+    def test_water_symbols_use_brackets(self):
+        state = _make_state(remaining_water=3, max_water=6)
+        output = render(state, ascii_mode=True)
+        self.assertIn("3/6 [***]", output)
+
+    def test_weed_symbols_use_brackets(self):
+        state = _make_state(weed_count=2)
+        output = render(state, ascii_mode=True)
+        self.assertIn("2 [--]", output)
+
+    def test_no_emoji_in_ascii_mode(self):
+        state = _make_state(weed_count=2, remaining_water=3)
+        output = render(state, ascii_mode=True)
+        self.assertNotIn("💧", output)
+        self.assertNotIn("🌿", output)
+        self.assertNotIn("🌱", output)
+
+
+# ---------------------------------------------------------------------------
+# Growth stages
+# ---------------------------------------------------------------------------
+
+class TestGrowthStages(unittest.TestCase):
+    def test_start_stage_when_no_letters_revealed(self):
+        state = _make_state(secret_word="GARDEN", guessed_letters=set())
+        output = render(state, ascii_mode=True)
+        self.assertIn("[seed]", output)
+
+    def test_progress_stage_when_some_letters_revealed(self):
+        # GARDEN has 6 unique letters; reveal 1 → 1/6 ≈ 17% (below 60%)
+        state = _make_state(secret_word="GARDEN", guessed_letters={"G"})
+        output = render(state, ascii_mode=True)
+        self.assertIn("[plant]", output)
+
+    def test_near_win_stage_when_most_letters_revealed(self):
+        # GARDEN: reveal 4 of 6 unique letters → 67% (above 60% threshold)
+        state = _make_state(secret_word="GARDEN", guessed_letters={"G", "A", "R", "D"})
+        output = render(state, ascii_mode=True)
+        self.assertIn("[bud]", output)
+
+    def test_win_stage_when_game_won(self):
+        state = _make_state(game_over=True, won=True)
+        output = render(state, ascii_mode=True)
+        self.assertIn("[flower]", output)
+
+    def test_loss_stage_when_game_lost(self):
+        state = _make_state(game_over=True, won=False, remaining_water=0)
+        output = render(state, ascii_mode=True)
+        self.assertIn("[wilted]", output)
+
+    def test_near_win_stage_exactly_at_threshold(self):
+        # "AB": 2 unique letters; reveal both → 100% > 60%
+        state = _make_state(secret_word="AB", guessed_letters={"A", "B"})
+        # won would not be set on the state itself, just guessed_letters
+        # (we're testing the stage logic, not the full win flow)
+        output = render(state, ascii_mode=True)
+        self.assertIn("[bud]", output)
+
+
+# ---------------------------------------------------------------------------
+# win_screen and loss_screen
+# ---------------------------------------------------------------------------
+
+class TestWinScreen(unittest.TestCase):
+    def test_emoji_mode_contains_header_and_word(self):
+        state = _make_state(secret_word="GARDEN")
+        output = win_screen(state)
+        self.assertIn(WIN_HEADER_EMOJI, output)
+        self.assertIn(f"{WIN_WORD_PREFIX}GARDEN", output)
+        self.assertIn(WIN_BODY, output)
+
+    def test_ascii_mode_contains_header_and_word(self):
+        state = _make_state(secret_word="GARDEN")
+        output = win_screen(state, ascii_mode=True)
+        self.assertIn(WIN_HEADER_ASCII, output)
+        self.assertIn(f"{WIN_WORD_PREFIX}GARDEN", output)
+        self.assertIn(WIN_BODY, output)
+
+    def test_ascii_mode_no_non_ascii_characters(self):
+        state = _make_state(secret_word="GARDEN")
+        output = win_screen(state, ascii_mode=True)
+        self.assertTrue(output.isascii(), f"Non-ASCII found in win_screen:\n{output!r}")
+
+    def test_emoji_mode_absent_in_ascii_win_screen(self):
+        state = _make_state(secret_word="GARDEN")
+        output = win_screen(state, ascii_mode=True)
+        self.assertNotIn(WIN_HEADER_EMOJI, output)
+
+
+class TestLossScreen(unittest.TestCase):
+    def test_emoji_mode_contains_header_and_word(self):
+        state = _make_state(secret_word="GARDEN")
+        output = loss_screen(state)
+        self.assertIn(LOSS_HEADER_EMOJI, output)
+        self.assertIn(f"{LOSS_WORD_PREFIX}GARDEN", output)
+        self.assertIn(LOSS_BODY, output)
+
+    def test_ascii_mode_contains_header_and_word(self):
+        state = _make_state(secret_word="GARDEN")
+        output = loss_screen(state, ascii_mode=True)
+        self.assertIn(LOSS_HEADER_ASCII, output)
+        self.assertIn(f"{LOSS_WORD_PREFIX}GARDEN", output)
+        self.assertIn(LOSS_BODY, output)
+
+    def test_ascii_mode_no_non_ascii_characters(self):
+        state = _make_state(secret_word="GARDEN")
+        output = loss_screen(state, ascii_mode=True)
+        self.assertTrue(output.isascii(), f"Non-ASCII found in loss_screen:\n{output!r}")
+
+    def test_loss_screen_reveals_secret_word(self):
+        state = _make_state(secret_word="PYTHON")
+        output = loss_screen(state)
+        self.assertIn("PYTHON", output)
+
+
+# ---------------------------------------------------------------------------
+# End-to-end main() tests
+# ---------------------------------------------------------------------------
+
+class TestMainEndToEnd(unittest.TestCase):
+    """Scripted game runs using injected input/output functions."""
+
+    def _run_main(self, initial_state, inputs, ascii_mode=False):
+        """Run main() with a fixed initial state and scripted inputs."""
+        outputs = []
+        input_iter = iter(inputs)
+
+        argv = ["--ascii"] if ascii_mode else []
+        with patch("word_garden.main.new_game", return_value=initial_state):
+            exit_code = main(
+                argv=argv,
+                input_fn=lambda prompt="": next(input_iter),
+                output_fn=outputs.append,
+            )
+
+        return exit_code, outputs
+
+    def test_win_scenario_shows_win_screen(self):
+        # "CAT": guess C, A, T → all letters revealed → win
+        initial = GameState(
+            secret_word="CAT",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        exit_code, outputs = self._run_main(initial, ["C", "A", "T"], ascii_mode=True)
+
+        full_output = "\n".join(outputs)
+        self.assertEqual(exit_code, 0)
+        self.assertIn(WIN_HEADER_ASCII, full_output)
+        self.assertIn(f"{WIN_WORD_PREFIX}CAT", full_output)
+        self.assertIn(WIN_BODY, full_output)
+
+    def test_loss_scenario_shows_loss_screen_with_word(self):
+        # "GARDEN" with 2 water: guess Z, X → both wrong → water runs out
+        initial = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=2,
+            weed_count=0,
+            max_water=2,
+        )
+        exit_code, outputs = self._run_main(initial, ["Z", "X"], ascii_mode=True)
+
+        full_output = "\n".join(outputs)
+        self.assertEqual(exit_code, 0)
+        self.assertIn(LOSS_HEADER_ASCII, full_output)
+        self.assertIn(f"{LOSS_WORD_PREFIX}GARDEN", full_output)
+        self.assertIn(LOSS_BODY, full_output)
+
+    def test_invalid_input_does_not_consume_turn(self):
+        # "AB": one wrong guess (Z) and one valid letter (B) — then A to win.
+        # If invalid input consumed a turn we would lose early.
+        initial = GameState(
+            secret_word="AB",
+            guessed_letters=set(),
+            remaining_water=1,
+            weed_count=0,
+            max_water=1,
+        )
+        # "7" is invalid, "A" and "B" are valid wins
+        exit_code, outputs = self._run_main(initial, ["7", "A", "B"], ascii_mode=True)
+
+        full_output = "\n".join(outputs)
+        self.assertEqual(exit_code, 0)
+        self.assertIn(WIN_HEADER_ASCII, full_output)
+
+    def test_eof_exits_cleanly(self):
+        initial = _make_state()
+        outputs = []
+
+        with patch("word_garden.main.new_game", return_value=initial):
+            exit_code = main(
+                argv=["--ascii"],
+                input_fn=lambda prompt="": (_ for _ in ()).throw(EOFError()),
+                output_fn=outputs.append,
+            )
+
+        self.assertEqual(exit_code, 0)
+        self.assertIn(GOODBYE_MESSAGE, "\n".join(outputs))
+
+    def test_keyboard_interrupt_exits_cleanly(self):
+        initial = _make_state()
+        outputs = []
+
+        with patch("word_garden.main.new_game", return_value=initial):
+            exit_code = main(
+                argv=["--ascii"],
+                input_fn=lambda prompt="": (_ for _ in ()).throw(KeyboardInterrupt()),
+                output_fn=outputs.append,
+            )
+
+        self.assertEqual(exit_code, 0)
+        self.assertIn(GOODBYE_MESSAGE, "\n".join(outputs))
