+"""Rendering functions for Word Garden. No I/O — every function returns a string."""
+
+from .game import GameState, display_word
+
+# ---------------------------------------------------------------------------
+# User-facing string constants.
+# Tests MUST import these rather than re-typing literals.
+# ---------------------------------------------------------------------------
+
+TITLE_EMOJI = "🌱 Word Garden"
+TITLE_ASCII = "* Word Garden"
+
+WIN_HEADER_EMOJI = "🌻 Bloom!"
+WIN_HEADER_ASCII = "[flower] Bloom!"
+WIN_WORD_PREFIX = "You guessed the word: "
+WIN_BODY = "The garden is thriving."
+
+LOSS_HEADER_EMOJI = "🥀 The garden ran out of water."
+LOSS_HEADER_ASCII = "[wilted] The garden ran out of water."
+LOSS_WORD_PREFIX = "The word was: "
+LOSS_BODY = "Try again and grow a new garden."
+
+WATER_EMOJI = "💧"
+WEED_EMOJI = "🌿"
+
+# Growth stage glyphs: stage name → (emoji, ascii)
+_STAGE_GLYPHS: dict[str, tuple[str, str]] = {
+    "start":    ("🌱", "[seed]"),
+    "progress": ("🌿", "[plant]"),
+    "near_win": ("🌷", "[bud]"),
+    "win":      ("🌻", "[flower]"),
+    "loss":     ("🥀", "[wilted]"),
+}
+
+_NEAR_WIN_THRESHOLD = 0.6
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+def _growth_stage(state: GameState) -> str:
+    """Return the current growth stage key based on state."""
+    if state.won:
+        return "win"
+    if state.game_over:
+        return "loss"
+    unique = set(state.secret_word)
+    if not unique:
+        return "start"
+    revealed = len(unique & state.guessed_letters) / len(unique)
+    if revealed == 0:
+        return "start"
+    if revealed >= _NEAR_WIN_THRESHOLD:
+        return "near_win"
+    return "progress"
+
+
+def _water_symbols(count: int, ascii_mode: bool) -> str:
+    if ascii_mode:
+        return f"[{'*' * count}]"
+    return WATER_EMOJI * count  # empty string when count is 0
+
+
+def _weed_symbols(count: int, ascii_mode: bool) -> str:
+    if ascii_mode:
+        return f"[{'-' * count}]"
+    return WEED_EMOJI * count  # empty string when count is 0
+
+
+# ---------------------------------------------------------------------------
+# Public rendering functions
+# ---------------------------------------------------------------------------
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the full turn display as a string.
+
+    Order: title, growth-stage visual, masked word, guessed letters,
+    water, weeds, and (if non-empty) the previous turn's status_message.
+    """
+    title = TITLE_ASCII if ascii_mode else TITLE_EMOJI
+
+    stage = _growth_stage(state)
+    emoji_glyph, ascii_glyph = _STAGE_GLYPHS[stage]
+    stage_visual = ascii_glyph if ascii_mode else emoji_glyph
+
+    word_display = display_word(state)
+    guessed = " ".join(sorted(state.guessed_letters))
+
+    # Water line: always shows count/max and symbols (empty brackets in ASCII when 0)
+    water_symbols = _water_symbols(state.remaining_water, ascii_mode)
+    water_line = f"Water:    {state.remaining_water}/{state.max_water}"
+    if water_symbols:
+        water_line += f" {water_symbols}"
+
+    # Weed line: shows count and symbols when count > 0
+    weed_symbols = _weed_symbols(state.weed_count, ascii_mode) if state.weed_count > 0 else ""
+    weed_line = f"Weeds:    {state.weed_count}"
+    if weed_symbols:
+        weed_line += f" {weed_symbols}"
+
+    lines = [
+        title,
+        "",
+        stage_visual,
+        "",
+        f"Word:     {word_display}",
+        f"Guessed:  {guessed}",
+        water_line,
+        weed_line,
+    ]
+
+    if state.status_message:
+        lines.extend(["", state.status_message])
+
+    return "\n".join(lines)
+
+
+def win_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the win end-screen as a string (SPEC §6.6)."""
+    header = WIN_HEADER_ASCII if ascii_mode else WIN_HEADER_EMOJI
+    return "\n".join([
+        header,
+        "",
+        f"{WIN_WORD_PREFIX}{state.secret_word}",
+        WIN_BODY,
+    ])
+
+
+def loss_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the loss end-screen as a string, revealing the secret word (SPEC §6.7)."""
+    header = LOSS_HEADER_ASCII if ascii_mode else LOSS_HEADER_EMOJI
+    return "\n".join([
+        header,
+        "",
+        f"{LOSS_WORD_PREFIX}{state.secret_word}",
+        LOSS_BODY,
+    ])
