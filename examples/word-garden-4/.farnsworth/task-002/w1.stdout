n=fake_print)\n\n        self.assertEqual(result, 0)\n        output_str = \"\\n\".join(outputs)\n        self.assertIn(\"Word Garden\", output_str)\n        self.assertIn(\"Guessed:\", output_str)\n        self.assertTrue(output_str.count(\"Bloom!\") > 0 or output_str.count(\"The garden ran out of water\") > 0)\n\n    def test_end_to_end_ascii_mode(self):\n        \"\"\"E2E: game in ASCII mode uses no emoji.\"\"\"\n        outputs = []\n\n        def fake_print(text, end=\"\\n\"):\n            outputs.append(text)\n\n        guesses = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\"\n        guess_index = [0]\n\n        def fake_input():\n            if guess_index[0] >= len(guesses):\n                raise EOFError()\n            letter = guesses[guess_index[0]]\n            guess_index[0] += 1\n            return letter\n\n        result = main([\"--ascii\", \"--difficulty\", \"easy\"], input_fn=fake_input, output_fn=fake_print)\n\n        self.assertEqual(result, 0)\n        output_str = \"\\n\".join(outputs)\n        self.assertNotIn(\"💧\", output_str)\n        self.assertNotIn(\"🌻\", output_str)\n        self.assertNotIn(\"🥀\", output_str)\n        self.assertNotIn(\"🌱\", output_str)\n        self.assertNotIn(\"🌿\", output_str)\n        self.assertNotIn(\"🌷\", output_str)"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1171,"cache_read_input_tokens":90375,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1171},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"802dcc07-f06a-4920-82f9-0be55de92fb4","uuid":"7d94af22-9c1d-40e1-b1e9-655cc729132a","request_id":"req_011Cbxge1fxH6CgeniYv88Ls"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D8fR7CmErGPeGriCxy7ivu","type":"tool_result","content":"The file /Volumes/990EVO4TB/De