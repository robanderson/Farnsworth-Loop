+from .game import GameState, display_word
+
+# Growth stage glyphs
+_GROWTH_EMOJI = {
+    "start": "🌱",
+    "progress": "🌿",
+    "near_win": "🌷",
+    "win": "🌻",
+    "loss": "🥀",
+}
+
+_GROWTH_ASCII = {
+    "start": "*",
+    "progress": "*",
+    "near_win": "*",
+    "win": "*",
+    "loss": "*",
+}
+
+_WATER_EMOJI = "💧"
+_WATER_ASCII = "*"
+
+_WEED_EMOJI = "🌿"
+_WEED_ASCII = "-"
+
+
+def _growth_stage(state: GameState) -> str:
+    """Determine the current growth stage."""
+    if state.game_over:
+        return "win" if state.won else "loss"
+    revealed = sum(1 for ch in state.secret_word if ch in state.guessed_letters)
+    total = len(state.secret_word)
+    if revealed == total - 1 and total > 1:
+        return "near_win"
+    if revealed > 0:
+        return "progress"
+    return "start"
+
+
+def _glyph(stage: str, ascii_mode: bool) -> str:
+    """Get the growth stage glyph."""
+    glyphs = _GROWTH_ASCII if ascii_mode else _GROWTH_EMOJI
+    return glyphs[stage]
+
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the full turn display."""
+    stage = _growth_stage(state)
+    glyph = _glyph(stage, ascii_mode)
+    title = f"{glyph} Word Garden"
+
+    word_display = display_word(state)
+    guessed_display = " ".join(sorted(state.guessed_letters)) if state.guessed_letters else ""
+
+    if ascii_mode:
+        water_str = f"Water: {state.remaining_water}/{state.max_water} [{_WATER_ASCII * state.remaining_water}]"
+        weed_str = f"Weeds: {state.weed_count} [{_WEED_ASCII * state.weed_count}]"
+    else:
+        water_str = f"Water: {state.remaining_water}/{state.max_water} {_WATER_EMOJI * state.remaining_water}"
+        weed_str = f"Weeds: {state.weed_count} {_WEED_EMOJI * state.weed_count}"
+
+    lines = [
+        title,
+        "",
+        f"Word:     {word_display}",
+    ]
+
+    if guessed_display:
+        lines.append(f"Guessed:  {guessed_display}")
+    else:
+        lines.append("Guessed:")
+
+    lines.extend([
+        water_str,
+        weed_str,
+    ])
+
+    if state.status_message:
+        lines.extend(["", state.status_message])
+
+    lines.append("")
+    return "\n".join(lines)
+
+
+def win_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the win screen."""
+    glyph = _glyph("win", ascii_mode)
+    lines = [
+        f"{glyph} Bloom!",
+        "",
+        f"You guessed the word: {state.secret_word}",
+        "The garden is thriving.",
+    ]
+    return "\n".join(lines)
+
+
+def loss_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the loss screen."""
+    glyph = _glyph("loss", ascii_mode)
+    lines = [
+        f"{glyph} The garden ran out of water.",
+        "",
+        f"The word was: {state.secret_word}",
+        "Try again and grow a new garden.",
+    ]
+    return "\n".join(lines)
