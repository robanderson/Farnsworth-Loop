+import argparse
+import sys
+
+from .game import new_game, validate_guess, apply_guess
+from .ui import render, win_screen, loss_screen
+
+
+def main(argv=None, input_fn=None, output_fn=None) -> int:
+    """Run the Word Garden game loop.
+
+    Args:
+        argv: Command-line arguments (default: sys.argv[1:])
+        input_fn: Injectable input function (default: input)
+        output_fn: Injectable output function (default: print)
+
+    Returns:
+        Exit code (0 on success or EOF/interrupt)
+    """
+    if input_fn is None:
+        input_fn = input
+    if output_fn is None:
+        output_fn = print
+
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description="A friendly terminal word-guessing game.",
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty (default: normal)",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        help="Use ASCII-only output (no emoji)",
+    )
+
+    args = parser.parse_args(argv)
+
+    state = new_game(args.difficulty)
+
+    try:
+        while not state.game_over:
+            output_fn(render(state, ascii_mode=args.ascii))
+            output_fn("Guess a letter: ", end="")
+            user_input = input_fn()
+
+            letter, error = validate_guess(user_input)
+            if error:
+                output_fn(error)
+                continue
+
+            state = apply_guess(state, letter)
+
+        if state.won:
+            output_fn(win_screen(state, ascii_mode=args.ascii))
+        else:
+            output_fn(loss_screen(state, ascii_mode=args.ascii))
+
+        return 0
+
+    except (EOFError, KeyboardInterrupt):
+        output_fn("\nThanks for playing! Goodbye.")
+        return 0
