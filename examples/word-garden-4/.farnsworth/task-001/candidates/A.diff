+from dataclasses import dataclass, field
+from word_garden import words
+
+
+@dataclass
+class GameState:
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty="normal", rng=None):
+    """Create a new game with a random word.
+
+    Args:
+        difficulty: "easy", "normal", or "hard"
+        rng: optional random.Random instance for deterministic tests
+
+    Returns:
+        A new GameState ready for play
+    """
+    word = words.select_word(difficulty=difficulty, rng=rng)
+    max_water = words.water_for(difficulty=difficulty)
+
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=max_water,
+        weed_count=0,
+        max_water=max_water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text):
+    """Validate user input and extract a letter.
+
+    Args:
+        input_text: raw user input string
+
+    Returns:
+        tuple: (letter, message) where letter is None if invalid,
+               or (letter, "") if valid
+    """
+    trimmed = input_text.strip().upper()
+
+    if not trimmed:
+        return (None, "Please enter a single letter.")
+
+    if len(trimmed) > 1:
+        return (None, "Please enter a single letter.")
+
+    if not trimmed.isalpha():
+        return (None, "That is not a letter.")
+
+    return (trimmed, "")
+
+
+def display_word(state):
+    """Display the secret word with guessed letters revealed.
+
+    Args:
+        state: GameState
+
+    Returns:
+        String with letters revealed and blanks for unguessed letters,
+        space-separated (e.g., "G _ R _ E _")
+    """
+    return " ".join(
+        letter if letter in state.guessed_letters else "_"
+        for letter in state.secret_word
+    )
+
+
+def is_won(state):
+    """Check if the player has won.
+
+    Args:
+        state: GameState
+
+    Returns:
+        True if all letters in secret_word are in guessed_letters
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state):
+    """Check if the player has lost.
+
+    Args:
+        state: GameState
+
+    Returns:
+        True if water has reached 0 before winning
+    """
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+def apply_guess(state, letter):
+    """Apply a validated letter guess to the game state.
+
+    Args:
+        state: GameState
+        letter: uppercase single letter
+
+    Returns:
+        Updated GameState with the guess applied
+    """
+    if state.game_over:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters.copy(),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="The game is over. Start a new game.",
+            game_over=state.game_over,
+            won=state.won,
+        )
+
+    if letter in state.guessed_letters:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters.copy(),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=f"You already guessed {letter}. Try another letter.",
+            game_over=state.game_over,
+            won=state.won,
+        )
+
+    new_guessed = state.guessed_letters | {letter}
+
+    if letter in state.secret_word:
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="Good guess! The garden grows.",
+            game_over=False,
+            won=False,
+        )
+
+        if is_won(new_state):
+            new_state.won = True
+            new_state.game_over = True
+
+        return new_state
+
+    else:
+        new_water = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_water,
+            weed_count=new_weeds,
+            max_water=state.max_water,
+            status_message="No match. A weed appears.",
+            game_over=False,
+            won=False,
+        )
+
+        if is_lost(new_state):
+            new_state.game_over = True
+
+        return new_state
