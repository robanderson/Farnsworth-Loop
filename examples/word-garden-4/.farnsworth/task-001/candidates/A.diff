+import random
+import unittest
+from word_garden import words
+
+
+class TestWords(unittest.TestCase):
+    def test_words_list_exists(self):
+        """SPEC 16.10: Word list is available."""
+        self.assertIsNotNone(words.WORDS)
+        self.assertEqual(len(words.WORDS), 10)
+
+    def test_words_are_uppercase(self):
+        """All words in WORDS are uppercase."""
+        for word in words.WORDS:
+            self.assertEqual(word, word.upper())
+
+    def test_select_word_easy_returns_valid_word(self):
+        """SPEC 16.10: select_word returns a word matching easy difficulty."""
+        rng = random.Random(42)
+        word = words.select_word(difficulty="easy", rng=rng)
+        self.assertIn(word, words.WORDS)
+        self.assertTrue(4 <= len(word) <= 6)
+
+    def test_select_word_normal_returns_valid_word(self):
+        """SPEC 16.10: select_word returns a word matching normal difficulty."""
+        rng = random.Random(42)
+        word = words.select_word(difficulty="normal", rng=rng)
+        self.assertIn(word, words.WORDS)
+        self.assertTrue(5 <= len(word) <= 8)
+
+    def test_select_word_hard_returns_valid_word(self):
+        """SPEC 16.10: select_word returns a word matching hard difficulty."""
+        rng = random.Random(42)
+        word = words.select_word(difficulty="hard", rng=rng)
+        self.assertIn(word, words.WORDS)
+        self.assertTrue(len(word) >= 7)
+
+    def test_select_word_deterministic_with_seeded_rng(self):
+        """select_word is deterministic when given a seeded random.Random."""
+        rng1 = random.Random(123)
+        rng2 = random.Random(123)
+        word1 = words.select_word(difficulty="normal", rng=rng1)
+        word2 = words.select_word(difficulty="normal", rng=rng2)
+        self.assertEqual(word1, word2)
+
+    def test_select_word_invalid_difficulty_raises_error(self):
+        """select_word raises ValueError for unknown difficulty."""
+        with self.assertRaises(ValueError):
+            words.select_word(difficulty="impossible")
+
+    def test_water_for_easy(self):
+        """water_for returns correct water level for easy."""
+        self.assertEqual(words.water_for("easy"), 8)
+
+    def test_water_for_normal(self):
+        """water_for returns correct water level for normal."""
+        self.assertEqual(words.water_for("normal"), 6)
+
+    def test_water_for_hard(self):
+        """water_for returns correct water level for hard."""
+        self.assertEqual(words.water_for("hard"), 4)
+
+    def test_water_for_invalid_difficulty_raises_error(self):
+        """water_for raises ValueError for unknown difficulty."""
+        with self.assertRaises(ValueError):
+            words.water_for("impossible")
+
+
+if __name__ == "__main__":
+    unittest.main()
