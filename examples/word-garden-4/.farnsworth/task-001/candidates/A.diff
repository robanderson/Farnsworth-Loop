+import random
+
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+DIFFICULTY_CONFIG = {
+    "easy": {"water": 8, "min_length": 4, "max_length": 6},
+    "normal": {"water": 6, "min_length": 5, "max_length": 8},
+    "hard": {"water": 4, "min_length": 7, "max_length": float("inf")},
+}
+
+
+def select_word(difficulty="normal", rng=None):
+    """Select a random word filtered by difficulty settings.
+
+    Args:
+        difficulty: "easy", "normal", or "hard"
+        rng: optional random.Random instance for deterministic tests
+
+    Returns:
+        An uppercase word from WORDS matching the difficulty filter
+
+    Raises:
+        ValueError: if difficulty is unknown
+    """
+    if difficulty not in DIFFICULTY_CONFIG:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    if rng is None:
+        rng = random
+
+    config = DIFFICULTY_CONFIG[difficulty]
+    min_len = config["min_length"]
+    max_len = config["max_length"]
+
+    filtered = [w for w in WORDS if min_len <= len(w) <= max_len]
+
+    if not filtered:
+        raise ValueError(f"No words available for difficulty: {difficulty}")
+
+    return rng.choice(filtered)
+
+
+def water_for(difficulty="normal"):
+    """Return the starting water level for a difficulty.
+
+    Args:
+        difficulty: "easy", "normal", or "hard"
+
+    Returns:
+        Starting water amount
+
+    Raises:
+        ValueError: if difficulty is unknown
+    """
+    if difficulty not in DIFFICULTY_CONFIG:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    return DIFFICULTY_CONFIG[difficulty]["water"]
