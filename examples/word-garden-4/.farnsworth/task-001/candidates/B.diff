+from __future__ import annotations
+
+import random
+from dataclasses import dataclass
+
+from . import words as _words
+
+# User-facing message constants — import these in tests instead of re-typing literals.
+MSG_CORRECT = "Good guess! The garden grows."
+MSG_WRONG = "No match. A weed appears."
+MSG_ALREADY_GUESSED = "You already guessed {letter}. Try another letter."
+MSG_WIN = "Bloom! You've revealed the whole word!"
+MSG_LOSS = "The garden ran out of water."
+MSG_GAME_OVER = "The game is already over."
+
+MSG_INVALID_SINGLE = "Please enter a single letter."
+MSG_INVALID_NOT_ALPHA = "That is not a letter."
+
+
+@dataclass
+class GameState:
+    secret_word: str
+    guessed_letters: set[str]
+    remaining_water: int
+    weed_count: int
+    max_water: int
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng: random.Random | None = None) -> GameState:
+    word = _words.select_word(difficulty=difficulty, rng=rng)
+    water = _words.water_for(difficulty=difficulty)
+    return GameState(
+        secret_word=word.upper(),
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+def validate_guess(input_text: object) -> tuple[str | None, str]:
+    if not isinstance(input_text, str):
+        return (None, MSG_INVALID_SINGLE)
+    stripped = input_text.strip()
+    if not stripped:
+        return (None, MSG_INVALID_SINGLE)
+    if len(stripped) > 1:
+        return (None, MSG_INVALID_SINGLE)
+    if not stripped.isalpha():
+        return (None, MSG_INVALID_NOT_ALPHA)
+    return (stripped.upper(), "")
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    if state.game_over:
+        return _clone(state, status_message=MSG_GAME_OVER)
+
+    letter = letter.upper()
+
+    if letter in state.guessed_letters:
+        msg = MSG_ALREADY_GUESSED.format(letter=letter)
+        return _clone(state, status_message=msg)
+
+    new_guessed = set(state.guessed_letters) | {letter}
+
+    if letter in state.secret_word:
+        won = _all_revealed(state.secret_word, new_guessed)
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=MSG_WIN if won else MSG_CORRECT,
+            game_over=won,
+            won=won,
+        )
+
+    new_water = state.remaining_water - 1
+    new_weeds = state.weed_count + 1
+    lost = new_water <= 0
+    return GameState(
+        secret_word=state.secret_word,
+        guessed_letters=new_guessed,
+        remaining_water=max(new_water, 0),
+        weed_count=new_weeds,
+        max_water=state.max_water,
+        status_message=MSG_LOSS if lost else MSG_WRONG,
+        game_over=lost,
+        won=False,
+    )
+
+
+def display_word(state: GameState) -> str:
+    return " ".join(
+        c if c in state.guessed_letters else "_"
+        for c in state.secret_word
+    )
+
+
+def is_won(state: GameState) -> bool:
+    return _all_revealed(state.secret_word, state.guessed_letters)
+
+
+def is_lost(state: GameState) -> bool:
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+def _all_revealed(secret_word: str, guessed_letters: set[str]) -> bool:
+    return bool(secret_word) and all(c in guessed_letters for c in secret_word)
+
+
+def _clone(state: GameState, **overrides: object) -> GameState:
+    kwargs: dict[str, object] = dict(
+        secret_word=state.secret_word,
+        guessed_letters=set(state.guessed_letters),
+        remaining_water=state.remaining_water,
+        weed_count=state.weed_count,
+        max_water=state.max_water,
+        status_message=state.status_message,
+        game_over=state.game_over,
+        won=state.won,
+    )
+    kwargs.update(overrides)
+    return GameState(**kwargs)  # type: ignore[arg-type]
