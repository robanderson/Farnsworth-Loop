+import random
+import unittest
+
+from word_garden.words import WORDS, select_word, water_for
+
+
+class TestWordList(unittest.TestCase):
+
+    def test_words_are_uppercase(self):
+        for word in WORDS:
+            self.assertEqual(word, word.upper(), f"{word!r} is not uppercase")
+
+    def test_words_are_non_empty_strings(self):
+        for word in WORDS:
+            self.assertIsInstance(word, str)
+            self.assertGreater(len(word), 0)
+
+
+class TestWaterFor(unittest.TestCase):
+
+    def test_easy_water(self):
+        self.assertEqual(water_for("easy"), 8)
+
+    def test_normal_water(self):
+        self.assertEqual(water_for("normal"), 6)
+
+    def test_hard_water(self):
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            water_for("extreme")
+
+    def test_empty_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            water_for("")
+
+
+class TestSelectWord(unittest.TestCase):
+
+    # SPEC section 16 case 10: word selector returns a valid word for every difficulty.
+
+    def test_easy_returns_word_in_length_range(self):
+        rng = random.Random(1)
+        word = select_word("easy", rng=rng)
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 4)
+        self.assertLessEqual(len(word), 6)
+
+    def test_normal_returns_word_in_length_range(self):
+        rng = random.Random(2)
+        word = select_word("normal", rng=rng)
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 5)
+        self.assertLessEqual(len(word), 8)
+
+    def test_hard_returns_word_in_length_range(self):
+        rng = random.Random(3)
+        word = select_word("hard", rng=rng)
+        self.assertIn(word, WORDS)
+        self.assertGreaterEqual(len(word), 7)
+
+    def test_all_difficulties_return_uppercase_string(self):
+        for diff in ("easy", "normal", "hard"):
+            rng = random.Random(99)
+            word = select_word(diff, rng=rng)
+            self.assertIsInstance(word, str, f"difficulty={diff!r}")
+            self.assertEqual(word, word.upper(), f"difficulty={diff!r}")
+            self.assertGreater(len(word), 0, f"difficulty={diff!r}")
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            select_word("extreme")
+
+    def test_seeded_rng_is_deterministic(self):
+        word1 = select_word("normal", rng=random.Random(42))
+        word2 = select_word("normal", rng=random.Random(42))
+        self.assertEqual(word1, word2)
+
+    def test_none_rng_uses_module_random(self):
+        # Should not raise; returned word must be in the list.
+        word = select_word("normal")
+        self.assertIn(word, WORDS)
