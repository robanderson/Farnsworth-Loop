@@ -0,0 +1,319 @@
+import random
+import unittest
+
+from word_garden.game import (
+    GameState,
+    apply_guess,
+    display_word,
+    is_lost,
+    is_won,
+    new_game,
+    validate_guess,
+    MSG_ALREADY_GUESSED,
+    MSG_CORRECT,
+    MSG_GAME_OVER,
+    MSG_INVALID_NOT_ALPHA,
+    MSG_INVALID_SINGLE,
+    MSG_LOSS,
+    MSG_WIN,
+    MSG_WRONG,
+)
+
+
+def _state(**kwargs) -> GameState:
+    defaults = dict(
+        secret_word="GARDEN",
+        guessed_letters=set(),
+        remaining_water=6,
+        weed_count=0,
+        max_water=6,
+    )
+    defaults.update(kwargs)
+    return GameState(**defaults)
+
+
+class TestCorrectGuess(unittest.TestCase):
+    """SPEC section 16 case 1: a correct guess reveals matching letters."""
+
+    def test_correct_guess_adds_letter_and_sets_message(self):
+        state = _state(secret_word="GARDEN", guessed_letters=set(), remaining_water=6, weed_count=0)
+        result = apply_guess(state, "A")
+        self.assertIn("A", result.guessed_letters)
+        self.assertEqual(result.remaining_water, 6)
+        self.assertEqual(result.weed_count, 0)
+        self.assertEqual(result.status_message, MSG_CORRECT)
+        self.assertFalse(result.game_over)
+        self.assertFalse(result.won)
+
+    def test_correct_guess_reveals_all_occurrences_in_display(self):
+        # SPEC section 16 case 9: display_word masks unguessed letters.
+        state = _state(secret_word="SEEDLING", guessed_letters={"E"})
+        self.assertEqual(display_word(state), "_ E E _ _ _ _ _")
+
+    def test_correct_guess_does_not_change_water_or_weeds(self):
+        state = _state(secret_word="PYTHON", remaining_water=4, weed_count=2)
+        result = apply_guess(state, "Y")
+        self.assertEqual(result.remaining_water, 4)
+        self.assertEqual(result.weed_count, 2)
+
+
+class TestIncorrectGuess(unittest.TestCase):
+    """SPEC section 16 cases 2 & 3: incorrect guess reduces water and increases weeds."""
+
+    def test_wrong_guess_water_minus_one_weeds_plus_one_letter_recorded(self):
+        state = _state(secret_word="GARDEN", remaining_water=6, weed_count=0, guessed_letters=set())
+        result = apply_guess(state, "Z")
+        self.assertEqual(result.remaining_water, 5)
+        self.assertEqual(result.weed_count, 1)
+        self.assertIn("Z", result.guessed_letters)
+        self.assertEqual(result.status_message, MSG_WRONG)
+        self.assertFalse(result.game_over)
+        self.assertFalse(result.won)
+
+    def test_wrong_guess_accumulates_correctly(self):
+        state = _state(secret_word="GARDEN", remaining_water=3, weed_count=3, guessed_letters={"Z"})
+        result = apply_guess(state, "Q")
+        self.assertEqual(result.remaining_water, 2)
+        self.assertEqual(result.weed_count, 4)
+        self.assertIn("Q", result.guessed_letters)
+
+
+class TestRepeatedGuess(unittest.TestCase):
+    """SPEC section 16 case 4: repeated guesses do not reduce water."""
+
+    def test_repeated_guess_no_water_or_weed_change(self):
+        state = _state(secret_word="GARDEN", guessed_letters={"A"}, remaining_water=6, weed_count=0)
+        result = apply_guess(state, "A")
+        self.assertEqual(result.remaining_water, 6)
+        self.assertEqual(result.weed_count, 0)
+        self.assertEqual(result.guessed_letters, {"A"})
+        self.assertEqual(result.status_message, MSG_ALREADY_GUESSED.format(letter="A"))
+        self.assertFalse(result.game_over)
+        self.assertFalse(result.won)
+
+    def test_repeated_wrong_guess_no_water_or_weed_change(self):
+        state = _state(secret_word="GARDEN", guessed_letters={"Z"}, remaining_water=5, weed_count=1)
+        result = apply_guess(state, "Z")
+        self.assertEqual(result.remaining_water, 5)
+        self.assertEqual(result.weed_count, 1)
+        self.assertEqual(result.status_message, MSG_ALREADY_GUESSED.format(letter="Z"))
+
+
+class TestValidateGuess(unittest.TestCase):
+    """SPEC section 16 cases 5 & 6: invalid input is rejected; lowercase is normalised."""
+
+    def test_empty_string_rejected(self):
+        letter, msg = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_INVALID_SINGLE)
+
+    def test_whitespace_only_rejected(self):
+        letter, msg = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_INVALID_SINGLE)
+
+    def test_multiple_characters_rejected(self):
+        letter, msg = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_INVALID_SINGLE)
+
+    def test_digit_rejected(self):
+        letter, msg = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_INVALID_NOT_ALPHA)
+
+    def test_symbol_rejected(self):
+        letter, msg = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, MSG_INVALID_NOT_ALPHA)
+
+    def test_none_rejected(self):
+        letter, msg = validate_guess(None)
+        self.assertIsNone(letter)
+        self.assertNotEqual(msg, "")
+
+    def test_integer_rejected(self):
+        letter, msg = validate_guess(42)
+        self.assertIsNone(letter)
+        self.assertNotEqual(msg, "")
+
+    def test_lowercase_normalised_to_uppercase(self):
+        # SPEC section 16 case 6
+        letter, msg = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_uppercase_accepted(self):
+        letter, msg = validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+    def test_leading_trailing_spaces_stripped(self):
+        letter, msg = validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(msg, "")
+
+    def test_valid_returns_empty_message(self):
+        letter, msg = validate_guess("G")
+        self.assertEqual(letter, "G")
+        self.assertEqual(msg, "")
+
+
+class TestWinDetection(unittest.TestCase):
+    """SPEC section 16 case 7: the game detects a win."""
+
+    def test_final_correct_letter_triggers_win(self):
+        # GARDEN: G A R D E N — guess N last.
+        state = _state(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E"},
+            remaining_water=3,
+            weed_count=1,
+        )
+        result = apply_guess(state, "N")
+        self.assertTrue(result.won)
+        self.assertTrue(result.game_over)
+        self.assertIn("N", result.guessed_letters)
+        self.assertEqual(result.remaining_water, 3)
+        self.assertEqual(result.weed_count, 1)
+        self.assertEqual(result.status_message, MSG_WIN)
+
+    def test_is_won_true_when_all_letters_guessed(self):
+        state = _state(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+        )
+        self.assertTrue(is_won(state))
+
+    def test_is_won_false_when_letters_missing(self):
+        state = _state(secret_word="GARDEN", guessed_letters={"G", "A"})
+        self.assertFalse(is_won(state))
+
+    def test_non_final_correct_guess_does_not_set_won(self):
+        state = _state(secret_word="GARDEN", guessed_letters=set(), remaining_water=6)
+        result = apply_guess(state, "G")
+        self.assertFalse(result.won)
+        self.assertFalse(result.game_over)
+
+
+class TestLossDetection(unittest.TestCase):
+    """SPEC section 16 case 8: the game detects a loss."""
+
+    def test_final_wrong_guess_triggers_loss(self):
+        state = _state(
+            secret_word="GARDEN",
+            guessed_letters={"Z"},
+            remaining_water=1,
+            weed_count=5,
+        )
+        result = apply_guess(state, "Q")
+        self.assertTrue(result.game_over)
+        self.assertFalse(result.won)
+        self.assertEqual(result.remaining_water, 0)
+        self.assertEqual(result.weed_count, 6)
+        self.assertIn("Q", result.guessed_letters)
+        self.assertEqual(result.status_message, MSG_LOSS)
+
+    def test_is_lost_true_when_water_zero_and_not_won(self):
+        state = _state(secret_word="GARDEN", guessed_letters={"Z"}, remaining_water=0)
+        self.assertTrue(is_lost(state))
+
+    def test_is_lost_false_when_water_remains(self):
+        state = _state(remaining_water=1)
+        self.assertFalse(is_lost(state))
+
+    def test_is_lost_false_when_won(self):
+        state = _state(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=0,
+        )
+        self.assertFalse(is_lost(state))
+
+
+class TestDisplayWord(unittest.TestCase):
+    """SPEC section 16 case 9: displayed word masks unguessed letters."""
+
+    def test_all_masked_at_start(self):
+        state = _state(secret_word="GARDEN", guessed_letters=set())
+        self.assertEqual(display_word(state), "_ _ _ _ _ _")
+
+    def test_partial_reveal(self):
+        state = _state(secret_word="GARDEN", guessed_letters={"G", "R", "E"})
+        self.assertEqual(display_word(state), "G _ R _ E _")
+
+    def test_fully_revealed(self):
+        state = _state(secret_word="GARDEN", guessed_letters={"G", "A", "R", "D", "E", "N"})
+        self.assertEqual(display_word(state), "G A R D E N")
+
+    def test_repeated_letter_all_positions_revealed(self):
+        state = _state(secret_word="SEEDLING", guessed_letters={"S", "E"})
+        self.assertEqual(display_word(state), "S E E _ _ _ _ _")
+
+
+class TestGuessAfterGameOver(unittest.TestCase):
+
+    def test_guess_after_win_is_noop(self):
+        state = _state(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=3,
+            weed_count=0,
+            game_over=True,
+            won=True,
+            status_message=MSG_WIN,
+        )
+        result = apply_guess(state, "X")
+        self.assertEqual(result.remaining_water, 3)
+        self.assertEqual(result.weed_count, 0)
+        self.assertTrue(result.game_over)
+        self.assertTrue(result.won)
+        self.assertEqual(result.status_message, MSG_GAME_OVER)
+
+    def test_guess_after_loss_is_noop(self):
+        state = _state(remaining_water=0, game_over=True, won=False)
+        result = apply_guess(state, "A")
+        self.assertEqual(result.remaining_water, 0)
+        self.assertTrue(result.game_over)
+        self.assertFalse(result.won)
+        self.assertEqual(result.status_message, MSG_GAME_OVER)
+
+
+class TestNewGame(unittest.TestCase):
+
+    def test_new_game_normal_has_correct_initial_state(self):
+        rng = random.Random(42)
+        state = new_game(difficulty="normal", rng=rng)
+        self.assertIsInstance(state.secret_word, str)
+        self.assertGreater(len(state.secret_word), 0)
+        self.assertEqual(state.secret_word, state.secret_word.upper())
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(len(state.guessed_letters), 0)
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_easy_has_eight_water(self):
+        rng = random.Random(1)
+        state = new_game(difficulty="easy", rng=rng)
+        self.assertEqual(state.remaining_water, 8)
+        self.assertEqual(state.max_water, 8)
+
+    def test_new_game_hard_has_four_water(self):
+        rng = random.Random(1)
+        state = new_game(difficulty="hard", rng=rng)
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.max_water, 4)
+
+    def test_new_game_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            new_game(difficulty="extreme")
+
+    def test_apply_guess_does_not_mutate_original_state(self):
+        state = _state(secret_word="GARDEN", guessed_letters=set(), remaining_water=6)
+        original_guessed = set(state.guessed_letters)
+        original_water = state.remaining_water
+        apply_guess(state, "Z")
+        self.assertEqual(state.guessed_letters, original_guessed)
+        self.assertEqual(state.remaining_water, original_water)
