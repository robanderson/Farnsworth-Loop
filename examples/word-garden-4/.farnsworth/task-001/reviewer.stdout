ence_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"e03d56ec-3947-4966-bf34-35ecaf4fbed0","request_id":"req_011CbxfU2RTG1U4faNAJw9mh"},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_017spUiY9XCoCNBYevVczJNb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RdPqznreJ9fUSGfBs5XfbL","name":"Read","input":{"file_path":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/C.diff"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":24462,"cache_read_input_tokens":35116,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":24462},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"d3279f61-b7e8-4ea4-864d-a2f58e6aa222","request_id":"req_011CbxfU2RTG1U4faNAJw9mh"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RdPqznreJ9fUSGfBs5XfbL","type":"tool_result","content":"1\tdiff --git a/tests/__init__.py b/tests/__init__.py\n2\tnew file mode 100644\n3\tindex 0000000..e69de29\n4\tdiff --git a/tests/test_game.py b/tests/test_game.py\n5\tnew file mode 100644\n6\tindex 0000000..888482e\n7\t--- /dev/null\n8\t+++ b/tests/test_game.py\n9\t@@ -0,0 +1,360 @@\n10\t+import random\n11\t+import unittest\n12\t+\n13\t+from word_garden.game import (\n14\t+    GameState,\n15\t+    apply_guess,\n16\t+    display_word,\n17\t+    is_lost,\n18\t+    is_won,\n19\t+    new_game,\n20\t+    validate_guess,\n21\t+    MSG_ALREADY_GUESSED_TEMPLATE,\n22\t+    MSG_CORRECT,\n23\t+    MSG_GAME_OVER,\n24\t+    MSG_INCORRECT,\n25\t+    MSG_INVALID_NOT_LETTER,\n26\t+    MSG_INVALID_NOT_SINGLE,\n27\t+    MSG_LOSS_TEMPLATE,\n28\t+    MSG_WIN_TEMPLATE,\n29\t+)\n30\t+\n31\t+\n32\t+def _make_state(**kwargs) -> GameState:\n33\t+    \"\"\"Build a GameState with sensible defaults, overridden by kwargs.\"\"\"\n34\t+    defaults = dict(\n35\t+        secret_word=\"GARDEN\",\n36\t+        guessed_letters=set(),\n37\t+        remaining_water=6,\n38\t+        weed_count=0,\n39\t+        max_water=6,\n40\t+    )\n41\t+    defaults.update(kwargs)\n42\t+    return GameState(**defaults)\n43\t+\n44\t+\n45\t+# ---------------------------------------------------------------------------\n46\t+# new_game\n47\t+# ---------------------------------------------------------------------------\n48\t+\n49\t+class TestNewGame(unittest.TestCase):\n50\t+    def test_initial_state_fields(self):\n51\t+        rng = random.Random(42)\n52\t+        state = new_game(\"normal\", rng=rng)\n53\t+        self.assertIsInstance(state.secret_word, str)\n54\t+        self.assertTrue(state.secret_word.isupper())\n55\t+        self.assertEqual(state.guessed_letters, set())\n56\t+        self.assertEqual(state.remaining_water, 6)\n57\t+        self.assertEqual(state.max_water, 6)\n58\t+        self.assertEqual(state.weed_count, 0)\n59\t+        self.assertEqual(state.status_message, \"\")\n60\t+        self.assertFalse(state.game_over)\n61\t+        self.assertFalse(state.won)\n62\t+\n63\t+    def test_easy_water_level(self):\n64\t+        state = new_game(\"easy\", rng=random.Random(1))\n65\t+        self.assertEqual(state.remaining_water, 8)\n66\t+        self.assertEqual(state.max_water, 8)\n67\t+\n68\t+    def test_hard_water_level(self):\n69\t+        state = new_game(\"hard\", rng=random.Random(1))\n70\t+        self.assertEqual(state.remaining_water, 4)\n71\t+        self.assertEqual(state.max_water, 4)\n72\t+\n73\t+\n74\t+# ---------------------------------------------------------------------------\n75\t+# validate_guess — Test 5 (invalid input) and Test 6 (lowercase normalised)\n76\t+# ---------------------------------------------------------------------------\n77\t+\n78\t+class TestValidateGuess(unittest.TestCase):\n79\t+    # Test 5: Invalid input is rejected with a specific message.\n80\t+\n81\t+    def test_empty_string_rejected(self):\n82\t+        letter, msg = validate_guess(\"\")\n83\t+        self.assertIsNone(letter)\n84\t+        self.assertEqual(msg, MSG_INVALID_NOT_SINGLE)\n85\t+\n86\t+    def test_whitespace_only_rejected(self):\n87\t+        letter, msg = validate_guess(\"   \")\n88\t+        self.assertIsNone(letter)\n89\t+        self.assertEqual(msg, MSG_INVALID_NOT_SINGLE)\n90\t+\n91\t+    def test_multiple_letters_rejected(self):\n92\t+        letter, msg = validate_guess(\"AB\")\n93\t+        self.assertIsNone(letter)\n94\t+        self.assertEqual(msg, MSG_INVALID_NOT_SINGLE)\n95\t+\n96\t+    def test_word_rejected(self):\n97\t+        letter, msg = validate_guess(\"apple\")\n98\t+        self.assertIsNone(letter)\n99\t+        self.assertEqual(msg, MSG_INVALID_NOT_SINGLE)\n100\t+\n101\t+    def test_digit_rejected(self):\n102\t+        letter, msg = validate_guess(\"7\")\n103\t+        self.assertIsNone(letter)\n104\t+        self.assertEqual(msg, MSG_INVALID_NOT_LETTER)\n105\t+\n106\t+    def test_symbol_rejected(self):\n107\t+        letter, msg = validate_guess(\"!\")\n108\t+        self.assertIsNone(letter)\n109\t+        self.assertEqual(msg, MSG_INVALID_NOT_LETTER)\n110\t+\n111\t+    # Test 6: Lowercase input is normalised to uppercase.\n112\t+\n113\t+    def test_lowercase_normalised(self):\n114\t+        letter, msg = validate_guess(\"a\")\n115\t+        self.assertEqual(letter, \"A\")\n116\t+        self.assertEqual(msg, \"\")\n117\t+\n118\t+    def test_leading_trailing_spaces_stripped(self):\n119\t+        letter, msg = validate_guess(\"  b  \")\n120\t+        self.assertEqual(letter, \"B\")\n121\t+        self.assertEqual(msg, \"\")\n122\t+\n123\t+    def test_valid_uppercase_accepted(self):\n124\t+        letter, msg = validate_guess(\"Z\")\n125\t+        self.assertEqual(letter, \"Z\")\n126\t+        self.assertEqual(msg, \"\")\n127\t+\n128\t+\n129\t+# ---------------------------------------------------------------------------\n130\t+# apply_guess — Tests 1–4, 7–8\n131\t+# ---------------------------------------------------------------------------\n132\t+\n133\t+class TestApplyGuessCorrect(unittest.TestCase):\n134\t+    # Test 1: A correct guess reveals matching letters.\n135\t+\n136\t+    def test_correct_guess_adds_letter_to_guessed(self):\n137\t+        state = _make_state(secret_word=\"GARDEN\")\n138\t+        result = apply_guess(state, \"G\")\n139\t+        self.assertIn(\"G\", result.guessed_letters)\n140\t+        self.assertEqual(result.remaining_water, 6)\n141\t+        self.assertEqual(result.weed_count, 0)\n142\t+        self.assertEqual(result.status_message, MSG_CORRECT)\n143\t+        self.assertFalse(result.game_over)\n144\t+        self.assertFalse(result.won)\n145\t+\n146\t+    def test_correct_guess_display_reveals_letter(self):\n147\t+        state = _make_state(secret_word=\"GARDEN\")\n148\t+        result = apply_guess(state, \"G\")\n149\t+        # GARDEN with only G revealed → G _ _ _ _ _\n150\t+        self.assertEqual(display_word(result), \"G _ _ _ _ _\")\n151\t+\n152\t+    def test_correct_guess_recurring_letter_all_positions_revealed(self):\n153\t+        # SEEDLING has two E's; both should appear in display\n154\t+        state = _make_state(secret_word=\"SEEDLING\")\n155\t+        result = apply_guess(state, \"E\")\n156\t+        self.assertIn(\"E\", result.guessed_letters)\n157\t+        displayed = display_word(result)\n158\t+        parts = displayed.split(\" \")\n159\t+        self.assertEqual(parts[1], \"E\")  # index 1 in SEEDLING\n160\t+        self.assertEqual(parts[2], \"E\")  # index 2 in SEEDLING\n161\t+\n162\t+\n163\t+class TestApplyGuessIncorrect(unittest.TestCase):\n164\t+    # Tests 2 & 3: An incorrect guess reduces water by one and adds one weed.\n165\t+\n166\t+    def test_incorrect_guess_water_weed_letter(self):\n167\t+        state = _make_state(secret_word=\"GARDEN\")\n168\t+        result = apply_guess(state, \"Z\")\n169\t+        self.assertIn(\"Z\", result.guessed_letters)\n170\t+        self.assertEqual(result.remaining_water, 5)\n171\t+        self.assertEqual(result.weed_count, 1)\n172\t+        self.assertEqual(result.status_message, MSG_INCORRECT)\n173\t+        self.assertFalse(result.game_over)\n174\t+        self.assertFalse(result.won)\n175\t+\n176\t+    def test_incorrect_guess_exact_decrements(self):\n177\t+        state = _make_state(remaining_water=4, weed_count=2)\n178\t+        result = apply_guess(state, \"Z\")\n179\t+        self.assertEqual(result.remaining_water, 3)\n180\t+        self.assertEqual(result.weed_count, 3)\n181\t+\n182\t+\n183\t+class TestApplyGuessRepeated(unittest.TestCase):\n184\t+    # Test 4: Repeated guesses do not reduce water or weeds.\n185\t+\n186\t+    def test_repeated_correct_letter_no_change(self):\n187\t+        state = _make_state(\n188\t+            secret_word=\"GARDEN\",\n189\t+            guessed_letters={\"G\"},\n190\t+            remaining_water=6,\n191\t+            weed_count=0,\n192\t+        )\n193\t+        result = apply_guess(state, \"G\")\n194\t+        self.assertEqual(result.remaining_water, 6)\n195\t+        self.assertEqual(result.weed_count, 0)\n196\t+        self.assertEqual(result.guessed_letters, {\"G\"})\n197\t+        self.assertEqual(\n198\t+            result.status_message,\n199\t+            MSG_ALREADY_GUESSED_TEMPLATE.format(letter=\"G\"),\n200\t+        )\n201\t+        self.assertFalse(result.game_over)\n202\t+        self.assertFalse(result.won)\n203\t+\n204\t+    def test_repeated_wrong_letter_no_change(self):\n205\t+        state = _make_state(\n206\t+            secret_word=\"GARDEN\",\n207\t+            guessed_letters={\"Z\"},\n208\t+            remaining_water=5,\n209\t+            weed_count=1,\n210\t+        )\n211\t+        result = apply_guess(state, \"Z\")\n212\t+        self.assertEqual(result.remaining_water, 5)\n213\t+        self.assertEqual(result.weed_count, 1)\n214\t+        self.assertEqual(result.guessed_letters, {\"Z\"})\n215\t+        self.assertEqual(\n216\t+            result.status_message,\n217\t+            MSG_ALREADY_GUESSED_TEMPLATE.format(letter=\"Z\"),\n218\t+        )\n219\t+\n220\t+\n221\t+class TestApplyGuessWin(unittest.TestCase):\n222\t+    # Test 7: The game detects a win.\n223\t+\n224\t+    def test_win_on_last_letter(self):\n225\t+        state = _make_state(\n226\t+            secret_word=\"GARDEN\",\n227\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\"},\n228\t+            remaining_water=6,\n229\t+            weed_count=0,\n230\t+        )\n231\t+        result = apply_guess(state, \"N\")\n232\t+        self.assertIn(\"N\", result.guessed_letters)\n233\t+        self.assertTrue(result.game_over)\n234\t+        self.assertTrue(result.won)\n235\t+        self.assertEqual(result.remaining_water, 6)\n236\t+        self.assertEqual(result.weed_count, 0)\n237\t+        self.assertEqual(result.status_message, MSG_WIN_TEMPLATE.format(word=\"GARDEN\"))\n238\t+        self.assertTrue(is_won(result))\n239\t+        self.assertFalse(is_lost(result))\n240\t+\n241\t+    def test_guess_after_win_is_noop(self):\n242\t+        state = _make_state(game_over=True, won=True, remaining_water=6, weed_count=0)\n243\t+        result = apply_guess(state, \"X\")\n244\t+        self.assertEqual(result.remaining_water, 6)\n245\t+        self.assertEqual(result.weed_count, 0)\n246\t+        self.assertTrue(result.game_over)\n247\t+        self.assertTrue(result.won)\n248\t+        self.assertEqual(result.status_message, MSG_GAME_OVER)\n249\t+\n250\t+\n251\t+class TestApplyGuessLoss(unittest.TestCase):\n252\t+    # Test 8: The game detects a loss.\n253\t+\n254\t+    def test_loss_on_final_water(self):\n255\t+        state = _make_state(\n256\t+            secret_word=\"GARDEN\",\n257\t+            remaining_water=1,\n258\t+            weed_count=5,\n259\t+        )\n260\t+        result = apply_guess(state, \"Z\")\n261\t+        self.assertIn(\"Z\", result.guessed_letters)\n262\t+        self.assertTrue(result.game_over)\n263\t+        self.assertFalse(result.won)\n264\t+        self.assertEqual(result.remaining_water, 0)\n265\t+        self.assertEqual(result.weed_count, 6)\n266\t+        self.assertEqual(result.status_message, MSG_LOSS_TEMPLATE.format(word=\"GARDEN\"))\n267\t+        self.assertFalse(is_won(result))\n268\t+        self.assertTrue(is_lost(result))\n269\t+\n270\t+    def test_guess_after_loss_is_noop(self):\n271\t+        state = _make_state(game_over=True, won=False, remaining_water=0, weed_count=6)\n272\t+        result = apply_guess(state, \"A\")\n273\t+        self.assertEqual(result.remaining_water, 0)\n274\t+        self.assertEqual(result.weed_count, 6)\n275\t+        self.assertTrue(result.game_over)\n276\t+        self.assertFalse(result.won)\n277\t+        self.assertEqual(result.status_message, MSG_GAME_OVER)\n278\t+\n279\t+\n280\t+class TestApplyGuessImmutability(unittest.TestCase):\n281\t+    def test_original_state_not_mutated_on_correct_guess(self):\n282\t+        state = _make_state(secret_word=\"GARDEN\")\n283\t+        original_guessed = frozenset(state.guessed_letters)\n284\t+        original_water = state.remaining_water\n285\t+        apply_guess(state, \"G\")\n286\t+        self.assertEqual(state.guessed_letters, original_guessed)\n287\t+        self.assertEqual(state.remaining_water, original_water)\n288\t+\n289\t+    def test_original_state_not_mutated_on_wrong_guess(self):\n290\t+        state = _make_state(secret_word=\"GARDEN\")\n291\t+        original_guessed = frozenset(state.guessed_letters)\n292\t+        original_water = state.remaining_water\n293\t+        apply_guess(state, \"Z\")\n294\t+        self.assertEqual(state.guessed_letters, original_guessed)\n295\t+        self.assertEqual(state.remaining_water, original_water)\n296\t+\n297\t+\n298\t+# ---------------------------------------------------------------------------\n299\t+# display_word — Test 9\n300\t+# ---------------------------------------------------------------------------\n301\t+\n302\t+class TestDisplayWord(unittest.TestCase):\n303\t+    # Test 9: The displayed word masks unguessed letters.\n304\t+\n305\t+    def test_all_unguessed_shows_blanks(self):\n306\t+        state = _make_state(secret_word=\"GARDEN\", guessed_letters=set())\n307\t+        self.assertEqual(display_word(state), \"_ _ _ _ _ _\")\n308\t+\n309\t+    def test_some_guessed_shows_mixed(self):\n310\t+        # GARDEN: G(0) A(1) R(2) D(3) E(4) N(5) — G and R guessed\n311\t+        state = _make_state(secret_word=\"GARDEN\", guessed_letters={\"G\", \"R\"})\n312\t+        self.assertEqual(display_word(state), \"G _ R _ _ _\")\n313\t+\n314\t+    def test_all_guessed_shows_full_word(self):\n315\t+        state = _make_state(\n316\t+            secret_word=\"GARDEN\",\n317\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n318\t+        )\n319\t+        self.assertEqual(display_word(state), \"G A R D E N\")\n320\t+\n321\t+    def test_single_letter_word(self):\n322\t+        state = _make_state(secret_word=\"A\", guessed_letters=set())\n323\t+        self.assertEqual(display_word(state), \"_\")\n324\t+\n325\t+    def test_single_letter_word_guessed(self):\n326\t+        state = _make_state(secret_word=\"A\", guessed_letters={\"A\"})\n327\t+        self.assertEqual(display_word(state), \"A\")\n328\t+\n329\t+\n330\t+# ---------------------------------------------------------------------------\n331\t+# is_won / is_lost\n332\t+# ---------------------------------------------------------------------------\n333\t+\n334\t+class TestIsWonIsLost(unittest.TestCase):\n335\t+    def test_is_won_false_when_incomplete(self):\n336\t+        state = _make_state(secret_word=\"GARDEN\", guessed_letters={\"G\"})\n337\t+        self.assertFalse(is_won(state))\n338\t+\n339\t+    def test_is_won_true_when_all_letters_guessed(self):\n340\t+        state = _make_state(\n341\t+            secret_word=\"GARDEN\",\n342\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n343\t+        )\n344\t+        self.assertTrue(is_won(state))\n345\t+\n346\t+    def test_is_won_true_with_extra_guessed_letters(self):\n347\t+        # Extra wrong guesses don't prevent a win\n348\t+        state = _make_state(\n349\t+            secret_word=\"GARDEN\",\n350\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\", \"Z\", \"X\"},\n351\t+        )\n352\t+        self.assertTrue(is_won(state))\n353\t+\n354\t+    def test_is_lost_false_when_water_remains(self):\n355\t+        state = _make_state(remaining_water=1)\n356\t+        self.assertFalse(is_lost(state))\n357\t+\n358\t+    def test_is_lost_true_when_water_zero_and_not_won(self):\n359\t+        state = _make_state(secret_word=\"GARDEN\", remaining_water=0, guessed_letters=set())\n360\t+        self.assertTrue(is_lost(state))\n361\t+\n362\t+    def test_is_lost_false_when_won_despite_zero_water(self):\n363\t+        # Logically shouldn't happen in normal play, but the predicate should be correct\n364\t+        state = _make_state(\n365\t+            secret_word=\"GARDEN\",\n366\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n367\t+            remaining_water=0,\n368\t+        )\n369\t+        self.assertFalse(is_lost(state))\n370\tdiff --git a/tests/test_words.py b/tests/test_words.py\n371\tnew file mode 100644\n372\tindex 0000000..1f8e75f\n373\t--- /dev/null\n374\t+++ b/tests/test_words.py\n375\t@@ -0,0 +1,79 @@\n376\t+import random\n377\t+import unittest\n378\t+\n379\t+from word_garden.words import WORDS, select_word, water_for\n380\t+\n381\t+\n382\t+class TestWordList(unittest.TestCase):\n383\t+    def test_words_are_uppercase_strings(self):\n384\t+        for word in WORDS:\n385\t+            self.assertIsInstance(word, str)\n386\t+            self.assertEqual(word, word.upper(), f\"{word!r} is not uppercase\")\n387\t+\n388\t+    def test_word_list_has_ten_entries(self):\n389\t+        self.assertEqual(len(WORDS), 10)\n390\t+\n391\t+\n392\t+class TestWaterFor(unittest.TestCase):\n393\t+    def test_easy_water(self):\n394\t+        self.assertEqual(water_for(\"easy\"), 8)\n395\t+\n396\t+    def test_normal_water(self):\n397\t+        self.assertEqual(water_for(\"normal\"), 6)\n398\t+\n399\t+    def test_hard_water(self):\n400\t+        self.assertEqual(water_for(\"hard\"), 4)\n401\t+\n402\t+    def test_unknown_difficulty_raises(self):\n403\t+        with self.assertRaises(ValueError):\n404\t+            water_for(\"extreme\")\n405\t+\n406\t+\n407\t+class TestSelectWord(unittest.TestCase):\n408\t+    # Test 10: The word selector returns a valid word for every difficulty.\n409\t+\n410\t+    def test_easy_returns_word_from_list_with_correct_length(self):\n411\t+        rng = random.Random(42)\n412\t+        word = select_word(\"easy\", rng=rng)\n413\t+        self.assertIn(word, WORDS)\n414\t+        self.assertGreaterEqual(len(word), 4)\n415\t+        self.assertLessEqual(len(word), 6)\n416\t+\n417\t+    def test_normal_returns_word_from_list_with_correct_length(self):\n418\t+        rng = random.Random(42)\n419\t+        word = select_word(\"normal\", rng=rng)\n420\t+        self.assertIn(word, WORDS)\n421\t+        self.assertGreaterEqual(len(word), 5)\n422\t+        self.assertLessEqual(len(word), 8)\n423\t+\n424\t+    def test_hard_returns_word_from_list_with_correct_length(self):\n425\t+        rng = random.Random(42)\n426\t+        word = select_word(\"hard\", rng=rng)\n427\t+        self.assertIn(word, WORDS)\n428\t+        self.assertGreaterEqual(len(word), 7)\n429\t+\n430\t+    def test_all_difficulties_return_valid_word(self):\n431\t+        rng = random.Random(7)\n432\t+        for difficulty in (\"easy\", \"normal\", \"hard\"):\n433\t+            with self.subTest(difficulty=difficulty):\n434\t+                word = select_word(difficulty, rng=rng)\n435\t+                self.assertIn(word, WORDS)\n436\t+\n437\t+    def test_unknown_difficulty_raises(self):\n438\t+        with self.assertRaises(ValueError):\n439\t+            select_word(\"extreme\")\n440\t+\n441\t+    def test_injected_rng_is_deterministic(self):\n442\t+        rng_a = random.Random(99)\n443\t+        rng_b = random.Random(99)\n444\t+        self.assertEqual(\n445\t+            select_word(\"normal\", rng=rng_a),\n446\t+            select_word(\"normal\", rng=rng_b),\n447\t+        )\n448\t+\n449\t+    def test_multiple_calls_with_same_seed_agree(self):\n450\t+        rng = random.Random(0)\n451\t+        first = select_word(\"hard\", rng=rng)\n452\t+        rng2 = random.Random(0)\n453\t+        second = select_word(\"hard\", rng=rng2)\n454\t+        self.assertEqual(first, second)\n455\tdiff --git a/word_garden/__init__.py b/word_garden/__init__.py\n456\tnew file mode 100644\n457\tindex 0000000..e69de29\n458\tdiff --git a/word_garden/game.py b/word_garden/game.py\n459\tnew file mode 100644\n460\tindex 0000000..910a11c\n461\t--- /dev/null\n462\t+++ b/word_garden/game.py\n463\t@@ -0,0 +1,114 @@\n464\t+from dataclasses import dataclass, replace\n465\t+\n466\t+from . import words\n467\t+\n468\t+# ---------------------------------------------------------------------------\n469\t+# User-facing message constants.\n470\t+# Tests MUST import these rather than re-typing string literals.\n471\t+# ---------------------------------------------------------------------------\n472\t+\n473\t+MSG_CORRECT = \"Good guess! The garden grows.\"\n474\t+MSG_INCORRECT = \"No match. A weed appears.\"\n475\t+MSG_ALREADY_GUESSED_TEMPLATE = \"You already guessed {letter}. Try another letter.\"\n476\t+MSG_INVALID_NOT_SINGLE = \"Please enter a single letter.\"\n477\t+MSG_INVALID_NOT_LETTER = \"That is not a letter.\"\n478\t+MSG_GAME_OVER = \"The game is already over.\"\n479\t+MSG_WIN_TEMPLATE = \"You guessed the word: {word}. The garden is thriving.\"\n480\t+MSG_LOSS_TEMPLATE = \"The garden ran out of water. The word was: {word}.\"\n481\t+\n482\t+\n483\t+@dataclass\n484\t+class GameState:\n485\t+    secret_word: str\n486\t+    guessed_letters: set[str]\n487\t+    remaining_water: int\n488\t+    weed_count: int\n489\t+    max_water: int\n490\t+    status_message: str = \"\"\n491\t+    game_over: bool = False\n492\t+    won: bool = False\n493\t+\n494\t+\n495\t+def new_game(difficulty: str = \"normal\", rng=None) -> GameState:\n496\t+    \"\"\"Create and return a fresh GameState for the given difficulty.\"\"\"\n497\t+    word = words.select_word(difficulty, rng=rng)\n498\t+    water = words.water_for(difficulty)\n499\t+    return GameState(\n500\t+        secret_word=word.upper(),\n501\t+        guessed_letters=set(),\n502\t+        remaining_water=water,\n503\t+        weed_count=0,\n504\t+        max_water=water,\n505\t+    )\n506\t+\n507\t+\n508\t+def validate_guess(input_text: str) -> tuple[str | None, str]:\n509\t+    \"\"\"Validate raw player input without consulting game state.\n510\t+\n511\t+    Returns (letter, \"\") on success, or (None, error_message) on failure.\n512\t+    The returned letter is trimmed and uppercased.\n513\t+    \"\"\"\n514\t+    text = input_text.strip().upper()\n515\t+    if not text:\n516\t+        return (None, MSG_INVALID_NOT_SINGLE)\n517\t+    if len(text) > 1:\n518\t+        return (None, MSG_INVALID_NOT_SINGLE)\n519\t+    if not text.isalpha():\n520\t+        return (None, MSG_INVALID_NOT_LETTER)\n521\t+    return (text, \"\")\n522\t+\n523\t+\n524\t+def apply_guess(state: GameState, letter: str) -> GameState:\n525\t+    \"\"\"Apply one already-validated uppercase letter to the game state.\n526\t+\n527\t+    Returns a new GameState; the original is never mutated.\n528\t+    Repeated-guess detection and post-game-over no-op are handled here.\n529\t+    \"\"\"\n530\t+    if state.game_over:\n531\t+        return replace(state, status_message=MSG_GAME_OVER)\n532\t+\n533\t+    if letter in state.guessed_letters:\n534\t+        msg = MSG_ALREADY_GUESSED_TEMPLATE.format(letter=letter)\n535\t+        return replace(state, status_message=msg)\n536\t+\n537\t+    new_guessed = state.guessed_letters | {letter}\n538\t+\n539\t+    if letter in state.secret_word:\n540\t+        new_state = replace(state, guessed_letters=new_guessed, status_message=MSG_CORRECT)\n541\t+        if is_won(new_state):\n542\t+            msg = MSG_WIN_TEMPLATE.format(word=new_state.secret_word)\n543\t+            return replace(new_state, game_over=True, won=True, status_message=msg)\n544\t+        return new_state\n545\t+\n546\t+    new_state = replace(\n547\t+        state,\n548\t+        guessed_letters=new_guessed,\n549\t+        remaining_water=state.remaining_water - 1,\n550\t+        weed_count=state.weed_count + 1,\n551\t+        status_message=MSG_INCORRECT,\n552\t+    )\n553\t+    if is_lost(new_state):\n554\t+        msg = MSG_LOSS_TEMPLATE.format(word=new_state.secret_word)\n555\t+        return replace(new_state, game_over=True, won=False, status_message=msg)\n556\t+    return new_state\n557\t+\n558\t+\n559\t+def display_word(state: GameState) -> str:\n560\t+    \"\"\"Return the secret word with unguessed letters masked as underscores.\n561\t+\n562\t+    Letters are space-separated, e.g. 'G _ R _ E _'.\n563\t+    \"\"\"\n564\t+    return \" \".join(\n565\t+        ch if ch in state.guessed_letters else \"_\"\n566\t+        for ch in state.secret_word\n567\t+    )\n568\t+\n569\t+\n570\t+def is_won(state: GameState) -> bool:\n571\t+    \"\"\"Return True when every letter of the secret word has been guessed.\"\"\"\n572\t+    return all(ch in state.guessed_letters for ch in state.secret_word)\n573\t+\n574\t+\n575\t+def is_lost(state: GameState) -> bool:\n576\t+    \"\"\"Return True when water is exhausted and the word has not been won.\"\"\"\n577\t+    return state.remaining_water <= 0 and not is_won(state)\n578\tdiff --git a/word_garden/words.py b/word_garden/words.py\n579\tnew file mode 100644\n580\tindex 0000000..01ee595\n581\t--- /dev/null\n582\t+++ b/word_garden/words.py\n583\t@@ -0,0 +1,49 @@\n584\t+import random as _random\n585\t+\n586\t+WORDS = [\n587\t+    \"GARDEN\",\n588\t+    \"FLOWER\",\n589\t+    \"PLANET\",\n590\t+    \"PYTHON\",\n591\t+    \"TERMINAL\",\n592\t+    \"MEADOW\",\n593\t+    \"ORCHARD\",\n594\t+    \"VINEYARD\",\n595\t+    \"SEEDLING\",\n596\t+    \"HARVEST\",\n597\t+]\n598\t+\n599\t+# Difficulty table: (starting water, minimum word length, maximum word length or None)\n600\t+_DIFFICULTY_CONFIG: dict[str, dict] = {\n601\t+    \"easy\":   {\"water\": 8, \"min_len\": 4, \"max_len\": 6},\n602\t+    \"normal\": {\"water\": 6, \"min_len\": 5, \"max_len\": 8},\n603\t+    \"hard\":   {\"water\": 4, \"min_len\": 7, \"max_len\": None},\n604\t+}\n605\t+\n606\t+\n607\t+def water_for(difficulty: str = \"normal\") -> int:\n608\t+    \"\"\"Return the starting water level for the given difficulty.\"\"\"\n609\t+    if difficulty not in _DIFFICULTY_CONFIG:\n610\t+        raise ValueError(f\"Unknown difficulty: {difficulty!r}\")\n611\t+    return _DIFFICULTY_CONFIG[difficulty][\"water\"]\n612\t+\n613\t+\n614\t+def select_word(difficulty: str = \"normal\", rng=None) -> str:\n615\t+    \"\"\"Return a random word matching the given difficulty's length constraints.\n616\t+\n617\t+    Raises ValueError for an unknown difficulty or if no words match.\n618\t+    Pass a seeded random.Random instance as rng for deterministic selection.\n619\t+    \"\"\"\n620\t+    if difficulty not in _DIFFICULTY_CONFIG:\n621\t+        raise ValueError(f\"Unknown difficulty: {difficulty!r}\")\n622\t+    cfg = _DIFFICULTY_CONFIG[difficulty]\n623\t+    pool = [\n624\t+        w for w in WORDS\n625\t+        if len(w) >= cfg[\"min_len\"]\n626\t+        and (cfg[\"max_len\"] is None or len(w) <= cfg[\"max_len\"])\n627\t+    ]\n628\t+    if not pool:\n629\t+        raise ValueError(f\"No words match difficulty {difficulty!r}\")\n630\t+    if rng is not None:\n631\t+        return rng.choice(pool)\n632\t+    return _random.choice(pool)\n633\t"}]},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"a93e1021-ff15-4829-bc9f-dea3363ea57f","timestamp":"2026-06-12T03:34:52.454Z","tool_use_result":{"type":"text","file":{"filePath":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/C.diff","content":"diff --git a/tests/__init__.py b/tests/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/tests/test_game.py b/tests/test_game.py\nnew file mode 100644\nindex 0000000..888482e\n--- /dev/null\n+++ b/tests/test_game.py\n@@ -0,0 +1,360 @@\n+import random\n+import unittest\n+\n+from word_garden.game import (\n+    GameState,\n+    apply_guess,\n+    display_word,\n+    is_lost,\n+    is_won,\n+    new_game,\n+    validate_guess,\n+    MSG_ALREADY_GUESSED_TEMPLATE,\n+    MSG_CORRECT,\n+    MSG_GAME_OVER,\n+    MSG_INCORRECT,\n+    MSG_INVALID_NOT_LETTER,\n+    MSG_INVALID_NOT_SINGLE,\n+    MSG_LOSS_TEMPLATE,\n+    MSG_WIN_TEMPLATE,\n+)\n+\n+\n+def _make_state(**kwargs) -> GameState:\n+    \"\"\"Build a GameState with sensible defaults, overridden by kwargs.\"\"\"\n+    defaults = dict(\n+        secret_word=\"GARDEN\",\n+        guessed_letters=set(),\n+        remaining_water=6,\n+        weed_count=0,\n+        max_water=6,\n+    )\n+    defaults.update(kwargs)\n+    return GameState(**defaults)\n+\n+\n+# ---------------------------------------------------------------------------\n+# new_game\n+# ---------------------------------------------------------------------------\n+\n+class TestNewGame(unittest.TestCase):\n+    def test_initial_state_fields(self):\n+        rng = random.Random(42)\n+        state = new_game(\"normal\", rng=rng)\n+        self.assertIsInstance(state.secret_word, str)\n+        self.assertTrue(state.secret_word.isupper())\n+        self.assertEqual(state.guessed_letters, set())\n+        self.assertEqual(state.remaining_water, 6)\n+        self.assertEqual(state.max_water, 6)\n+        self.assertEqual(state.weed_count, 0)\n+        self.assertEqual(state.status_message, \"\")\n+        self.assertFalse(state.game_over)\n+        self.assertFalse(state.won)\n+\n+    def test_easy_water_level(self):\n+        state = new_game(\"easy\", rng=random.Random(1))\n+        self.assertEqual(state.remaining_water, 8)\n+        self.assertEqual(state.max_water, 8)\n+\n+    def test_hard_water_level(self):\n+        state = new_game(\"hard\", rng=random.Random(1))\n+        self.assertEqual(state.remaining_water, 4)\n+        self.assertEqual(state.max_water, 4)\n+\n+\n+# ---------------------------------------------------------------------------\n+# validate_guess — Test 5 (invalid input) and Test 6 (lowercase normalised)\n+# ---------------------------------------------------------------------------\n+\n+class TestValidateGuess(unittest.TestCase):\n+    # Test 5: Invalid input is rejected with a specific message.\n+\n+    def test_empty_string_rejected(self):\n+        letter, msg = validate_guess(\"\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_NOT_SINGLE)\n+\n+    def test_whitespace_only_rejected(self):\n+        letter, msg = validate_guess(\"   \")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_NOT_SINGLE)\n+\n+    def test_multiple_letters_rejected(self):\n+        letter, msg = validate_guess(\"AB\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_NOT_SINGLE)\n+\n+    def test_word_rejected(self):\n+        letter, msg = validate_guess(\"apple\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_NOT_SINGLE)\n+\n+    def test_digit_rejected(self):\n+        letter, msg = validate_guess(\"7\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_NOT_LETTER)\n+\n+    def test_symbol_rejected(self):\n+        letter, msg = validate_guess(\"!\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_NOT_LETTER)\n+\n+    # Test 6: Lowercase input is normalised to uppercase.\n+\n+    def test_lowercase_normalised(self):\n+        letter, msg = validate_guess(\"a\")\n+        self.assertEqual(letter, \"A\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_leading_trailing_spaces_stripped(self):\n+        letter, msg = validate_guess(\"  b  \")\n+        self.assertEqual(letter, \"B\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_valid_uppercase_accepted(self):\n+        letter, msg = validate_guess(\"Z\")\n+        self.assertEqual(letter, \"Z\")\n+        self.assertEqual(msg, \"\")\n+\n+\n+# ---------------------------------------------------------------------------\n+# apply_guess — Tests 1–4, 7–8\n+# ---------------------------------------------------------------------------\n+\n+class TestApplyGuessCorrect(unittest.TestCase):\n+    # Test 1: A correct guess reveals matching letters.\n+\n+    def test_correct_guess_adds_letter_to_guessed(self):\n+        state = _make_state(secret_word=\"GARDEN\")\n+        result = apply_guess(state, \"G\")\n+        self.assertIn(\"G\", result.guessed_letters)\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertEqual(result.status_message, MSG_CORRECT)\n+        self.assertFalse(result.game_over)\n+        self.assertFalse(result.won)\n+\n+    def test_correct_guess_display_reveals_letter(self):\n+        state = _make_state(secret_word=\"GARDEN\")\n+        result = apply_guess(state, \"G\")\n+        # GARDEN with only G revealed → G _ _ _ _ _\n+        self.assertEqual(display_word(result), \"G _ _ _ _ _\")\n+\n+    def test_correct_guess_recurring_letter_all_positions_revealed(self):\n+        # SEEDLING has two E's; both should appear in display\n+        state = _make_state(secret_word=\"SEEDLING\")\n+        result = apply_guess(state, \"E\")\n+        self.assertIn(\"E\", result.guessed_letters)\n+        displayed = display_word(result)\n+        parts = displayed.split(\" \")\n+        self.assertEqual(parts[1], \"E\")  # index 1 in SEEDLING\n+        self.assertEqual(parts[2], \"E\")  # index 2 in SEEDLING\n+\n+\n+class TestApplyGuessIncorrect(unittest.TestCase):\n+    # Tests 2 & 3: An incorrect guess reduces water by one and adds one weed.\n+\n+    def test_incorrect_guess_water_weed_letter(self):\n+        state = _make_state(secret_word=\"GARDEN\")\n+        result = apply_guess(state, \"Z\")\n+        self.assertIn(\"Z\", result.guessed_letters)\n+        self.assertEqual(result.remaining_water, 5)\n+        self.assertEqual(result.weed_count, 1)\n+        self.assertEqual(result.status_message, MSG_INCORRECT)\n+        self.assertFalse(result.game_over)\n+        self.assertFalse(result.won)\n+\n+    def test_incorrect_guess_exact_decrements(self):\n+        state = _make_state(remaining_water=4, weed_count=2)\n+        result = apply_guess(state, \"Z\")\n+        self.assertEqual(result.remaining_water, 3)\n+        self.assertEqual(result.weed_count, 3)\n+\n+\n+class TestApplyGuessRepeated(unittest.TestCase):\n+    # Test 4: Repeated guesses do not reduce water or weeds.\n+\n+    def test_repeated_correct_letter_no_change(self):\n+        state = _make_state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\"},\n+            remaining_water=6,\n+            weed_count=0,\n+        )\n+        result = apply_guess(state, \"G\")\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertEqual(result.guessed_letters, {\"G\"})\n+        self.assertEqual(\n+            result.status_message,\n+            MSG_ALREADY_GUESSED_TEMPLATE.format(letter=\"G\"),\n+        )\n+        self.assertFalse(result.game_over)\n+        self.assertFalse(result.won)\n+\n+    def test_repeated_wrong_letter_no_change(self):\n+        state = _make_state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"Z\"},\n+            remaining_water=5,\n+            weed_count=1,\n+        )\n+        result = apply_guess(state, \"Z\")\n+        self.assertEqual(result.remaining_water, 5)\n+        self.assertEqual(result.weed_count, 1)\n+        self.assertEqual(result.guessed_letters, {\"Z\"})\n+        self.assertEqual(\n+            result.status_message,\n+            MSG_ALREADY_GUESSED_TEMPLATE.format(letter=\"Z\"),\n+        )\n+\n+\n+class TestApplyGuessWin(unittest.TestCase):\n+    # Test 7: The game detects a win.\n+\n+    def test_win_on_last_letter(self):\n+        state = _make_state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\"},\n+            remaining_water=6,\n+            weed_count=0,\n+        )\n+        result = apply_guess(state, \"N\")\n+        self.assertIn(\"N\", result.guessed_letters)\n+        self.assertTrue(result.game_over)\n+        self.assertTrue(result.won)\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertEqual(result.status_message, MSG_WIN_TEMPLATE.format(word=\"GARDEN\"))\n+        self.assertTrue(is_won(result))\n+        self.assertFalse(is_lost(result))\n+\n+    def test_guess_after_win_is_noop(self):\n+        state = _make_state(game_over=True, won=True, remaining_water=6, weed_count=0)\n+        result = apply_guess(state, \"X\")\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertTrue(result.game_over)\n+        self.assertTrue(result.won)\n+        self.assertEqual(result.status_message, MSG_GAME_OVER)\n+\n+\n+class TestApplyGuessLoss(unittest.TestCase):\n+    # Test 8: The game detects a loss.\n+\n+    def test_loss_on_final_water(self):\n+        state = _make_state(\n+            secret_word=\"GARDEN\",\n+            remaining_water=1,\n+            weed_count=5,\n+        )\n+        result = apply_guess(state, \"Z\")\n+        self.assertIn(\"Z\", result.guessed_letters)\n+        self.assertTrue(result.game_over)\n+        self.assertFalse(result.won)\n+        self.assertEqual(result.remaining_water, 0)\n+        self.assertEqual(result.weed_count, 6)\n+        self.assertEqual(result.status_message, MSG_LOSS_TEMPLATE.format(word=\"GARDEN\"))\n+        self.assertFalse(is_won(result))\n+        self.assertTrue(is_lost(result))\n+\n+    def test_guess_after_loss_is_noop(self):\n+        state = _make_state(game_over=True, won=False, remaining_water=0, weed_count=6)\n+        result = apply_guess(state, \"A\")\n+        self.assertEqual(result.remaining_water, 0)\n+        self.assertEqual(result.weed_count, 6)\n+        self.assertTrue(result.game_over)\n+        self.assertFalse(result.won)\n+        self.assertEqual(result.status_message, MSG_GAME_OVER)\n+\n+\n+class TestApplyGuessImmutability(unittest.TestCase):\n+    def test_original_state_not_mutated_on_correct_guess(self):\n+        state = _make_state(secret_word=\"GARDEN\")\n+        original_guessed = frozenset(state.guessed_letters)\n+        original_water = state.remaining_water\n+        apply_guess(state, \"G\")\n+        self.assertEqual(state.guessed_letters, original_guessed)\n+        self.assertEqual(state.remaining_water, original_water)\n+\n+    def test_original_state_not_mutated_on_wrong_guess(self):\n+        state = _make_state(secret_word=\"GARDEN\")\n+        original_guessed = frozenset(state.guessed_letters)\n+        original_water = state.remaining_water\n+        apply_guess(state, \"Z\")\n+        self.assertEqual(state.guessed_letters, original_guessed)\n+        self.assertEqual(state.remaining_water, original_water)\n+\n+\n+# ---------------------------------------------------------------------------\n+# display_word — Test 9\n+# ---------------------------------------------------------------------------\n+\n+class TestDisplayWord(unittest.TestCase):\n+    # Test 9: The displayed word masks unguessed letters.\n+\n+    def test_all_unguessed_shows_blanks(self):\n+        state = _make_state(secret_word=\"GARDEN\", guessed_letters=set())\n+        self.assertEqual(display_word(state), \"_ _ _ _ _ _\")\n+\n+    def test_some_guessed_shows_mixed(self):\n+        # GARDEN: G(0) A(1) R(2) D(3) E(4) N(5) — G and R guessed\n+        state = _make_state(secret_word=\"GARDEN\", guessed_letters={\"G\", \"R\"})\n+        self.assertEqual(display_word(state), \"G _ R _ _ _\")\n+\n+    def test_all_guessed_shows_full_word(self):\n+        state = _make_state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+        )\n+        self.assertEqual(display_word(state), \"G A R D E N\")\n+\n+    def test_single_letter_word(self):\n+        state = _make_state(secret_word=\"A\", guessed_letters=set())\n+        self.assertEqual(display_word(state), \"_\")\n+\n+    def test_single_letter_word_guessed(self):\n+        state = _make_state(secret_word=\"A\", guessed_letters={\"A\"})\n+        self.assertEqual(display_word(state), \"A\")\n+\n+\n+# ---------------------------------------------------------------------------\n+# is_won / is_lost\n+# ---------------------------------------------------------------------------\n+\n+class TestIsWonIsLost(unittest.TestCase):\n+    def test_is_won_false_when_incomplete(self):\n+        state = _make_state(secret_word=\"GARDEN\", guessed_letters={\"G\"})\n+        self.assertFalse(is_won(state))\n+\n+    def test_is_won_true_when_all_letters_guessed(self):\n+        state = _make_state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+        )\n+        self.assertTrue(is_won(state))\n+\n+    def test_is_won_true_with_extra_guessed_letters(self):\n+        # Extra wrong guesses don't prevent a win\n+        state = _make_state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\", \"Z\", \"X\"},\n+        )\n+        self.assertTrue(is_won(state))\n+\n+    def test_is_lost_false_when_water_remains(self):\n+        state = _make_state(remaining_water=1)\n+        self.assertFalse(is_lost(state))\n+\n+    def test_is_lost_true_when_water_zero_and_not_won(self):\n+        state = _make_state(secret_word=\"GARDEN\", remaining_water=0, guessed_letters=set())\n+        self.assertTrue(is_lost(state))\n+\n+    def test_is_lost_false_when_won_despite_zero_water(self):\n+        # Logically shouldn't happen in normal play, but the predicate should be correct\n+        state = _make_state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+            remaining_water=0,\n+        )\n+        self.assertFalse(is_lost(state))\ndiff --git a/tests/test_words.py b/tests/test_words.py\nnew file mode 100644\nindex 0000000..1f8e75f\n--- /dev/null\n+++ b/tests/test_words.py\n@@ -0,0 +1,79 @@\n+import random\n+import unittest\n+\n+from word_garden.words import WORDS, select_word, water_for\n+\n+\n+class TestWordList(unittest.TestCase):\n+    def test_words_are_uppercase_strings(self):\n+        for word in WORDS:\n+            self.assertIsInstance(word, str)\n+            self.assertEqual(word, word.upper(), f\"{word!r} is not uppercase\")\n+\n+    def test_word_list_has_ten_entries(self):\n+        self.assertEqual(len(WORDS), 10)\n+\n+\n+class TestWaterFor(unittest.TestCase):\n+    def test_easy_water(self):\n+        self.assertEqual(water_for(\"easy\"), 8)\n+\n+    def test_normal_water(self):\n+        self.assertEqual(water_for(\"normal\"), 6)\n+\n+    def test_hard_water(self):\n+        self.assertEqual(water_for(\"hard\"), 4)\n+\n+    def test_unknown_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            water_for(\"extreme\")\n+\n+\n+class TestSelectWord(unittest.TestCase):\n+    # Test 10: The word selector returns a valid word for every difficulty.\n+\n+    def test_easy_returns_word_from_list_with_correct_length(self):\n+        rng = random.Random(42)\n+        word = select_word(\"easy\", rng=rng)\n+        self.assertIn(word, WORDS)\n+        self.assertGreaterEqual(len(word), 4)\n+        self.assertLessEqual(len(word), 6)\n+\n+    def test_normal_returns_word_from_list_with_correct_length(self):\n+        rng = random.Random(42)\n+        word = select_word(\"normal\", rng=rng)\n+        self.assertIn(word, WORDS)\n+        self.assertGreaterEqual(len(word), 5)\n+        self.assertLessEqual(len(word), 8)\n+\n+    def test_hard_returns_word_from_list_with_correct_length(self):\n+        rng = random.Random(42)\n+        word = select_word(\"hard\", rng=rng)\n+        self.assertIn(word, WORDS)\n+        self.assertGreaterEqual(len(word), 7)\n+\n+    def test_all_difficulties_return_valid_word(self):\n+        rng = random.Random(7)\n+        for difficulty in (\"easy\", \"normal\", \"hard\"):\n+            with self.subTest(difficulty=difficulty):\n+                word = select_word(difficulty, rng=rng)\n+                self.assertIn(word, WORDS)\n+\n+    def test_unknown_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            select_word(\"extreme\")\n+\n+    def test_injected_rng_is_deterministic(self):\n+        rng_a = random.Random(99)\n+        rng_b = random.Random(99)\n+        self.assertEqual(\n+            select_word(\"normal\", rng=rng_a),\n+            select_word(\"normal\", rng=rng_b),\n+        )\n+\n+    def test_multiple_calls_with_same_seed_agree(self):\n+        rng = random.Random(0)\n+        first = select_word(\"hard\", rng=rng)\n+        rng2 = random.Random(0)\n+        second = select_word(\"hard\", rng=rng2)\n+        self.assertEqual(first, second)\ndiff --git a/word_garden/__init__.py b/word_garden/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/word_garden/game.py b/word_garden/game.py\nnew file mode 100644\nindex 0000000..910a11c\n--- /dev/null\n+++ b/word_garden/game.py\n@@ -0,0 +1,114 @@\n+from dataclasses import dataclass, replace\n+\n+from . import words\n+\n+# ---------------------------------------------------------------------------\n+# User-facing message constants.\n+# Tests MUST import these rather than re-typing string literals.\n+# ---------------------------------------------------------------------------\n+\n+MSG_CORRECT = \"Good guess! The garden grows.\"\n+MSG_INCORRECT = \"No match. A weed appears.\"\n+MSG_ALREADY_GUESSED_TEMPLATE = \"You already guessed {letter}. Try another letter.\"\n+MSG_INVALID_NOT_SINGLE = \"Please enter a single letter.\"\n+MSG_INVALID_NOT_LETTER = \"That is not a letter.\"\n+MSG_GAME_OVER = \"The game is already over.\"\n+MSG_WIN_TEMPLATE = \"You guessed the word: {word}. The garden is thriving.\"\n+MSG_LOSS_TEMPLATE = \"The garden ran out of water. The word was: {word}.\"\n+\n+\n+@dataclass\n+class GameState:\n+    secret_word: str\n+    guessed_letters: set[str]\n+    remaining_water: int\n+    weed_count: int\n+    max_water: int\n+    status_message: str = \"\"\n+    game_over: bool = False\n+    won: bool = False\n+\n+\n+def new_game(difficulty: str = \"normal\", rng=None) -> GameState:\n+    \"\"\"Create and return a fresh GameState for the given difficulty.\"\"\"\n+    word = words.select_word(difficulty, rng=rng)\n+    water = words.water_for(difficulty)\n+    return GameState(\n+        secret_word=word.upper(),\n+        guessed_letters=set(),\n+        remaining_water=water,\n+        weed_count=0,\n+        max_water=water,\n+    )\n+\n+\n+def validate_guess(input_text: str) -> tuple[str | None, str]:\n+    \"\"\"Validate raw player input without consulting game state.\n+\n+    Returns (letter, \"\") on success, or (None, error_message) on failure.\n+    The returned letter is trimmed and uppercased.\n+    \"\"\"\n+    text = input_text.strip().upper()\n+    if not text:\n+        return (None, MSG_INVALID_NOT_SINGLE)\n+    if len(text) > 1:\n+        return (None, MSG_INVALID_NOT_SINGLE)\n+    if not text.isalpha():\n+        return (None, MSG_INVALID_NOT_LETTER)\n+    return (text, \"\")\n+\n+\n+def apply_guess(state: GameState, letter: str) -> GameState:\n+    \"\"\"Apply one already-validated uppercase letter to the game state.\n+\n+    Returns a new GameState; the original is never mutated.\n+    Repeated-guess detection and post-game-over no-op are handled here.\n+    \"\"\"\n+    if state.game_over:\n+        return replace(state, status_message=MSG_GAME_OVER)\n+\n+    if letter in state.guessed_letters:\n+        msg = MSG_ALREADY_GUESSED_TEMPLATE.format(letter=letter)\n+        return replace(state, status_message=msg)\n+\n+    new_guessed = state.guessed_letters | {letter}\n+\n+    if letter in state.secret_word:\n+        new_state = replace(state, guessed_letters=new_guessed, status_message=MSG_CORRECT)\n+        if is_won(new_state):\n+            msg = MSG_WIN_TEMPLATE.format(word=new_state.secret_word)\n+            return replace(new_state, game_over=True, won=True, status_message=msg)\n+        return new_state\n+\n+    new_state = replace(\n+        state,\n+        guessed_letters=new_guessed,\n+        remaining_water=state.remaining_water - 1,\n+        weed_count=state.weed_count + 1,\n+        status_message=MSG_INCORRECT,\n+    )\n+    if is_lost(new_state):\n+        msg = MSG_LOSS_TEMPLATE.format(word=new_state.secret_word)\n+        return replace(new_state, game_over=True, won=False, status_message=msg)\n+    return new_state\n+\n+\n+def display_word(state: GameState) -> str:\n+    \"\"\"Return the secret word with unguessed letters masked as underscores.\n+\n+    Letters are space-separated, e.g. 'G _ R _ E _'.\n+    \"\"\"\n+    return \" \".join(\n+        ch if ch in state.guessed_letters else \"_\"\n+        for ch in state.secret_word\n+    )\n+\n+\n+def is_won(state: GameState) -> bool:\n+    \"\"\"Return True when every letter of the secret word has been guessed.\"\"\"\n+    return all(ch in state.guessed_letters for ch in state.secret_word)\n+\n+\n+def is_lost(state: GameState) -> bool:\n+    \"\"\"Return True when water is exhausted and the word has not been won.\"\"\"\n+    return state.remaining_water <= 0 and not is_won(state)\ndiff --git a/word_garden/words.py b/word_garden/words.py\nnew file mode 100644\nindex 0000000..01ee595\n--- /dev/null\n+++ b/word_garden/words.py\n@@ -0,0 +1,49 @@\n+import random as _random\n+\n+WORDS = [\n+    \"GARDEN\",\n+    \"FLOWER\",\n+    \"PLANET\",\n+    \"PYTHON\",\n+    \"TERMINAL\",\n+    \"MEADOW\",\n+    \"ORCHARD\",\n+    \"VINEYARD\",\n+    \"SEEDLING\",\n+    \"HARVEST\",\n+]\n+\n+# Difficulty table: (starting water, minimum word length, maximum word length or None)\n+_DIFFICULTY_CONFIG: dict[str, dict] = {\n+    \"easy\":   {\"water\": 8, \"min_len\": 4, \"max_len\": 6},\n+    \"normal\": {\"water\": 6, \"min_len\": 5, \"max_len\": 8},\n+    \"hard\":   {\"water\": 4, \"min_len\": 7, \"max_len\": None},\n+}\n+\n+\n+def water_for(difficulty: str = \"normal\") -> int:\n+    \"\"\"Return the starting water level for the given difficulty.\"\"\"\n+    if difficulty not in _DIFFICULTY_CONFIG:\n+        raise ValueError(f\"Unknown difficulty: {difficulty!r}\")\n+    return _DIFFICULTY_CONFIG[difficulty][\"water\"]\n+\n+\n+def select_word(difficulty: str = \"normal\", rng=None) -> str:\n+    \"\"\"Return a random word matching the given difficulty's length constraints.\n+\n+    Raises ValueError for an unknown difficulty or if no words match.\n+    Pass a seeded random.Random instance as rng for deterministic selection.\n+    \"\"\"\n+    if difficulty not in _DIFFICULTY_CONFIG:\n+        raise ValueError(f\"Unknown difficulty: {difficulty!r}\")\n+    cfg = _DIFFICULTY_CONFIG[difficulty]\n+    pool = [\n+        w for w in WORDS\n+        if len(w) >= cfg[\"min_len\"]\n+        and (cfg[\"max_len\"] is None or len(w) <= cfg[\"max_len\"])\n+    ]\n+    if not pool:\n+        raise ValueError(f\"No words match difficulty {difficulty!r}\")\n+    if rng is not None:\n+        return rng.choice(pool)\n+    return _random.choice(pool)\n","numLines":633,"startLine":1,"totalLines":633}}},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_017spUiY9XCoCNBYevVczJNb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014oNPXQR1G7FAo3qGLGzb2e","name":"Read","input":{"file_path":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/D.diff"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":24462,"cache_read_input_tokens":35116,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":24462},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"cbd24b49-afd0-4e01-8d71-c755b5f3baad","request_id":"req_011CbxfU2RTG1U4faNAJw9mh"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014oNPXQR1G7FAo3qGLGzb2e","type":"tool_result","content":"1\tdiff --git a/tests/__init__.py b/tests/__init__.py\n2\tnew file mode 100644\n3\tindex 0000000..e69de29\n4\tdiff --git a/tests/test_game.py b/tests/test_game.py\n5\tnew file mode 100644\n6\tindex 0000000..610407e\n7\t--- /dev/null\n8\t+++ b/tests/test_game.py\n9\t@@ -0,0 +1,199 @@\n10\t+\"\"\"Tests for word_garden.game (SPEC.md section 16, cases 1-9).\n11\t+\n12\t+Fixtures construct GameState directly with pinned values rather than calling a\n13\t+randomized constructor and overwriting fields. Tests assert the full positive\n14\t+outcome of each state transition, not just the absence of the negative.\n15\t+\"\"\"\n16\t+\n17\t+import random\n18\t+import unittest\n19\t+\n20\t+from word_garden import game, words\n21\t+from word_garden.game import GameState\n22\t+\n23\t+\n24\t+def make_state(secret=\"GARDEN\", guessed=None, water=6, weeds=0, max_water=6):\n25\t+    return GameState(\n26\t+        secret_word=secret,\n27\t+        guessed_letters=set(guessed or ()),\n28\t+        remaining_water=water,\n29\t+        weed_count=weeds,\n30\t+        max_water=max_water,\n31\t+    )\n32\t+\n33\t+\n34\t+class NewGameTests(unittest.TestCase):\n35\t+    def test_new_game_initial_state(self):\n36\t+        state = game.new_game(\"normal\", rng=random.Random(7))\n37\t+        self.assertIn(state.secret_word, words.WORDS)\n38\t+        self.assertTrue(state.secret_word.isupper())\n39\t+        self.assertEqual(state.guessed_letters, set())\n40\t+        self.assertEqual(state.remaining_water, 6)\n41\t+        self.assertEqual(state.max_water, 6)\n42\t+        self.assertEqual(state.weed_count, 0)\n43\t+        self.assertEqual(state.status_message, \"\")\n44\t+        self.assertFalse(state.game_over)\n45\t+        self.assertFalse(state.won)\n46\t+\n47\t+    def test_new_game_water_follows_difficulty(self):\n48\t+        easy = game.new_game(\"easy\", rng=random.Random(1))\n49\t+        self.assertEqual(easy.remaining_water, 8)\n50\t+        self.assertEqual(easy.max_water, 8)\n51\t+        hard = game.new_game(\"hard\", rng=random.Random(1))\n52\t+        self.assertEqual(hard.remaining_water, 4)\n53\t+        self.assertEqual(hard.max_water, 4)\n54\t+\n55\t+    def test_new_game_unknown_difficulty_raises(self):\n56\t+        with self.assertRaises(ValueError):\n57\t+            game.new_game(\"expert\", rng=random.Random(0))\n58\t+\n59\t+\n60\t+class ValidateGuessTests(unittest.TestCase):\n61\t+    def test_empty_input_rejected(self):\n62\t+        # Case 5: invalid input is rejected with a specific message.\n63\t+        self.assertEqual(game.validate_guess(\"\"), (None, game.MSG_ENTER_SINGLE))\n64\t+        self.assertEqual(game.validate_guess(\"   \"), (None, game.MSG_ENTER_SINGLE))\n65\t+\n66\t+    def test_multiple_characters_rejected(self):\n67\t+        self.assertEqual(game.validate_guess(\"apple\"), (None, game.MSG_ENTER_SINGLE))\n68\t+        self.assertEqual(game.validate_guess(\"ab\"), (None, game.MSG_ENTER_SINGLE))\n69\t+\n70\t+    def test_number_rejected(self):\n71\t+        self.assertEqual(game.validate_guess(\"7\"), (None, game.MSG_NOT_A_LETTER))\n72\t+\n73\t+    def test_symbol_rejected(self):\n74\t+        self.assertEqual(game.validate_guess(\"!\"), (None, game.MSG_NOT_A_LETTER))\n75\t+\n76\t+    def test_lowercase_is_normalized(self):\n77\t+        # Case 6: lowercase input is normalized to uppercase.\n78\t+        self.assertEqual(game.validate_guess(\"a\"), (\"A\", \"\"))\n79\t+\n80\t+    def test_surrounding_whitespace_is_trimmed(self):\n81\t+        self.assertEqual(game.validate_guess(\"  Z  \"), (\"Z\", \"\"))\n82\t+\n83\t+    def test_uppercase_letter_passes(self):\n84\t+        self.assertEqual(game.validate_guess(\"Q\"), (\"Q\", \"\"))\n85\t+\n86\t+\n87\t+class ApplyGuessCorrectTests(unittest.TestCase):\n88\t+    def test_correct_guess_reveals_without_penalty(self):\n89\t+        # Cases 1: a correct guess reveals matching letters, no water/weed cost.\n90\t+        state = make_state(secret=\"GARDEN\", water=6, weeds=0)\n91\t+        result = game.apply_guess(state, \"G\")\n92\t+        self.assertIn(\"G\", result.guessed_letters)\n93\t+        self.assertEqual(result.remaining_water, 6)\n94\t+        self.assertEqual(result.weed_count, 0)\n95\t+        self.assertEqual(result.status_message, game.MSG_CORRECT)\n96\t+        self.assertFalse(result.game_over)\n97\t+        self.assertFalse(result.won)\n98\t+        self.assertEqual(game.display_word(result), \"G _ _ _ _ _\")\n99\t+\n100\t+\n101\t+class ApplyGuessWrongTests(unittest.TestCase):\n102\t+    def test_wrong_guess_full_outcome(self):\n103\t+        # Cases 2 & 3: water -1 AND weeds +1 AND letter recorded AND message.\n104\t+        state = make_state(secret=\"GARDEN\", water=6, weeds=0)\n105\t+        result = game.apply_guess(state, \"Z\")\n106\t+        self.assertIn(\"Z\", result.guessed_letters)\n107\t+        self.assertEqual(result.remaining_water, 5)\n108\t+        self.assertEqual(result.weed_count, 1)\n109\t+        self.assertEqual(result.status_message, game.MSG_WRONG)\n110\t+        self.assertFalse(result.game_over)\n111\t+        self.assertFalse(result.won)\n112\t+\n113\t+\n114\t+class ApplyGuessRepeatTests(unittest.TestCase):\n115\t+    def test_repeated_wrong_guess_changes_nothing_but_message(self):\n116\t+        # Case 4: repeated guesses do not reduce water (or change weeds).\n117\t+        state = make_state(secret=\"GARDEN\", water=6, weeds=0)\n118\t+        game.apply_guess(state, \"Z\")\n119\t+        self.assertEqual(state.remaining_water, 5)\n120\t+        self.assertEqual(state.weed_count, 1)\n121\t+\n122\t+        result = game.apply_guess(state, \"Z\")\n123\t+        self.assertEqual(result.remaining_water, 5)\n124\t+        self.assertEqual(result.weed_count, 1)\n125\t+        self.assertEqual(result.guessed_letters, {\"Z\"})\n126\t+        self.assertEqual(\n127\t+            result.status_message,\n128\t+            game.MSG_ALREADY_GUESSED.format(letter=\"Z\"),\n129\t+        )\n130\t+\n131\t+    def test_repeated_correct_guess_does_not_re_reveal(self):\n132\t+        state = make_state(secret=\"GARDEN\", guessed={\"G\"}, water=6, weeds=0)\n133\t+        result = game.apply_guess(state, \"G\")\n134\t+        self.assertEqual(result.remaining_water, 6)\n135\t+        self.assertEqual(result.weed_count, 0)\n136\t+        self.assertEqual(\n137\t+            result.status_message,\n138\t+            game.MSG_ALREADY_GUESSED.format(letter=\"G\"),\n139\t+        )\n140\t+\n141\t+\n142\t+class WinTests(unittest.TestCase):\n143\t+    def test_win_is_detected_and_flagged(self):\n144\t+        # Case 7: the game detects a win and sets won/game_over with the message.\n145\t+        state = make_state(secret=\"GO\", guessed={\"G\"}, water=6, weeds=0)\n146\t+        self.assertFalse(game.is_won(state))\n147\t+        result = game.apply_guess(state, \"O\")\n148\t+        self.assertTrue(result.won)\n149\t+        self.assertTrue(result.game_over)\n150\t+        self.assertTrue(game.is_won(result))\n151\t+        self.assertFalse(game.is_lost(result))\n152\t+        self.assertEqual(result.remaining_water, 6)\n153\t+        self.assertEqual(\n154\t+            result.status_message, game.MSG_WIN.format(word=\"GO\")\n155\t+        )\n156\t+\n157\t+    def test_winning_on_last_water_still_wins(self):\n158\t+        # A correct final guess never counts as a loss even at low water.\n159\t+        state = make_state(secret=\"GO\", guessed={\"G\"}, water=1, weeds=5)\n160\t+        result = game.apply_guess(state, \"O\")\n161\t+        self.assertTrue(result.won)\n162\t+        self.assertFalse(game.is_lost(result))\n163\t+\n164\t+\n165\t+class LossTests(unittest.TestCase):\n166\t+    def test_loss_is_detected_when_water_hits_zero(self):\n167\t+        # Case 8: the game detects a loss and sets game_over (won stays False).\n168\t+        state = make_state(secret=\"GARDEN\", guessed={\"X\"}, water=1, weeds=4)\n169\t+        self.assertFalse(game.is_lost(state))\n170\t+        result = game.apply_guess(state, \"Z\")\n171\t+        self.assertEqual(result.remaining_water, 0)\n172\t+        self.assertEqual(result.weed_count, 5)\n173\t+        self.assertTrue(result.game_over)\n174\t+        self.assertFalse(result.won)\n175\t+        self.assertTrue(game.is_lost(result))\n176\t+        self.assertEqual(\n177\t+            result.status_message, game.MSG_LOSS.format(word=\"GARDEN\")\n178\t+        )\n179\t+\n180\t+\n181\t+class GameOverNoOpTests(unittest.TestCase):\n182\t+    def test_guess_after_game_over_is_a_no_op(self):\n183\t+        state = make_state(secret=\"GARDEN\", guessed={\"G\"}, water=3, weeds=2)\n184\t+        state.game_over = True\n185\t+        result = game.apply_guess(state, \"A\")\n186\t+        self.assertNotIn(\"A\", result.guessed_letters)\n187\t+        self.assertEqual(result.remaining_water, 3)\n188\t+        self.assertEqual(result.weed_count, 2)\n189\t+        self.assertEqual(result.status_message, game.MSG_GAME_OVER)\n190\t+\n191\t+\n192\t+class DisplayWordTests(unittest.TestCase):\n193\t+    def test_masks_unguessed_letters(self):\n194\t+        # Case 9: the displayed word masks unguessed letters, space-separated.\n195\t+        state = make_state(secret=\"GARDEN\", guessed={\"G\", \"R\", \"E\"})\n196\t+        self.assertEqual(game.display_word(state), \"G _ R _ E _\")\n197\t+\n198\t+    def test_no_guesses_is_all_blanks(self):\n199\t+        state = make_state(secret=\"GARDEN\", guessed=set())\n200\t+        self.assertEqual(game.display_word(state), \"_ _ _ _ _ _\")\n201\t+\n202\t+    def test_repeated_letters_all_revealed(self):\n203\t+        state = make_state(secret=\"SEEDLING\", guessed={\"E\"})\n204\t+        self.assertEqual(game.display_word(state), \"_ E E _ _ _ _ _\")\n205\t+\n206\t+\n207\t+if __name__ == \"__main__\":\n208\t+    unittest.main()\n209\tdiff --git a/tests/test_words.py b/tests/test_words.py\n210\tnew file mode 100644\n211\tindex 0000000..4dc12fa\n212\t--- /dev/null\n213\t+++ b/tests/test_words.py\n214\t@@ -0,0 +1,86 @@\n215\t+\"\"\"Tests for word_garden.words (SPEC.md section 16, case 10).\"\"\"\n216\t+\n217\t+import random\n218\t+import unittest\n219\t+\n220\t+from word_garden import words\n221\t+\n222\t+\n223\t+class WordListTests(unittest.TestCase):\n224\t+    def test_word_list_matches_spec_and_is_uppercase(self):\n225\t+        self.assertEqual(\n226\t+            words.WORDS,\n227\t+            [\n228\t+                \"GARDEN\",\n229\t+                \"FLOWER\",\n230\t+                \"PLANET\",\n231\t+                \"PYTHON\",\n232\t+                \"TERMINAL\",\n233\t+                \"MEADOW\",\n234\t+                \"ORCHARD\",\n235\t+                \"VINEYARD\",\n236\t+                \"SEEDLING\",\n237\t+                \"HARVEST\",\n238\t+            ],\n239\t+        )\n240\t+        for word in words.WORDS:\n241\t+            self.assertTrue(word.isupper(), word)\n242\t+            self.assertTrue(word.isalpha(), word)\n243\t+\n244\t+\n245\t+class WaterForTests(unittest.TestCase):\n246\t+    def test_water_per_difficulty(self):\n247\t+        self.assertEqual(words.water_for(\"easy\"), 8)\n248\t+        self.assertEqual(words.water_for(\"normal\"), 6)\n249\t+        self.assertEqual(words.water_for(\"hard\"), 4)\n250\t+\n251\t+    def test_default_is_normal(self):\n252\t+        self.assertEqual(words.water_for(), 6)\n253\t+\n254\t+    def test_unknown_difficulty_raises(self):\n255\t+        with self.assertRaises(ValueError):\n256\t+            words.water_for(\"impossible\")\n257\t+\n258\t+\n259\t+class SelectWordTests(unittest.TestCase):\n260\t+    # SPEC.md section 7 length bands, inclusive; hard has no upper bound.\n261\t+    BANDS = {\"easy\": (4, 6), \"normal\": (5, 8), \"hard\": (7, 99)}\n262\t+\n263\t+    def test_returns_valid_word_for_every_difficulty(self):\n264\t+        # Case 10: the selector returns a valid word respecting the band.\n265\t+        # Sweep many seeds so we exercise the whole pool deterministically.\n266\t+        for difficulty, (low, high) in self.BANDS.items():\n267\t+            for seed in range(50):\n268\t+                rng = random.Random(seed)\n269\t+                word = words.select_word(difficulty, rng=rng)\n270\t+                self.assertIn(word, words.WORDS)\n271\t+                self.assertTrue(word.isupper())\n272\t+                self.assertGreaterEqual(len(word), low, (difficulty, word))\n273\t+                self.assertLessEqual(len(word), high, (difficulty, word))\n274\t+\n275\t+    def test_injected_rng_is_deterministic(self):\n276\t+        first = words.select_word(\"normal\", rng=random.Random(1234))\n277\t+        second = words.select_word(\"normal\", rng=random.Random(1234))\n278\t+        self.assertEqual(first, second)\n279\t+\n280\t+    def test_default_rng_returns_valid_word(self):\n281\t+        word = words.select_word()\n282\t+        self.assertIn(word, words.WORDS)\n283\t+\n284\t+    def test_unknown_difficulty_raises(self):\n285\t+        with self.assertRaises(ValueError):\n286\t+            words.select_word(\"nightmare\", rng=random.Random(0))\n287\t+\n288\t+    def test_easy_pool_excludes_long_words(self):\n289\t+        seen = {words.select_word(\"easy\", rng=random.Random(s)) for s in range(50)}\n290\t+        self.assertNotIn(\"VINEYARD\", seen)\n291\t+        self.assertNotIn(\"ORCHARD\", seen)\n292\t+\n293\t+    def test_hard_pool_excludes_short_words(self):\n294\t+        seen = {words.select_word(\"hard\", rng=random.Random(s)) for s in range(50)}\n295\t+        self.assertNotIn(\"GARDEN\", seen)\n296\t+        self.assertNotIn(\"FLOWER\", seen)\n297\t+\n298\t+\n299\t+if __name__ == \"__main__\":\n300\t+    unittest.main()\n301\tdiff --git a/word_garden/__init__.py b/word_garden/__init__.py\n302\tnew file mode 100644\n303\tindex 0000000..151b7e0\n304\t--- /dev/null\n305\t+++ b/word_garden/__init__.py\n306\t@@ -0,0 +1,5 @@\n307\t+\"\"\"Word Garden — a friendly terminal word-guessing game.\n308\t+\n309\t+This package holds the pure game engine (`game`) and word list (`words`).\n310\t+The terminal UI is layered on top in a separate module.\n311\t+\"\"\"\n312\tdiff --git a/word_garden/game.py b/word_garden/game.py\n313\tnew file mode 100644\n314\tindex 0000000..709caa0\n315\t--- /dev/null\n316\t+++ b/word_garden/game.py\n317\t@@ -0,0 +1,129 @@\n318\t+\"\"\"Core Word Garden game logic: state, guesses, win/loss detection.\n319\t+\n320\t+Pure stdlib. This module never reads stdin or writes stdout — every function\n321\t+returns data or strings so the engine is fully testable without a terminal\n322\t+(SPEC.md section 16). The terminal UI is a separate task built on top of this.\n323\t+\n324\t+All user-facing message strings live here as module-level constants so the UI\n325\t+and the tests import them instead of re-typing literals.\n326\t+\"\"\"\n327\t+\n328\t+from dataclasses import dataclass\n329\t+\n330\t+from . import words\n331\t+\n332\t+# Turn-feedback messages (SPEC.md sections 6.3-6.5, 6.6-6.7, 14).\n333\t+MSG_CORRECT = \"Good guess! The garden grows.\"\n334\t+MSG_WRONG = \"No match. A weed appears.\"\n335\t+MSG_ALREADY_GUESSED = \"You already guessed {letter}. Try another letter.\"\n336\t+MSG_WIN = \"Bloom! You guessed the word: {word}. The garden is thriving.\"\n337\t+MSG_LOSS = (\n338\t+    \"The garden ran out of water. The word was: {word}. \"\n339\t+    \"Try again and grow a new garden.\"\n340\t+)\n341\t+MSG_GAME_OVER = \"The game is over. Start a new garden to play again.\"\n342\t+\n343\t+# Validation messages (SPEC.md section 14).\n344\t+MSG_ENTER_SINGLE = \"Please enter a single letter.\"\n345\t+MSG_NOT_A_LETTER = \"That is not a letter.\"\n346\t+\n347\t+\n348\t+@dataclass\n349\t+class GameState:\n350\t+    \"\"\"Mutable per-session game state (field order per SPEC.md section 12).\"\"\"\n351\t+\n352\t+    secret_word: str\n353\t+    guessed_letters: set[str]\n354\t+    remaining_water: int\n355\t+    weed_count: int\n356\t+    max_water: int\n357\t+    status_message: str = \"\"\n358\t+    game_over: bool = False\n359\t+    won: bool = False\n360\t+\n361\t+\n362\t+def new_game(difficulty=\"normal\", rng=None):\n363\t+    \"\"\"Start a new game: pick a word, full water, zero weeds.\n364\t+\n365\t+    `rng` is forwarded to `words.select_word` for deterministic tests.\n366\t+    Raises ValueError for an unknown difficulty.\n367\t+    \"\"\"\n368\t+    secret_word = words.select_word(difficulty, rng=rng).upper()\n369\t+    water = words.water_for(difficulty)\n370\t+    return GameState(\n371\t+        secret_word=secret_word,\n372\t+        guessed_letters=set(),\n373\t+        remaining_water=water,\n374\t+        weed_count=0,\n375\t+        max_water=water,\n376\t+    )\n377\t+\n378\t+\n379\t+def validate_guess(input_text):\n380\t+    \"\"\"Validate raw guess text without consulting game state.\n381\t+\n382\t+    Returns `(letter, \"\")` for a valid guess — trimmed, uppercased, exactly\n383\t+    one alphabetic character — or `(None, message)` with a specific message.\n384\t+    Repeated-guess detection is NOT done here; it belongs to `apply_guess`.\n385\t+    \"\"\"\n386\t+    cleaned = input_text.strip()\n387\t+    if len(cleaned) != 1:\n388\t+        return None, MSG_ENTER_SINGLE\n389\t+    if not cleaned.isalpha():\n390\t+        return None, MSG_NOT_A_LETTER\n391\t+    return cleaned.upper(), \"\"\n392\t+\n393\t+\n394\t+def apply_guess(state, letter):\n395\t+    \"\"\"Apply one already-validated uppercase letter and return the state.\n396\t+\n397\t+    Correct guess: reveal, no water/weed change. Wrong guess: -1 water,\n398\t+    +1 weed. Repeated guess: nothing changes but the message. Guessing after\n399\t+    the game is over is a no-op with a message. Sets `game_over`/`won` when\n400\t+    the guess ends the game. Mutates and returns the same `GameState`.\n401\t+    \"\"\"\n402\t+    if state.game_over:\n403\t+        state.status_message = MSG_GAME_OVER\n404\t+        return state\n405\t+\n406\t+    if letter in state.guessed_letters:\n407\t+        state.status_message = MSG_ALREADY_GUESSED.format(letter=letter)\n408\t+        return state\n409\t+\n410\t+    state.guessed_letters.add(letter)\n411\t+\n412\t+    if letter in state.secret_word:\n413\t+        if is_won(state):\n414\t+            state.won = True\n415\t+            state.game_over = True\n416\t+            state.status_message = MSG_WIN.format(word=state.secret_word)\n417\t+        else:\n418\t+            state.status_message = MSG_CORRECT\n419\t+    else:\n420\t+        state.remaining_water -= 1\n421\t+        state.weed_count += 1\n422\t+        if is_lost(state):\n423\t+            state.game_over = True\n424\t+            state.status_message = MSG_LOSS.format(word=state.secret_word)\n425\t+        else:\n426\t+            state.status_message = MSG_WRONG\n427\t+\n428\t+    return state\n429\t+\n430\t+\n431\t+def display_word(state):\n432\t+    \"\"\"Return the secret word masked, space-separated, e.g. `G _ R _ E _`.\"\"\"\n433\t+    return \" \".join(\n434\t+        char if char in state.guessed_letters else \"_\"\n435\t+        for char in state.secret_word\n436\t+    )\n437\t+\n438\t+\n439\t+def is_won(state):\n440\t+    \"\"\"Win: every letter of the secret word has been guessed.\"\"\"\n441\t+    return all(char in state.guessed_letters for char in state.secret_word)\n442\t+\n443\t+\n444\t+def is_lost(state):\n445\t+    \"\"\"Loss: water is exhausted before the word is fully revealed.\"\"\"\n446\t+    return state.remaining_water <= 0 and not is_won(state)\n447\tdiff --git a/word_garden/words.py b/word_garden/words.py\n448\tnew file mode 100644\n449\tindex 0000000..263be13\n450\t--- /dev/null\n451\t+++ b/word_garden/words.py\n452\t@@ -0,0 +1,84 @@\n453\t+\"\"\"Word list and difficulty-aware word selection for Word Garden.\n454\t+\n455\t+Pure stdlib. No I/O. The difficulty table mirrors SPEC.md section 7 and is\n456\t+encoded exactly once here so it cannot diverge from the water amounts.\n457\t+\"\"\"\n458\t+\n459\t+import random\n460\t+\n461\t+# The 10-word list from SPEC.md section 8, uppercase. Easy to replace/extend.\n462\t+WORDS = [\n463\t+    \"GARDEN\",\n464\t+    \"FLOWER\",\n465\t+    \"PLANET\",\n466\t+    \"PYTHON\",\n467\t+    \"TERMINAL\",\n468\t+    \"MEADOW\",\n469\t+    \"ORCHARD\",\n470\t+    \"VINEYARD\",\n471\t+    \"SEEDLING\",\n472\t+    \"HARVEST\",\n473\t+]\n474\t+\n475\t+# Difficulty table (SPEC.md section 7), encoded once. `max_length` of None\n476\t+# means \"no upper bound\" (the 7+ band). Each entry pins starting water and the\n477\t+# inclusive word-length window used to filter WORDS.\n478\t+DIFFICULTIES = {\n479\t+    \"easy\": {\"water\": 8, \"min_length\": 4, \"max_length\": 6},\n480\t+    \"normal\": {\"water\": 6, \"min_length\": 5, \"max_length\": 8},\n481\t+    \"hard\": {\"water\": 4, \"min_length\": 7, \"max_length\": None},\n482\t+}\n483\t+\n484\t+UNKNOWN_DIFFICULTY_MSG = (\n485\t+    \"Unknown difficulty: {difficulty!r}. Choose from: easy, normal, hard.\"\n486\t+)\n487\t+EMPTY_POOL_MSG = \"No words match difficulty {difficulty!r}.\"\n488\t+\n489\t+\n490\t+def _config_for(difficulty):\n491\t+    \"\"\"Return the pinned config for a difficulty or raise ValueError.\"\"\"\n492\t+    try:\n493\t+        return DIFFICULTIES[difficulty]\n494\t+    except KeyError:\n495\t+        raise ValueError(UNKNOWN_DIFFICULTY_MSG.format(difficulty=difficulty))\n496\t+\n497\t+\n498\t+def water_for(difficulty=\"normal\"):\n499\t+    \"\"\"Return the starting water level for the given difficulty.\n500\t+\n501\t+    Raises ValueError for an unknown difficulty.\n502\t+    \"\"\"\n503\t+    return _config_for(difficulty)[\"water\"]\n504\t+\n505\t+\n506\t+def _pool_for(difficulty):\n507\t+    \"\"\"Return the non-empty list of words allowed at this difficulty.\n508\t+\n509\t+    Raises ValueError for an unknown difficulty, or if the length filter\n510\t+    yields an empty pool (never silently fall back to the full list).\n511\t+    \"\"\"\n512\t+    config = _config_for(difficulty)\n513\t+    low = config[\"min_length\"]\n514\t+    high = config[\"max_length\"]\n515\t+    pool = [\n516\t+        word\n517\t+        for word in WORDS\n518\t+        if len(word) >= low and (high is None or len(word) <= high)\n519\t+    ]\n520\t+    if not pool:\n521\t+        raise ValueError(EMPTY_POOL_MSG.format(difficulty=difficulty))\n522\t+    return pool\n523\t+\n524\t+\n525\t+def select_word(difficulty=\"normal\", rng=None):\n526\t+    \"\"\"Return a random uppercase word filtered by difficulty.\n527\t+\n528\t+    `rng` is an injectable `random.Random` instance for deterministic tests.\n529\t+    When `rng` is None the module-level `random` functions are used, so\n530\t+    production play stays non-deterministic.\n531\t+\n532\t+    Raises ValueError for an unknown difficulty.\n533\t+    \"\"\"\n534\t+    pool = _pool_for(difficulty)\n535\t+    chooser = random.choice if rng is None else rng.choice\n536\t+    return chooser(pool).upper()\n537\t"}]},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"05e0239c-2a18-42ce-acdf-dde2c0c95fa0","timestamp":"2026-06-12T03:34:52.918Z","tool_use_result":{"type":"text","file":{"filePath":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/D.diff","content":"diff --git a/tests/__init__.py b/tests/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/tests/test_game.py b/tests/test_game.py\nnew file mode 100644\nindex 0000000..610407e\n--- /dev/null\n+++ b/tests/test_game.py\n@@ -0,0 +1,199 @@\n+\"\"\"Tests for word_garden.game (SPEC.md section 16, cases 1-9).\n+\n+Fixtures construct GameState directly with pinned values rather than calling a\n+randomized constructor and overwriting fields. Tests assert the full positive\n+outcome of each state transition, not just the absence of the negative.\n+\"\"\"\n+\n+import random\n+import unittest\n+\n+from word_garden import game, words\n+from word_garden.game import GameState\n+\n+\n+def make_state(secret=\"GARDEN\", guessed=None, water=6, weeds=0, max_water=6):\n+    return GameState(\n+        secret_word=secret,\n+        guessed_letters=set(guessed or ()),\n+        remaining_water=water,\n+        weed_count=weeds,\n+        max_water=max_water,\n+    )\n+\n+\n+class NewGameTests(unittest.TestCase):\n+    def test_new_game_initial_state(self):\n+        state = game.new_game(\"normal\", rng=random.Random(7))\n+        self.assertIn(state.secret_word, words.WORDS)\n+        self.assertTrue(state.secret_word.isupper())\n+        self.assertEqual(state.guessed_letters, set())\n+        self.assertEqual(state.remaining_water, 6)\n+        self.assertEqual(state.max_water, 6)\n+        self.assertEqual(state.weed_count, 0)\n+        self.assertEqual(state.status_message, \"\")\n+        self.assertFalse(state.game_over)\n+        self.assertFalse(state.won)\n+\n+    def test_new_game_water_follows_difficulty(self):\n+        easy = game.new_game(\"easy\", rng=random.Random(1))\n+        self.assertEqual(easy.remaining_water, 8)\n+        self.assertEqual(easy.max_water, 8)\n+        hard = game.new_game(\"hard\", rng=random.Random(1))\n+        self.assertEqual(hard.remaining_water, 4)\n+        self.assertEqual(hard.max_water, 4)\n+\n+    def test_new_game_unknown_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            game.new_game(\"expert\", rng=random.Random(0))\n+\n+\n+class ValidateGuessTests(unittest.TestCase):\n+    def test_empty_input_rejected(self):\n+        # Case 5: invalid input is rejected with a specific message.\n+        self.assertEqual(game.validate_guess(\"\"), (None, game.MSG_ENTER_SINGLE))\n+        self.assertEqual(game.validate_guess(\"   \"), (None, game.MSG_ENTER_SINGLE))\n+\n+    def test_multiple_characters_rejected(self):\n+        self.assertEqual(game.validate_guess(\"apple\"), (None, game.MSG_ENTER_SINGLE))\n+        self.assertEqual(game.validate_guess(\"ab\"), (None, game.MSG_ENTER_SINGLE))\n+\n+    def test_number_rejected(self):\n+        self.assertEqual(game.validate_guess(\"7\"), (None, game.MSG_NOT_A_LETTER))\n+\n+    def test_symbol_rejected(self):\n+        self.assertEqual(game.validate_guess(\"!\"), (None, game.MSG_NOT_A_LETTER))\n+\n+    def test_lowercase_is_normalized(self):\n+        # Case 6: lowercase input is normalized to uppercase.\n+        self.assertEqual(game.validate_guess(\"a\"), (\"A\", \"\"))\n+\n+    def test_surrounding_whitespace_is_trimmed(self):\n+        self.assertEqual(game.validate_guess(\"  Z  \"), (\"Z\", \"\"))\n+\n+    def test_uppercase_letter_passes(self):\n+        self.assertEqual(game.validate_guess(\"Q\"), (\"Q\", \"\"))\n+\n+\n+class ApplyGuessCorrectTests(unittest.TestCase):\n+    def test_correct_guess_reveals_without_penalty(self):\n+        # Cases 1: a correct guess reveals matching letters, no water/weed cost.\n+        state = make_state(secret=\"GARDEN\", water=6, weeds=0)\n+        result = game.apply_guess(state, \"G\")\n+        self.assertIn(\"G\", result.guessed_letters)\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertEqual(result.status_message, game.MSG_CORRECT)\n+        self.assertFalse(result.game_over)\n+        self.assertFalse(result.won)\n+        self.assertEqual(game.display_word(result), \"G _ _ _ _ _\")\n+\n+\n+class ApplyGuessWrongTests(unittest.TestCase):\n+    def test_wrong_guess_full_outcome(self):\n+        # Cases 2 & 3: water -1 AND weeds +1 AND letter recorded AND message.\n+        state = make_state(secret=\"GARDEN\", water=6, weeds=0)\n+        result = game.apply_guess(state, \"Z\")\n+        self.assertIn(\"Z\", result.guessed_letters)\n+        self.assertEqual(result.remaining_water, 5)\n+        self.assertEqual(result.weed_count, 1)\n+        self.assertEqual(result.status_message, game.MSG_WRONG)\n+        self.assertFalse(result.game_over)\n+        self.assertFalse(result.won)\n+\n+\n+class ApplyGuessRepeatTests(unittest.TestCase):\n+    def test_repeated_wrong_guess_changes_nothing_but_message(self):\n+        # Case 4: repeated guesses do not reduce water (or change weeds).\n+        state = make_state(secret=\"GARDEN\", water=6, weeds=0)\n+        game.apply_guess(state, \"Z\")\n+        self.assertEqual(state.remaining_water, 5)\n+        self.assertEqual(state.weed_count, 1)\n+\n+        result = game.apply_guess(state, \"Z\")\n+        self.assertEqual(result.remaining_water, 5)\n+        self.assertEqual(result.weed_count, 1)\n+        self.assertEqual(result.guessed_letters, {\"Z\"})\n+        self.assertEqual(\n+            result.status_message,\n+            game.MSG_ALREADY_GUESSED.format(letter=\"Z\"),\n+        )\n+\n+    def test_repeated_correct_guess_does_not_re_reveal(self):\n+        state = make_state(secret=\"GARDEN\", guessed={\"G\"}, water=6, weeds=0)\n+        result = game.apply_guess(state, \"G\")\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertEqual(\n+            result.status_message,\n+            game.MSG_ALREADY_GUESSED.format(letter=\"G\"),\n+        )\n+\n+\n+class WinTests(unittest.TestCase):\n+    def test_win_is_detected_and_flagged(self):\n+        # Case 7: the game detects a win and sets won/game_over with the message.\n+        state = make_state(secret=\"GO\", guessed={\"G\"}, water=6, weeds=0)\n+        self.assertFalse(game.is_won(state))\n+        result = game.apply_guess(state, \"O\")\n+        self.assertTrue(result.won)\n+        self.assertTrue(result.game_over)\n+        self.assertTrue(game.is_won(result))\n+        self.assertFalse(game.is_lost(result))\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(\n+            result.status_message, game.MSG_WIN.format(word=\"GO\")\n+        )\n+\n+    def test_winning_on_last_water_still_wins(self):\n+        # A correct final guess never counts as a loss even at low water.\n+        state = make_state(secret=\"GO\", guessed={\"G\"}, water=1, weeds=5)\n+        result = game.apply_guess(state, \"O\")\n+        self.assertTrue(result.won)\n+        self.assertFalse(game.is_lost(result))\n+\n+\n+class LossTests(unittest.TestCase):\n+    def test_loss_is_detected_when_water_hits_zero(self):\n+        # Case 8: the game detects a loss and sets game_over (won stays False).\n+        state = make_state(secret=\"GARDEN\", guessed={\"X\"}, water=1, weeds=4)\n+        self.assertFalse(game.is_lost(state))\n+        result = game.apply_guess(state, \"Z\")\n+        self.assertEqual(result.remaining_water, 0)\n+        self.assertEqual(result.weed_count, 5)\n+        self.assertTrue(result.game_over)\n+        self.assertFalse(result.won)\n+        self.assertTrue(game.is_lost(result))\n+        self.assertEqual(\n+            result.status_message, game.MSG_LOSS.format(word=\"GARDEN\")\n+        )\n+\n+\n+class GameOverNoOpTests(unittest.TestCase):\n+    def test_guess_after_game_over_is_a_no_op(self):\n+        state = make_state(secret=\"GARDEN\", guessed={\"G\"}, water=3, weeds=2)\n+        state.game_over = True\n+        result = game.apply_guess(state, \"A\")\n+        self.assertNotIn(\"A\", result.guessed_letters)\n+        self.assertEqual(result.remaining_water, 3)\n+        self.assertEqual(result.weed_count, 2)\n+        self.assertEqual(result.status_message, game.MSG_GAME_OVER)\n+\n+\n+class DisplayWordTests(unittest.TestCase):\n+    def test_masks_unguessed_letters(self):\n+        # Case 9: the displayed word masks unguessed letters, space-separated.\n+        state = make_state(secret=\"GARDEN\", guessed={\"G\", \"R\", \"E\"})\n+        self.assertEqual(game.display_word(state), \"G _ R _ E _\")\n+\n+    def test_no_guesses_is_all_blanks(self):\n+        state = make_state(secret=\"GARDEN\", guessed=set())\n+        self.assertEqual(game.display_word(state), \"_ _ _ _ _ _\")\n+\n+    def test_repeated_letters_all_revealed(self):\n+        state = make_state(secret=\"SEEDLING\", guessed={\"E\"})\n+        self.assertEqual(game.display_word(state), \"_ E E _ _ _ _ _\")\n+\n+\n+if __name__ == \"__main__\":\n+    unittest.main()\ndiff --git a/tests/test_words.py b/tests/test_words.py\nnew file mode 100644\nindex 0000000..4dc12fa\n--- /dev/null\n+++ b/tests/test_words.py\n@@ -0,0 +1,86 @@\n+\"\"\"Tests for word_garden.words (SPEC.md section 16, case 10).\"\"\"\n+\n+import random\n+import unittest\n+\n+from word_garden import words\n+\n+\n+class WordListTests(unittest.TestCase):\n+    def test_word_list_matches_spec_and_is_uppercase(self):\n+        self.assertEqual(\n+            words.WORDS,\n+            [\n+                \"GARDEN\",\n+                \"FLOWER\",\n+                \"PLANET\",\n+                \"PYTHON\",\n+                \"TERMINAL\",\n+                \"MEADOW\",\n+                \"ORCHARD\",\n+                \"VINEYARD\",\n+                \"SEEDLING\",\n+                \"HARVEST\",\n+            ],\n+        )\n+        for word in words.WORDS:\n+            self.assertTrue(word.isupper(), word)\n+            self.assertTrue(word.isalpha(), word)\n+\n+\n+class WaterForTests(unittest.TestCase):\n+    def test_water_per_difficulty(self):\n+        self.assertEqual(words.water_for(\"easy\"), 8)\n+        self.assertEqual(words.water_for(\"normal\"), 6)\n+        self.assertEqual(words.water_for(\"hard\"), 4)\n+\n+    def test_default_is_normal(self):\n+        self.assertEqual(words.water_for(), 6)\n+\n+    def test_unknown_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            words.water_for(\"impossible\")\n+\n+\n+class SelectWordTests(unittest.TestCase):\n+    # SPEC.md section 7 length bands, inclusive; hard has no upper bound.\n+    BANDS = {\"easy\": (4, 6), \"normal\": (5, 8), \"hard\": (7, 99)}\n+\n+    def test_returns_valid_word_for_every_difficulty(self):\n+        # Case 10: the selector returns a valid word respecting the band.\n+        # Sweep many seeds so we exercise the whole pool deterministically.\n+        for difficulty, (low, high) in self.BANDS.items():\n+            for seed in range(50):\n+                rng = random.Random(seed)\n+                word = words.select_word(difficulty, rng=rng)\n+                self.assertIn(word, words.WORDS)\n+                self.assertTrue(word.isupper())\n+                self.assertGreaterEqual(len(word), low, (difficulty, word))\n+                self.assertLessEqual(len(word), high, (difficulty, word))\n+\n+    def test_injected_rng_is_deterministic(self):\n+        first = words.select_word(\"normal\", rng=random.Random(1234))\n+        second = words.select_word(\"normal\", rng=random.Random(1234))\n+        self.assertEqual(first, second)\n+\n+    def test_default_rng_returns_valid_word(self):\n+        word = words.select_word()\n+        self.assertIn(word, words.WORDS)\n+\n+    def test_unknown_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            words.select_word(\"nightmare\", rng=random.Random(0))\n+\n+    def test_easy_pool_excludes_long_words(self):\n+        seen = {words.select_word(\"easy\", rng=random.Random(s)) for s in range(50)}\n+        self.assertNotIn(\"VINEYARD\", seen)\n+        self.assertNotIn(\"ORCHARD\", seen)\n+\n+    def test_hard_pool_excludes_short_words(self):\n+        seen = {words.select_word(\"hard\", rng=random.Random(s)) for s in range(50)}\n+        self.assertNotIn(\"GARDEN\", seen)\n+        self.assertNotIn(\"FLOWER\", seen)\n+\n+\n+if __name__ == \"__main__\":\n+    unittest.main()\ndiff --git a/word_garden/__init__.py b/word_garden/__init__.py\nnew file mode 100644\nindex 0000000..151b7e0\n--- /dev/null\n+++ b/word_garden/__init__.py\n@@ -0,0 +1,5 @@\n+\"\"\"Word Garden — a friendly terminal word-guessing game.\n+\n+This package holds the pure game engine (`game`) and word list (`words`).\n+The terminal UI is layered on top in a separate module.\n+\"\"\"\ndiff --git a/word_garden/game.py b/word_garden/game.py\nnew file mode 100644\nindex 0000000..709caa0\n--- /dev/null\n+++ b/word_garden/game.py\n@@ -0,0 +1,129 @@\n+\"\"\"Core Word Garden game logic: state, guesses, win/loss detection.\n+\n+Pure stdlib. This module never reads stdin or writes stdout — every function\n+returns data or strings so the engine is fully testable without a terminal\n+(SPEC.md section 16). The terminal UI is a separate task built on top of this.\n+\n+All user-facing message strings live here as module-level constants so the UI\n+and the tests import them instead of re-typing literals.\n+\"\"\"\n+\n+from dataclasses import dataclass\n+\n+from . import words\n+\n+# Turn-feedback messages (SPEC.md sections 6.3-6.5, 6.6-6.7, 14).\n+MSG_CORRECT = \"Good guess! The garden grows.\"\n+MSG_WRONG = \"No match. A weed appears.\"\n+MSG_ALREADY_GUESSED = \"You already guessed {letter}. Try another letter.\"\n+MSG_WIN = \"Bloom! You guessed the word: {word}. The garden is thriving.\"\n+MSG_LOSS = (\n+    \"The garden ran out of water. The word was: {word}. \"\n+    \"Try again and grow a new garden.\"\n+)\n+MSG_GAME_OVER = \"The game is over. Start a new garden to play again.\"\n+\n+# Validation messages (SPEC.md section 14).\n+MSG_ENTER_SINGLE = \"Please enter a single letter.\"\n+MSG_NOT_A_LETTER = \"That is not a letter.\"\n+\n+\n+@dataclass\n+class GameState:\n+    \"\"\"Mutable per-session game state (field order per SPEC.md section 12).\"\"\"\n+\n+    secret_word: str\n+    guessed_letters: set[str]\n+    remaining_water: int\n+    weed_count: int\n+    max_water: int\n+    status_message: str = \"\"\n+    game_over: bool = False\n+    won: bool = False\n+\n+\n+def new_game(difficulty=\"normal\", rng=None):\n+    \"\"\"Start a new game: pick a word, full water, zero weeds.\n+\n+    `rng` is forwarded to `words.select_word` for deterministic tests.\n+    Raises ValueError for an unknown difficulty.\n+    \"\"\"\n+    secret_word = words.select_word(difficulty, rng=rng).upper()\n+    water = words.water_for(difficulty)\n+    return GameState(\n+        secret_word=secret_word,\n+        guessed_letters=set(),\n+        remaining_water=water,\n+        weed_count=0,\n+        max_water=water,\n+    )\n+\n+\n+def validate_guess(input_text):\n+    \"\"\"Validate raw guess text without consulting game state.\n+\n+    Returns `(letter, \"\")` for a valid guess — trimmed, uppercased, exactly\n+    one alphabetic character — or `(None, message)` with a specific message.\n+    Repeated-guess detection is NOT done here; it belongs to `apply_guess`.\n+    \"\"\"\n+    cleaned = input_text.strip()\n+    if len(cleaned) != 1:\n+        return None, MSG_ENTER_SINGLE\n+    if not cleaned.isalpha():\n+        return None, MSG_NOT_A_LETTER\n+    return cleaned.upper(), \"\"\n+\n+\n+def apply_guess(state, letter):\n+    \"\"\"Apply one already-validated uppercase letter and return the state.\n+\n+    Correct guess: reveal, no water/weed change. Wrong guess: -1 water,\n+    +1 weed. Repeated guess: nothing changes but the message. Guessing after\n+    the game is over is a no-op with a message. Sets `game_over`/`won` when\n+    the guess ends the game. Mutates and returns the same `GameState`.\n+    \"\"\"\n+    if state.game_over:\n+        state.status_message = MSG_GAME_OVER\n+        return state\n+\n+    if letter in state.guessed_letters:\n+        state.status_message = MSG_ALREADY_GUESSED.format(letter=letter)\n+        return state\n+\n+    state.guessed_letters.add(letter)\n+\n+    if letter in state.secret_word:\n+        if is_won(state):\n+            state.won = True\n+            state.game_over = True\n+            state.status_message = MSG_WIN.format(word=state.secret_word)\n+        else:\n+            state.status_message = MSG_CORRECT\n+    else:\n+        state.remaining_water -= 1\n+        state.weed_count += 1\n+        if is_lost(state):\n+            state.game_over = True\n+            state.status_message = MSG_LOSS.format(word=state.secret_word)\n+        else:\n+            state.status_message = MSG_WRONG\n+\n+    return state\n+\n+\n+def display_word(state):\n+    \"\"\"Return the secret word masked, space-separated, e.g. `G _ R _ E _`.\"\"\"\n+    return \" \".join(\n+        char if char in state.guessed_letters else \"_\"\n+        for char in state.secret_word\n+    )\n+\n+\n+def is_won(state):\n+    \"\"\"Win: every letter of the secret word has been guessed.\"\"\"\n+    return all(char in state.guessed_letters for char in state.secret_word)\n+\n+\n+def is_lost(state):\n+    \"\"\"Loss: water is exhausted before the word is fully revealed.\"\"\"\n+    return state.remaining_water <= 0 and not is_won(state)\ndiff --git a/word_garden/words.py b/word_garden/words.py\nnew file mode 100644\nindex 0000000..263be13\n--- /dev/null\n+++ b/word_garden/words.py\n@@ -0,0 +1,84 @@\n+\"\"\"Word list and difficulty-aware word selection for Word Garden.\n+\n+Pure stdlib. No I/O. The difficulty table mirrors SPEC.md section 7 and is\n+encoded exactly once here so it cannot diverge from the water amounts.\n+\"\"\"\n+\n+import random\n+\n+# The 10-word list from SPEC.md section 8, uppercase. Easy to replace/extend.\n+WORDS = [\n+    \"GARDEN\",\n+    \"FLOWER\",\n+    \"PLANET\",\n+    \"PYTHON\",\n+    \"TERMINAL\",\n+    \"MEADOW\",\n+    \"ORCHARD\",\n+    \"VINEYARD\",\n+    \"SEEDLING\",\n+    \"HARVEST\",\n+]\n+\n+# Difficulty table (SPEC.md section 7), encoded once. `max_length` of None\n+# means \"no upper bound\" (the 7+ band). Each entry pins starting water and the\n+# inclusive word-length window used to filter WORDS.\n+DIFFICULTIES = {\n+    \"easy\": {\"water\": 8, \"min_length\": 4, \"max_length\": 6},\n+    \"normal\": {\"water\": 6, \"min_length\": 5, \"max_length\": 8},\n+    \"hard\": {\"water\": 4, \"min_length\": 7, \"max_length\": None},\n+}\n+\n+UNKNOWN_DIFFICULTY_MSG = (\n+    \"Unknown difficulty: {difficulty!r}. Choose from: easy, normal, hard.\"\n+)\n+EMPTY_POOL_MSG = \"No words match difficulty {difficulty!r}.\"\n+\n+\n+def _config_for(difficulty):\n+    \"\"\"Return the pinned config for a difficulty or raise ValueError.\"\"\"\n+    try:\n+        return DIFFICULTIES[difficulty]\n+    except KeyError:\n+        raise ValueError(UNKNOWN_DIFFICULTY_MSG.format(difficulty=difficulty))\n+\n+\n+def water_for(difficulty=\"normal\"):\n+    \"\"\"Return the starting water level for the given difficulty.\n+\n+    Raises ValueError for an unknown difficulty.\n+    \"\"\"\n+    return _config_for(difficulty)[\"water\"]\n+\n+\n+def _pool_for(difficulty):\n+    \"\"\"Return the non-empty list of words allowed at this difficulty.\n+\n+    Raises ValueError for an unknown difficulty, or if the length filter\n+    yields an empty pool (never silently fall back to the full list).\n+    \"\"\"\n+    config = _config_for(difficulty)\n+    low = config[\"min_length\"]\n+    high = config[\"max_length\"]\n+    pool = [\n+        word\n+        for word in WORDS\n+        if len(word) >= low and (high is None or len(word) <= high)\n+    ]\n+    if not pool:\n+        raise ValueError(EMPTY_POOL_MSG.format(difficulty=difficulty))\n+    return pool\n+\n+\n+def select_word(difficulty=\"normal\", rng=None):\n+    \"\"\"Return a random uppercase word filtered by difficulty.\n+\n+    `rng` is an injectable `random.Random` instance for deterministic tests.\n+    When `rng` is None the module-level `random` functions are used, so\n+    production play stays non-deterministic.\n+\n+    Raises ValueError for an unknown difficulty.\n+    \"\"\"\n+    pool = _pool_for(difficulty)\n+    chooser = random.choice if rng is None else rng.choice\n+    return chooser(pool).upper()\n","numLines":537,"startLine":1,"totalLines":537}}},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_017spUiY9XCoCNBYevVczJNb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MZXho31EtdtsMircLtTpPp","name":"Read","input":{"file_path":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/E.diff"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":24462,"cache_read_input_tokens":35116,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":24462},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"3141d66c-3b36-400e-b5d0-d56813398c5e","request_id":"req_011CbxfU2RTG1U4faNAJw9mh"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MZXho31EtdtsMircLtTpPp","type":"tool_result","content":"1\tdiff --git a/tests/__init__.py b/tests/__init__.py\n2\tnew file mode 100644\n3\tindex 0000000..e69de29\n4\tdiff --git a/tests/test_game.py b/tests/test_game.py\n5\tnew file mode 100644\n6\tindex 0000000..c4907f6\n7\t--- /dev/null\n8\t+++ b/tests/test_game.py\n9\t@@ -0,0 +1,333 @@\n10\t+import unittest\n11\t+import random\n12\t+\n13\t+from word_garden import game\n14\t+\n15\t+\n16\t+class TestNewGame(unittest.TestCase):\n17\t+    \"\"\"Test game initialization.\"\"\"\n18\t+\n19\t+    def test_new_game_creates_state(self):\n20\t+        \"\"\"new_game returns a GameState object.\"\"\"\n21\t+        state = game.new_game()\n22\t+        self.assertIsInstance(state, game.GameState)\n23\t+\n24\t+    def test_new_game_sets_secret_word(self):\n25\t+        \"\"\"new_game sets a secret word from the word list.\"\"\"\n26\t+        state = game.new_game()\n27\t+        self.assertIsNotNone(state.secret_word)\n28\t+        self.assertEqual(state.secret_word, state.secret_word.upper())\n29\t+\n30\t+    def test_new_game_initializes_water(self):\n31\t+        \"\"\"new_game sets remaining_water and max_water correctly.\"\"\"\n32\t+        state = game.new_game(difficulty=\"normal\")\n33\t+        self.assertEqual(state.remaining_water, 6)\n34\t+        self.assertEqual(state.max_water, 6)\n35\t+\n36\t+    def test_new_game_initializes_weeds_zero(self):\n37\t+        \"\"\"new_game sets weed_count to zero.\"\"\"\n38\t+        state = game.new_game()\n39\t+        self.assertEqual(state.weed_count, 0)\n40\t+\n41\t+    def test_new_game_initializes_guessed_letters_empty(self):\n42\t+        \"\"\"new_game starts with no guessed letters.\"\"\"\n43\t+        state = game.new_game()\n44\t+        self.assertEqual(state.guessed_letters, set())\n45\t+\n46\t+    def test_new_game_not_over(self):\n47\t+        \"\"\"new_game starts with game_over=False and won=False.\"\"\"\n48\t+        state = game.new_game()\n49\t+        self.assertFalse(state.game_over)\n50\t+        self.assertFalse(state.won)\n51\t+\n52\t+    def test_new_game_easy_difficulty(self):\n53\t+        \"\"\"new_game with easy difficulty sets 8 water.\"\"\"\n54\t+        state = game.new_game(difficulty=\"easy\")\n55\t+        self.assertEqual(state.remaining_water, 8)\n56\t+\n57\t+\n58\t+class TestValidateGuess(unittest.TestCase):\n59\t+    \"\"\"Test input validation.\"\"\"\n60\t+\n61\t+    def test_validate_guess_single_letter(self):\n62\t+        \"\"\"Valid single letter returns (letter, '').\"\"\"\n63\t+        letter, msg = game.validate_guess(\"a\")\n64\t+        self.assertEqual(letter, \"A\")\n65\t+        self.assertEqual(msg, \"\")\n66\t+\n67\t+    def test_validate_guess_uppercase(self):\n68\t+        \"\"\"Uppercase letter is returned as-is.\"\"\"\n69\t+        letter, msg = game.validate_guess(\"Z\")\n70\t+        self.assertEqual(letter, \"Z\")\n71\t+        self.assertEqual(msg, \"\")\n72\t+\n73\t+    def test_validate_guess_strips_whitespace(self):\n74\t+        \"\"\"Input is trimmed before validation.\"\"\"\n75\t+        letter, msg = game.validate_guess(\"  a  \")\n76\t+        self.assertEqual(letter, \"A\")\n77\t+        self.assertEqual(msg, \"\")\n78\t+\n79\t+    def test_validate_guess_empty_input(self):\n80\t+        \"\"\"Empty input returns (None, message).\"\"\"\n81\t+        letter, msg = game.validate_guess(\"\")\n82\t+        self.assertIsNone(letter)\n83\t+        self.assertIn(\"single letter\", msg.lower())\n84\t+\n85\t+    def test_validate_guess_multiple_letters(self):\n86\t+        \"\"\"Multiple letters return error.\"\"\"\n87\t+        letter, msg = game.validate_guess(\"abc\")\n88\t+        self.assertIsNone(letter)\n89\t+        self.assertIn(\"single letter\", msg.lower())\n90\t+\n91\t+    def test_validate_guess_number(self):\n92\t+        \"\"\"Numbers are rejected.\"\"\"\n93\t+        letter, msg = game.validate_guess(\"7\")\n94\t+        self.assertIsNone(letter)\n95\t+        self.assertIn(\"not a letter\", msg.lower())\n96\t+\n97\t+    def test_validate_guess_symbol(self):\n98\t+        \"\"\"Symbols are rejected.\"\"\"\n99\t+        letter, msg = game.validate_guess(\"!\")\n100\t+        self.assertIsNone(letter)\n101\t+        self.assertIn(\"not a letter\", msg.lower())\n102\t+\n103\t+    def test_validate_guess_whitespace_only(self):\n104\t+        \"\"\"Whitespace-only input is rejected.\"\"\"\n105\t+        letter, msg = game.validate_guess(\"   \")\n106\t+        self.assertIsNone(letter)\n107\t+\n108\t+\n109\t+class TestDisplayWord(unittest.TestCase):\n110\t+    \"\"\"Test word display.\"\"\"\n111\t+\n112\t+    def test_display_word_no_guesses(self):\n113\t+        \"\"\"With no guesses, all letters are blanks.\"\"\"\n114\t+        state = game.new_game()\n115\t+        state.secret_word = \"GARDEN\"\n116\t+        state.guessed_letters = set()\n117\t+        self.assertEqual(game.display_word(state), \"_ _ _ _ _ _\")\n118\t+\n119\t+    def test_display_word_some_guesses(self):\n120\t+        \"\"\"Guessed letters are revealed, others are blanks.\"\"\"\n121\t+        state = game.new_game()\n122\t+        state.secret_word = \"GARDEN\"\n123\t+        state.guessed_letters = {\"G\", \"A\", \"E\"}\n124\t+        self.assertEqual(game.display_word(state), \"G A _ _ E _\")\n125\t+\n126\t+    def test_display_word_all_guessed(self):\n127\t+        \"\"\"With all letters guessed, word is fully revealed.\"\"\"\n128\t+        state = game.new_game()\n129\t+        state.secret_word = \"GARDEN\"\n130\t+        state.guessed_letters = {\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"}\n131\t+        self.assertEqual(game.display_word(state), \"G A R D E N\")\n132\t+\n133\t+\n134\t+class TestCorrectGuess(unittest.TestCase):\n135\t+    \"\"\"Test correct guesses.\"\"\"\n136\t+\n137\t+    def test_correct_guess_adds_letter(self):\n138\t+        \"\"\"Correct guess adds letter to guessed_letters.\"\"\"\n139\t+        state = game.new_game()\n140\t+        state.secret_word = \"GARDEN\"\n141\t+        state.guessed_letters = set()\n142\t+        new_state = game.apply_guess(state, \"G\")\n143\t+        self.assertIn(\"G\", new_state.guessed_letters)\n144\t+\n145\t+    def test_correct_guess_no_water_penalty(self):\n146\t+        \"\"\"Correct guess does not reduce water.\"\"\"\n147\t+        state = game.new_game()\n148\t+        state.secret_word = \"GARDEN\"\n149\t+        state.remaining_water = 6\n150\t+        new_state = game.apply_guess(state, \"G\")\n151\t+        self.assertEqual(new_state.remaining_water, 6)\n152\t+\n153\t+    def test_correct_guess_no_weed_increase(self):\n154\t+        \"\"\"Correct guess does not increase weeds.\"\"\"\n155\t+        state = game.new_game()\n156\t+        state.secret_word = \"GARDEN\"\n157\t+        state.weed_count = 0\n158\t+        new_state = game.apply_guess(state, \"G\")\n159\t+        self.assertEqual(new_state.weed_count, 0)\n160\t+\n161\t+    def test_correct_guess_sets_message(self):\n162\t+        \"\"\"Correct guess sets a positive message.\"\"\"\n163\t+        state = game.new_game()\n164\t+        state.secret_word = \"GARDEN\"\n165\t+        new_state = game.apply_guess(state, \"G\")\n166\t+        self.assertIn(\"Good guess\", new_state.status_message)\n167\t+\n168\t+\n169\t+class TestIncorrectGuess(unittest.TestCase):\n170\t+    \"\"\"Test incorrect guesses.\"\"\"\n171\t+\n172\t+    def test_incorrect_guess_reduces_water(self):\n173\t+        \"\"\"Incorrect guess reduces water by exactly 1.\"\"\"\n174\t+        state = game.new_game()\n175\t+        state.secret_word = \"GARDEN\"\n176\t+        state.remaining_water = 6\n177\t+        new_state = game.apply_guess(state, \"Z\")\n178\t+        self.assertEqual(new_state.remaining_water, 5)\n179\t+\n180\t+    def test_incorrect_guess_increases_weeds(self):\n181\t+        \"\"\"Incorrect guess increases weeds by exactly 1.\"\"\"\n182\t+        state = game.new_game()\n183\t+        state.secret_word = \"GARDEN\"\n184\t+        state.weed_count = 0\n185\t+        new_state = game.apply_guess(state, \"Z\")\n186\t+        self.assertEqual(new_state.weed_count, 1)\n187\t+\n188\t+    def test_incorrect_guess_adds_letter(self):\n189\t+        \"\"\"Incorrect guess still adds letter to guessed_letters.\"\"\"\n190\t+        state = game.new_game()\n191\t+        state.secret_word = \"GARDEN\"\n192\t+        state.guessed_letters = set()\n193\t+        new_state = game.apply_guess(state, \"Z\")\n194\t+        self.assertIn(\"Z\", new_state.guessed_letters)\n195\t+\n196\t+    def test_incorrect_guess_sets_message(self):\n197\t+        \"\"\"Incorrect guess sets a warning message.\"\"\"\n198\t+        state = game.new_game()\n199\t+        state.secret_word = \"GARDEN\"\n200\t+        new_state = game.apply_guess(state, \"Z\")\n201\t+        self.assertIn(\"No match\", new_state.status_message)\n202\t+\n203\t+\n204\t+class TestRepeatedGuess(unittest.TestCase):\n205\t+    \"\"\"Test repeated guesses.\"\"\"\n206\t+\n207\t+    def test_repeated_guess_no_water_change(self):\n208\t+        \"\"\"Repeated guess does not change water.\"\"\"\n209\t+        state = game.new_game()\n210\t+        state.secret_word = \"GARDEN\"\n211\t+        state.remaining_water = 6\n212\t+        state.guessed_letters = {\"A\"}\n213\t+        new_state = game.apply_guess(state, \"A\")\n214\t+        self.assertEqual(new_state.remaining_water, 6)\n215\t+\n216\t+    def test_repeated_guess_no_weed_change(self):\n217\t+        \"\"\"Repeated guess does not change weeds.\"\"\"\n218\t+        state = game.new_game()\n219\t+        state.secret_word = \"GARDEN\"\n220\t+        state.weed_count = 1\n221\t+        state.guessed_letters = {\"Z\"}\n222\t+        new_state = game.apply_guess(state, \"Z\")\n223\t+        self.assertEqual(new_state.weed_count, 1)\n224\t+\n225\t+    def test_repeated_guess_sets_message(self):\n226\t+        \"\"\"Repeated guess sets an informative message.\"\"\"\n227\t+        state = game.new_game()\n228\t+        state.secret_word = \"GARDEN\"\n229\t+        state.guessed_letters = {\"A\"}\n230\t+        new_state = game.apply_guess(state, \"A\")\n231\t+        self.assertIn(\"already guessed\", new_state.status_message.lower())\n232\t+\n233\t+\n234\t+class TestWinCondition(unittest.TestCase):\n235\t+    \"\"\"Test win detection.\"\"\"\n236\t+\n237\t+    def test_is_won_false_initially(self):\n238\t+        \"\"\"New game is not won.\"\"\"\n239\t+        state = game.new_game()\n240\t+        self.assertFalse(game.is_won(state))\n241\t+\n242\t+    def test_is_won_true_when_all_letters_guessed(self):\n243\t+        \"\"\"Game is won when all letters of secret word are guessed.\"\"\"\n244\t+        state = game.new_game()\n245\t+        state.secret_word = \"GARDEN\"\n246\t+        state.guessed_letters = {\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"}\n247\t+        self.assertTrue(game.is_won(state))\n248\t+\n249\t+    def test_is_won_false_with_missing_letters(self):\n250\t+        \"\"\"Game is not won when some letters are missing.\"\"\"\n251\t+        state = game.new_game()\n252\t+        state.secret_word = \"GARDEN\"\n253\t+        state.guessed_letters = {\"G\", \"A\", \"R\"}\n254\t+        self.assertFalse(game.is_won(state))\n255\t+\n256\t+    def test_apply_guess_detects_win(self):\n257\t+        \"\"\"Winning guess sets game_over and won.\"\"\"\n258\t+        state = game.new_game()\n259\t+        state.secret_word = \"AB\"\n260\t+        state.guessed_letters = {\"A\"}\n261\t+        new_state = game.apply_guess(state, \"B\")\n262\t+        self.assertTrue(new_state.game_over)\n263\t+        self.assertTrue(new_state.won)\n264\t+\n265\t+\n266\t+class TestLossCondition(unittest.TestCase):\n267\t+    \"\"\"Test loss detection.\"\"\"\n268\t+\n269\t+    def test_is_lost_false_initially(self):\n270\t+        \"\"\"New game is not lost.\"\"\"\n271\t+        state = game.new_game()\n272\t+        self.assertFalse(game.is_lost(state))\n273\t+\n274\t+    def test_is_lost_true_when_water_zero(self):\n275\t+        \"\"\"Game is lost when water reaches zero.\"\"\"\n276\t+        state = game.new_game()\n277\t+        state.secret_word = \"GARDEN\"\n278\t+        state.remaining_water = 0\n279\t+        state.guessed_letters = {\"X\", \"Y\", \"Z\"}\n280\t+        self.assertTrue(game.is_lost(state))\n281\t+\n282\t+    def test_is_lost_false_if_word_complete(self):\n283\t+        \"\"\"Game is not lost if word is completely guessed.\"\"\"\n284\t+        state = game.new_game()\n285\t+        state.secret_word = \"GARDEN\"\n286\t+        state.remaining_water = 0\n287\t+        state.guessed_letters = {\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"}\n288\t+        self.assertFalse(game.is_lost(state))\n289\t+\n290\t+    def test_apply_guess_detects_loss(self):\n291\t+        \"\"\"Wrong guess that empties water sets game_over.\"\"\"\n292\t+        state = game.new_game()\n293\t+        state.secret_word = \"GARDEN\"\n294\t+        state.remaining_water = 1\n295\t+        state.guessed_letters = set()\n296\t+        new_state = game.apply_guess(state, \"Z\")\n297\t+        self.assertTrue(new_state.game_over)\n298\t+        self.assertFalse(new_state.won)\n299\t+\n300\t+\n301\t+class TestGameOverBehavior(unittest.TestCase):\n302\t+    \"\"\"Test behavior when game is over.\"\"\"\n303\t+\n304\t+    def test_guess_after_game_over_is_noop(self):\n305\t+        \"\"\"Guessing after game_over does not change state.\"\"\"\n306\t+        state = game.new_game()\n307\t+        state.secret_word = \"AB\"\n308\t+        state.guessed_letters = {\"A\", \"B\"}\n309\t+        state.game_over = True\n310\t+        state.won = True\n311\t+        state.remaining_water = 1\n312\t+\n313\t+        new_state = game.apply_guess(state, \"C\")\n314\t+\n315\t+        self.assertEqual(new_state.remaining_water, 1)\n316\t+        self.assertEqual(new_state.weed_count, state.weed_count)\n317\t+        self.assertEqual(new_state.guessed_letters, state.guessed_letters)\n318\t+        self.assertTrue(new_state.game_over)\n319\t+\n320\t+\n321\t+class TestStatePurity(unittest.TestCase):\n322\t+    \"\"\"Test that apply_guess returns a new state without mutating the original.\"\"\"\n323\t+\n324\t+    def test_apply_guess_does_not_mutate_original(self):\n325\t+        \"\"\"apply_guess returns a new state, original is unchanged.\"\"\"\n326\t+        state = game.new_game()\n327\t+        state.secret_word = \"GARDEN\"\n328\t+        state.remaining_water = 6\n329\t+\n330\t+        original_guessed = state.guessed_letters.copy()\n331\t+        original_water = state.remaining_water\n332\t+\n333\t+        new_state = game.apply_guess(state, \"Z\")\n334\t+\n335\t+        self.assertEqual(state.guessed_letters, original_guessed)\n336\t+        self.assertEqual(state.remaining_water, original_water)\n337\t+        self.assertNotEqual(new_state.guessed_letters, original_guessed)\n338\t+        self.assertNotEqual(new_state.remaining_water, original_water)\n339\t+\n340\t+\n341\t+if __name__ == \"__main__\":\n342\t+    unittest.main()\n343\tdiff --git a/tests/test_words.py b/tests/test_words.py\n344\tnew file mode 100644\n345\tindex 0000000..53163b4\n346\t--- /dev/null\n347\t+++ b/tests/test_words.py\n348\t@@ -0,0 +1,73 @@\n349\t+import unittest\n350\t+import random\n351\t+\n352\t+from word_garden import words\n353\t+\n354\t+\n355\t+class TestSelectWord(unittest.TestCase):\n356\t+    \"\"\"Test word selection for all difficulties.\"\"\"\n357\t+\n358\t+    def test_select_word_returns_uppercase(self):\n359\t+        \"\"\"Selected word is uppercase.\"\"\"\n360\t+        word = words.select_word()\n361\t+        self.assertEqual(word, word.upper())\n362\t+\n363\t+    def test_select_word_from_list(self):\n364\t+        \"\"\"Selected word is in the word list.\"\"\"\n365\t+        word = words.select_word()\n366\t+        self.assertIn(word, words.WORDS)\n367\t+\n368\t+    def test_select_word_easy_respects_length(self):\n369\t+        \"\"\"Easy difficulty respects 4-6 letter constraint.\"\"\"\n370\t+        rng = random.Random(42)\n371\t+        for _ in range(20):\n372\t+            word = words.select_word(difficulty=\"easy\", rng=rng)\n373\t+            self.assertIn(len(word), range(4, 7))\n374\t+\n375\t+    def test_select_word_normal_respects_length(self):\n376\t+        \"\"\"Normal difficulty respects 5-8 letter constraint.\"\"\"\n377\t+        rng = random.Random(42)\n378\t+        for _ in range(20):\n379\t+            word = words.select_word(difficulty=\"normal\", rng=rng)\n380\t+            self.assertIn(len(word), range(5, 9))\n381\t+\n382\t+    def test_select_word_hard_respects_length(self):\n383\t+        \"\"\"Hard difficulty respects 7+ letter constraint.\"\"\"\n384\t+        rng = random.Random(42)\n385\t+        for _ in range(20):\n386\t+            word = words.select_word(difficulty=\"hard\", rng=rng)\n387\t+            self.assertGreaterEqual(len(word), 7)\n388\t+\n389\t+    def test_select_word_deterministic_with_seeded_rng(self):\n390\t+        \"\"\"Seeded RNG produces deterministic results.\"\"\"\n391\t+        rng1 = random.Random(123)\n392\t+        rng2 = random.Random(123)\n393\t+        word1 = words.select_word(difficulty=\"normal\", rng=rng1)\n394\t+        word2 = words.select_word(difficulty=\"normal\", rng=rng2)\n395\t+        self.assertEqual(word1, word2)\n396\t+\n397\t+    def test_select_word_unknown_difficulty_raises(self):\n398\t+        \"\"\"Unknown difficulty raises ValueError.\"\"\"\n399\t+        with self.assertRaises(ValueError):\n400\t+            words.select_word(difficulty=\"extreme\")\n401\t+\n402\t+    def test_water_for_easy(self):\n403\t+        \"\"\"Easy difficulty has 8 water.\"\"\"\n404\t+        self.assertEqual(words.water_for(\"easy\"), 8)\n405\t+\n406\t+    def test_water_for_normal(self):\n407\t+        \"\"\"Normal difficulty has 6 water.\"\"\"\n408\t+        self.assertEqual(words.water_for(\"normal\"), 6)\n409\t+\n410\t+    def test_water_for_hard(self):\n411\t+        \"\"\"Hard difficulty has 4 water.\"\"\"\n412\t+        self.assertEqual(words.water_for(\"hard\"), 4)\n413\t+\n414\t+    def test_water_for_unknown_difficulty_raises(self):\n415\t+        \"\"\"Unknown difficulty raises ValueError.\"\"\"\n416\t+        with self.assertRaises(ValueError):\n417\t+            words.water_for(\"impossible\")\n418\t+\n419\t+\n420\t+if __name__ == \"__main__\":\n421\t+    unittest.main()\n422\tdiff --git a/word_garden/__init__.py b/word_garden/__init__.py\n423\tnew file mode 100644\n424\tindex 0000000..e69de29\n425\tdiff --git a/word_garden/game.py b/word_garden/game.py\n426\tnew file mode 100644\n427\tindex 0000000..e9ac9e8\n428\t--- /dev/null\n429\t+++ b/word_garden/game.py\n430\t@@ -0,0 +1,144 @@\n431\t+from dataclasses import dataclass, field\n432\t+from . import words\n433\t+\n434\t+\n435\t+@dataclass\n436\t+class GameState:\n437\t+    secret_word: str\n438\t+    guessed_letters: set[str] = field(default_factory=set)\n439\t+    remaining_water: int = 0\n440\t+    weed_count: int = 0\n441\t+    max_water: int = 0\n442\t+    status_message: str = \"\"\n443\t+    game_over: bool = False\n444\t+    won: bool = False\n445\t+\n446\t+\n447\t+def new_game(difficulty=\"normal\", rng=None):\n448\t+    \"\"\"Create a new game with a random word at the given difficulty.\"\"\"\n449\t+    secret_word = words.select_word(difficulty=difficulty, rng=rng)\n450\t+    max_water = words.water_for(difficulty=difficulty)\n451\t+    return GameState(\n452\t+        secret_word=secret_word,\n453\t+        guessed_letters=set(),\n454\t+        remaining_water=max_water,\n455\t+        weed_count=0,\n456\t+        max_water=max_water,\n457\t+        status_message=\"\",\n458\t+        game_over=False,\n459\t+        won=False,\n460\t+    )\n461\t+\n462\t+\n463\t+def validate_guess(input_text):\n464\t+    \"\"\"\n465\t+    Validate user input as a single letter.\n466\t+\n467\t+    Returns:\n468\t+        tuple[str | None, str]: (letter, message)\n469\t+        - If valid: (uppercase letter, \"\")\n470\t+        - If invalid: (None, error message)\n471\t+    \"\"\"\n472\t+    trimmed = input_text.strip()\n473\t+\n474\t+    if not trimmed:\n475\t+        return None, \"Please enter a single letter.\"\n476\t+\n477\t+    if len(trimmed) > 1:\n478\t+        return None, \"Please enter a single letter.\"\n479\t+\n480\t+    letter = trimmed.upper()\n481\t+\n482\t+    if not letter.isalpha():\n483\t+        return None, \"That is not a letter.\"\n484\t+\n485\t+    return letter, \"\"\n486\t+\n487\t+\n488\t+def display_word(state):\n489\t+    \"\"\"Return the masked word with guessed letters revealed, space-separated.\"\"\"\n490\t+    return \" \".join(\n491\t+        letter if letter in state.guessed_letters else \"_\"\n492\t+        for letter in state.secret_word\n493\t+    )\n494\t+\n495\t+\n496\t+def is_won(state):\n497\t+    \"\"\"Check if the game is won (all letters guessed).\"\"\"\n498\t+    return all(letter in state.guessed_letters for letter in state.secret_word)\n499\t+\n500\t+\n501\t+def is_lost(state):\n502\t+    \"\"\"Check if the game is lost (water at 0 before winning).\"\"\"\n503\t+    return state.remaining_water <= 0 and not is_won(state)\n504\t+\n505\t+\n506\t+def apply_guess(state, letter):\n507\t+    \"\"\"\n508\t+    Apply a validated, uppercase letter guess to the game state.\n509\t+\n510\t+    Returns:\n511\t+        A new GameState with the guess applied.\n512\t+    \"\"\"\n513\t+    if state.game_over:\n514\t+        new_state = GameState(\n515\t+            secret_word=state.secret_word,\n516\t+            guessed_letters=state.guessed_letters.copy(),\n517\t+            remaining_water=state.remaining_water,\n518\t+            weed_count=state.weed_count,\n519\t+            max_water=state.max_water,\n520\t+            status_message=\"Game is over.\",\n521\t+            game_over=True,\n522\t+            won=state.won,\n523\t+        )\n524\t+        return new_state\n525\t+\n526\t+    if letter in state.guessed_letters:\n527\t+        new_state = GameState(\n528\t+            secret_word=state.secret_word,\n529\t+            guessed_letters=state.guessed_letters.copy(),\n530\t+            remaining_water=state.remaining_water,\n531\t+            weed_count=state.weed_count,\n532\t+            max_water=state.max_water,\n533\t+            status_message=f\"You already guessed {letter}. Try another letter.\",\n534\t+            game_over=state.game_over,\n535\t+            won=state.won,\n536\t+        )\n537\t+        return new_state\n538\t+\n539\t+    new_guessed = state.guessed_letters.copy()\n540\t+    new_guessed.add(letter)\n541\t+\n542\t+    if letter in state.secret_word:\n543\t+        new_state = GameState(\n544\t+            secret_word=state.secret_word,\n545\t+            guessed_letters=new_guessed,\n546\t+            remaining_water=state.remaining_water,\n547\t+            weed_count=state.weed_count,\n548\t+            max_water=state.max_water,\n549\t+            status_message=\"Good guess! The garden grows.\",\n550\t+            game_over=False,\n551\t+            won=False,\n552\t+        )\n553\t+    else:\n554\t+        new_water = state.remaining_water - 1\n555\t+        new_weeds = state.weed_count + 1\n556\t+        new_state = GameState(\n557\t+            secret_word=state.secret_word,\n558\t+            guessed_letters=new_guessed,\n559\t+            remaining_water=new_water,\n560\t+            weed_count=new_weeds,\n561\t+            max_water=state.max_water,\n562\t+            status_message=\"No match. A weed appears.\",\n563\t+            game_over=False,\n564\t+            won=False,\n565\t+        )\n566\t+\n567\t+    if is_won(new_state):\n568\t+        new_state.game_over = True\n569\t+        new_state.won = True\n570\t+    elif is_lost(new_state):\n571\t+        new_state.game_over = True\n572\t+        new_state.won = False\n573\t+\n574\t+    return new_state\n575\tdiff --git a/word_garden/words.py b/word_garden/words.py\n576\tnew file mode 100644\n577\tindex 0000000..e30bc78\n578\t--- /dev/null\n579\t+++ b/word_garden/words.py\n580\t@@ -0,0 +1,58 @@\n581\t+import random\n582\t+\n583\t+WORDS = [\n584\t+    \"GARDEN\",\n585\t+    \"FLOWER\",\n586\t+    \"PLANET\",\n587\t+    \"PYTHON\",\n588\t+    \"TERMINAL\",\n589\t+    \"MEADOW\",\n590\t+    \"ORCHARD\",\n591\t+    \"VINEYARD\",\n592\t+    \"SEEDLING\",\n593\t+    \"HARVEST\",\n594\t+]\n595\t+\n596\t+\n597\t+def select_word(difficulty=\"normal\", rng=None):\n598\t+    \"\"\"\n599\t+    Select a random word filtered by difficulty level.\n600\t+\n601\t+    Args:\n602\t+        difficulty: \"easy\", \"normal\", or \"hard\"\n603\t+        rng: injectable random.Random instance (uses module-level random if None)\n604\t+\n605\t+    Returns:\n606\t+        A word string, uppercase\n607\t+\n608\t+    Raises:\n609\t+        ValueError: if difficulty is unknown\n610\t+    \"\"\"\n611\t+    if difficulty == \"easy\":\n612\t+        min_len, max_len = 4, 6\n613\t+    elif difficulty == \"normal\":\n614\t+        min_len, max_len = 5, 8\n615\t+    elif difficulty == \"hard\":\n616\t+        min_len, max_len = 7, float(\"inf\")\n617\t+    else:\n618\t+        raise ValueError(f\"Unknown difficulty: {difficulty}\")\n619\t+\n620\t+    filtered = [w for w in WORDS if min_len <= len(w) <= max_len]\n621\t+    if not filtered:\n622\t+        raise ValueError(f\"No words available for difficulty {difficulty}\")\n623\t+\n624\t+    if rng is None:\n625\t+        return random.choice(filtered)\n626\t+    return rng.choice(filtered)\n627\t+\n628\t+\n629\t+def water_for(difficulty=\"normal\"):\n630\t+    \"\"\"Return starting water level for a given difficulty.\"\"\"\n631\t+    levels = {\n632\t+        \"easy\": 8,\n633\t+        \"normal\": 6,\n634\t+        \"hard\": 4,\n635\t+    }\n636\t+    if difficulty not in levels:\n637\t+        raise ValueError(f\"Unknown difficulty: {difficulty}\")\n638\t+    return levels[difficulty]\n639\t"}]},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"d6adeb9a-8749-40bd-84af-0543a4736fa3","timestamp":"2026-06-12T03:34:53.389Z","tool_use_result":{"type":"text","file":{"filePath":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/E.diff","content":"diff --git a/tests/__init__.py b/tests/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/tests/test_game.py b/tests/test_game.py\nnew file mode 100644\nindex 0000000..c4907f6\n--- /dev/null\n+++ b/tests/test_game.py\n@@ -0,0 +1,333 @@\n+import unittest\n+import random\n+\n+from word_garden import game\n+\n+\n+class TestNewGame(unittest.TestCase):\n+    \"\"\"Test game initialization.\"\"\"\n+\n+    def test_new_game_creates_state(self):\n+        \"\"\"new_game returns a GameState object.\"\"\"\n+        state = game.new_game()\n+        self.assertIsInstance(state, game.GameState)\n+\n+    def test_new_game_sets_secret_word(self):\n+        \"\"\"new_game sets a secret word from the word list.\"\"\"\n+        state = game.new_game()\n+        self.assertIsNotNone(state.secret_word)\n+        self.assertEqual(state.secret_word, state.secret_word.upper())\n+\n+    def test_new_game_initializes_water(self):\n+        \"\"\"new_game sets remaining_water and max_water correctly.\"\"\"\n+        state = game.new_game(difficulty=\"normal\")\n+        self.assertEqual(state.remaining_water, 6)\n+        self.assertEqual(state.max_water, 6)\n+\n+    def test_new_game_initializes_weeds_zero(self):\n+        \"\"\"new_game sets weed_count to zero.\"\"\"\n+        state = game.new_game()\n+        self.assertEqual(state.weed_count, 0)\n+\n+    def test_new_game_initializes_guessed_letters_empty(self):\n+        \"\"\"new_game starts with no guessed letters.\"\"\"\n+        state = game.new_game()\n+        self.assertEqual(state.guessed_letters, set())\n+\n+    def test_new_game_not_over(self):\n+        \"\"\"new_game starts with game_over=False and won=False.\"\"\"\n+        state = game.new_game()\n+        self.assertFalse(state.game_over)\n+        self.assertFalse(state.won)\n+\n+    def test_new_game_easy_difficulty(self):\n+        \"\"\"new_game with easy difficulty sets 8 water.\"\"\"\n+        state = game.new_game(difficulty=\"easy\")\n+        self.assertEqual(state.remaining_water, 8)\n+\n+\n+class TestValidateGuess(unittest.TestCase):\n+    \"\"\"Test input validation.\"\"\"\n+\n+    def test_validate_guess_single_letter(self):\n+        \"\"\"Valid single letter returns (letter, '').\"\"\"\n+        letter, msg = game.validate_guess(\"a\")\n+        self.assertEqual(letter, \"A\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_validate_guess_uppercase(self):\n+        \"\"\"Uppercase letter is returned as-is.\"\"\"\n+        letter, msg = game.validate_guess(\"Z\")\n+        self.assertEqual(letter, \"Z\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_validate_guess_strips_whitespace(self):\n+        \"\"\"Input is trimmed before validation.\"\"\"\n+        letter, msg = game.validate_guess(\"  a  \")\n+        self.assertEqual(letter, \"A\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_validate_guess_empty_input(self):\n+        \"\"\"Empty input returns (None, message).\"\"\"\n+        letter, msg = game.validate_guess(\"\")\n+        self.assertIsNone(letter)\n+        self.assertIn(\"single letter\", msg.lower())\n+\n+    def test_validate_guess_multiple_letters(self):\n+        \"\"\"Multiple letters return error.\"\"\"\n+        letter, msg = game.validate_guess(\"abc\")\n+        self.assertIsNone(letter)\n+        self.assertIn(\"single letter\", msg.lower())\n+\n+    def test_validate_guess_number(self):\n+        \"\"\"Numbers are rejected.\"\"\"\n+        letter, msg = game.validate_guess(\"7\")\n+        self.assertIsNone(letter)\n+        self.assertIn(\"not a letter\", msg.lower())\n+\n+    def test_validate_guess_symbol(self):\n+        \"\"\"Symbols are rejected.\"\"\"\n+        letter, msg = game.validate_guess(\"!\")\n+        self.assertIsNone(letter)\n+        self.assertIn(\"not a letter\", msg.lower())\n+\n+    def test_validate_guess_whitespace_only(self):\n+        \"\"\"Whitespace-only input is rejected.\"\"\"\n+        letter, msg = game.validate_guess(\"   \")\n+        self.assertIsNone(letter)\n+\n+\n+class TestDisplayWord(unittest.TestCase):\n+    \"\"\"Test word display.\"\"\"\n+\n+    def test_display_word_no_guesses(self):\n+        \"\"\"With no guesses, all letters are blanks.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.guessed_letters = set()\n+        self.assertEqual(game.display_word(state), \"_ _ _ _ _ _\")\n+\n+    def test_display_word_some_guesses(self):\n+        \"\"\"Guessed letters are revealed, others are blanks.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.guessed_letters = {\"G\", \"A\", \"E\"}\n+        self.assertEqual(game.display_word(state), \"G A _ _ E _\")\n+\n+    def test_display_word_all_guessed(self):\n+        \"\"\"With all letters guessed, word is fully revealed.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.guessed_letters = {\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"}\n+        self.assertEqual(game.display_word(state), \"G A R D E N\")\n+\n+\n+class TestCorrectGuess(unittest.TestCase):\n+    \"\"\"Test correct guesses.\"\"\"\n+\n+    def test_correct_guess_adds_letter(self):\n+        \"\"\"Correct guess adds letter to guessed_letters.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.guessed_letters = set()\n+        new_state = game.apply_guess(state, \"G\")\n+        self.assertIn(\"G\", new_state.guessed_letters)\n+\n+    def test_correct_guess_no_water_penalty(self):\n+        \"\"\"Correct guess does not reduce water.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.remaining_water = 6\n+        new_state = game.apply_guess(state, \"G\")\n+        self.assertEqual(new_state.remaining_water, 6)\n+\n+    def test_correct_guess_no_weed_increase(self):\n+        \"\"\"Correct guess does not increase weeds.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.weed_count = 0\n+        new_state = game.apply_guess(state, \"G\")\n+        self.assertEqual(new_state.weed_count, 0)\n+\n+    def test_correct_guess_sets_message(self):\n+        \"\"\"Correct guess sets a positive message.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        new_state = game.apply_guess(state, \"G\")\n+        self.assertIn(\"Good guess\", new_state.status_message)\n+\n+\n+class TestIncorrectGuess(unittest.TestCase):\n+    \"\"\"Test incorrect guesses.\"\"\"\n+\n+    def test_incorrect_guess_reduces_water(self):\n+        \"\"\"Incorrect guess reduces water by exactly 1.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.remaining_water = 6\n+        new_state = game.apply_guess(state, \"Z\")\n+        self.assertEqual(new_state.remaining_water, 5)\n+\n+    def test_incorrect_guess_increases_weeds(self):\n+        \"\"\"Incorrect guess increases weeds by exactly 1.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.weed_count = 0\n+        new_state = game.apply_guess(state, \"Z\")\n+        self.assertEqual(new_state.weed_count, 1)\n+\n+    def test_incorrect_guess_adds_letter(self):\n+        \"\"\"Incorrect guess still adds letter to guessed_letters.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.guessed_letters = set()\n+        new_state = game.apply_guess(state, \"Z\")\n+        self.assertIn(\"Z\", new_state.guessed_letters)\n+\n+    def test_incorrect_guess_sets_message(self):\n+        \"\"\"Incorrect guess sets a warning message.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        new_state = game.apply_guess(state, \"Z\")\n+        self.assertIn(\"No match\", new_state.status_message)\n+\n+\n+class TestRepeatedGuess(unittest.TestCase):\n+    \"\"\"Test repeated guesses.\"\"\"\n+\n+    def test_repeated_guess_no_water_change(self):\n+        \"\"\"Repeated guess does not change water.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.remaining_water = 6\n+        state.guessed_letters = {\"A\"}\n+        new_state = game.apply_guess(state, \"A\")\n+        self.assertEqual(new_state.remaining_water, 6)\n+\n+    def test_repeated_guess_no_weed_change(self):\n+        \"\"\"Repeated guess does not change weeds.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.weed_count = 1\n+        state.guessed_letters = {\"Z\"}\n+        new_state = game.apply_guess(state, \"Z\")\n+        self.assertEqual(new_state.weed_count, 1)\n+\n+    def test_repeated_guess_sets_message(self):\n+        \"\"\"Repeated guess sets an informative message.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.guessed_letters = {\"A\"}\n+        new_state = game.apply_guess(state, \"A\")\n+        self.assertIn(\"already guessed\", new_state.status_message.lower())\n+\n+\n+class TestWinCondition(unittest.TestCase):\n+    \"\"\"Test win detection.\"\"\"\n+\n+    def test_is_won_false_initially(self):\n+        \"\"\"New game is not won.\"\"\"\n+        state = game.new_game()\n+        self.assertFalse(game.is_won(state))\n+\n+    def test_is_won_true_when_all_letters_guessed(self):\n+        \"\"\"Game is won when all letters of secret word are guessed.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.guessed_letters = {\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"}\n+        self.assertTrue(game.is_won(state))\n+\n+    def test_is_won_false_with_missing_letters(self):\n+        \"\"\"Game is not won when some letters are missing.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.guessed_letters = {\"G\", \"A\", \"R\"}\n+        self.assertFalse(game.is_won(state))\n+\n+    def test_apply_guess_detects_win(self):\n+        \"\"\"Winning guess sets game_over and won.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"AB\"\n+        state.guessed_letters = {\"A\"}\n+        new_state = game.apply_guess(state, \"B\")\n+        self.assertTrue(new_state.game_over)\n+        self.assertTrue(new_state.won)\n+\n+\n+class TestLossCondition(unittest.TestCase):\n+    \"\"\"Test loss detection.\"\"\"\n+\n+    def test_is_lost_false_initially(self):\n+        \"\"\"New game is not lost.\"\"\"\n+        state = game.new_game()\n+        self.assertFalse(game.is_lost(state))\n+\n+    def test_is_lost_true_when_water_zero(self):\n+        \"\"\"Game is lost when water reaches zero.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.remaining_water = 0\n+        state.guessed_letters = {\"X\", \"Y\", \"Z\"}\n+        self.assertTrue(game.is_lost(state))\n+\n+    def test_is_lost_false_if_word_complete(self):\n+        \"\"\"Game is not lost if word is completely guessed.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.remaining_water = 0\n+        state.guessed_letters = {\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"}\n+        self.assertFalse(game.is_lost(state))\n+\n+    def test_apply_guess_detects_loss(self):\n+        \"\"\"Wrong guess that empties water sets game_over.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.remaining_water = 1\n+        state.guessed_letters = set()\n+        new_state = game.apply_guess(state, \"Z\")\n+        self.assertTrue(new_state.game_over)\n+        self.assertFalse(new_state.won)\n+\n+\n+class TestGameOverBehavior(unittest.TestCase):\n+    \"\"\"Test behavior when game is over.\"\"\"\n+\n+    def test_guess_after_game_over_is_noop(self):\n+        \"\"\"Guessing after game_over does not change state.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"AB\"\n+        state.guessed_letters = {\"A\", \"B\"}\n+        state.game_over = True\n+        state.won = True\n+        state.remaining_water = 1\n+\n+        new_state = game.apply_guess(state, \"C\")\n+\n+        self.assertEqual(new_state.remaining_water, 1)\n+        self.assertEqual(new_state.weed_count, state.weed_count)\n+        self.assertEqual(new_state.guessed_letters, state.guessed_letters)\n+        self.assertTrue(new_state.game_over)\n+\n+\n+class TestStatePurity(unittest.TestCase):\n+    \"\"\"Test that apply_guess returns a new state without mutating the original.\"\"\"\n+\n+    def test_apply_guess_does_not_mutate_original(self):\n+        \"\"\"apply_guess returns a new state, original is unchanged.\"\"\"\n+        state = game.new_game()\n+        state.secret_word = \"GARDEN\"\n+        state.remaining_water = 6\n+\n+        original_guessed = state.guessed_letters.copy()\n+        original_water = state.remaining_water\n+\n+        new_state = game.apply_guess(state, \"Z\")\n+\n+        self.assertEqual(state.guessed_letters, original_guessed)\n+        self.assertEqual(state.remaining_water, original_water)\n+        self.assertNotEqual(new_state.guessed_letters, original_guessed)\n+        self.assertNotEqual(new_state.remaining_water, original_water)\n+\n+\n+if __name__ == \"__main__\":\n+    unittest.main()\ndiff --git a/tests/test_words.py b/tests/test_words.py\nnew file mode 100644\nindex 0000000..53163b4\n--- /dev/null\n+++ b/tests/test_words.py\n@@ -0,0 +1,73 @@\n+import unittest\n+import random\n+\n+from word_garden import words\n+\n+\n+class TestSelectWord(unittest.TestCase):\n+    \"\"\"Test word selection for all difficulties.\"\"\"\n+\n+    def test_select_word_returns_uppercase(self):\n+        \"\"\"Selected word is uppercase.\"\"\"\n+        word = words.select_word()\n+        self.assertEqual(word, word.upper())\n+\n+    def test_select_word_from_list(self):\n+        \"\"\"Selected word is in the word list.\"\"\"\n+        word = words.select_word()\n+        self.assertIn(word, words.WORDS)\n+\n+    def test_select_word_easy_respects_length(self):\n+        \"\"\"Easy difficulty respects 4-6 letter constraint.\"\"\"\n+        rng = random.Random(42)\n+        for _ in range(20):\n+            word = words.select_word(difficulty=\"easy\", rng=rng)\n+            self.assertIn(len(word), range(4, 7))\n+\n+    def test_select_word_normal_respects_length(self):\n+        \"\"\"Normal difficulty respects 5-8 letter constraint.\"\"\"\n+        rng = random.Random(42)\n+        for _ in range(20):\n+            word = words.select_word(difficulty=\"normal\", rng=rng)\n+            self.assertIn(len(word), range(5, 9))\n+\n+    def test_select_word_hard_respects_length(self):\n+        \"\"\"Hard difficulty respects 7+ letter constraint.\"\"\"\n+        rng = random.Random(42)\n+        for _ in range(20):\n+            word = words.select_word(difficulty=\"hard\", rng=rng)\n+            self.assertGreaterEqual(len(word), 7)\n+\n+    def test_select_word_deterministic_with_seeded_rng(self):\n+        \"\"\"Seeded RNG produces deterministic results.\"\"\"\n+        rng1 = random.Random(123)\n+        rng2 = random.Random(123)\n+        word1 = words.select_word(difficulty=\"normal\", rng=rng1)\n+        word2 = words.select_word(difficulty=\"normal\", rng=rng2)\n+        self.assertEqual(word1, word2)\n+\n+    def test_select_word_unknown_difficulty_raises(self):\n+        \"\"\"Unknown difficulty raises ValueError.\"\"\"\n+        with self.assertRaises(ValueError):\n+            words.select_word(difficulty=\"extreme\")\n+\n+    def test_water_for_easy(self):\n+        \"\"\"Easy difficulty has 8 water.\"\"\"\n+        self.assertEqual(words.water_for(\"easy\"), 8)\n+\n+    def test_water_for_normal(self):\n+        \"\"\"Normal difficulty has 6 water.\"\"\"\n+        self.assertEqual(words.water_for(\"normal\"), 6)\n+\n+    def test_water_for_hard(self):\n+        \"\"\"Hard difficulty has 4 water.\"\"\"\n+        self.assertEqual(words.water_for(\"hard\"), 4)\n+\n+    def test_water_for_unknown_difficulty_raises(self):\n+        \"\"\"Unknown difficulty raises ValueError.\"\"\"\n+        with self.assertRaises(ValueError):\n+            words.water_for(\"impossible\")\n+\n+\n+if __name__ == \"__main__\":\n+    unittest.main()\ndiff --git a/word_garden/__init__.py b/word_garden/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/word_garden/game.py b/word_garden/game.py\nnew file mode 100644\nindex 0000000..e9ac9e8\n--- /dev/null\n+++ b/word_garden/game.py\n@@ -0,0 +1,144 @@\n+from dataclasses import dataclass, field\n+from . import words\n+\n+\n+@dataclass\n+class GameState:\n+    secret_word: str\n+    guessed_letters: set[str] = field(default_factory=set)\n+    remaining_water: int = 0\n+    weed_count: int = 0\n+    max_water: int = 0\n+    status_message: str = \"\"\n+    game_over: bool = False\n+    won: bool = False\n+\n+\n+def new_game(difficulty=\"normal\", rng=None):\n+    \"\"\"Create a new game with a random word at the given difficulty.\"\"\"\n+    secret_word = words.select_word(difficulty=difficulty, rng=rng)\n+    max_water = words.water_for(difficulty=difficulty)\n+    return GameState(\n+        secret_word=secret_word,\n+        guessed_letters=set(),\n+        remaining_water=max_water,\n+        weed_count=0,\n+        max_water=max_water,\n+        status_message=\"\",\n+        game_over=False,\n+        won=False,\n+    )\n+\n+\n+def validate_guess(input_text):\n+    \"\"\"\n+    Validate user input as a single letter.\n+\n+    Returns:\n+        tuple[str | None, str]: (letter, message)\n+        - If valid: (uppercase letter, \"\")\n+        - If invalid: (None, error message)\n+    \"\"\"\n+    trimmed = input_text.strip()\n+\n+    if not trimmed:\n+        return None, \"Please enter a single letter.\"\n+\n+    if len(trimmed) > 1:\n+        return None, \"Please enter a single letter.\"\n+\n+    letter = trimmed.upper()\n+\n+    if not letter.isalpha():\n+        return None, \"That is not a letter.\"\n+\n+    return letter, \"\"\n+\n+\n+def display_word(state):\n+    \"\"\"Return the masked word with guessed letters revealed, space-separated.\"\"\"\n+    return \" \".join(\n+        letter if letter in state.guessed_letters else \"_\"\n+        for letter in state.secret_word\n+    )\n+\n+\n+def is_won(state):\n+    \"\"\"Check if the game is won (all letters guessed).\"\"\"\n+    return all(letter in state.guessed_letters for letter in state.secret_word)\n+\n+\n+def is_lost(state):\n+    \"\"\"Check if the game is lost (water at 0 before winning).\"\"\"\n+    return state.remaining_water <= 0 and not is_won(state)\n+\n+\n+def apply_guess(state, letter):\n+    \"\"\"\n+    Apply a validated, uppercase letter guess to the game state.\n+\n+    Returns:\n+        A new GameState with the guess applied.\n+    \"\"\"\n+    if state.game_over:\n+        new_state = GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=state.guessed_letters.copy(),\n+            remaining_water=state.remaining_water,\n+            weed_count=state.weed_count,\n+            max_water=state.max_water,\n+            status_message=\"Game is over.\",\n+            game_over=True,\n+            won=state.won,\n+        )\n+        return new_state\n+\n+    if letter in state.guessed_letters:\n+        new_state = GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=state.guessed_letters.copy(),\n+            remaining_water=state.remaining_water,\n+            weed_count=state.weed_count,\n+            max_water=state.max_water,\n+            status_message=f\"You already guessed {letter}. Try another letter.\",\n+            game_over=state.game_over,\n+            won=state.won,\n+        )\n+        return new_state\n+\n+    new_guessed = state.guessed_letters.copy()\n+    new_guessed.add(letter)\n+\n+    if letter in state.secret_word:\n+        new_state = GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=new_guessed,\n+            remaining_water=state.remaining_water,\n+            weed_count=state.weed_count,\n+            max_water=state.max_water,\n+            status_message=\"Good guess! The garden grows.\",\n+            game_over=False,\n+            won=False,\n+        )\n+    else:\n+        new_water = state.remaining_water - 1\n+        new_weeds = state.weed_count + 1\n+        new_state = GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=new_guessed,\n+            remaining_water=new_water,\n+            weed_count=new_weeds,\n+            max_water=state.max_water,\n+            status_message=\"No match. A weed appears.\",\n+            game_over=False,\n+            won=False,\n+        )\n+\n+    if is_won(new_state):\n+        new_state.game_over = True\n+        new_state.won = True\n+    elif is_lost(new_state):\n+        new_state.game_over = True\n+        new_state.won = False\n+\n+    return new_state\ndiff --git a/word_garden/words.py b/word_garden/words.py\nnew file mode 100644\nindex 0000000..e30bc78\n--- /dev/null\n+++ b/word_garden/words.py\n@@ -0,0 +1,58 @@\n+import random\n+\n+WORDS = [\n+    \"GARDEN\",\n+    \"FLOWER\",\n+    \"PLANET\",\n+    \"PYTHON\",\n+    \"TERMINAL\",\n+    \"MEADOW\",\n+    \"ORCHARD\",\n+    \"VINEYARD\",\n+    \"SEEDLING\",\n+    \"HARVEST\",\n+]\n+\n+\n+def select_word(difficulty=\"normal\", rng=None):\n+    \"\"\"\n+    Select a random word filtered by difficulty level.\n+\n+    Args:\n+        difficulty: \"easy\", \"normal\", or \"hard\"\n+        rng: injectable random.Random instance (uses module-level random if None)\n+\n+    Returns:\n+        A word string, uppercase\n+\n+    Raises:\n+        ValueError: if difficulty is unknown\n+    \"\"\"\n+    if difficulty == \"easy\":\n+        min_len, max_len = 4, 6\n+    elif difficulty == \"normal\":\n+        min_len, max_len = 5, 8\n+    elif difficulty == \"hard\":\n+        min_len, max_len = 7, float(\"inf\")\n+    else:\n+        raise ValueError(f\"Unknown difficulty: {difficulty}\")\n+\n+    filtered = [w for w in WORDS if min_len <= len(w) <= max_len]\n+    if not filtered:\n+        raise ValueError(f\"No words available for difficulty {difficulty}\")\n+\n+    if rng is None:\n+        return random.choice(filtered)\n+    return rng.choice(filtered)\n+\n+\n+def water_for(difficulty=\"normal\"):\n+    \"\"\"Return starting water level for a given difficulty.\"\"\"\n+    levels = {\n+        \"easy\": 8,\n+        \"normal\": 6,\n+        \"hard\": 4,\n+    }\n+    if difficulty not in levels:\n+        raise ValueError(f\"Unknown difficulty: {difficulty}\")\n+    return levels[difficulty]\n","numLines":639,"startLine":1,"totalLines":639}}},{"type":"system","subtype":"thinking_tokens","estimated_tokens":50,"estimated_tokens_delta":50,"uuid":"b94de3fe-b2e0-44db-a146-1cabf748e0a7","session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9"},{"type":"system","subtype":"thinking_tokens","estimated_tokens":100,"estimated_tokens_delta":50,"uuid":"6e57bd10-e22d-4beb-8979-f5969b4e5f0f","session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9"},{"type":"system","subtype":"thinking_tokens","estima