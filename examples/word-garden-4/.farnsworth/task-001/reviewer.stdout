bf927b760ad","session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9"},{"type":"system","subtype":"thinking_tokens","estimated_tokens":950,"estimated_tokens_delta":100,"uuid":"773f2460-f502-4ced-882d-9a8d9635cc61","session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9"},{"type":"system","subtype":"thinking_tokens","estimated_tokens":1050,"estimated_tokens_delta":100,"uuid":"5aa7f909-cde2-4511-96a1-f5b992026913","session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9"},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_01EHaU3bQHrskqC9BG8o8y4t","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":10574,"cache_read_input_tokens":20522,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":10574},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"4791bdbc-86ee-4c5c-a167-30125f99dce6","request_id":"req_011CbxfQAKqyt7BAerBoXSNu"},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_01EHaU3bQHrskqC9BG8o8y4t","type":"message","role":"assistant","content":[{"type":"text","text":"Context absorbed. Now writing my blind sketch **before** opening any candidate diff (anchoring defence)."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":10574,"cache_read_input_tokens":20522,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":10574},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"72d28e54-7e73-4e34-93ac-a8740cabe64d","request_id":"req_011CbxfQAKqyt7BAerBoXSNu"},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_01EHaU3bQHrskqC9BG8o8y4t","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XX7MY9dpagVKvn69pUh82p","name":"Write","input":{"file_path":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/blind-sketch.md","content":"# Blind Sketch — Task 001 (Word Garden core)\n\nWritten before reading any candidate. My own outline of how I'd build this.\n\n## Module layout\n```\nword_garden/__init__.py   # may re-export, keep light\nword_garden/words.py\nword_garden/game.py\ntests/__init__.py\ntests/test_words.py\ntests/test_game.py\n```\n\n## words.py\n\n```python\nimport random\n\nWORDS = [\"GARDEN\",\"FLOWER\",\"PLANET\",\"PYTHON\",\"TERMINAL\",\n         \"MEADOW\",\"ORCHARD\",\"VINEYARD\",\"SEEDLING\",\"HARVEST\"]  # all uppercase\n\n# Single source of truth for the difficulty table (DRY — code-tips rule).\n# (water, min_len, max_len_or_None)\n_DIFFICULTY = {\n    \"easy\":   (8, 4, 6),\n    \"normal\": (6, 5, 8),\n    \"hard\":   (4, 7, None),\n}\n\ndef water_for(difficulty=\"normal\") -> int:\n    try:\n        return _DIFFICULTY[difficulty][0]\n    except KeyError:\n        raise ValueError(...)\n\ndef select_word(difficulty=\"normal\", rng=None) -> str:\n    if difficulty not in _DIFFICULTY: raise ValueError(...)\n    _, lo, hi = _DIFFICULTY[difficulty]\n    pool = [w for w in WORDS if lo <= len(w) <= (hi if hi is not None else 10**9)]\n    if not pool: raise ValueError(...)   # never silently fall back (code-tips)\n    chooser = rng if rng is not None else random   # default to module random (code-tips)\n    return chooser.choice(pool)\n```\n\n### Pool sanity check (lengths)\nGARDEN6 FLOWER6 PLANET6 PYTHON6 TERMINAL8 MEADOW6 ORCHARD7 VINEYARD8 SEEDLING8 HARVEST7\n- easy 4–6: GARDEN,FLOWER,PLANET,PYTHON,MEADOW (5) — non-empty ✓\n- normal 5–8: all 10 ✓\n- hard 7+: TERMINAL,ORCHARD,VINEYARD,SEEDLING,HARVEST (5) — non-empty ✓\n\n## game.py\n\n```python\nfrom dataclasses import dataclass, field\nfrom . import words\n\n# Message constants defined ONCE (code-tips: messages as module constants).\nMSG_CORRECT = \"Good guess! The garden grows.\"\nMSG_WRONG   = \"No match. A weed appears.\"\nMSG_REPEAT  = \"You already guessed {letter}. Try another letter.\"\nMSG_WON     = ...   # \"Bloom!\" themed\nMSG_LOST    = ...   # ran out of water themed\nMSG_OVER    = ...   # guess after game over no-op\n# validation messages\nMSG_NEED_ONE = \"Please enter a single letter.\"\nMSG_NOT_LETTER = \"That is not a letter.\"\n\n@dataclass\nclass GameState:\n    secret_word: str\n    guessed_letters: set       # set[str]\n    remaining_water: int\n    weed_count: int\n    max_water: int\n    status_message: str = \"\"\n    game_over: bool = False\n    won: bool = False\n```\n\nField names MUST match SPEC §12 exactly (acceptance criterion). Order/defaults as given.\n\n### new_game(difficulty=\"normal\", rng=None)\n- word = words.select_word(difficulty, rng).upper()\n- water = words.water_for(difficulty)\n- GameState(secret_word=word, guessed_letters=set(), remaining_water=water,\n  weed_count=0, max_water=water, status_message=\"\", game_over=False, won=False)\n\n### validate_guess(input_text) -> (letter|None, message)\n- MUST NOT consult game state (no repeat detection here).\n- s = input_text.strip().upper()\n- empty -> (None, MSG_NEED_ONE)\n- len != 1 -> (None, MSG_NEED_ONE)\n- not s.isalpha() -> (None, MSG_NOT_LETTER)\n- else (s, \"\")\n- Order matters: check length before alpha so \"7!\" → single-letter message? Actually\n  \"ab\" is len2 → need-one; \"7\" is len1 non-alpha → not-letter; \"!\" len1 → not-letter.\n  Edge: \"  \" strips to \"\" → need-one. Multi like \"apple\" → need-one.\n\n### apply_guess(state, letter) -> GameState\nAssume letter already validated (single uppercase alpha). Mutate-and-return (or copy; spec\nsays returns GameState — I'll mutate in place and return same object, documenting it).\n1. if state.game_over: set status to MSG_OVER, return (no-op).\n2. if letter in state.guessed_letters: status = MSG_REPEAT, no water/weed change, return.\n3. add letter to guessed_letters.\n4. if letter in secret_word:\n     status = MSG_CORRECT\n     if all letters revealed (is_won): won=True, game_over=True, status=MSG_WON\n   else:\n     remaining_water -= 1\n     weed_count += 1\n     status = MSG_WRONG\n     if remaining_water <= 0: game_over=True, won=False, status=MSG_LOST\n5. return state\n\n### display_word(state) -> str\n`\" \".join(c if c in guessed_letters else \"_\" for c in secret_word)` → \"G _ R _ E _\"\n\n### is_won(state) -> bool\n`all(c in state.guessed_letters for c in state.secret_word)`\n\n### is_lost(state) -> bool\n`state.remaining_water <= 0 and not is_won(state)`\n\n## Risks / edge cases to guard & test\n- **Terminal-state priority**: a correct final guess wins even if water is low; a wrong\n  guess that zeroes water loses. The two paths are mutually exclusive (win only via\n  correct, loss only via wrong) so no simultaneous win+loss — good, but verify ordering.\n- **No double penalty on repeat**: repeated WRONG guess must not drain water again\n  (letter already in set → early return). Classic bug.\n- **Guess after game_over**: must be a pure no-op except message.\n- **validate_guess never mutates state** — it doesn't even receive state. Confirm signature.\n- **Lowercase normalization**: \"a\" → \"A\" and matches uppercase secret.\n- **Whitespace**: \" a \" → \"A\".\n- **isalpha on unicode**: \"é\".isalpha() is True in Python — spec says \"alphabetic\", acceptable;\n  but digits/symbols rejected with NOT_LETTER. Don't over-engineer ASCII-only unless spec demands.\n- **select_word determinism**: tests MUST inject seeded Random (code-tips).\n- **win with repeated letters in word** (e.g. none here have dup? SEEDLING has E,E and\n  two... S-E-E-D-L-I-N-G has E twice; guessing E reveals both). Test reveal-all.\n- **Purity**: no print/input/non-stdlib import in word_garden/.\n\n## Test plan (SPEC §16, positive assertions)\n1. correct guess reveals all matching positions (assert display + letter in set + no water change)\n2. wrong guess: water-1 AND weed+1 AND letter recorded AND message\n3. (covered by 2) weed+1\n4. repeated guess: water unchanged AND weed unchanged AND message says already\n5. invalid input rejected: each of empty/multi/digit/symbol → (None, specific msg), state untouched\n6. lowercase normalized\n7. win detected: game_over & won True, MSG_WON\n8. loss detected: drive water to 0, game_over True & won False, MSG_LOST\n9. display_word masks unguessed\n10. select_word valid word for EVERY difficulty (easy/normal/hard), length within band, ∈ WORDS\n- plus: guess-after-over no-op; repeated wrong guess no double drain; ValueError on bad difficulty.\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":10574,"cache_read_input_tokens":20522,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":10574},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"cc073484-98f0-43f5-8b70-e03627e0fd94","request_id":"req_011CbxfQAKqyt7BAerBoXSNu"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XX7MY9dpagVKvn69pUh82p","type":"tool_result","content":"File created successfully at: /Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/blind-sketch.md (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"b0743da6-3e5a-4217-a846-6a1714b9cb84","timestamp":"2026-06-12T03:34:36.508Z","tool_use_result":{"type":"create","filePath":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/blind-sketch.md","content":"# Blind Sketch — Task 001 (Word Garden core)\n\nWritten before reading any candidate. My own outline of how I'd build this.\n\n## Module layout\n```\nword_garden/__init__.py   # may re-export, keep light\nword_garden/words.py\nword_garden/game.py\ntests/__init__.py\ntests/test_words.py\ntests/test_game.py\n```\n\n## words.py\n\n```python\nimport random\n\nWORDS = [\"GARDEN\",\"FLOWER\",\"PLANET\",\"PYTHON\",\"TERMINAL\",\n         \"MEADOW\",\"ORCHARD\",\"VINEYARD\",\"SEEDLING\",\"HARVEST\"]  # all uppercase\n\n# Single source of truth for the difficulty table (DRY — code-tips rule).\n# (water, min_len, max_len_or_None)\n_DIFFICULTY = {\n    \"easy\":   (8, 4, 6),\n    \"normal\": (6, 5, 8),\n    \"hard\":   (4, 7, None),\n}\n\ndef water_for(difficulty=\"normal\") -> int:\n    try:\n        return _DIFFICULTY[difficulty][0]\n    except KeyError:\n        raise ValueError(...)\n\ndef select_word(difficulty=\"normal\", rng=None) -> str:\n    if difficulty not in _DIFFICULTY: raise ValueError(...)\n    _, lo, hi = _DIFFICULTY[difficulty]\n    pool = [w for w in WORDS if lo <= len(w) <= (hi if hi is not None else 10**9)]\n    if not pool: raise ValueError(...)   # never silently fall back (code-tips)\n    chooser = rng if rng is not None else random   # default to module random (code-tips)\n    return chooser.choice(pool)\n```\n\n### Pool sanity check (lengths)\nGARDEN6 FLOWER6 PLANET6 PYTHON6 TERMINAL8 MEADOW6 ORCHARD7 VINEYARD8 SEEDLING8 HARVEST7\n- easy 4–6: GARDEN,FLOWER,PLANET,PYTHON,MEADOW (5) — non-empty ✓\n- normal 5–8: all 10 ✓\n- hard 7+: TERMINAL,ORCHARD,VINEYARD,SEEDLING,HARVEST (5) — non-empty ✓\n\n## game.py\n\n```python\nfrom dataclasses import dataclass, field\nfrom . import words\n\n# Message constants defined ONCE (code-tips: messages as module constants).\nMSG_CORRECT = \"Good guess! The garden grows.\"\nMSG_WRONG   = \"No match. A weed appears.\"\nMSG_REPEAT  = \"You already guessed {letter}. Try another letter.\"\nMSG_WON     = ...   # \"Bloom!\" themed\nMSG_LOST    = ...   # ran out of water themed\nMSG_OVER    = ...   # guess after game over no-op\n# validation messages\nMSG_NEED_ONE = \"Please enter a single letter.\"\nMSG_NOT_LETTER = \"That is not a letter.\"\n\n@dataclass\nclass GameState:\n    secret_word: str\n    guessed_letters: set       # set[str]\n    remaining_water: int\n    weed_count: int\n    max_water: int\n    status_message: str = \"\"\n    game_over: bool = False\n    won: bool = False\n```\n\nField names MUST match SPEC §12 exactly (acceptance criterion). Order/defaults as given.\n\n### new_game(difficulty=\"normal\", rng=None)\n- word = words.select_word(difficulty, rng).upper()\n- water = words.water_for(difficulty)\n- GameState(secret_word=word, guessed_letters=set(), remaining_water=water,\n  weed_count=0, max_water=water, status_message=\"\", game_over=False, won=False)\n\n### validate_guess(input_text) -> (letter|None, message)\n- MUST NOT consult game state (no repeat detection here).\n- s = input_text.strip().upper()\n- empty -> (None, MSG_NEED_ONE)\n- len != 1 -> (None, MSG_NEED_ONE)\n- not s.isalpha() -> (None, MSG_NOT_LETTER)\n- else (s, \"\")\n- Order matters: check length before alpha so \"7!\" → single-letter message? Actually\n  \"ab\" is len2 → need-one; \"7\" is len1 non-alpha → not-letter; \"!\" len1 → not-letter.\n  Edge: \"  \" strips to \"\" → need-one. Multi like \"apple\" → need-one.\n\n### apply_guess(state, letter) -> GameState\nAssume letter already validated (single uppercase alpha). Mutate-and-return (or copy; spec\nsays returns GameState — I'll mutate in place and return same object, documenting it).\n1. if state.game_over: set status to MSG_OVER, return (no-op).\n2. if letter in state.guessed_letters: status = MSG_REPEAT, no water/weed change, return.\n3. add letter to guessed_letters.\n4. if letter in secret_word:\n     status = MSG_CORRECT\n     if all letters revealed (is_won): won=True, game_over=True, status=MSG_WON\n   else:\n     remaining_water -= 1\n     weed_count += 1\n     status = MSG_WRONG\n     if remaining_water <= 0: game_over=True, won=False, status=MSG_LOST\n5. return state\n\n### display_word(state) -> str\n`\" \".join(c if c in guessed_letters else \"_\" for c in secret_word)` → \"G _ R _ E _\"\n\n### is_won(state) -> bool\n`all(c in state.guessed_letters for c in state.secret_word)`\n\n### is_lost(state) -> bool\n`state.remaining_water <= 0 and not is_won(state)`\n\n## Risks / edge cases to guard & test\n- **Terminal-state priority**: a correct final guess wins even if water is low; a wrong\n  guess that zeroes water loses. The two paths are mutually exclusive (win only via\n  correct, loss only via wrong) so no simultaneous win+loss — good, but verify ordering.\n- **No double penalty on repeat**: repeated WRONG guess must not drain water again\n  (letter already in set → early return). Classic bug.\n- **Guess after game_over**: must be a pure no-op except message.\n- **validate_guess never mutates state** — it doesn't even receive state. Confirm signature.\n- **Lowercase normalization**: \"a\" → \"A\" and matches uppercase secret.\n- **Whitespace**: \" a \" → \"A\".\n- **isalpha on unicode**: \"é\".isalpha() is True in Python — spec says \"alphabetic\", acceptable;\n  but digits/symbols rejected with NOT_LETTER. Don't over-engineer ASCII-only unless spec demands.\n- **select_word determinism**: tests MUST inject seeded Random (code-tips).\n- **win with repeated letters in word** (e.g. none here have dup? SEEDLING has E,E and\n  two... S-E-E-D-L-I-N-G has E twice; guessing E reveals both). Test reveal-all.\n- **Purity**: no print/input/non-stdlib import in word_garden/.\n\n## Test plan (SPEC §16, positive assertions)\n1. correct guess reveals all matching positions (assert display + letter in set + no water change)\n2. wrong guess: water-1 AND weed+1 AND letter recorded AND message\n3. (covered by 2) weed+1\n4. repeated guess: water unchanged AND weed unchanged AND message says already\n5. invalid input rejected: each of empty/multi/digit/symbol → (None, specific msg), state untouched\n6. lowercase normalized\n7. win detected: game_over & won True, MSG_WON\n8. loss detected: drive water to 0, game_over True & won False, MSG_LOST\n9. display_word masks unguessed\n10. select_word valid word for EVERY difficulty (easy/normal/hard), length within band, ∈ WORDS\n- plus: guess-after-over no-op; repeated wrong guess no double drain; ValueError on bad difficulty.\n","structuredPatch":[],"originalFile":null,"userModified":false}},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_018NiA6ZVosayeehLobnDQ6s","type":"message","role":"assistant","content":[{"type":"text","text":"Blind sketch is committed. Now reading the candidate diffs."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2237,"cache_creation_input_tokens":4020,"cache_read_input_tokens":31096,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4020},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"46c9f41a-ed13-48c6-adb1-62de45e4631f","request_id":"req_011CbxfTgtxBQqWbSEqzGVnm"},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_018NiA6ZVosayeehLobnDQ6s","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CCAu3TVEKav9QFyytzikcK","name":"Read","input":{"file_path":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/A.diff"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2237,"cache_creation_input_tokens":4020,"cache_read_input_tokens":31096,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4020},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"5688f8fb-cbf0-4fd4-826c-f4d6bcaf590c","request_id":"req_011CbxfTgtxBQqWbSEqzGVnm"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CCAu3TVEKav9QFyytzikcK","type":"tool_result","content":"1\tdiff --git a/tests/__init__.py b/tests/__init__.py\n2\tnew file mode 100644\n3\tindex 0000000..e69de29\n4\tdiff --git a/tests/test_game.py b/tests/test_game.py\n5\tnew file mode 100644\n6\tindex 0000000..ca6a9a6\n7\t--- /dev/null\n8\t+++ b/tests/test_game.py\n9\t@@ -0,0 +1,395 @@\n10\t+import random\n11\t+import unittest\n12\t+from word_garden import game, words\n13\t+\n14\t+\n15\t+class TestGameState(unittest.TestCase):\n16\t+    def test_new_game_creates_state(self):\n17\t+        \"\"\"new_game creates a GameState with correct initial values.\"\"\"\n18\t+        rng = random.Random(42)\n19\t+        state = game.new_game(difficulty=\"normal\", rng=rng)\n20\t+\n21\t+        self.assertIsNotNone(state.secret_word)\n22\t+        self.assertEqual(state.secret_word, state.secret_word.upper())\n23\t+        self.assertEqual(state.guessed_letters, set())\n24\t+        self.assertEqual(state.remaining_water, 6)\n25\t+        self.assertEqual(state.max_water, 6)\n26\t+        self.assertEqual(state.weed_count, 0)\n27\t+        self.assertEqual(state.status_message, \"\")\n28\t+        self.assertFalse(state.game_over)\n29\t+        self.assertFalse(state.won)\n30\t+\n31\t+    def test_new_game_easy_has_correct_water(self):\n32\t+        \"\"\"new_game with easy difficulty starts with 8 water.\"\"\"\n33\t+        rng = random.Random(42)\n34\t+        state = game.new_game(difficulty=\"easy\", rng=rng)\n35\t+        self.assertEqual(state.remaining_water, 8)\n36\t+        self.assertEqual(state.max_water, 8)\n37\t+\n38\t+    def test_new_game_hard_has_correct_water(self):\n39\t+        \"\"\"new_game with hard difficulty starts with 4 water.\"\"\"\n40\t+        rng = random.Random(42)\n41\t+        state = game.new_game(difficulty=\"hard\", rng=rng)\n42\t+        self.assertEqual(state.remaining_water, 4)\n43\t+        self.assertEqual(state.max_water, 4)\n44\t+\n45\t+    def test_new_game_deterministic_with_seeded_rng(self):\n46\t+        \"\"\"new_game is deterministic with seeded random.Random.\"\"\"\n47\t+        rng1 = random.Random(999)\n48\t+        rng2 = random.Random(999)\n49\t+        state1 = game.new_game(difficulty=\"normal\", rng=rng1)\n50\t+        state2 = game.new_game(difficulty=\"normal\", rng=rng2)\n51\t+        self.assertEqual(state1.secret_word, state2.secret_word)\n52\t+\n53\t+\n54\t+class TestValidateGuess(unittest.TestCase):\n55\t+    def test_valid_single_letter_lowercase(self):\n56\t+        \"\"\"SPEC 16.6: validate_guess accepts lowercase and normalizes.\"\"\"\n57\t+        letter, msg = game.validate_guess(\"a\")\n58\t+        self.assertEqual(letter, \"A\")\n59\t+        self.assertEqual(msg, \"\")\n60\t+\n61\t+    def test_valid_single_letter_uppercase(self):\n62\t+        \"\"\"validate_guess accepts uppercase letters.\"\"\"\n63\t+        letter, msg = game.validate_guess(\"Z\")\n64\t+        self.assertEqual(letter, \"Z\")\n65\t+        self.assertEqual(msg, \"\")\n66\t+\n67\t+    def test_valid_with_leading_trailing_space(self):\n68\t+        \"\"\"SPEC 16.6: validate_guess trims whitespace.\"\"\"\n69\t+        letter, msg = game.validate_guess(\"  a  \")\n70\t+        self.assertEqual(letter, \"A\")\n71\t+        self.assertEqual(msg, \"\")\n72\t+\n73\t+    def test_invalid_empty_input(self):\n74\t+        \"\"\"SPEC 16.6: validate_guess rejects empty input.\"\"\"\n75\t+        letter, msg = game.validate_guess(\"\")\n76\t+        self.assertIsNone(letter)\n77\t+        self.assertEqual(msg, \"Please enter a single letter.\")\n78\t+\n79\t+    def test_invalid_multiple_characters(self):\n80\t+        \"\"\"SPEC 16.6: validate_guess rejects multiple characters.\"\"\"\n81\t+        letter, msg = game.validate_guess(\"apple\")\n82\t+        self.assertIsNone(letter)\n83\t+        self.assertEqual(msg, \"Please enter a single letter.\")\n84\t+\n85\t+    def test_invalid_number(self):\n86\t+        \"\"\"SPEC 16.6: validate_guess rejects numbers.\"\"\"\n87\t+        letter, msg = game.validate_guess(\"7\")\n88\t+        self.assertIsNone(letter)\n89\t+        self.assertEqual(msg, \"That is not a letter.\")\n90\t+\n91\t+    def test_invalid_symbol(self):\n92\t+        \"\"\"SPEC 16.6: validate_guess rejects symbols.\"\"\"\n93\t+        letter, msg = game.validate_guess(\"!\")\n94\t+        self.assertIsNone(letter)\n95\t+        self.assertEqual(msg, \"That is not a letter.\")\n96\t+\n97\t+    def test_invalid_whitespace_only(self):\n98\t+        \"\"\"validate_guess rejects whitespace-only input.\"\"\"\n99\t+        letter, msg = game.validate_guess(\"   \")\n100\t+        self.assertIsNone(letter)\n101\t+        self.assertEqual(msg, \"Please enter a single letter.\")\n102\t+\n103\t+\n104\t+class TestDisplayWord(unittest.TestCase):\n105\t+    def test_display_word_no_guesses(self):\n106\t+        \"\"\"SPEC 16.9: display_word masks all letters initially.\"\"\"\n107\t+        state = game.GameState(\n108\t+            secret_word=\"GARDEN\",\n109\t+            guessed_letters=set(),\n110\t+            remaining_water=6,\n111\t+            max_water=6,\n112\t+            weed_count=0,\n113\t+        )\n114\t+        self.assertEqual(game.display_word(state), \"_ _ _ _ _ _\")\n115\t+\n116\t+    def test_display_word_partial_guesses(self):\n117\t+        \"\"\"display_word reveals only guessed letters.\"\"\"\n118\t+        state = game.GameState(\n119\t+            secret_word=\"GARDEN\",\n120\t+            guessed_letters={\"G\", \"A\", \"E\"},\n121\t+            remaining_water=6,\n122\t+            max_water=6,\n123\t+            weed_count=0,\n124\t+        )\n125\t+        self.assertEqual(game.display_word(state), \"G A _ _ E _\")\n126\t+\n127\t+    def test_display_word_all_guesses(self):\n128\t+        \"\"\"display_word reveals the entire word when all letters guessed.\"\"\"\n129\t+        state = game.GameState(\n130\t+            secret_word=\"GARDEN\",\n131\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n132\t+            remaining_water=6,\n133\t+            max_water=6,\n134\t+            weed_count=0,\n135\t+        )\n136\t+        self.assertEqual(game.display_word(state), \"G A R D E N\")\n137\t+\n138\t+    def test_display_word_space_separated(self):\n139\t+        \"\"\"display_word output is space-separated.\"\"\"\n140\t+        state = game.GameState(\n141\t+            secret_word=\"CAT\",\n142\t+            guessed_letters={\"C\"},\n143\t+            remaining_water=6,\n144\t+            max_water=6,\n145\t+            weed_count=0,\n146\t+        )\n147\t+        displayed = game.display_word(state)\n148\t+        self.assertEqual(displayed, \"C _ _\")\n149\t+        self.assertEqual(displayed.count(\" \"), 2)\n150\t+\n151\t+\n152\t+class TestIsWon(unittest.TestCase):\n153\t+    def test_is_won_false_when_not_all_guessed(self):\n154\t+        \"\"\"is_won returns False when not all letters are guessed.\"\"\"\n155\t+        state = game.GameState(\n156\t+            secret_word=\"GARDEN\",\n157\t+            guessed_letters={\"G\", \"A\"},\n158\t+            remaining_water=6,\n159\t+            max_water=6,\n160\t+            weed_count=0,\n161\t+        )\n162\t+        self.assertFalse(game.is_won(state))\n163\t+\n164\t+    def test_is_won_true_when_all_guessed(self):\n165\t+        \"\"\"SPEC 16.7: is_won returns True when all letters are guessed.\"\"\"\n166\t+        state = game.GameState(\n167\t+            secret_word=\"GARDEN\",\n168\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n169\t+            remaining_water=6,\n170\t+            max_water=6,\n171\t+            weed_count=0,\n172\t+        )\n173\t+        self.assertTrue(game.is_won(state))\n174\t+\n175\t+    def test_is_won_with_extra_guesses(self):\n176\t+        \"\"\"is_won ignores extra guessed letters not in the word.\"\"\"\n177\t+        state = game.GameState(\n178\t+            secret_word=\"GARDEN\",\n179\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\", \"X\", \"Y\", \"Z\"},\n180\t+            remaining_water=6,\n181\t+            max_water=6,\n182\t+            weed_count=0,\n183\t+        )\n184\t+        self.assertTrue(game.is_won(state))\n185\t+\n186\t+\n187\t+class TestIsLost(unittest.TestCase):\n188\t+    def test_is_lost_false_when_water_remains(self):\n189\t+        \"\"\"is_lost returns False when water is above 0.\"\"\"\n190\t+        state = game.GameState(\n191\t+            secret_word=\"GARDEN\",\n192\t+            guessed_letters={\"X\", \"Y\", \"Z\"},\n193\t+            remaining_water=1,\n194\t+            max_water=6,\n195\t+            weed_count=3,\n196\t+        )\n197\t+        self.assertFalse(game.is_lost(state))\n198\t+\n199\t+    def test_is_lost_true_when_water_at_zero(self):\n200\t+        \"\"\"SPEC 16.8: is_lost returns True when water reaches 0.\"\"\"\n201\t+        state = game.GameState(\n202\t+            secret_word=\"GARDEN\",\n203\t+            guessed_letters={\"X\", \"Y\", \"Z\"},\n204\t+            remaining_water=0,\n205\t+            max_water=6,\n206\t+            weed_count=3,\n207\t+        )\n208\t+        self.assertTrue(game.is_lost(state))\n209\t+\n210\t+    def test_is_lost_false_when_won(self):\n211\t+        \"\"\"is_lost returns False even if water is 0 when game is won.\"\"\"\n212\t+        state = game.GameState(\n213\t+            secret_word=\"GARDEN\",\n214\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n215\t+            remaining_water=0,\n216\t+            max_water=6,\n217\t+            weed_count=0,\n218\t+        )\n219\t+        self.assertFalse(game.is_lost(state))\n220\t+\n221\t+\n222\t+class TestApplyGuess(unittest.TestCase):\n223\t+    def test_correct_guess_reveals_letter(self):\n224\t+        \"\"\"SPEC 16.1: A correct guess reveals matching letters.\"\"\"\n225\t+        rng = random.Random(42)\n226\t+        state = game.new_game(difficulty=\"normal\", rng=rng)\n227\t+        initial_word = state.secret_word\n228\t+\n229\t+        state = game.apply_guess(state, initial_word[0])\n230\t+\n231\t+        self.assertIn(initial_word[0], state.guessed_letters)\n232\t+        self.assertEqual(\n233\t+            state.status_message, \"Good guess! The garden grows.\"\n234\t+        )\n235\t+        self.assertEqual(state.remaining_water, state.max_water)\n236\t+        self.assertEqual(state.weed_count, 0)\n237\t+\n238\t+    def test_incorrect_guess_reduces_water(self):\n239\t+        \"\"\"SPEC 16.2: An incorrect guess reduces water by one.\"\"\"\n240\t+        rng = random.Random(42)\n241\t+        state = game.new_game(difficulty=\"normal\", rng=rng)\n242\t+        initial_water = state.remaining_water\n243\t+\n244\t+        state = game.apply_guess(state, \"X\")\n245\t+\n246\t+        self.assertEqual(state.remaining_water, initial_water - 1)\n247\t+        self.assertEqual(state.status_message, \"No match. A weed appears.\")\n248\t+\n249\t+    def test_incorrect_guess_increases_weeds(self):\n250\t+        \"\"\"SPEC 16.3: An incorrect guess increases weed count by one.\"\"\"\n251\t+        rng = random.Random(42)\n252\t+        state = game.new_game(difficulty=\"normal\", rng=rng)\n253\t+        initial_weeds = state.weed_count\n254\t+\n255\t+        state = game.apply_guess(state, \"X\")\n256\t+\n257\t+        self.assertEqual(state.weed_count, initial_weeds + 1)\n258\t+\n259\t+    def test_incorrect_guess_records_letter(self):\n260\t+        \"\"\"An incorrect guess still records the guessed letter.\"\"\"\n261\t+        rng = random.Random(42)\n262\t+        state = game.new_game(difficulty=\"normal\", rng=rng)\n263\t+\n264\t+        state = game.apply_guess(state, \"X\")\n265\t+\n266\t+        self.assertIn(\"X\", state.guessed_letters)\n267\t+\n268\t+    def test_repeated_guess_no_water_change(self):\n269\t+        \"\"\"SPEC 16.4: Repeated guesses do not reduce water.\"\"\"\n270\t+        rng = random.Random(42)\n271\t+        state = game.new_game(difficulty=\"normal\", rng=rng)\n272\t+\n273\t+        state = game.apply_guess(state, \"X\")\n274\t+        initial_water = state.remaining_water\n275\t+        state = game.apply_guess(state, \"X\")\n276\t+\n277\t+        self.assertEqual(state.remaining_water, initial_water)\n278\t+\n279\t+    def test_repeated_guess_no_weed_change(self):\n280\t+        \"\"\"Repeated guesses do not increase weed count.\"\"\"\n281\t+        rng = random.Random(42)\n282\t+        state = game.new_game(difficulty=\"normal\", rng=rng)\n283\t+\n284\t+        state = game.apply_guess(state, \"X\")\n285\t+        initial_weeds = state.weed_count\n286\t+        state = game.apply_guess(state, \"X\")\n287\t+\n288\t+        self.assertEqual(state.weed_count, initial_weeds)\n289\t+\n290\t+    def test_repeated_guess_produces_message(self):\n291\t+        \"\"\"Repeated guesses produce an appropriate message.\"\"\"\n292\t+        rng = random.Random(42)\n293\t+        state = game.new_game(difficulty=\"normal\", rng=rng)\n294\t+\n295\t+        state = game.apply_guess(state, \"X\")\n296\t+        state = game.apply_guess(state, \"X\")\n297\t+\n298\t+        self.assertIn(\"already guessed\", state.status_message.lower())\n299\t+\n300\t+    def test_guess_after_game_over_no_op(self):\n301\t+        \"\"\"Guessing after game_over is set produces a message.\"\"\"\n302\t+        state = game.GameState(\n303\t+            secret_word=\"GARDEN\",\n304\t+            guessed_letters=set(),\n305\t+            remaining_water=6,\n306\t+            max_water=6,\n307\t+            weed_count=0,\n308\t+            game_over=True,\n309\t+            won=False,\n310\t+        )\n311\t+\n312\t+        new_state = game.apply_guess(state, \"A\")\n313\t+\n314\t+        self.assertEqual(new_state.guessed_letters, state.guessed_letters)\n315\t+        self.assertEqual(new_state.remaining_water, state.remaining_water)\n316\t+        self.assertTrue(new_state.game_over)\n317\t+        self.assertIn(\"game is over\", new_state.status_message.lower())\n318\t+\n319\t+    def test_win_detected_on_final_letter(self):\n320\t+        \"\"\"SPEC 16.7: The game detects a win when final letter is guessed.\"\"\"\n321\t+        state = game.GameState(\n322\t+            secret_word=\"GARDEN\",\n323\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\"},\n324\t+            remaining_water=6,\n325\t+            max_water=6,\n326\t+            weed_count=0,\n327\t+        )\n328\t+\n329\t+        state = game.apply_guess(state, \"N\")\n330\t+\n331\t+        self.assertTrue(state.won)\n332\t+        self.assertTrue(state.game_over)\n333\t+\n334\t+    def test_loss_detected_on_water_zero(self):\n335\t+        \"\"\"SPEC 16.8: The game detects a loss when water reaches 0.\"\"\"\n336\t+        state = game.GameState(\n337\t+            secret_word=\"GARDEN\",\n338\t+            guessed_letters={\"X\", \"Y\", \"Z\"},\n339\t+            remaining_water=1,\n340\t+            max_water=6,\n341\t+            weed_count=3,\n342\t+        )\n343\t+\n344\t+        state = game.apply_guess(state, \"Q\")\n345\t+\n346\t+        self.assertTrue(state.game_over)\n347\t+        self.assertFalse(state.won)\n348\t+\n349\t+    def test_apply_guess_does_not_mutate_original_state(self):\n350\t+        \"\"\"apply_guess returns a new state, not mutating the original.\"\"\"\n351\t+        rng = random.Random(42)\n352\t+        original_state = game.new_game(difficulty=\"normal\", rng=rng)\n353\t+        original_guessed = original_state.guessed_letters.copy()\n354\t+        original_water = original_state.remaining_water\n355\t+\n356\t+        new_state = game.apply_guess(original_state, \"X\")\n357\t+\n358\t+        self.assertEqual(original_state.guessed_letters, original_guessed)\n359\t+        self.assertEqual(original_state.remaining_water, original_water)\n360\t+        self.assertNotEqual(new_state.guessed_letters, original_guessed)\n361\t+\n362\t+    def test_multiple_correct_guesses_reveal_multiple_positions(self):\n363\t+        \"\"\"Correct guesses for letters appearing multiple times work correctly.\"\"\"\n364\t+        state = game.GameState(\n365\t+            secret_word=\"BANANA\",\n366\t+            guessed_letters=set(),\n367\t+            remaining_water=6,\n368\t+            max_water=6,\n369\t+            weed_count=0,\n370\t+        )\n371\t+\n372\t+        state = game.apply_guess(state, \"A\")\n373\t+\n374\t+        self.assertIn(\"A\", state.guessed_letters)\n375\t+        self.assertEqual(game.display_word(state), \"_ A _ A _ A\")\n376\t+\n377\t+    def test_game_flow_correct_then_incorrect(self):\n378\t+        \"\"\"A sequence of correct then incorrect guesses is handled correctly.\"\"\"\n379\t+        state = game.GameState(\n380\t+            secret_word=\"GARDEN\",\n381\t+            guessed_letters=set(),\n382\t+            remaining_water=6,\n383\t+            max_water=6,\n384\t+            weed_count=0,\n385\t+        )\n386\t+\n387\t+        state = game.apply_guess(state, \"G\")\n388\t+        self.assertEqual(state.remaining_water, 6)\n389\t+        self.assertEqual(state.weed_count, 0)\n390\t+        self.assertFalse(state.game_over)\n391\t+\n392\t+        state = game.apply_guess(state, \"X\")\n393\t+        self.assertEqual(state.remaining_water, 5)\n394\t+        self.assertEqual(state.weed_count, 1)\n395\t+        self.assertFalse(state.game_over)\n396\t+\n397\t+        state = game.apply_guess(state, \"A\")\n398\t+        self.assertEqual(state.remaining_water, 5)\n399\t+        self.assertEqual(state.weed_count, 1)\n400\t+        self.assertFalse(state.game_over)\n401\t+\n402\t+\n403\t+if __name__ == \"__main__\":\n404\t+    unittest.main()\n405\tdiff --git a/tests/test_words.py b/tests/test_words.py\n406\tnew file mode 100644\n407\tindex 0000000..dbc1b35\n408\t--- /dev/null\n409\t+++ b/tests/test_words.py\n410\t@@ -0,0 +1,70 @@\n411\t+import random\n412\t+import unittest\n413\t+from word_garden import words\n414\t+\n415\t+\n416\t+class TestWords(unittest.TestCase):\n417\t+    def test_words_list_exists(self):\n418\t+        \"\"\"SPEC 16.10: Word list is available.\"\"\"\n419\t+        self.assertIsNotNone(words.WORDS)\n420\t+        self.assertEqual(len(words.WORDS), 10)\n421\t+\n422\t+    def test_words_are_uppercase(self):\n423\t+        \"\"\"All words in WORDS are uppercase.\"\"\"\n424\t+        for word in words.WORDS:\n425\t+            self.assertEqual(word, word.upper())\n426\t+\n427\t+    def test_select_word_easy_returns_valid_word(self):\n428\t+        \"\"\"SPEC 16.10: select_word returns a word matching easy difficulty.\"\"\"\n429\t+        rng = random.Random(42)\n430\t+        word = words.select_word(difficulty=\"easy\", rng=rng)\n431\t+        self.assertIn(word, words.WORDS)\n432\t+        self.assertTrue(4 <= len(word) <= 6)\n433\t+\n434\t+    def test_select_word_normal_returns_valid_word(self):\n435\t+        \"\"\"SPEC 16.10: select_word returns a word matching normal difficulty.\"\"\"\n436\t+        rng = random.Random(42)\n437\t+        word = words.select_word(difficulty=\"normal\", rng=rng)\n438\t+        self.assertIn(word, words.WORDS)\n439\t+        self.assertTrue(5 <= len(word) <= 8)\n440\t+\n441\t+    def test_select_word_hard_returns_valid_word(self):\n442\t+        \"\"\"SPEC 16.10: select_word returns a word matching hard difficulty.\"\"\"\n443\t+        rng = random.Random(42)\n444\t+        word = words.select_word(difficulty=\"hard\", rng=rng)\n445\t+        self.assertIn(word, words.WORDS)\n446\t+        self.assertTrue(len(word) >= 7)\n447\t+\n448\t+    def test_select_word_deterministic_with_seeded_rng(self):\n449\t+        \"\"\"select_word is deterministic when given a seeded random.Random.\"\"\"\n450\t+        rng1 = random.Random(123)\n451\t+        rng2 = random.Random(123)\n452\t+        word1 = words.select_word(difficulty=\"normal\", rng=rng1)\n453\t+        word2 = words.select_word(difficulty=\"normal\", rng=rng2)\n454\t+        self.assertEqual(word1, word2)\n455\t+\n456\t+    def test_select_word_invalid_difficulty_raises_error(self):\n457\t+        \"\"\"select_word raises ValueError for unknown difficulty.\"\"\"\n458\t+        with self.assertRaises(ValueError):\n459\t+            words.select_word(difficulty=\"impossible\")\n460\t+\n461\t+    def test_water_for_easy(self):\n462\t+        \"\"\"water_for returns correct water level for easy.\"\"\"\n463\t+        self.assertEqual(words.water_for(\"easy\"), 8)\n464\t+\n465\t+    def test_water_for_normal(self):\n466\t+        \"\"\"water_for returns correct water level for normal.\"\"\"\n467\t+        self.assertEqual(words.water_for(\"normal\"), 6)\n468\t+\n469\t+    def test_water_for_hard(self):\n470\t+        \"\"\"water_for returns correct water level for hard.\"\"\"\n471\t+        self.assertEqual(words.water_for(\"hard\"), 4)\n472\t+\n473\t+    def test_water_for_invalid_difficulty_raises_error(self):\n474\t+        \"\"\"water_for raises ValueError for unknown difficulty.\"\"\"\n475\t+        with self.assertRaises(ValueError):\n476\t+            words.water_for(\"impossible\")\n477\t+\n478\t+\n479\t+if __name__ == \"__main__\":\n480\t+    unittest.main()\n481\tdiff --git a/word_garden/__init__.py b/word_garden/__init__.py\n482\tnew file mode 100644\n483\tindex 0000000..e69de29\n484\tdiff --git a/word_garden/game.py b/word_garden/game.py\n485\tnew file mode 100644\n486\tindex 0000000..8a8c6db\n487\t--- /dev/null\n488\t+++ b/word_garden/game.py\n489\t@@ -0,0 +1,178 @@\n490\t+from dataclasses import dataclass, field\n491\t+from word_garden import words\n492\t+\n493\t+\n494\t+@dataclass\n495\t+class GameState:\n496\t+    secret_word: str\n497\t+    guessed_letters: set[str] = field(default_factory=set)\n498\t+    remaining_water: int = 0\n499\t+    weed_count: int = 0\n500\t+    max_water: int = 0\n501\t+    status_message: str = \"\"\n502\t+    game_over: bool = False\n503\t+    won: bool = False\n504\t+\n505\t+\n506\t+def new_game(difficulty=\"normal\", rng=None):\n507\t+    \"\"\"Create a new game with a random word.\n508\t+\n509\t+    Args:\n510\t+        difficulty: \"easy\", \"normal\", or \"hard\"\n511\t+        rng: optional random.Random instance for deterministic tests\n512\t+\n513\t+    Returns:\n514\t+        A new GameState ready for play\n515\t+    \"\"\"\n516\t+    word = words.select_word(difficulty=difficulty, rng=rng)\n517\t+    max_water = words.water_for(difficulty=difficulty)\n518\t+\n519\t+    return GameState(\n520\t+        secret_word=word,\n521\t+        guessed_letters=set(),\n522\t+        remaining_water=max_water,\n523\t+        weed_count=0,\n524\t+        max_water=max_water,\n525\t+        status_message=\"\",\n526\t+        game_over=False,\n527\t+        won=False,\n528\t+    )\n529\t+\n530\t+\n531\t+def validate_guess(input_text):\n532\t+    \"\"\"Validate user input and extract a letter.\n533\t+\n534\t+    Args:\n535\t+        input_text: raw user input string\n536\t+\n537\t+    Returns:\n538\t+        tuple: (letter, message) where letter is None if invalid,\n539\t+               or (letter, \"\") if valid\n540\t+    \"\"\"\n541\t+    trimmed = input_text.strip().upper()\n542\t+\n543\t+    if not trimmed:\n544\t+        return (None, \"Please enter a single letter.\")\n545\t+\n546\t+    if len(trimmed) > 1:\n547\t+        return (None, \"Please enter a single letter.\")\n548\t+\n549\t+    if not trimmed.isalpha():\n550\t+        return (None, \"That is not a letter.\")\n551\t+\n552\t+    return (trimmed, \"\")\n553\t+\n554\t+\n555\t+def display_word(state):\n556\t+    \"\"\"Display the secret word with guessed letters revealed.\n557\t+\n558\t+    Args:\n559\t+        state: GameState\n560\t+\n561\t+    Returns:\n562\t+        String with letters revealed and blanks for unguessed letters,\n563\t+        space-separated (e.g., \"G _ R _ E _\")\n564\t+    \"\"\"\n565\t+    return \" \".join(\n566\t+        letter if letter in state.guessed_letters else \"_\"\n567\t+        for letter in state.secret_word\n568\t+    )\n569\t+\n570\t+\n571\t+def is_won(state):\n572\t+    \"\"\"Check if the player has won.\n573\t+\n574\t+    Args:\n575\t+        state: GameState\n576\t+\n577\t+    Returns:\n578\t+        True if all letters in secret_word are in guessed_letters\n579\t+    \"\"\"\n580\t+    return all(letter in state.guessed_letters for letter in state.secret_word)\n581\t+\n582\t+\n583\t+def is_lost(state):\n584\t+    \"\"\"Check if the player has lost.\n585\t+\n586\t+    Args:\n587\t+        state: GameState\n588\t+\n589\t+    Returns:\n590\t+        True if water has reached 0 before winning\n591\t+    \"\"\"\n592\t+    return state.remaining_water <= 0 and not is_won(state)\n593\t+\n594\t+\n595\t+def apply_guess(state, letter):\n596\t+    \"\"\"Apply a validated letter guess to the game state.\n597\t+\n598\t+    Args:\n599\t+        state: GameState\n600\t+        letter: uppercase single letter\n601\t+\n602\t+    Returns:\n603\t+        Updated GameState with the guess applied\n604\t+    \"\"\"\n605\t+    if state.game_over:\n606\t+        return GameState(\n607\t+            secret_word=state.secret_word,\n608\t+            guessed_letters=state.guessed_letters.copy(),\n609\t+            remaining_water=state.remaining_water,\n610\t+            weed_count=state.weed_count,\n611\t+            max_water=state.max_water,\n612\t+            status_message=\"The game is over. Start a new game.\",\n613\t+            game_over=state.game_over,\n614\t+            won=state.won,\n615\t+        )\n616\t+\n617\t+    if letter in state.guessed_letters:\n618\t+        return GameState(\n619\t+            secret_word=state.secret_word,\n620\t+            guessed_letters=state.guessed_letters.copy(),\n621\t+            remaining_water=state.remaining_water,\n622\t+            weed_count=state.weed_count,\n623\t+            max_water=state.max_water,\n624\t+            status_message=f\"You already guessed {letter}. Try another letter.\",\n625\t+            game_over=state.game_over,\n626\t+            won=state.won,\n627\t+        )\n628\t+\n629\t+    new_guessed = state.guessed_letters | {letter}\n630\t+\n631\t+    if letter in state.secret_word:\n632\t+        new_state = GameState(\n633\t+            secret_word=state.secret_word,\n634\t+            guessed_letters=new_guessed,\n635\t+            remaining_water=state.remaining_water,\n636\t+            weed_count=state.weed_count,\n637\t+            max_water=state.max_water,\n638\t+            status_message=\"Good guess! The garden grows.\",\n639\t+            game_over=False,\n640\t+            won=False,\n641\t+        )\n642\t+\n643\t+        if is_won(new_state):\n644\t+            new_state.won = True\n645\t+            new_state.game_over = True\n646\t+\n647\t+        return new_state\n648\t+\n649\t+    else:\n650\t+        new_water = state.remaining_water - 1\n651\t+        new_weeds = state.weed_count + 1\n652\t+\n653\t+        new_state = GameState(\n654\t+            secret_word=state.secret_word,\n655\t+            guessed_letters=new_guessed,\n656\t+            remaining_water=new_water,\n657\t+            weed_count=new_weeds,\n658\t+            max_water=state.max_water,\n659\t+            status_message=\"No match. A weed appears.\",\n660\t+            game_over=False,\n661\t+            won=False,\n662\t+        )\n663\t+\n664\t+        if is_lost(new_state):\n665\t+            new_state.game_over = True\n666\t+\n667\t+        return new_state\n668\tdiff --git a/word_garden/words.py b/word_garden/words.py\n669\tnew file mode 100644\n670\tindex 0000000..1543582\n671\t--- /dev/null\n672\t+++ b/word_garden/words.py\n673\t@@ -0,0 +1,69 @@\n674\t+import random\n675\t+\n676\t+WORDS = [\n677\t+    \"GARDEN\",\n678\t+    \"FLOWER\",\n679\t+    \"PLANET\",\n680\t+    \"PYTHON\",\n681\t+    \"TERMINAL\",\n682\t+    \"MEADOW\",\n683\t+    \"ORCHARD\",\n684\t+    \"VINEYARD\",\n685\t+    \"SEEDLING\",\n686\t+    \"HARVEST\",\n687\t+]\n688\t+\n689\t+DIFFICULTY_CONFIG = {\n690\t+    \"easy\": {\"water\": 8, \"min_length\": 4, \"max_length\": 6},\n691\t+    \"normal\": {\"water\": 6, \"min_length\": 5, \"max_length\": 8},\n692\t+    \"hard\": {\"water\": 4, \"min_length\": 7, \"max_length\": float(\"inf\")},\n693\t+}\n694\t+\n695\t+\n696\t+def select_word(difficulty=\"normal\", rng=None):\n697\t+    \"\"\"Select a random word filtered by difficulty settings.\n698\t+\n699\t+    Args:\n700\t+        difficulty: \"easy\", \"normal\", or \"hard\"\n701\t+        rng: optional random.Random instance for deterministic tests\n702\t+\n703\t+    Returns:\n704\t+        An uppercase word from WORDS matching the difficulty filter\n705\t+\n706\t+    Raises:\n707\t+        ValueError: if difficulty is unknown\n708\t+    \"\"\"\n709\t+    if difficulty not in DIFFICULTY_CONFIG:\n710\t+        raise ValueError(f\"Unknown difficulty: {difficulty}\")\n711\t+\n712\t+    if rng is None:\n713\t+        rng = random\n714\t+\n715\t+    config = DIFFICULTY_CONFIG[difficulty]\n716\t+    min_len = config[\"min_length\"]\n717\t+    max_len = config[\"max_length\"]\n718\t+\n719\t+    filtered = [w for w in WORDS if min_len <= len(w) <= max_len]\n720\t+\n721\t+    if not filtered:\n722\t+        raise ValueError(f\"No words available for difficulty: {difficulty}\")\n723\t+\n724\t+    return rng.choice(filtered)\n725\t+\n726\t+\n727\t+def water_for(difficulty=\"normal\"):\n728\t+    \"\"\"Return the starting water level for a difficulty.\n729\t+\n730\t+    Args:\n731\t+        difficulty: \"easy\", \"normal\", or \"hard\"\n732\t+\n733\t+    Returns:\n734\t+        Starting water amount\n735\t+\n736\t+    Raises:\n737\t+        ValueError: if difficulty is unknown\n738\t+    \"\"\"\n739\t+    if difficulty not in DIFFICULTY_CONFIG:\n740\t+        raise ValueError(f\"Unknown difficulty: {difficulty}\")\n741\t+\n742\t+    return DIFFICULTY_CONFIG[difficulty][\"water\"]\n743\t"}]},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"2aac2c15-9464-4b2c-a8ec-cd262e4eb0f8","timestamp":"2026-06-12T03:34:40.394Z","tool_use_result":{"type":"text","file":{"filePath":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/A.diff","content":"diff --git a/tests/__init__.py b/tests/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/tests/test_game.py b/tests/test_game.py\nnew file mode 100644\nindex 0000000..ca6a9a6\n--- /dev/null\n+++ b/tests/test_game.py\n@@ -0,0 +1,395 @@\n+import random\n+import unittest\n+from word_garden import game, words\n+\n+\n+class TestGameState(unittest.TestCase):\n+    def test_new_game_creates_state(self):\n+        \"\"\"new_game creates a GameState with correct initial values.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"normal\", rng=rng)\n+\n+        self.assertIsNotNone(state.secret_word)\n+        self.assertEqual(state.secret_word, state.secret_word.upper())\n+        self.assertEqual(state.guessed_letters, set())\n+        self.assertEqual(state.remaining_water, 6)\n+        self.assertEqual(state.max_water, 6)\n+        self.assertEqual(state.weed_count, 0)\n+        self.assertEqual(state.status_message, \"\")\n+        self.assertFalse(state.game_over)\n+        self.assertFalse(state.won)\n+\n+    def test_new_game_easy_has_correct_water(self):\n+        \"\"\"new_game with easy difficulty starts with 8 water.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"easy\", rng=rng)\n+        self.assertEqual(state.remaining_water, 8)\n+        self.assertEqual(state.max_water, 8)\n+\n+    def test_new_game_hard_has_correct_water(self):\n+        \"\"\"new_game with hard difficulty starts with 4 water.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"hard\", rng=rng)\n+        self.assertEqual(state.remaining_water, 4)\n+        self.assertEqual(state.max_water, 4)\n+\n+    def test_new_game_deterministic_with_seeded_rng(self):\n+        \"\"\"new_game is deterministic with seeded random.Random.\"\"\"\n+        rng1 = random.Random(999)\n+        rng2 = random.Random(999)\n+        state1 = game.new_game(difficulty=\"normal\", rng=rng1)\n+        state2 = game.new_game(difficulty=\"normal\", rng=rng2)\n+        self.assertEqual(state1.secret_word, state2.secret_word)\n+\n+\n+class TestValidateGuess(unittest.TestCase):\n+    def test_valid_single_letter_lowercase(self):\n+        \"\"\"SPEC 16.6: validate_guess accepts lowercase and normalizes.\"\"\"\n+        letter, msg = game.validate_guess(\"a\")\n+        self.assertEqual(letter, \"A\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_valid_single_letter_uppercase(self):\n+        \"\"\"validate_guess accepts uppercase letters.\"\"\"\n+        letter, msg = game.validate_guess(\"Z\")\n+        self.assertEqual(letter, \"Z\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_valid_with_leading_trailing_space(self):\n+        \"\"\"SPEC 16.6: validate_guess trims whitespace.\"\"\"\n+        letter, msg = game.validate_guess(\"  a  \")\n+        self.assertEqual(letter, \"A\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_invalid_empty_input(self):\n+        \"\"\"SPEC 16.6: validate_guess rejects empty input.\"\"\"\n+        letter, msg = game.validate_guess(\"\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, \"Please enter a single letter.\")\n+\n+    def test_invalid_multiple_characters(self):\n+        \"\"\"SPEC 16.6: validate_guess rejects multiple characters.\"\"\"\n+        letter, msg = game.validate_guess(\"apple\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, \"Please enter a single letter.\")\n+\n+    def test_invalid_number(self):\n+        \"\"\"SPEC 16.6: validate_guess rejects numbers.\"\"\"\n+        letter, msg = game.validate_guess(\"7\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, \"That is not a letter.\")\n+\n+    def test_invalid_symbol(self):\n+        \"\"\"SPEC 16.6: validate_guess rejects symbols.\"\"\"\n+        letter, msg = game.validate_guess(\"!\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, \"That is not a letter.\")\n+\n+    def test_invalid_whitespace_only(self):\n+        \"\"\"validate_guess rejects whitespace-only input.\"\"\"\n+        letter, msg = game.validate_guess(\"   \")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, \"Please enter a single letter.\")\n+\n+\n+class TestDisplayWord(unittest.TestCase):\n+    def test_display_word_no_guesses(self):\n+        \"\"\"SPEC 16.9: display_word masks all letters initially.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters=set(),\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+        self.assertEqual(game.display_word(state), \"_ _ _ _ _ _\")\n+\n+    def test_display_word_partial_guesses(self):\n+        \"\"\"display_word reveals only guessed letters.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"E\"},\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+        self.assertEqual(game.display_word(state), \"G A _ _ E _\")\n+\n+    def test_display_word_all_guesses(self):\n+        \"\"\"display_word reveals the entire word when all letters guessed.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+        self.assertEqual(game.display_word(state), \"G A R D E N\")\n+\n+    def test_display_word_space_separated(self):\n+        \"\"\"display_word output is space-separated.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"CAT\",\n+            guessed_letters={\"C\"},\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+        displayed = game.display_word(state)\n+        self.assertEqual(displayed, \"C _ _\")\n+        self.assertEqual(displayed.count(\" \"), 2)\n+\n+\n+class TestIsWon(unittest.TestCase):\n+    def test_is_won_false_when_not_all_guessed(self):\n+        \"\"\"is_won returns False when not all letters are guessed.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\"},\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+        self.assertFalse(game.is_won(state))\n+\n+    def test_is_won_true_when_all_guessed(self):\n+        \"\"\"SPEC 16.7: is_won returns True when all letters are guessed.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+        self.assertTrue(game.is_won(state))\n+\n+    def test_is_won_with_extra_guesses(self):\n+        \"\"\"is_won ignores extra guessed letters not in the word.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\", \"X\", \"Y\", \"Z\"},\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+        self.assertTrue(game.is_won(state))\n+\n+\n+class TestIsLost(unittest.TestCase):\n+    def test_is_lost_false_when_water_remains(self):\n+        \"\"\"is_lost returns False when water is above 0.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"X\", \"Y\", \"Z\"},\n+            remaining_water=1,\n+            max_water=6,\n+            weed_count=3,\n+        )\n+        self.assertFalse(game.is_lost(state))\n+\n+    def test_is_lost_true_when_water_at_zero(self):\n+        \"\"\"SPEC 16.8: is_lost returns True when water reaches 0.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"X\", \"Y\", \"Z\"},\n+            remaining_water=0,\n+            max_water=6,\n+            weed_count=3,\n+        )\n+        self.assertTrue(game.is_lost(state))\n+\n+    def test_is_lost_false_when_won(self):\n+        \"\"\"is_lost returns False even if water is 0 when game is won.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+            remaining_water=0,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+        self.assertFalse(game.is_lost(state))\n+\n+\n+class TestApplyGuess(unittest.TestCase):\n+    def test_correct_guess_reveals_letter(self):\n+        \"\"\"SPEC 16.1: A correct guess reveals matching letters.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"normal\", rng=rng)\n+        initial_word = state.secret_word\n+\n+        state = game.apply_guess(state, initial_word[0])\n+\n+        self.assertIn(initial_word[0], state.guessed_letters)\n+        self.assertEqual(\n+            state.status_message, \"Good guess! The garden grows.\"\n+        )\n+        self.assertEqual(state.remaining_water, state.max_water)\n+        self.assertEqual(state.weed_count, 0)\n+\n+    def test_incorrect_guess_reduces_water(self):\n+        \"\"\"SPEC 16.2: An incorrect guess reduces water by one.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"normal\", rng=rng)\n+        initial_water = state.remaining_water\n+\n+        state = game.apply_guess(state, \"X\")\n+\n+        self.assertEqual(state.remaining_water, initial_water - 1)\n+        self.assertEqual(state.status_message, \"No match. A weed appears.\")\n+\n+    def test_incorrect_guess_increases_weeds(self):\n+        \"\"\"SPEC 16.3: An incorrect guess increases weed count by one.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"normal\", rng=rng)\n+        initial_weeds = state.weed_count\n+\n+        state = game.apply_guess(state, \"X\")\n+\n+        self.assertEqual(state.weed_count, initial_weeds + 1)\n+\n+    def test_incorrect_guess_records_letter(self):\n+        \"\"\"An incorrect guess still records the guessed letter.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"normal\", rng=rng)\n+\n+        state = game.apply_guess(state, \"X\")\n+\n+        self.assertIn(\"X\", state.guessed_letters)\n+\n+    def test_repeated_guess_no_water_change(self):\n+        \"\"\"SPEC 16.4: Repeated guesses do not reduce water.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"normal\", rng=rng)\n+\n+        state = game.apply_guess(state, \"X\")\n+        initial_water = state.remaining_water\n+        state = game.apply_guess(state, \"X\")\n+\n+        self.assertEqual(state.remaining_water, initial_water)\n+\n+    def test_repeated_guess_no_weed_change(self):\n+        \"\"\"Repeated guesses do not increase weed count.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"normal\", rng=rng)\n+\n+        state = game.apply_guess(state, \"X\")\n+        initial_weeds = state.weed_count\n+        state = game.apply_guess(state, \"X\")\n+\n+        self.assertEqual(state.weed_count, initial_weeds)\n+\n+    def test_repeated_guess_produces_message(self):\n+        \"\"\"Repeated guesses produce an appropriate message.\"\"\"\n+        rng = random.Random(42)\n+        state = game.new_game(difficulty=\"normal\", rng=rng)\n+\n+        state = game.apply_guess(state, \"X\")\n+        state = game.apply_guess(state, \"X\")\n+\n+        self.assertIn(\"already guessed\", state.status_message.lower())\n+\n+    def test_guess_after_game_over_no_op(self):\n+        \"\"\"Guessing after game_over is set produces a message.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters=set(),\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+            game_over=True,\n+            won=False,\n+        )\n+\n+        new_state = game.apply_guess(state, \"A\")\n+\n+        self.assertEqual(new_state.guessed_letters, state.guessed_letters)\n+        self.assertEqual(new_state.remaining_water, state.remaining_water)\n+        self.assertTrue(new_state.game_over)\n+        self.assertIn(\"game is over\", new_state.status_message.lower())\n+\n+    def test_win_detected_on_final_letter(self):\n+        \"\"\"SPEC 16.7: The game detects a win when final letter is guessed.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\"},\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+\n+        state = game.apply_guess(state, \"N\")\n+\n+        self.assertTrue(state.won)\n+        self.assertTrue(state.game_over)\n+\n+    def test_loss_detected_on_water_zero(self):\n+        \"\"\"SPEC 16.8: The game detects a loss when water reaches 0.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"X\", \"Y\", \"Z\"},\n+            remaining_water=1,\n+            max_water=6,\n+            weed_count=3,\n+        )\n+\n+        state = game.apply_guess(state, \"Q\")\n+\n+        self.assertTrue(state.game_over)\n+        self.assertFalse(state.won)\n+\n+    def test_apply_guess_does_not_mutate_original_state(self):\n+        \"\"\"apply_guess returns a new state, not mutating the original.\"\"\"\n+        rng = random.Random(42)\n+        original_state = game.new_game(difficulty=\"normal\", rng=rng)\n+        original_guessed = original_state.guessed_letters.copy()\n+        original_water = original_state.remaining_water\n+\n+        new_state = game.apply_guess(original_state, \"X\")\n+\n+        self.assertEqual(original_state.guessed_letters, original_guessed)\n+        self.assertEqual(original_state.remaining_water, original_water)\n+        self.assertNotEqual(new_state.guessed_letters, original_guessed)\n+\n+    def test_multiple_correct_guesses_reveal_multiple_positions(self):\n+        \"\"\"Correct guesses for letters appearing multiple times work correctly.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"BANANA\",\n+            guessed_letters=set(),\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+\n+        state = game.apply_guess(state, \"A\")\n+\n+        self.assertIn(\"A\", state.guessed_letters)\n+        self.assertEqual(game.display_word(state), \"_ A _ A _ A\")\n+\n+    def test_game_flow_correct_then_incorrect(self):\n+        \"\"\"A sequence of correct then incorrect guesses is handled correctly.\"\"\"\n+        state = game.GameState(\n+            secret_word=\"GARDEN\",\n+            guessed_letters=set(),\n+            remaining_water=6,\n+            max_water=6,\n+            weed_count=0,\n+        )\n+\n+        state = game.apply_guess(state, \"G\")\n+        self.assertEqual(state.remaining_water, 6)\n+        self.assertEqual(state.weed_count, 0)\n+        self.assertFalse(state.game_over)\n+\n+        state = game.apply_guess(state, \"X\")\n+        self.assertEqual(state.remaining_water, 5)\n+        self.assertEqual(state.weed_count, 1)\n+        self.assertFalse(state.game_over)\n+\n+        state = game.apply_guess(state, \"A\")\n+        self.assertEqual(state.remaining_water, 5)\n+        self.assertEqual(state.weed_count, 1)\n+        self.assertFalse(state.game_over)\n+\n+\n+if __name__ == \"__main__\":\n+    unittest.main()\ndiff --git a/tests/test_words.py b/tests/test_words.py\nnew file mode 100644\nindex 0000000..dbc1b35\n--- /dev/null\n+++ b/tests/test_words.py\n@@ -0,0 +1,70 @@\n+import random\n+import unittest\n+from word_garden import words\n+\n+\n+class TestWords(unittest.TestCase):\n+    def test_words_list_exists(self):\n+        \"\"\"SPEC 16.10: Word list is available.\"\"\"\n+        self.assertIsNotNone(words.WORDS)\n+        self.assertEqual(len(words.WORDS), 10)\n+\n+    def test_words_are_uppercase(self):\n+        \"\"\"All words in WORDS are uppercase.\"\"\"\n+        for word in words.WORDS:\n+            self.assertEqual(word, word.upper())\n+\n+    def test_select_word_easy_returns_valid_word(self):\n+        \"\"\"SPEC 16.10: select_word returns a word matching easy difficulty.\"\"\"\n+        rng = random.Random(42)\n+        word = words.select_word(difficulty=\"easy\", rng=rng)\n+        self.assertIn(word, words.WORDS)\n+        self.assertTrue(4 <= len(word) <= 6)\n+\n+    def test_select_word_normal_returns_valid_word(self):\n+        \"\"\"SPEC 16.10: select_word returns a word matching normal difficulty.\"\"\"\n+        rng = random.Random(42)\n+        word = words.select_word(difficulty=\"normal\", rng=rng)\n+        self.assertIn(word, words.WORDS)\n+        self.assertTrue(5 <= len(word) <= 8)\n+\n+    def test_select_word_hard_returns_valid_word(self):\n+        \"\"\"SPEC 16.10: select_word returns a word matching hard difficulty.\"\"\"\n+        rng = random.Random(42)\n+        word = words.select_word(difficulty=\"hard\", rng=rng)\n+        self.assertIn(word, words.WORDS)\n+        self.assertTrue(len(word) >= 7)\n+\n+    def test_select_word_deterministic_with_seeded_rng(self):\n+        \"\"\"select_word is deterministic when given a seeded random.Random.\"\"\"\n+        rng1 = random.Random(123)\n+        rng2 = random.Random(123)\n+        word1 = words.select_word(difficulty=\"normal\", rng=rng1)\n+        word2 = words.select_word(difficulty=\"normal\", rng=rng2)\n+        self.assertEqual(word1, word2)\n+\n+    def test_select_word_invalid_difficulty_raises_error(self):\n+        \"\"\"select_word raises ValueError for unknown difficulty.\"\"\"\n+        with self.assertRaises(ValueError):\n+            words.select_word(difficulty=\"impossible\")\n+\n+    def test_water_for_easy(self):\n+        \"\"\"water_for returns correct water level for easy.\"\"\"\n+        self.assertEqual(words.water_for(\"easy\"), 8)\n+\n+    def test_water_for_normal(self):\n+        \"\"\"water_for returns correct water level for normal.\"\"\"\n+        self.assertEqual(words.water_for(\"normal\"), 6)\n+\n+    def test_water_for_hard(self):\n+        \"\"\"water_for returns correct water level for hard.\"\"\"\n+        self.assertEqual(words.water_for(\"hard\"), 4)\n+\n+    def test_water_for_invalid_difficulty_raises_error(self):\n+        \"\"\"water_for raises ValueError for unknown difficulty.\"\"\"\n+        with self.assertRaises(ValueError):\n+            words.water_for(\"impossible\")\n+\n+\n+if __name__ == \"__main__\":\n+    unittest.main()\ndiff --git a/word_garden/__init__.py b/word_garden/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/word_garden/game.py b/word_garden/game.py\nnew file mode 100644\nindex 0000000..8a8c6db\n--- /dev/null\n+++ b/word_garden/game.py\n@@ -0,0 +1,178 @@\n+from dataclasses import dataclass, field\n+from word_garden import words\n+\n+\n+@dataclass\n+class GameState:\n+    secret_word: str\n+    guessed_letters: set[str] = field(default_factory=set)\n+    remaining_water: int = 0\n+    weed_count: int = 0\n+    max_water: int = 0\n+    status_message: str = \"\"\n+    game_over: bool = False\n+    won: bool = False\n+\n+\n+def new_game(difficulty=\"normal\", rng=None):\n+    \"\"\"Create a new game with a random word.\n+\n+    Args:\n+        difficulty: \"easy\", \"normal\", or \"hard\"\n+        rng: optional random.Random instance for deterministic tests\n+\n+    Returns:\n+        A new GameState ready for play\n+    \"\"\"\n+    word = words.select_word(difficulty=difficulty, rng=rng)\n+    max_water = words.water_for(difficulty=difficulty)\n+\n+    return GameState(\n+        secret_word=word,\n+        guessed_letters=set(),\n+        remaining_water=max_water,\n+        weed_count=0,\n+        max_water=max_water,\n+        status_message=\"\",\n+        game_over=False,\n+        won=False,\n+    )\n+\n+\n+def validate_guess(input_text):\n+    \"\"\"Validate user input and extract a letter.\n+\n+    Args:\n+        input_text: raw user input string\n+\n+    Returns:\n+        tuple: (letter, message) where letter is None if invalid,\n+               or (letter, \"\") if valid\n+    \"\"\"\n+    trimmed = input_text.strip().upper()\n+\n+    if not trimmed:\n+        return (None, \"Please enter a single letter.\")\n+\n+    if len(trimmed) > 1:\n+        return (None, \"Please enter a single letter.\")\n+\n+    if not trimmed.isalpha():\n+        return (None, \"That is not a letter.\")\n+\n+    return (trimmed, \"\")\n+\n+\n+def display_word(state):\n+    \"\"\"Display the secret word with guessed letters revealed.\n+\n+    Args:\n+        state: GameState\n+\n+    Returns:\n+        String with letters revealed and blanks for unguessed letters,\n+        space-separated (e.g., \"G _ R _ E _\")\n+    \"\"\"\n+    return \" \".join(\n+        letter if letter in state.guessed_letters else \"_\"\n+        for letter in state.secret_word\n+    )\n+\n+\n+def is_won(state):\n+    \"\"\"Check if the player has won.\n+\n+    Args:\n+        state: GameState\n+\n+    Returns:\n+        True if all letters in secret_word are in guessed_letters\n+    \"\"\"\n+    return all(letter in state.guessed_letters for letter in state.secret_word)\n+\n+\n+def is_lost(state):\n+    \"\"\"Check if the player has lost.\n+\n+    Args:\n+        state: GameState\n+\n+    Returns:\n+        True if water has reached 0 before winning\n+    \"\"\"\n+    return state.remaining_water <= 0 and not is_won(state)\n+\n+\n+def apply_guess(state, letter):\n+    \"\"\"Apply a validated letter guess to the game state.\n+\n+    Args:\n+        state: GameState\n+        letter: uppercase single letter\n+\n+    Returns:\n+        Updated GameState with the guess applied\n+    \"\"\"\n+    if state.game_over:\n+        return GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=state.guessed_letters.copy(),\n+            remaining_water=state.remaining_water,\n+            weed_count=state.weed_count,\n+            max_water=state.max_water,\n+            status_message=\"The game is over. Start a new game.\",\n+            game_over=state.game_over,\n+            won=state.won,\n+        )\n+\n+    if letter in state.guessed_letters:\n+        return GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=state.guessed_letters.copy(),\n+            remaining_water=state.remaining_water,\n+            weed_count=state.weed_count,\n+            max_water=state.max_water,\n+            status_message=f\"You already guessed {letter}. Try another letter.\",\n+            game_over=state.game_over,\n+            won=state.won,\n+        )\n+\n+    new_guessed = state.guessed_letters | {letter}\n+\n+    if letter in state.secret_word:\n+        new_state = GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=new_guessed,\n+            remaining_water=state.remaining_water,\n+            weed_count=state.weed_count,\n+            max_water=state.max_water,\n+            status_message=\"Good guess! The garden grows.\",\n+            game_over=False,\n+            won=False,\n+        )\n+\n+        if is_won(new_state):\n+            new_state.won = True\n+            new_state.game_over = True\n+\n+        return new_state\n+\n+    else:\n+        new_water = state.remaining_water - 1\n+        new_weeds = state.weed_count + 1\n+\n+        new_state = GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=new_guessed,\n+            remaining_water=new_water,\n+            weed_count=new_weeds,\n+            max_water=state.max_water,\n+            status_message=\"No match. A weed appears.\",\n+            game_over=False,\n+            won=False,\n+        )\n+\n+        if is_lost(new_state):\n+            new_state.game_over = True\n+\n+        return new_state\ndiff --git a/word_garden/words.py b/word_garden/words.py\nnew file mode 100644\nindex 0000000..1543582\n--- /dev/null\n+++ b/word_garden/words.py\n@@ -0,0 +1,69 @@\n+import random\n+\n+WORDS = [\n+    \"GARDEN\",\n+    \"FLOWER\",\n+    \"PLANET\",\n+    \"PYTHON\",\n+    \"TERMINAL\",\n+    \"MEADOW\",\n+    \"ORCHARD\",\n+    \"VINEYARD\",\n+    \"SEEDLING\",\n+    \"HARVEST\",\n+]\n+\n+DIFFICULTY_CONFIG = {\n+    \"easy\": {\"water\": 8, \"min_length\": 4, \"max_length\": 6},\n+    \"normal\": {\"water\": 6, \"min_length\": 5, \"max_length\": 8},\n+    \"hard\": {\"water\": 4, \"min_length\": 7, \"max_length\": float(\"inf\")},\n+}\n+\n+\n+def select_word(difficulty=\"normal\", rng=None):\n+    \"\"\"Select a random word filtered by difficulty settings.\n+\n+    Args:\n+        difficulty: \"easy\", \"normal\", or \"hard\"\n+        rng: optional random.Random instance for deterministic tests\n+\n+    Returns:\n+        An uppercase word from WORDS matching the difficulty filter\n+\n+    Raises:\n+        ValueError: if difficulty is unknown\n+    \"\"\"\n+    if difficulty not in DIFFICULTY_CONFIG:\n+        raise ValueError(f\"Unknown difficulty: {difficulty}\")\n+\n+    if rng is None:\n+        rng = random\n+\n+    config = DIFFICULTY_CONFIG[difficulty]\n+    min_len = config[\"min_length\"]\n+    max_len = config[\"max_length\"]\n+\n+    filtered = [w for w in WORDS if min_len <= len(w) <= max_len]\n+\n+    if not filtered:\n+        raise ValueError(f\"No words available for difficulty: {difficulty}\")\n+\n+    return rng.choice(filtered)\n+\n+\n+def water_for(difficulty=\"normal\"):\n+    \"\"\"Return the starting water level for a difficulty.\n+\n+    Args:\n+        difficulty: \"easy\", \"normal\", or \"hard\"\n+\n+    Returns:\n+        Starting water amount\n+\n+    Raises:\n+        ValueError: if difficulty is unknown\n+    \"\"\"\n+    if difficulty not in DIFFICULTY_CONFIG:\n+        raise ValueError(f\"Unknown difficulty: {difficulty}\")\n+\n+    return DIFFICULTY_CONFIG[difficulty][\"water\"]\n","numLines":743,"startLine":1,"totalLines":743}}},{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_018NiA6ZVosayeehLobnDQ6s","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FDf8P3BoBJZL7qgrKvW46N","name":"Read","input":{"file_path":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/B.diff"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2237,"cache_creation_input_tokens":4020,"cache_read_input_tokens":31096,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4020},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"93c09421-768a-4497-85fa-2fedb261b7c2","request_id":"req_011CbxfTgtxBQqWbSEqzGVnm"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FDf8P3BoBJZL7qgrKvW46N","type":"tool_result","content":"1\tdiff --git a/tests/__init__.py b/tests/__init__.py\n2\tnew file mode 100644\n3\tindex 0000000..e69de29\n4\tdiff --git a/tests/test_game.py b/tests/test_game.py\n5\tnew file mode 100644\n6\tindex 0000000..6d8ef7b\n7\t--- /dev/null\n8\t+++ b/tests/test_game.py\n9\t@@ -0,0 +1,319 @@\n10\t+import random\n11\t+import unittest\n12\t+\n13\t+from word_garden.game import (\n14\t+    GameState,\n15\t+    apply_guess,\n16\t+    display_word,\n17\t+    is_lost,\n18\t+    is_won,\n19\t+    new_game,\n20\t+    validate_guess,\n21\t+    MSG_ALREADY_GUESSED,\n22\t+    MSG_CORRECT,\n23\t+    MSG_GAME_OVER,\n24\t+    MSG_INVALID_NOT_ALPHA,\n25\t+    MSG_INVALID_SINGLE,\n26\t+    MSG_LOSS,\n27\t+    MSG_WIN,\n28\t+    MSG_WRONG,\n29\t+)\n30\t+\n31\t+\n32\t+def _state(**kwargs) -> GameState:\n33\t+    defaults = dict(\n34\t+        secret_word=\"GARDEN\",\n35\t+        guessed_letters=set(),\n36\t+        remaining_water=6,\n37\t+        weed_count=0,\n38\t+        max_water=6,\n39\t+    )\n40\t+    defaults.update(kwargs)\n41\t+    return GameState(**defaults)\n42\t+\n43\t+\n44\t+class TestCorrectGuess(unittest.TestCase):\n45\t+    \"\"\"SPEC section 16 case 1: a correct guess reveals matching letters.\"\"\"\n46\t+\n47\t+    def test_correct_guess_adds_letter_and_sets_message(self):\n48\t+        state = _state(secret_word=\"GARDEN\", guessed_letters=set(), remaining_water=6, weed_count=0)\n49\t+        result = apply_guess(state, \"A\")\n50\t+        self.assertIn(\"A\", result.guessed_letters)\n51\t+        self.assertEqual(result.remaining_water, 6)\n52\t+        self.assertEqual(result.weed_count, 0)\n53\t+        self.assertEqual(result.status_message, MSG_CORRECT)\n54\t+        self.assertFalse(result.game_over)\n55\t+        self.assertFalse(result.won)\n56\t+\n57\t+    def test_correct_guess_reveals_all_occurrences_in_display(self):\n58\t+        # SPEC section 16 case 9: display_word masks unguessed letters.\n59\t+        state = _state(secret_word=\"SEEDLING\", guessed_letters={\"E\"})\n60\t+        self.assertEqual(display_word(state), \"_ E E _ _ _ _ _\")\n61\t+\n62\t+    def test_correct_guess_does_not_change_water_or_weeds(self):\n63\t+        state = _state(secret_word=\"PYTHON\", remaining_water=4, weed_count=2)\n64\t+        result = apply_guess(state, \"Y\")\n65\t+        self.assertEqual(result.remaining_water, 4)\n66\t+        self.assertEqual(result.weed_count, 2)\n67\t+\n68\t+\n69\t+class TestIncorrectGuess(unittest.TestCase):\n70\t+    \"\"\"SPEC section 16 cases 2 & 3: incorrect guess reduces water and increases weeds.\"\"\"\n71\t+\n72\t+    def test_wrong_guess_water_minus_one_weeds_plus_one_letter_recorded(self):\n73\t+        state = _state(secret_word=\"GARDEN\", remaining_water=6, weed_count=0, guessed_letters=set())\n74\t+        result = apply_guess(state, \"Z\")\n75\t+        self.assertEqual(result.remaining_water, 5)\n76\t+        self.assertEqual(result.weed_count, 1)\n77\t+        self.assertIn(\"Z\", result.guessed_letters)\n78\t+        self.assertEqual(result.status_message, MSG_WRONG)\n79\t+        self.assertFalse(result.game_over)\n80\t+        self.assertFalse(result.won)\n81\t+\n82\t+    def test_wrong_guess_accumulates_correctly(self):\n83\t+        state = _state(secret_word=\"GARDEN\", remaining_water=3, weed_count=3, guessed_letters={\"Z\"})\n84\t+        result = apply_guess(state, \"Q\")\n85\t+        self.assertEqual(result.remaining_water, 2)\n86\t+        self.assertEqual(result.weed_count, 4)\n87\t+        self.assertIn(\"Q\", result.guessed_letters)\n88\t+\n89\t+\n90\t+class TestRepeatedGuess(unittest.TestCase):\n91\t+    \"\"\"SPEC section 16 case 4: repeated guesses do not reduce water.\"\"\"\n92\t+\n93\t+    def test_repeated_guess_no_water_or_weed_change(self):\n94\t+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"A\"}, remaining_water=6, weed_count=0)\n95\t+        result = apply_guess(state, \"A\")\n96\t+        self.assertEqual(result.remaining_water, 6)\n97\t+        self.assertEqual(result.weed_count, 0)\n98\t+        self.assertEqual(result.guessed_letters, {\"A\"})\n99\t+        self.assertEqual(result.status_message, MSG_ALREADY_GUESSED.format(letter=\"A\"))\n100\t+        self.assertFalse(result.game_over)\n101\t+        self.assertFalse(result.won)\n102\t+\n103\t+    def test_repeated_wrong_guess_no_water_or_weed_change(self):\n104\t+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"Z\"}, remaining_water=5, weed_count=1)\n105\t+        result = apply_guess(state, \"Z\")\n106\t+        self.assertEqual(result.remaining_water, 5)\n107\t+        self.assertEqual(result.weed_count, 1)\n108\t+        self.assertEqual(result.status_message, MSG_ALREADY_GUESSED.format(letter=\"Z\"))\n109\t+\n110\t+\n111\t+class TestValidateGuess(unittest.TestCase):\n112\t+    \"\"\"SPEC section 16 cases 5 & 6: invalid input is rejected; lowercase is normalised.\"\"\"\n113\t+\n114\t+    def test_empty_string_rejected(self):\n115\t+        letter, msg = validate_guess(\"\")\n116\t+        self.assertIsNone(letter)\n117\t+        self.assertEqual(msg, MSG_INVALID_SINGLE)\n118\t+\n119\t+    def test_whitespace_only_rejected(self):\n120\t+        letter, msg = validate_guess(\"   \")\n121\t+        self.assertIsNone(letter)\n122\t+        self.assertEqual(msg, MSG_INVALID_SINGLE)\n123\t+\n124\t+    def test_multiple_characters_rejected(self):\n125\t+        letter, msg = validate_guess(\"apple\")\n126\t+        self.assertIsNone(letter)\n127\t+        self.assertEqual(msg, MSG_INVALID_SINGLE)\n128\t+\n129\t+    def test_digit_rejected(self):\n130\t+        letter, msg = validate_guess(\"7\")\n131\t+        self.assertIsNone(letter)\n132\t+        self.assertEqual(msg, MSG_INVALID_NOT_ALPHA)\n133\t+\n134\t+    def test_symbol_rejected(self):\n135\t+        letter, msg = validate_guess(\"!\")\n136\t+        self.assertIsNone(letter)\n137\t+        self.assertEqual(msg, MSG_INVALID_NOT_ALPHA)\n138\t+\n139\t+    def test_none_rejected(self):\n140\t+        letter, msg = validate_guess(None)\n141\t+        self.assertIsNone(letter)\n142\t+        self.assertNotEqual(msg, \"\")\n143\t+\n144\t+    def test_integer_rejected(self):\n145\t+        letter, msg = validate_guess(42)\n146\t+        self.assertIsNone(letter)\n147\t+        self.assertNotEqual(msg, \"\")\n148\t+\n149\t+    def test_lowercase_normalised_to_uppercase(self):\n150\t+        # SPEC section 16 case 6\n151\t+        letter, msg = validate_guess(\"a\")\n152\t+        self.assertEqual(letter, \"A\")\n153\t+        self.assertEqual(msg, \"\")\n154\t+\n155\t+    def test_uppercase_accepted(self):\n156\t+        letter, msg = validate_guess(\"Z\")\n157\t+        self.assertEqual(letter, \"Z\")\n158\t+        self.assertEqual(msg, \"\")\n159\t+\n160\t+    def test_leading_trailing_spaces_stripped(self):\n161\t+        letter, msg = validate_guess(\"  b  \")\n162\t+        self.assertEqual(letter, \"B\")\n163\t+        self.assertEqual(msg, \"\")\n164\t+\n165\t+    def test_valid_returns_empty_message(self):\n166\t+        letter, msg = validate_guess(\"G\")\n167\t+        self.assertEqual(letter, \"G\")\n168\t+        self.assertEqual(msg, \"\")\n169\t+\n170\t+\n171\t+class TestWinDetection(unittest.TestCase):\n172\t+    \"\"\"SPEC section 16 case 7: the game detects a win.\"\"\"\n173\t+\n174\t+    def test_final_correct_letter_triggers_win(self):\n175\t+        # GARDEN: G A R D E N — guess N last.\n176\t+        state = _state(\n177\t+            secret_word=\"GARDEN\",\n178\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\"},\n179\t+            remaining_water=3,\n180\t+            weed_count=1,\n181\t+        )\n182\t+        result = apply_guess(state, \"N\")\n183\t+        self.assertTrue(result.won)\n184\t+        self.assertTrue(result.game_over)\n185\t+        self.assertIn(\"N\", result.guessed_letters)\n186\t+        self.assertEqual(result.remaining_water, 3)\n187\t+        self.assertEqual(result.weed_count, 1)\n188\t+        self.assertEqual(result.status_message, MSG_WIN)\n189\t+\n190\t+    def test_is_won_true_when_all_letters_guessed(self):\n191\t+        state = _state(\n192\t+            secret_word=\"GARDEN\",\n193\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n194\t+        )\n195\t+        self.assertTrue(is_won(state))\n196\t+\n197\t+    def test_is_won_false_when_letters_missing(self):\n198\t+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"G\", \"A\"})\n199\t+        self.assertFalse(is_won(state))\n200\t+\n201\t+    def test_non_final_correct_guess_does_not_set_won(self):\n202\t+        state = _state(secret_word=\"GARDEN\", guessed_letters=set(), remaining_water=6)\n203\t+        result = apply_guess(state, \"G\")\n204\t+        self.assertFalse(result.won)\n205\t+        self.assertFalse(result.game_over)\n206\t+\n207\t+\n208\t+class TestLossDetection(unittest.TestCase):\n209\t+    \"\"\"SPEC section 16 case 8: the game detects a loss.\"\"\"\n210\t+\n211\t+    def test_final_wrong_guess_triggers_loss(self):\n212\t+        state = _state(\n213\t+            secret_word=\"GARDEN\",\n214\t+            guessed_letters={\"Z\"},\n215\t+            remaining_water=1,\n216\t+            weed_count=5,\n217\t+        )\n218\t+        result = apply_guess(state, \"Q\")\n219\t+        self.assertTrue(result.game_over)\n220\t+        self.assertFalse(result.won)\n221\t+        self.assertEqual(result.remaining_water, 0)\n222\t+        self.assertEqual(result.weed_count, 6)\n223\t+        self.assertIn(\"Q\", result.guessed_letters)\n224\t+        self.assertEqual(result.status_message, MSG_LOSS)\n225\t+\n226\t+    def test_is_lost_true_when_water_zero_and_not_won(self):\n227\t+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"Z\"}, remaining_water=0)\n228\t+        self.assertTrue(is_lost(state))\n229\t+\n230\t+    def test_is_lost_false_when_water_remains(self):\n231\t+        state = _state(remaining_water=1)\n232\t+        self.assertFalse(is_lost(state))\n233\t+\n234\t+    def test_is_lost_false_when_won(self):\n235\t+        state = _state(\n236\t+            secret_word=\"GARDEN\",\n237\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n238\t+            remaining_water=0,\n239\t+        )\n240\t+        self.assertFalse(is_lost(state))\n241\t+\n242\t+\n243\t+class TestDisplayWord(unittest.TestCase):\n244\t+    \"\"\"SPEC section 16 case 9: displayed word masks unguessed letters.\"\"\"\n245\t+\n246\t+    def test_all_masked_at_start(self):\n247\t+        state = _state(secret_word=\"GARDEN\", guessed_letters=set())\n248\t+        self.assertEqual(display_word(state), \"_ _ _ _ _ _\")\n249\t+\n250\t+    def test_partial_reveal(self):\n251\t+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"G\", \"R\", \"E\"})\n252\t+        self.assertEqual(display_word(state), \"G _ R _ E _\")\n253\t+\n254\t+    def test_fully_revealed(self):\n255\t+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"})\n256\t+        self.assertEqual(display_word(state), \"G A R D E N\")\n257\t+\n258\t+    def test_repeated_letter_all_positions_revealed(self):\n259\t+        state = _state(secret_word=\"SEEDLING\", guessed_letters={\"S\", \"E\"})\n260\t+        self.assertEqual(display_word(state), \"S E E _ _ _ _ _\")\n261\t+\n262\t+\n263\t+class TestGuessAfterGameOver(unittest.TestCase):\n264\t+\n265\t+    def test_guess_after_win_is_noop(self):\n266\t+        state = _state(\n267\t+            secret_word=\"GARDEN\",\n268\t+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n269\t+            remaining_water=3,\n270\t+            weed_count=0,\n271\t+            game_over=True,\n272\t+            won=True,\n273\t+            status_message=MSG_WIN,\n274\t+        )\n275\t+        result = apply_guess(state, \"X\")\n276\t+        self.assertEqual(result.remaining_water, 3)\n277\t+        self.assertEqual(result.weed_count, 0)\n278\t+        self.assertTrue(result.game_over)\n279\t+        self.assertTrue(result.won)\n280\t+        self.assertEqual(result.status_message, MSG_GAME_OVER)\n281\t+\n282\t+    def test_guess_after_loss_is_noop(self):\n283\t+        state = _state(remaining_water=0, game_over=True, won=False)\n284\t+        result = apply_guess(state, \"A\")\n285\t+        self.assertEqual(result.remaining_water, 0)\n286\t+        self.assertTrue(result.game_over)\n287\t+        self.assertFalse(result.won)\n288\t+        self.assertEqual(result.status_message, MSG_GAME_OVER)\n289\t+\n290\t+\n291\t+class TestNewGame(unittest.TestCase):\n292\t+\n293\t+    def test_new_game_normal_has_correct_initial_state(self):\n294\t+        rng = random.Random(42)\n295\t+        state = new_game(difficulty=\"normal\", rng=rng)\n296\t+        self.assertIsInstance(state.secret_word, str)\n297\t+        self.assertGreater(len(state.secret_word), 0)\n298\t+        self.assertEqual(state.secret_word, state.secret_word.upper())\n299\t+        self.assertEqual(state.remaining_water, 6)\n300\t+        self.assertEqual(state.max_water, 6)\n301\t+        self.assertEqual(state.weed_count, 0)\n302\t+        self.assertEqual(len(state.guessed_letters), 0)\n303\t+        self.assertFalse(state.game_over)\n304\t+        self.assertFalse(state.won)\n305\t+\n306\t+    def test_new_game_easy_has_eight_water(self):\n307\t+        rng = random.Random(1)\n308\t+        state = new_game(difficulty=\"easy\", rng=rng)\n309\t+        self.assertEqual(state.remaining_water, 8)\n310\t+        self.assertEqual(state.max_water, 8)\n311\t+\n312\t+    def test_new_game_hard_has_four_water(self):\n313\t+        rng = random.Random(1)\n314\t+        state = new_game(difficulty=\"hard\", rng=rng)\n315\t+        self.assertEqual(state.remaining_water, 4)\n316\t+        self.assertEqual(state.max_water, 4)\n317\t+\n318\t+    def test_new_game_unknown_difficulty_raises(self):\n319\t+        with self.assertRaises(ValueError):\n320\t+            new_game(difficulty=\"extreme\")\n321\t+\n322\t+    def test_apply_guess_does_not_mutate_original_state(self):\n323\t+        state = _state(secret_word=\"GARDEN\", guessed_letters=set(), remaining_water=6)\n324\t+        original_guessed = set(state.guessed_letters)\n325\t+        original_water = state.remaining_water\n326\t+        apply_guess(state, \"Z\")\n327\t+        self.assertEqual(state.guessed_letters, original_guessed)\n328\t+        self.assertEqual(state.remaining_water, original_water)\n329\tdiff --git a/tests/test_words.py b/tests/test_words.py\n330\tnew file mode 100644\n331\tindex 0000000..f1a504c\n332\t--- /dev/null\n333\t+++ b/tests/test_words.py\n334\t@@ -0,0 +1,83 @@\n335\t+import random\n336\t+import unittest\n337\t+\n338\t+from word_garden.words import WORDS, select_word, water_for\n339\t+\n340\t+\n341\t+class TestWordList(unittest.TestCase):\n342\t+\n343\t+    def test_words_are_uppercase(self):\n344\t+        for word in WORDS:\n345\t+            self.assertEqual(word, word.upper(), f\"{word!r} is not uppercase\")\n346\t+\n347\t+    def test_words_are_non_empty_strings(self):\n348\t+        for word in WORDS:\n349\t+            self.assertIsInstance(word, str)\n350\t+            self.assertGreater(len(word), 0)\n351\t+\n352\t+\n353\t+class TestWaterFor(unittest.TestCase):\n354\t+\n355\t+    def test_easy_water(self):\n356\t+        self.assertEqual(water_for(\"easy\"), 8)\n357\t+\n358\t+    def test_normal_water(self):\n359\t+        self.assertEqual(water_for(\"normal\"), 6)\n360\t+\n361\t+    def test_hard_water(self):\n362\t+        self.assertEqual(water_for(\"hard\"), 4)\n363\t+\n364\t+    def test_unknown_difficulty_raises(self):\n365\t+        with self.assertRaises(ValueError):\n366\t+            water_for(\"extreme\")\n367\t+\n368\t+    def test_empty_difficulty_raises(self):\n369\t+        with self.assertRaises(ValueError):\n370\t+            water_for(\"\")\n371\t+\n372\t+\n373\t+class TestSelectWord(unittest.TestCase):\n374\t+\n375\t+    # SPEC section 16 case 10: word selector returns a valid word for every difficulty.\n376\t+\n377\t+    def test_easy_returns_word_in_length_range(self):\n378\t+        rng = random.Random(1)\n379\t+        word = select_word(\"easy\", rng=rng)\n380\t+        self.assertIn(word, WORDS)\n381\t+        self.assertGreaterEqual(len(word), 4)\n382\t+        self.assertLessEqual(len(word), 6)\n383\t+\n384\t+    def test_normal_returns_word_in_length_range(self):\n385\t+        rng = random.Random(2)\n386\t+        word = select_word(\"normal\", rng=rng)\n387\t+        self.assertIn(word, WORDS)\n388\t+        self.assertGreaterEqual(len(word), 5)\n389\t+        self.assertLessEqual(len(word), 8)\n390\t+\n391\t+    def test_hard_returns_word_in_length_range(self):\n392\t+        rng = random.Random(3)\n393\t+        word = select_word(\"hard\", rng=rng)\n394\t+        self.assertIn(word, WORDS)\n395\t+        self.assertGreaterEqual(len(word), 7)\n396\t+\n397\t+    def test_all_difficulties_return_uppercase_string(self):\n398\t+        for diff in (\"easy\", \"normal\", \"hard\"):\n399\t+            rng = random.Random(99)\n400\t+            word = select_word(diff, rng=rng)\n401\t+            self.assertIsInstance(word, str, f\"difficulty={diff!r}\")\n402\t+            self.assertEqual(word, word.upper(), f\"difficulty={diff!r}\")\n403\t+            self.assertGreater(len(word), 0, f\"difficulty={diff!r}\")\n404\t+\n405\t+    def test_unknown_difficulty_raises(self):\n406\t+        with self.assertRaises(ValueError):\n407\t+            select_word(\"extreme\")\n408\t+\n409\t+    def test_seeded_rng_is_deterministic(self):\n410\t+        word1 = select_word(\"normal\", rng=random.Random(42))\n411\t+        word2 = select_word(\"normal\", rng=random.Random(42))\n412\t+        self.assertEqual(word1, word2)\n413\t+\n414\t+    def test_none_rng_uses_module_random(self):\n415\t+        # Should not raise; returned word must be in the list.\n416\t+        word = select_word(\"normal\")\n417\t+        self.assertIn(word, WORDS)\n418\tdiff --git a/word_garden/__init__.py b/word_garden/__init__.py\n419\tnew file mode 100644\n420\tindex 0000000..e69de29\n421\tdiff --git a/word_garden/game.py b/word_garden/game.py\n422\tnew file mode 100644\n423\tindex 0000000..862b24a\n424\t--- /dev/null\n425\t+++ b/word_garden/game.py\n426\t@@ -0,0 +1,128 @@\n427\t+from __future__ import annotations\n428\t+\n429\t+import random\n430\t+from dataclasses import dataclass\n431\t+\n432\t+from . import words as _words\n433\t+\n434\t+# User-facing message constants — import these in tests instead of re-typing literals.\n435\t+MSG_CORRECT = \"Good guess! The garden grows.\"\n436\t+MSG_WRONG = \"No match. A weed appears.\"\n437\t+MSG_ALREADY_GUESSED = \"You already guessed {letter}. Try another letter.\"\n438\t+MSG_WIN = \"Bloom! You've revealed the whole word!\"\n439\t+MSG_LOSS = \"The garden ran out of water.\"\n440\t+MSG_GAME_OVER = \"The game is already over.\"\n441\t+\n442\t+MSG_INVALID_SINGLE = \"Please enter a single letter.\"\n443\t+MSG_INVALID_NOT_ALPHA = \"That is not a letter.\"\n444\t+\n445\t+\n446\t+@dataclass\n447\t+class GameState:\n448\t+    secret_word: str\n449\t+    guessed_letters: set[str]\n450\t+    remaining_water: int\n451\t+    weed_count: int\n452\t+    max_water: int\n453\t+    status_message: str = \"\"\n454\t+    game_over: bool = False\n455\t+    won: bool = False\n456\t+\n457\t+\n458\t+def new_game(difficulty: str = \"normal\", rng: random.Random | None = None) -> GameState:\n459\t+    word = _words.select_word(difficulty=difficulty, rng=rng)\n460\t+    water = _words.water_for(difficulty=difficulty)\n461\t+    return GameState(\n462\t+        secret_word=word.upper(),\n463\t+        guessed_letters=set(),\n464\t+        remaining_water=water,\n465\t+        weed_count=0,\n466\t+        max_water=water,\n467\t+    )\n468\t+\n469\t+\n470\t+def validate_guess(input_text: object) -> tuple[str | None, str]:\n471\t+    if not isinstance(input_text, str):\n472\t+        return (None, MSG_INVALID_SINGLE)\n473\t+    stripped = input_text.strip()\n474\t+    if not stripped:\n475\t+        return (None, MSG_INVALID_SINGLE)\n476\t+    if len(stripped) > 1:\n477\t+        return (None, MSG_INVALID_SINGLE)\n478\t+    if not stripped.isalpha():\n479\t+        return (None, MSG_INVALID_NOT_ALPHA)\n480\t+    return (stripped.upper(), \"\")\n481\t+\n482\t+\n483\t+def apply_guess(state: GameState, letter: str) -> GameState:\n484\t+    if state.game_over:\n485\t+        return _clone(state, status_message=MSG_GAME_OVER)\n486\t+\n487\t+    letter = letter.upper()\n488\t+\n489\t+    if letter in state.guessed_letters:\n490\t+        msg = MSG_ALREADY_GUESSED.format(letter=letter)\n491\t+        return _clone(state, status_message=msg)\n492\t+\n493\t+    new_guessed = set(state.guessed_letters) | {letter}\n494\t+\n495\t+    if letter in state.secret_word:\n496\t+        won = _all_revealed(state.secret_word, new_guessed)\n497\t+        return GameState(\n498\t+            secret_word=state.secret_word,\n499\t+            guessed_letters=new_guessed,\n500\t+            remaining_water=state.remaining_water,\n501\t+            weed_count=state.weed_count,\n502\t+            max_water=state.max_water,\n503\t+            status_message=MSG_WIN if won else MSG_CORRECT,\n504\t+            game_over=won,\n505\t+            won=won,\n506\t+        )\n507\t+\n508\t+    new_water = state.remaining_water - 1\n509\t+    new_weeds = state.weed_count + 1\n510\t+    lost = new_water <= 0\n511\t+    return GameState(\n512\t+        secret_word=state.secret_word,\n513\t+        guessed_letters=new_guessed,\n514\t+        remaining_water=max(new_water, 0),\n515\t+        weed_count=new_weeds,\n516\t+        max_water=state.max_water,\n517\t+        status_message=MSG_LOSS if lost else MSG_WRONG,\n518\t+        game_over=lost,\n519\t+        won=False,\n520\t+    )\n521\t+\n522\t+\n523\t+def display_word(state: GameState) -> str:\n524\t+    return \" \".join(\n525\t+        c if c in state.guessed_letters else \"_\"\n526\t+        for c in state.secret_word\n527\t+    )\n528\t+\n529\t+\n530\t+def is_won(state: GameState) -> bool:\n531\t+    return _all_revealed(state.secret_word, state.guessed_letters)\n532\t+\n533\t+\n534\t+def is_lost(state: GameState) -> bool:\n535\t+    return state.remaining_water <= 0 and not is_won(state)\n536\t+\n537\t+\n538\t+def _all_revealed(secret_word: str, guessed_letters: set[str]) -> bool:\n539\t+    return bool(secret_word) and all(c in guessed_letters for c in secret_word)\n540\t+\n541\t+\n542\t+def _clone(state: GameState, **overrides: object) -> GameState:\n543\t+    kwargs: dict[str, object] = dict(\n544\t+        secret_word=state.secret_word,\n545\t+        guessed_letters=set(state.guessed_letters),\n546\t+        remaining_water=state.remaining_water,\n547\t+        weed_count=state.weed_count,\n548\t+        max_water=state.max_water,\n549\t+        status_message=state.status_message,\n550\t+        game_over=state.game_over,\n551\t+        won=state.won,\n552\t+    )\n553\t+    kwargs.update(overrides)\n554\t+    return GameState(**kwargs)  # type: ignore[arg-type]\n555\tdiff --git a/word_garden/words.py b/word_garden/words.py\n556\tnew file mode 100644\n557\tindex 0000000..92671e7\n558\t--- /dev/null\n559\t+++ b/word_garden/words.py\n560\t@@ -0,0 +1,50 @@\n561\t+import random as _random\n562\t+\n563\t+WORDS = [\n564\t+    \"GARDEN\",\n565\t+    \"FLOWER\",\n566\t+    \"PLANET\",\n567\t+    \"PYTHON\",\n568\t+    \"TERMINAL\",\n569\t+    \"MEADOW\",\n570\t+    \"ORCHARD\",\n571\t+    \"VINEYARD\",\n572\t+    \"SEEDLING\",\n573\t+    \"HARVEST\",\n574\t+]\n575\t+\n576\t+# Single source of truth for difficulty configuration.\n577\t+_DIFFICULTY = {\n578\t+    \"easy\":   {\"water\": 8, \"min_len\": 4, \"max_len\": 6},\n579\t+    \"normal\": {\"water\": 6, \"min_len\": 5, \"max_len\": 8},\n580\t+    \"hard\":   {\"water\": 4, \"min_len\": 7, \"max_len\": None},\n581\t+}\n582\t+\n583\t+\n584\t+def water_for(difficulty: str = \"normal\") -> int:\n585\t+    if difficulty not in _DIFFICULTY:\n586\t+        raise ValueError(f\"Unknown difficulty: {difficulty!r}\")\n587\t+    return _DIFFICULTY[difficulty][\"water\"]\n588\t+\n589\t+\n590\t+def select_word(difficulty: str = \"normal\", rng: _random.Random | None = None) -> str:\n591\t+    if difficulty not in _DIFFICULTY:\n592\t+        raise ValueError(f\"Unknown difficulty: {difficulty!r}\")\n593\t+    cfg = _DIFFICULTY[difficulty]\n594\t+    min_len: int = cfg[\"min_len\"]\n595\t+    max_len: int | None = cfg[\"max_len\"]\n596\t+\n597\t+    pool = [\n598\t+        w for w in WORDS\n599\t+        if len(w) >= min_len and (max_len is None or len(w) <= max_len)\n600\t+    ]\n601\t+\n602\t+    if not pool:\n603\t+        raise ValueError(\n604\t+            f\"No words match difficulty {difficulty!r} \"\n605\t+            f\"(min_len={min_len}, max_len={max_len})\"\n606\t+        )\n607\t+\n608\t+    if rng is not None:\n609\t+        return rng.choice(pool)\n610\t+    return _random.choice(pool)\n611\t"}]},"parent_tool_use_id":null,"session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9","uuid":"d9f8275e-0b54-468c-ab97-f3a1a4a2d35f","timestamp":"2026-06-12T03:34:40.979Z","tool_use_result":{"type":"text","file":{"filePath":"/Volumes/990EVO4TB/Dev/wg4/word-garden-4/.farnsworth/task-001/candidates/B.diff","content":"diff --git a/tests/__init__.py b/tests/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/tests/test_game.py b/tests/test_game.py\nnew file mode 100644\nindex 0000000..6d8ef7b\n--- /dev/null\n+++ b/tests/test_game.py\n@@ -0,0 +1,319 @@\n+import random\n+import unittest\n+\n+from word_garden.game import (\n+    GameState,\n+    apply_guess,\n+    display_word,\n+    is_lost,\n+    is_won,\n+    new_game,\n+    validate_guess,\n+    MSG_ALREADY_GUESSED,\n+    MSG_CORRECT,\n+    MSG_GAME_OVER,\n+    MSG_INVALID_NOT_ALPHA,\n+    MSG_INVALID_SINGLE,\n+    MSG_LOSS,\n+    MSG_WIN,\n+    MSG_WRONG,\n+)\n+\n+\n+def _state(**kwargs) -> GameState:\n+    defaults = dict(\n+        secret_word=\"GARDEN\",\n+        guessed_letters=set(),\n+        remaining_water=6,\n+        weed_count=0,\n+        max_water=6,\n+    )\n+    defaults.update(kwargs)\n+    return GameState(**defaults)\n+\n+\n+class TestCorrectGuess(unittest.TestCase):\n+    \"\"\"SPEC section 16 case 1: a correct guess reveals matching letters.\"\"\"\n+\n+    def test_correct_guess_adds_letter_and_sets_message(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters=set(), remaining_water=6, weed_count=0)\n+        result = apply_guess(state, \"A\")\n+        self.assertIn(\"A\", result.guessed_letters)\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertEqual(result.status_message, MSG_CORRECT)\n+        self.assertFalse(result.game_over)\n+        self.assertFalse(result.won)\n+\n+    def test_correct_guess_reveals_all_occurrences_in_display(self):\n+        # SPEC section 16 case 9: display_word masks unguessed letters.\n+        state = _state(secret_word=\"SEEDLING\", guessed_letters={\"E\"})\n+        self.assertEqual(display_word(state), \"_ E E _ _ _ _ _\")\n+\n+    def test_correct_guess_does_not_change_water_or_weeds(self):\n+        state = _state(secret_word=\"PYTHON\", remaining_water=4, weed_count=2)\n+        result = apply_guess(state, \"Y\")\n+        self.assertEqual(result.remaining_water, 4)\n+        self.assertEqual(result.weed_count, 2)\n+\n+\n+class TestIncorrectGuess(unittest.TestCase):\n+    \"\"\"SPEC section 16 cases 2 & 3: incorrect guess reduces water and increases weeds.\"\"\"\n+\n+    def test_wrong_guess_water_minus_one_weeds_plus_one_letter_recorded(self):\n+        state = _state(secret_word=\"GARDEN\", remaining_water=6, weed_count=0, guessed_letters=set())\n+        result = apply_guess(state, \"Z\")\n+        self.assertEqual(result.remaining_water, 5)\n+        self.assertEqual(result.weed_count, 1)\n+        self.assertIn(\"Z\", result.guessed_letters)\n+        self.assertEqual(result.status_message, MSG_WRONG)\n+        self.assertFalse(result.game_over)\n+        self.assertFalse(result.won)\n+\n+    def test_wrong_guess_accumulates_correctly(self):\n+        state = _state(secret_word=\"GARDEN\", remaining_water=3, weed_count=3, guessed_letters={\"Z\"})\n+        result = apply_guess(state, \"Q\")\n+        self.assertEqual(result.remaining_water, 2)\n+        self.assertEqual(result.weed_count, 4)\n+        self.assertIn(\"Q\", result.guessed_letters)\n+\n+\n+class TestRepeatedGuess(unittest.TestCase):\n+    \"\"\"SPEC section 16 case 4: repeated guesses do not reduce water.\"\"\"\n+\n+    def test_repeated_guess_no_water_or_weed_change(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"A\"}, remaining_water=6, weed_count=0)\n+        result = apply_guess(state, \"A\")\n+        self.assertEqual(result.remaining_water, 6)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertEqual(result.guessed_letters, {\"A\"})\n+        self.assertEqual(result.status_message, MSG_ALREADY_GUESSED.format(letter=\"A\"))\n+        self.assertFalse(result.game_over)\n+        self.assertFalse(result.won)\n+\n+    def test_repeated_wrong_guess_no_water_or_weed_change(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"Z\"}, remaining_water=5, weed_count=1)\n+        result = apply_guess(state, \"Z\")\n+        self.assertEqual(result.remaining_water, 5)\n+        self.assertEqual(result.weed_count, 1)\n+        self.assertEqual(result.status_message, MSG_ALREADY_GUESSED.format(letter=\"Z\"))\n+\n+\n+class TestValidateGuess(unittest.TestCase):\n+    \"\"\"SPEC section 16 cases 5 & 6: invalid input is rejected; lowercase is normalised.\"\"\"\n+\n+    def test_empty_string_rejected(self):\n+        letter, msg = validate_guess(\"\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_SINGLE)\n+\n+    def test_whitespace_only_rejected(self):\n+        letter, msg = validate_guess(\"   \")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_SINGLE)\n+\n+    def test_multiple_characters_rejected(self):\n+        letter, msg = validate_guess(\"apple\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_SINGLE)\n+\n+    def test_digit_rejected(self):\n+        letter, msg = validate_guess(\"7\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_NOT_ALPHA)\n+\n+    def test_symbol_rejected(self):\n+        letter, msg = validate_guess(\"!\")\n+        self.assertIsNone(letter)\n+        self.assertEqual(msg, MSG_INVALID_NOT_ALPHA)\n+\n+    def test_none_rejected(self):\n+        letter, msg = validate_guess(None)\n+        self.assertIsNone(letter)\n+        self.assertNotEqual(msg, \"\")\n+\n+    def test_integer_rejected(self):\n+        letter, msg = validate_guess(42)\n+        self.assertIsNone(letter)\n+        self.assertNotEqual(msg, \"\")\n+\n+    def test_lowercase_normalised_to_uppercase(self):\n+        # SPEC section 16 case 6\n+        letter, msg = validate_guess(\"a\")\n+        self.assertEqual(letter, \"A\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_uppercase_accepted(self):\n+        letter, msg = validate_guess(\"Z\")\n+        self.assertEqual(letter, \"Z\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_leading_trailing_spaces_stripped(self):\n+        letter, msg = validate_guess(\"  b  \")\n+        self.assertEqual(letter, \"B\")\n+        self.assertEqual(msg, \"\")\n+\n+    def test_valid_returns_empty_message(self):\n+        letter, msg = validate_guess(\"G\")\n+        self.assertEqual(letter, \"G\")\n+        self.assertEqual(msg, \"\")\n+\n+\n+class TestWinDetection(unittest.TestCase):\n+    \"\"\"SPEC section 16 case 7: the game detects a win.\"\"\"\n+\n+    def test_final_correct_letter_triggers_win(self):\n+        # GARDEN: G A R D E N — guess N last.\n+        state = _state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\"},\n+            remaining_water=3,\n+            weed_count=1,\n+        )\n+        result = apply_guess(state, \"N\")\n+        self.assertTrue(result.won)\n+        self.assertTrue(result.game_over)\n+        self.assertIn(\"N\", result.guessed_letters)\n+        self.assertEqual(result.remaining_water, 3)\n+        self.assertEqual(result.weed_count, 1)\n+        self.assertEqual(result.status_message, MSG_WIN)\n+\n+    def test_is_won_true_when_all_letters_guessed(self):\n+        state = _state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+        )\n+        self.assertTrue(is_won(state))\n+\n+    def test_is_won_false_when_letters_missing(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"G\", \"A\"})\n+        self.assertFalse(is_won(state))\n+\n+    def test_non_final_correct_guess_does_not_set_won(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters=set(), remaining_water=6)\n+        result = apply_guess(state, \"G\")\n+        self.assertFalse(result.won)\n+        self.assertFalse(result.game_over)\n+\n+\n+class TestLossDetection(unittest.TestCase):\n+    \"\"\"SPEC section 16 case 8: the game detects a loss.\"\"\"\n+\n+    def test_final_wrong_guess_triggers_loss(self):\n+        state = _state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"Z\"},\n+            remaining_water=1,\n+            weed_count=5,\n+        )\n+        result = apply_guess(state, \"Q\")\n+        self.assertTrue(result.game_over)\n+        self.assertFalse(result.won)\n+        self.assertEqual(result.remaining_water, 0)\n+        self.assertEqual(result.weed_count, 6)\n+        self.assertIn(\"Q\", result.guessed_letters)\n+        self.assertEqual(result.status_message, MSG_LOSS)\n+\n+    def test_is_lost_true_when_water_zero_and_not_won(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"Z\"}, remaining_water=0)\n+        self.assertTrue(is_lost(state))\n+\n+    def test_is_lost_false_when_water_remains(self):\n+        state = _state(remaining_water=1)\n+        self.assertFalse(is_lost(state))\n+\n+    def test_is_lost_false_when_won(self):\n+        state = _state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+            remaining_water=0,\n+        )\n+        self.assertFalse(is_lost(state))\n+\n+\n+class TestDisplayWord(unittest.TestCase):\n+    \"\"\"SPEC section 16 case 9: displayed word masks unguessed letters.\"\"\"\n+\n+    def test_all_masked_at_start(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters=set())\n+        self.assertEqual(display_word(state), \"_ _ _ _ _ _\")\n+\n+    def test_partial_reveal(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"G\", \"R\", \"E\"})\n+        self.assertEqual(display_word(state), \"G _ R _ E _\")\n+\n+    def test_fully_revealed(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"})\n+        self.assertEqual(display_word(state), \"G A R D E N\")\n+\n+    def test_repeated_letter_all_positions_revealed(self):\n+        state = _state(secret_word=\"SEEDLING\", guessed_letters={\"S\", \"E\"})\n+        self.assertEqual(display_word(state), \"S E E _ _ _ _ _\")\n+\n+\n+class TestGuessAfterGameOver(unittest.TestCase):\n+\n+    def test_guess_after_win_is_noop(self):\n+        state = _state(\n+            secret_word=\"GARDEN\",\n+            guessed_letters={\"G\", \"A\", \"R\", \"D\", \"E\", \"N\"},\n+            remaining_water=3,\n+            weed_count=0,\n+            game_over=True,\n+            won=True,\n+            status_message=MSG_WIN,\n+        )\n+        result = apply_guess(state, \"X\")\n+        self.assertEqual(result.remaining_water, 3)\n+        self.assertEqual(result.weed_count, 0)\n+        self.assertTrue(result.game_over)\n+        self.assertTrue(result.won)\n+        self.assertEqual(result.status_message, MSG_GAME_OVER)\n+\n+    def test_guess_after_loss_is_noop(self):\n+        state = _state(remaining_water=0, game_over=True, won=False)\n+        result = apply_guess(state, \"A\")\n+        self.assertEqual(result.remaining_water, 0)\n+        self.assertTrue(result.game_over)\n+        self.assertFalse(result.won)\n+        self.assertEqual(result.status_message, MSG_GAME_OVER)\n+\n+\n+class TestNewGame(unittest.TestCase):\n+\n+    def test_new_game_normal_has_correct_initial_state(self):\n+        rng = random.Random(42)\n+        state = new_game(difficulty=\"normal\", rng=rng)\n+        self.assertIsInstance(state.secret_word, str)\n+        self.assertGreater(len(state.secret_word), 0)\n+        self.assertEqual(state.secret_word, state.secret_word.upper())\n+        self.assertEqual(state.remaining_water, 6)\n+        self.assertEqual(state.max_water, 6)\n+        self.assertEqual(state.weed_count, 0)\n+        self.assertEqual(len(state.guessed_letters), 0)\n+        self.assertFalse(state.game_over)\n+        self.assertFalse(state.won)\n+\n+    def test_new_game_easy_has_eight_water(self):\n+        rng = random.Random(1)\n+        state = new_game(difficulty=\"easy\", rng=rng)\n+        self.assertEqual(state.remaining_water, 8)\n+        self.assertEqual(state.max_water, 8)\n+\n+    def test_new_game_hard_has_four_water(self):\n+        rng = random.Random(1)\n+        state = new_game(difficulty=\"hard\", rng=rng)\n+        self.assertEqual(state.remaining_water, 4)\n+        self.assertEqual(state.max_water, 4)\n+\n+    def test_new_game_unknown_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            new_game(difficulty=\"extreme\")\n+\n+    def test_apply_guess_does_not_mutate_original_state(self):\n+        state = _state(secret_word=\"GARDEN\", guessed_letters=set(), remaining_water=6)\n+        original_guessed = set(state.guessed_letters)\n+        original_water = state.remaining_water\n+        apply_guess(state, \"Z\")\n+        self.assertEqual(state.guessed_letters, original_guessed)\n+        self.assertEqual(state.remaining_water, original_water)\ndiff --git a/tests/test_words.py b/tests/test_words.py\nnew file mode 100644\nindex 0000000..f1a504c\n--- /dev/null\n+++ b/tests/test_words.py\n@@ -0,0 +1,83 @@\n+import random\n+import unittest\n+\n+from word_garden.words import WORDS, select_word, water_for\n+\n+\n+class TestWordList(unittest.TestCase):\n+\n+    def test_words_are_uppercase(self):\n+        for word in WORDS:\n+            self.assertEqual(word, word.upper(), f\"{word!r} is not uppercase\")\n+\n+    def test_words_are_non_empty_strings(self):\n+        for word in WORDS:\n+            self.assertIsInstance(word, str)\n+            self.assertGreater(len(word), 0)\n+\n+\n+class TestWaterFor(unittest.TestCase):\n+\n+    def test_easy_water(self):\n+        self.assertEqual(water_for(\"easy\"), 8)\n+\n+    def test_normal_water(self):\n+        self.assertEqual(water_for(\"normal\"), 6)\n+\n+    def test_hard_water(self):\n+        self.assertEqual(water_for(\"hard\"), 4)\n+\n+    def test_unknown_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            water_for(\"extreme\")\n+\n+    def test_empty_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            water_for(\"\")\n+\n+\n+class TestSelectWord(unittest.TestCase):\n+\n+    # SPEC section 16 case 10: word selector returns a valid word for every difficulty.\n+\n+    def test_easy_returns_word_in_length_range(self):\n+        rng = random.Random(1)\n+        word = select_word(\"easy\", rng=rng)\n+        self.assertIn(word, WORDS)\n+        self.assertGreaterEqual(len(word), 4)\n+        self.assertLessEqual(len(word), 6)\n+\n+    def test_normal_returns_word_in_length_range(self):\n+        rng = random.Random(2)\n+        word = select_word(\"normal\", rng=rng)\n+        self.assertIn(word, WORDS)\n+        self.assertGreaterEqual(len(word), 5)\n+        self.assertLessEqual(len(word), 8)\n+\n+    def test_hard_returns_word_in_length_range(self):\n+        rng = random.Random(3)\n+        word = select_word(\"hard\", rng=rng)\n+        self.assertIn(word, WORDS)\n+        self.assertGreaterEqual(len(word), 7)\n+\n+    def test_all_difficulties_return_uppercase_string(self):\n+        for diff in (\"easy\", \"normal\", \"hard\"):\n+            rng = random.Random(99)\n+            word = select_word(diff, rng=rng)\n+            self.assertIsInstance(word, str, f\"difficulty={diff!r}\")\n+            self.assertEqual(word, word.upper(), f\"difficulty={diff!r}\")\n+            self.assertGreater(len(word), 0, f\"difficulty={diff!r}\")\n+\n+    def test_unknown_difficulty_raises(self):\n+        with self.assertRaises(ValueError):\n+            select_word(\"extreme\")\n+\n+    def test_seeded_rng_is_deterministic(self):\n+        word1 = select_word(\"normal\", rng=random.Random(42))\n+        word2 = select_word(\"normal\", rng=random.Random(42))\n+        self.assertEqual(word1, word2)\n+\n+    def test_none_rng_uses_module_random(self):\n+        # Should not raise; returned word must be in the list.\n+        word = select_word(\"normal\")\n+        self.assertIn(word, WORDS)\ndiff --git a/word_garden/__init__.py b/word_garden/__init__.py\nnew file mode 100644\nindex 0000000..e69de29\ndiff --git a/word_garden/game.py b/word_garden/game.py\nnew file mode 100644\nindex 0000000..862b24a\n--- /dev/null\n+++ b/word_garden/game.py\n@@ -0,0 +1,128 @@\n+from __future__ import annotations\n+\n+import random\n+from dataclasses import dataclass\n+\n+from . import words as _words\n+\n+# User-facing message constants — import these in tests instead of re-typing literals.\n+MSG_CORRECT = \"Good guess! The garden grows.\"\n+MSG_WRONG = \"No match. A weed appears.\"\n+MSG_ALREADY_GUESSED = \"You already guessed {letter}. Try another letter.\"\n+MSG_WIN = \"Bloom! You've revealed the whole word!\"\n+MSG_LOSS = \"The garden ran out of water.\"\n+MSG_GAME_OVER = \"The game is already over.\"\n+\n+MSG_INVALID_SINGLE = \"Please enter a single letter.\"\n+MSG_INVALID_NOT_ALPHA = \"That is not a letter.\"\n+\n+\n+@dataclass\n+class GameState:\n+    secret_word: str\n+    guessed_letters: set[str]\n+    remaining_water: int\n+    weed_count: int\n+    max_water: int\n+    status_message: str = \"\"\n+    game_over: bool = False\n+    won: bool = False\n+\n+\n+def new_game(difficulty: str = \"normal\", rng: random.Random | None = None) -> GameState:\n+    word = _words.select_word(difficulty=difficulty, rng=rng)\n+    water = _words.water_for(difficulty=difficulty)\n+    return GameState(\n+        secret_word=word.upper(),\n+        guessed_letters=set(),\n+        remaining_water=water,\n+        weed_count=0,\n+        max_water=water,\n+    )\n+\n+\n+def validate_guess(input_text: object) -> tuple[str | None, str]:\n+    if not isinstance(input_text, str):\n+        return (None, MSG_INVALID_SINGLE)\n+    stripped = input_text.strip()\n+    if not stripped:\n+        return (None, MSG_INVALID_SINGLE)\n+    if len(stripped) > 1:\n+        return (None, MSG_INVALID_SINGLE)\n+    if not stripped.isalpha():\n+        return (None, MSG_INVALID_NOT_ALPHA)\n+    return (stripped.upper(), \"\")\n+\n+\n+def apply_guess(state: GameState, letter: str) -> GameState:\n+    if state.game_over:\n+        return _clone(state, status_message=MSG_GAME_OVER)\n+\n+    letter = letter.upper()\n+\n+    if letter in state.guessed_letters:\n+        msg = MSG_ALREADY_GUESSED.format(letter=letter)\n+        return _clone(state, status_message=msg)\n+\n+    new_guessed = set(state.guessed_letters) | {letter}\n+\n+    if letter in state.secret_word:\n+        won = _all_revealed(state.secret_word, new_guessed)\n+        return GameState(\n+            secret_word=state.secret_word,\n+            guessed_letters=new_guessed,\n+            remaining_water=state.remaining_water,\n+            weed_count=state.weed_count,\n+            max_water=state.max_water,\n+            status_message=MSG_WIN if won else MSG_CORRECT,\n+            game_over=won,\n+            won=won,\n+        )\n+\n+    new_water = state.remaining_water - 1\n+    new_weeds = state.weed_count + 1\n+    lost = new_water <= 0\n+    return GameState(\n+        secret_word=state.secret_word,\n+        guessed_letters=new_guessed,\n+        remaining_water=max(new_water, 0),\n+        weed_count=new_weeds,\n+        max_water=state.max_water,\n+        status_message=MSG_LOSS if lost else MSG_WRONG,\n+        game_over=lost,\n+        won=False,\n+    )\n+\n+\n+def display_word(state: GameState) -> str:\n+    return \" \".join(\n+        c if c in state.guessed_letters else \"_\"\n+        for c in state.secret_word\n+    )\n+\n+\n+def is_won(state: GameState) -> bool:\n+    return _all_revealed(state.secret_word, state.guessed_letters)\n+\n+\n+def is_lost(state: GameState) -> bool:\n+    return state.remaining_water <= 0 and not is_won(state)\n+\n+\n+def _all_revealed(secret_word: str, guessed_letters: set[str]) -> bool:\n+    return bool(secret_word) and all(c in guessed_letters for c in secret_word)\n+\n+\n+def _clone(state: GameState, **overrides: object) -> GameState:\n+    kwargs: dict[str, object] = dict(\n+        secret_word=state.secret_word,\n+        guessed_letters=set(state.guessed_letters),\n+        remaining_water=state.remaining_water,\n+        weed_count=state.weed_count,\n+        max_water=state.max_water,\n+        status_message=state.status_message,\n+        game_over=state.game_over,\n+        won=state.won,\n+    )\n+    kwargs.update(overrides)\n+    return GameState(**kwargs)  # type: ignore[arg-type]\ndiff --git a/word_garden/words.py b/word_garden/words.py\nnew file mode 100644\nindex 0000000..92671e7\n--- /dev/null\n+++ b/word_garden/words.py\n@@ -0,0 +1,50 @@\n+import random as _random\n+\n+WORDS = [\n+    \"GARDEN\",\n+    \"FLOWER\",\n+    \"PLANET\",\n+    \"PYTHON\",\n+    \"TERMINAL\",\n+    \"MEADOW\",\n+    \"ORCHARD\",\n+    \"VINEYARD\",\n+    \"SEEDLING\",\n+    \"HARVEST\",\n+]\n+\n+# Single source of truth for difficulty configuration.\n+_DIFFICULTY = {\n+    \"easy\":   {\"water\": 8, \"min_len\": 4, \"max_len\": 6},\n+    \"normal\": {\"water\": 6, \"min_len\": 5, \"max_len\": 8},\n+    \"hard\":   {\"water\": 4, \"min_len\": 7, \"max_len\": None},\n+}\n+\n+\n+def water_for(difficulty: str = \"normal\") -> int:\n+    if difficulty not in _DIFFICULTY:\n+        raise ValueError(f\"Unknown difficulty: {difficulty!r}\")\n+    return _DIFFICULTY[difficulty][\"water\"]\n+\n+\n+def select_word(difficulty: str = \"normal\", rng: _random.Random | None = None) -> str:\n+    if difficulty not in _DIFFICULTY:\n+        raise ValueError(f\"Unknown difficulty: {difficulty!r}\")\n+    cfg = _DIFFICULTY[difficulty]\n+    min_len: int = cfg[\"min_len\"]\n+    max_len: int | None = cfg[\"max_len\"]\n+\n+    pool = [\n+        w for w in WORDS\n+        if len(w) >= min_len and (max_len is None or len(w) <= max_len)\n+    ]\n+\n+    if not pool:\n+        raise ValueError(\n+            f\"No words match difficulty {difficulty!r} \"\n+            f\"(min_len={min_len}, max_len={max_len})\"\n+        )\n+\n+    if rng is not None:\n+        return rng.choice(pool)\n+    return _random.choice(pool)\n","numLines":611,"startLine":1,"totalLines":611}}},{"type":"system","subtype":"thinking_tokens","estimated_tokens":50,"estimated_tokens_delta":50,"uuid":"cc883ff6-f6f9-4b26-874d-5bae114fe0b7","session_id":"26931df1-8f61-42b8-a8d5-65221b0797a9"},{"type":"system","subtype":"thinking_tokens","estimated_tokens":150,"estimated_tokens_delta":100,"uuid":"de284892-e6ad-4059-ae48-7cd26d9828cb","session_id":"26931df1-8f61-4