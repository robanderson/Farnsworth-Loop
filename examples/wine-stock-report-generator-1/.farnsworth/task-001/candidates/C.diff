+"""Tests for wine_stock_reporter.csv_loader."""
+
+import io
+import os
+import tempfile
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.csv_loader import (
+    load_csv,
+    ERR_FILE_NOT_FOUND,
+    ERR_REQUIRED_COLUMN,
+    REQUIRED_COLUMNS,
+)
+
+
+HEADER = "Type1,Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Available,Units\n"
+
+
+def _write_csv(content: str) -> str:
+    """Write CSV content to a temp file and return the path."""
+    f = tempfile.NamedTemporaryFile(mode="w", suffix=".csv", delete=False, encoding="utf-8")
+    f.write(content)
+    f.close()
+    return f.name
+
+
+class TestLoadCsvValid(unittest.TestCase):
+    def test_loads_valid_csv(self):
+        path = _write_csv(
+            HEADER
+            + "Finished Goods,747691,FV 22 CHR EP NZ 750ml/12p,,Eva 22 CHR 12pk,W39189,48.58,Marlborough,0.00,0.00,48.58,Cases\n"
+        )
+        try:
+            rows, warnings = load_csv(path)
+            self.assertEqual(len(rows), 1)
+            row = rows[0]
+            self.assertEqual(row.type1, "Finished Goods")
+            self.assertEqual(row.item, "747691")
+            self.assertEqual(row.on_hand, Decimal("48.58"))
+            self.assertEqual(row.available, Decimal("48.58"))
+            self.assertEqual(row.units, "Cases")
+        finally:
+            os.unlink(path)
+
+    def test_parses_decimal_string(self):
+        path = _write_csv(
+            HEADER
+            + "Finished Goods,123,FV 22 CHR EP NZ 750ml/12p,,,W1,13.67,MB,0.00,0.00,13.67,Cases\n"
+        )
+        try:
+            rows, _ = load_csv(path)
+            self.assertEqual(rows[0].on_hand, Decimal("13.67"))
+        finally:
+            os.unlink(path)
+
+    def test_parses_thousands_separator(self):
+        path = _write_csv(
+            HEADER
+            + 'Finished Goods,773329,FV 25 SAB EP X+ 750ml/12p,,,W1,"2,216.50",MB,0.00,0.00,"2,216.50",Cases\n'
+        )
+        try:
+            rows, _ = load_csv(path)
+            self.assertEqual(rows[0].on_hand, Decimal("2216.50"))
+            self.assertEqual(rows[0].available, Decimal("2216.50"))
+        finally:
+            os.unlink(path)
+
+    def test_handles_blank_nullable_fields(self):
+        path = _write_csv(
+            HEADER
+            + "Finished Goods,999,FV 22 CHR EP NZ 750ml/12p,,,, 0.00,MB,0.00,0.00,0.00,Cases\n"
+        )
+        try:
+            rows, _ = load_csv(path)
+            self.assertEqual(rows[0].client_stock_code, "")
+            self.assertEqual(rows[0].lot, "")
+        finally:
+            os.unlink(path)
+
+    def test_returns_multiple_rows(self):
+        path = _write_csv(
+            HEADER
+            + "Finished Goods,111,Desc A,,,W1,5.00,MB,0.00,0.00,5.00,Cases\n"
+            + "Dry Goods,222,Desc B,,,W2,10.00,MB,0.00,0.00,10.00,Eaches\n"
+        )
+        try:
+            rows, _ = load_csv(path)
+            self.assertEqual(len(rows), 2)
+            self.assertEqual(rows[1].type1, "Dry Goods")
+        finally:
+            os.unlink(path)
+
+
+class TestLoadCsvErrors(unittest.TestCase):
+    def test_fails_on_missing_file(self):
+        with self.assertRaises(FileNotFoundError) as ctx:
+            load_csv("/tmp/this_file_does_not_exist_xyz.csv")
+        self.assertIn("Error:", str(ctx.exception))
+
+    def test_fails_on_missing_required_column(self):
+        # Missing 'Available' column
+        header = "Type1,Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Units\n"
+        path = _write_csv(
+            header + "Finished Goods,111,Desc,,,W1,5.00,MB,0.00,0.00,Cases\n"
+        )
+        try:
+            with self.assertRaises(ValueError) as ctx:
+                load_csv(path)
+            self.assertIn("Available", str(ctx.exception))
+        finally:
+            os.unlink(path)
+
+    def test_error_message_names_missing_column(self):
+        # Missing 'Type1'
+        header = "Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Available,Units\n"
+        path = _write_csv(header + "111,Desc,,,W1,5.00,MB,0.00,0.00,5.00,Cases\n")
+        try:
+            with self.assertRaises(ValueError) as ctx:
+                load_csv(path)
+            self.assertIn("Type1", str(ctx.exception))
+            self.assertIn("Error:", str(ctx.exception))
+        finally:
+            os.unlink(path)
+
+    def test_negative_values_do_not_crash(self):
+        path = _write_csv(
+            HEADER
+            + "Finished Goods,555,FV 22 CHR EP NZ 750ml/12p,,,W1,-1.00,MB,0.00,0.00,-1.00,Cases\n"
+        )
+        try:
+            rows, warnings = load_csv(path)
+            self.assertEqual(len(rows), 1)
+            self.assertEqual(rows[0].on_hand, Decimal("-1.00"))
+        finally:
+            os.unlink(path)
+
+
+class TestLoadCsvAllRequiredColumns(unittest.TestCase):
+    def test_all_required_columns_checked(self):
+        """Each required column triggers an error when absent."""
+        for col in REQUIRED_COLUMNS:
+            cols = [c for c in REQUIRED_COLUMNS if c != col]
+            header = ",".join(cols) + "\n"
+            path = _write_csv(header + ",".join(["x"] * len(cols)) + "\n")
+            try:
+                with self.assertRaises(ValueError) as ctx:
+                    load_csv(path)
+                self.assertIn(col, str(ctx.exception), f"Column {col!r} not named in error")
+            finally:
+                os.unlink(path)
+
+
+if __name__ == "__main__":
+    unittest.main()
