+"""CLI for the Wine Stock Report Generator.
+
+All prompting lives here behind injectable I/O so the suite runs hermetically.
+"""
+
+from __future__ import annotations
+
+import argparse
+import sys
+from decimal import Decimal, InvalidOperation
+from pathlib import Path
+from typing import Callable, Optional, TextIO
+
+from .models import ReportOptions
+
+# ---------------------------------------------------------------------------
+# Output constants (single-source per seed tip #7)
+# ---------------------------------------------------------------------------
+
+MSG_LOADED = "Loaded {path}."
+MSG_DETECTED_HEADER = "\nDetected:"
+MSG_REPORT_WRITTEN = "Report written to {path}"
+
+PROMPT_BASIS = "1. Use OnHand or Available stock for wine totals? [{default}]: "
+PROMPT_DRY_GOODS = "2. Include Dry Goods section? [{default}]: "
+PROMPT_GROUP_BY = "3. Group primary wine summary by variety, vintage, market, pack_size, lot, or none? [{default}]: "
+PROMPT_LOW_STOCK = "4. Include low-stock warnings? [{default}]: "
+PROMPT_THRESHOLD = "5. Low-stock threshold in 9LE? [{default}]: "
+PROMPT_OUTPUT = "6. Output filename? [{default}]: "
+
+VALID_BASIS = {"onhand", "available"}
+VALID_GROUP_BY = {"variety", "vintage", "market", "pack_size", "lot", "none"}
+VALID_YES_NO = {"yes", "no", "y", "n"}
+
+ERR_INVALID_BASIS = "Invalid input. Please enter 'OnHand' or 'Available'."
+ERR_INVALID_GROUP_BY = "Invalid input. Please enter: variety, vintage, market, pack_size, lot, or none."
+ERR_INVALID_YES_NO = "Invalid input. Please enter 'yes' or 'no'."
+ERR_INVALID_THRESHOLD = "Invalid input. Please enter a positive number (e.g. 10)."
+
+
+def build_arg_parser() -> argparse.ArgumentParser:
+    """Build and return the argument parser (never wraps SystemExit)."""
+    parser = argparse.ArgumentParser(
+        prog="wine_stock_reporter",
+        description="Wine Stock Report Generator — converts a warehouse stock CSV to a Markdown report.",
+    )
+    parser.add_argument("csv_path", metavar="CSV_PATH", help="Path to the warehouse stock CSV file.")
+    parser.add_argument(
+        "--basis",
+        choices=["OnHand", "Available"],
+        default="Available",
+        help="Stock quantity basis for wine totals (default: Available).",
+    )
+    parser.add_argument(
+        "--group-by",
+        choices=["variety", "vintage", "market", "pack_size", "lot", "none"],
+        default="variety",
+        dest="group_by",
+        help="Group primary wine summary by this field (default: variety).",
+    )
+    parser.add_argument(
+        "--include-dry-goods",
+        action="store_true",
+        default=True,
+        dest="include_dry_goods",
+        help="Include a Dry Goods section in the report (default: on).",
+    )
+    parser.add_argument(
+        "--no-dry-goods",
+        action="store_false",
+        dest="include_dry_goods",
+        help="Exclude the Dry Goods section from the report.",
+    )
+    parser.add_argument(
+        "--low-stock-warnings",
+        action="store_true",
+        default=True,
+        dest="low_stock_warnings",
+        help="Include low-stock warnings in the report (default: on).",
+    )
+    parser.add_argument(
+        "--no-low-stock-warnings",
+        action="store_false",
+        dest="low_stock_warnings",
+        help="Exclude low-stock warnings from the report.",
+    )
+    parser.add_argument(
+        "--low-stock-threshold",
+        type=Decimal,
+        default=Decimal("10"),
+        dest="low_stock_threshold",
+        metavar="N",
+        help="Low-stock threshold in 9LE (default: 10).",
+    )
+    parser.add_argument(
+        "--output",
+        default="stock-report.md",
+        dest="output_path",
+        metavar="PATH",
+        help="Output file path (default: stock-report.md).",
+    )
+    parser.add_argument(
+        "--no-interactive",
+        action="store_true",
+        default=False,
+        dest="no_interactive",
+        help="Skip all interactive prompts and use effective option values.",
+    )
+    return parser
+
+
+def _prompt_until_valid(
+    prompt_template: str,
+    default: str,
+    valid_fn: Callable[[str], bool],
+    err_msg: str,
+    input_fn: Callable[[], str],
+    output_fn: Callable[..., None],
+) -> Optional[str]:
+    """Prompt until a valid answer is given.
+
+    Returns the stripped answer (may be empty string for "accept default"),
+    or None when EOF is received.
+    """
+    while True:
+        output_fn(prompt_template.format(default=default), end="", flush=True)
+        try:
+            answer = input_fn()
+        except EOFError:
+            output_fn("")  # newline after EOF
+            return None
+        answer = answer.strip()
+        if answer == "":
+            return answer  # accept default
+        if valid_fn(answer):
+            return answer
+        output_fn(err_msg)
+
+
+def run_interactive_prompts(
+    options: ReportOptions,
+    rows_summary: dict,
+    input_fn: Callable[[], str] = input,
+    output_fn: Callable[..., None] = print,
+) -> ReportOptions:
+    """Ask the six interactive questions and return an updated ReportOptions.
+
+    `rows_summary` should contain keys:
+        'fg_count', 'dg_count', 'warehouses', 'units'
+    """
+    # Print detection summary
+    output_fn(MSG_DETECTED_HEADER)
+    output_fn(f"- Finished Goods rows: {rows_summary.get('fg_count', 0)}")
+    if rows_summary.get("dg_count", 0):
+        output_fn(f"- Dry Goods rows: {rows_summary.get('dg_count', 0)}")
+    whs = rows_summary.get("warehouses", [])
+    if whs:
+        output_fn(f"- Warehouse: {', '.join(sorted(whs))}")
+    units = rows_summary.get("units", [])
+    if units:
+        output_fn(f"- Units: {', '.join(sorted(units))}")
+    output_fn("\nReport options:\n")
+
+    eof_hit = False
+
+    # Q1: Basis
+    if not eof_hit:
+        ans = _prompt_until_valid(
+            PROMPT_BASIS,
+            default=options.basis,
+            valid_fn=lambda s: s.lower() in VALID_BASIS,
+            err_msg=ERR_INVALID_BASIS,
+            input_fn=input_fn,
+            output_fn=output_fn,
+        )
+        if ans is None:
+            eof_hit = True
+        elif ans:
+            options.basis = ans.capitalize() if ans.lower() == "onhand" else "Available"
+            if ans.lower() == "onhand":
+                options.basis = "OnHand"
+            elif ans.lower() == "available":
+                options.basis = "Available"
+
+    # Q2: Include dry goods
+    if not eof_hit:
+        default_dg = "yes" if options.include_dry_goods else "no"
+        ans = _prompt_until_valid(
+            PROMPT_DRY_GOODS,
+            default=default_dg,
+            valid_fn=lambda s: s.lower() in VALID_YES_NO,
+            err_msg=ERR_INVALID_YES_NO,
+            input_fn=input_fn,
+            output_fn=output_fn,
+        )
+        if ans is None:
+            eof_hit = True
+        elif ans:
+            options.include_dry_goods = ans.lower() in {"yes", "y"}
+
+    # Q3: Group by
+    if not eof_hit:
+        ans = _prompt_until_valid(
+            PROMPT_GROUP_BY,
+            default=options.group_by,
+            valid_fn=lambda s: s.lower() in VALID_GROUP_BY,
+            err_msg=ERR_INVALID_GROUP_BY,
+            input_fn=input_fn,
+            output_fn=output_fn,
+        )
+        if ans is None:
+            eof_hit = True
+        elif ans:
+            options.group_by = ans.lower()
+
+    # Q4: Low-stock warnings
+    if not eof_hit:
+        default_ls = "yes" if options.low_stock_warnings else "no"
+        ans = _prompt_until_valid(
+            PROMPT_LOW_STOCK,
+            default=default_ls,
+            valid_fn=lambda s: s.lower() in VALID_YES_NO,
+            err_msg=ERR_INVALID_YES_NO,
+            input_fn=input_fn,
+            output_fn=output_fn,
+        )
+        if ans is None:
+            eof_hit = True
+        elif ans:
+            options.low_stock_warnings = ans.lower() in {"yes", "y"}
+
+    # Q5: Low-stock threshold
+    if not eof_hit:
+        def _valid_threshold(s: str) -> bool:
+            try:
+                return Decimal(s) > Decimal("0")
+            except InvalidOperation:
+                return False
+
+        ans = _prompt_until_valid(
+            PROMPT_THRESHOLD,
+            default=str(options.low_stock_threshold),
+            valid_fn=_valid_threshold,
+            err_msg=ERR_INVALID_THRESHOLD,
+            input_fn=input_fn,
+            output_fn=output_fn,
+        )
+        if ans is None:
+            eof_hit = True
+        elif ans:
+            options.low_stock_threshold = Decimal(ans)
+
+    # Q6: Output filename
+    if not eof_hit:
+        ans = _prompt_until_valid(
+            PROMPT_OUTPUT,
+            default=options.output_path,
+            valid_fn=lambda s: len(s) > 0,
+            err_msg="Please enter a filename.",
+            input_fn=input_fn,
+            output_fn=output_fn,
+        )
+        if ans is None:
+            eof_hit = True  # noqa: F841 (eof_hit intentionally set, no more questions)
+        elif ans:
+            options.output_path = ans
+
+    output_fn("")
+    return options
+
+
+def main(
+    argv: Optional[list[str]] = None,
+    input_fn: Callable[[], str] = input,
+    output_fn: Callable[..., None] = print,
+    stderr_fn: Optional[Callable[..., None]] = None,
+) -> int:
+    """Main entry point. Returns exit code."""
+    if stderr_fn is None:
+        def stderr_fn(*args, **kwargs):
+            kwargs.setdefault("file", sys.stderr)
+            print(*args, **kwargs)
+
+    parser = build_arg_parser()
+    args = parser.parse_args(argv)
+
+    # Build initial options from CLI args
+    options = ReportOptions(
+        basis=args.basis,
+        group_by=args.group_by,
+        include_dry_goods=args.include_dry_goods,
+        low_stock_warnings=args.low_stock_warnings,
+        low_stock_threshold=args.low_stock_threshold,
+        output_path=args.output_path,
+    )
+
+    # --- Load CSV ---
+    from .csv_loader import load_csv
+
+    try:
+        rows, load_warnings = load_csv(args.csv_path)
+    except FileNotFoundError as exc:
+        stderr_fn(str(exc))
+        return 1
+    except ValueError as exc:
+        stderr_fn(str(exc))
+        return 1
+    except OSError as exc:
+        stderr_fn(str(exc))
+        return 1
+
+    source_file = Path(args.csv_path).name
+    output_fn(MSG_LOADED.format(path=source_file))
+
+    # --- Validation ---
+    from .validation import validate_rows
+    validation_warnings = validate_rows(rows)
+
+    # --- Interactive mode ---
+    if not args.no_interactive:
+        fg_rows_raw = [r for r in rows if r.type1 == "Finished Goods"]
+        dg_rows_raw = [r for r in rows if r.type1 == "Dry Goods"]
+        rows_summary = {
+            "fg_count": len(fg_rows_raw),
+            "dg_count": len(dg_rows_raw),
+            "warehouses": list({r.warehouse for r in rows if r.warehouse}),
+            "units": list({r.units for r in rows if r.units}),
+        }
+        options = run_interactive_prompts(
+            options=options,
+            rows_summary=rows_summary,
+            input_fn=input_fn,
+            output_fn=output_fn,
+        )
+
+    # --- Parse, calculate, aggregate ---
+    from .parser import parse_all_finished_goods
+    from .calculations import compute_nine_le_for_rows, aggregate, find_low_stock
+
+    wine_rows, parse_warnings = parse_all_finished_goods(rows)
+    compute_nine_le_for_rows(wine_rows, options.basis)
+
+    dry_goods_rows = [r for r in rows if r.type1 == "Dry Goods"]
+    aggregated = aggregate(wine_rows, options) if options.group_by != "none" else []
+    low_stock = find_low_stock(wine_rows, options) if options.low_stock_warnings else []
+
+    # Combine all warnings
+    all_warnings = load_warnings + validation_warnings + parse_warnings
+
+    # --- Render report ---
+    from .report import render_report
+
+    report_md = render_report(
+        all_rows=rows,
+        wine_rows=wine_rows,
+        dry_goods_rows=dry_goods_rows,
+        aggregated=aggregated,
+        low_stock_rows=low_stock,
+        warnings=all_warnings,
+        options=options,
+        source_file=source_file,
+    )
+
+    # --- Write report ---
+    try:
+        Path(options.output_path).write_text(report_md, encoding="utf-8")
+    except OSError as exc:
+        stderr_fn(f"Error: could not write report to '{options.output_path}': {exc}")
+        return 1
+
+    output_fn(MSG_REPORT_WRITTEN.format(path=options.output_path))
+    return 0
