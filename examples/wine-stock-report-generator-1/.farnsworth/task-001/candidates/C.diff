+"""Tests for wine_stock_reporter.calculations."""
+
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.models import ParsedWineRow, ReportOptions, StockRow
+from wine_stock_reporter.calculations import (
+    calculate_nine_le,
+    get_basis_qty,
+    compute_nine_le_for_rows,
+    aggregate,
+    find_low_stock,
+)
+
+
+def _make_stock_row(
+    item: str = "100",
+    type1: str = "Finished Goods",
+    on_hand: str = "10.00",
+    allocated: str = "0.00",
+    pending: str = "0.00",
+    available: str = "10.00",
+    units: str = "Cases",
+    description: str = "FV 22 CHR EP NZ 750ml/12p",
+    lot: str = "",
+) -> StockRow:
+    return StockRow(
+        type1=type1,
+        item=item,
+        description=description,
+        client_stock_code="",
+        client_stock_description="",
+        lot=lot,
+        on_hand=Decimal(on_hand),
+        warehouse="Marlborough",
+        allocated=Decimal(allocated),
+        pending=Decimal(pending),
+        available=Decimal(available),
+        units=units,
+    )
+
+
+def _make_wine_row(
+    item: str = "100",
+    variety: str = "Chardonnay",
+    vintage: str = "2022",
+    market: str = "NZ",
+    bottle_size_ml: int = 750,
+    pack_size: int = 12,
+    on_hand: str = "10.00",
+    available: str = "10.00",
+    lot: str = "",
+) -> ParsedWineRow:
+    raw = _make_stock_row(item=item, on_hand=on_hand, available=available, lot=lot)
+    return ParsedWineRow(
+        raw=raw,
+        variety=variety,
+        vintage=vintage,
+        market=market,
+        bottle_size_ml=bottle_size_ml,
+        pack_size=pack_size,
+        nine_le=None,
+    )
+
+
+class TestCalculateNineLE(unittest.TestCase):
+    def test_750ml_12p_gives_one_le_per_case(self):
+        # 48.58 cases of 750ml/12p = 48.58 9LE
+        result = calculate_nine_le(Decimal("48.58"), 750, 12)
+        self.assertEqual(result, Decimal("48.58"))
+
+    def test_750ml_6p_gives_half_le_per_case(self):
+        # 26.67 cases of 750ml/6p = 13.335 9LE
+        result = calculate_nine_le(Decimal("26.67"), 750, 6)
+        # 26.67 * 6 * 0.750 / 9 = 26.67 * 0.5 = 13.335
+        self.assertEqual(result, Decimal("13.335"))
+
+    def test_returns_none_when_bottle_size_unknown(self):
+        result = calculate_nine_le(Decimal("10"), None, 12)
+        self.assertIsNone(result)
+
+    def test_returns_none_when_pack_size_unknown(self):
+        result = calculate_nine_le(Decimal("10"), 750, None)
+        self.assertIsNone(result)
+
+    def test_returns_none_when_both_unknown(self):
+        result = calculate_nine_le(Decimal("10"), None, None)
+        self.assertIsNone(result)
+
+    def test_375ml_12p(self):
+        # 146.50 cases of 375ml/12p: 146.50 * 12 * 0.375 / 9 = 73.25
+        result = calculate_nine_le(Decimal("146.50"), 375, 12)
+        self.assertEqual(result, Decimal("73.25"))
+
+
+class TestGetBasisQty(unittest.TestCase):
+    def test_available_basis_returns_available(self):
+        row = _make_wine_row(on_hand="20.00", available="15.00")
+        qty = get_basis_qty(row, "Available")
+        self.assertEqual(qty, Decimal("15.00"))
+
+    def test_onhand_basis_returns_on_hand(self):
+        row = _make_wine_row(on_hand="20.00", available="15.00")
+        qty = get_basis_qty(row, "OnHand")
+        self.assertEqual(qty, Decimal("20.00"))
+
+
+class TestComputeNineLeForRows(unittest.TestCase):
+    def test_available_basis_used(self):
+        row = _make_wine_row(available="26.67", on_hand="30.00", bottle_size_ml=750, pack_size=6)
+        compute_nine_le_for_rows([row], "Available")
+        self.assertEqual(row.nine_le, Decimal("13.335"))
+
+    def test_onhand_basis_used(self):
+        row = _make_wine_row(available="26.67", on_hand="30.00", bottle_size_ml=750, pack_size=12)
+        compute_nine_le_for_rows([row], "OnHand")
+        self.assertEqual(row.nine_le, Decimal("30.00"))
+
+    def test_none_when_size_missing(self):
+        raw = _make_stock_row()
+        row = ParsedWineRow(raw=raw, bottle_size_ml=None, pack_size=None)
+        compute_nine_le_for_rows([row], "Available")
+        self.assertIsNone(row.nine_le)
+
+
+class TestAggregate(unittest.TestCase):
+    def _make_options(self, group_by="variety", basis="Available"):
+        return ReportOptions(group_by=group_by, basis=basis)
+
+    def test_aggregates_by_variety(self):
+        rows = [
+            _make_wine_row(item="1", variety="Chardonnay", available="10.00"),
+            _make_wine_row(item="2", variety="Chardonnay", available="20.00"),
+            _make_wine_row(item="3", variety="Sauvignon Blanc", available="30.00"),
+        ]
+        options = self._make_options(group_by="variety")
+        for row in rows:
+            compute_nine_le_for_rows([row], "Available")
+        result = aggregate(rows, options)
+        keys = [e["key"] for e in result]
+        self.assertIn("Chardonnay", keys)
+        self.assertIn("Sauvignon Blanc", keys)
+        chard = next(e for e in result if e["key"] == "Chardonnay")
+        self.assertEqual(chard["rows"], 2)
+        self.assertEqual(chard["cases"], Decimal("30.00"))
+
+    def test_aggregates_by_vintage(self):
+        rows = [
+            _make_wine_row(item="1", vintage="2022", available="10.00"),
+            _make_wine_row(item="2", vintage="2023", available="20.00"),
+        ]
+        options = self._make_options(group_by="vintage")
+        for row in rows:
+            compute_nine_le_for_rows([row], "Available")
+        result = aggregate(rows, options)
+        keys = [e["key"] for e in result]
+        self.assertIn("2022", keys)
+        self.assertIn("2023", keys)
+
+    def test_aggregates_by_market(self):
+        rows = [
+            _make_wine_row(item="1", market="NZ", available="10.00"),
+            _make_wine_row(item="2", market="UK", available="20.00"),
+            _make_wine_row(item="3", market="NZ", available="5.00"),
+        ]
+        options = self._make_options(group_by="market")
+        for row in rows:
+            compute_nine_le_for_rows([row], "Available")
+        result = aggregate(rows, options)
+        nz = next(e for e in result if e["key"] == "NZ")
+        self.assertEqual(nz["rows"], 2)
+        self.assertEqual(nz["cases"], Decimal("15.00"))
+
+
+class TestFindLowStock(unittest.TestCase):
+    def test_finds_low_stock_items(self):
+        options = ReportOptions(low_stock_threshold=Decimal("10"))
+        row_low = _make_wine_row(available="5.00")
+        row_ok = _make_wine_row(item="200", available="50.00")
+        compute_nine_le_for_rows([row_low, row_ok], "Available")
+        result = find_low_stock([row_low, row_ok], options)
+        self.assertEqual(len(result), 1)
+        self.assertEqual(result[0].raw.item, "100")
+
+    def test_excludes_items_above_threshold(self):
+        options = ReportOptions(low_stock_threshold=Decimal("10"))
+        row = _make_wine_row(available="20.00")
+        compute_nine_le_for_rows([row], "Available")
+        result = find_low_stock([row], options)
+        self.assertEqual(len(result), 0)
+
+    def test_excludes_rows_with_unknown_nine_le(self):
+        options = ReportOptions(low_stock_threshold=Decimal("10"))
+        raw = _make_stock_row()
+        row = ParsedWineRow(raw=raw, bottle_size_ml=None, pack_size=None, nine_le=None)
+        result = find_low_stock([row], options)
+        self.assertEqual(len(result), 0)
+
+    def test_dry_goods_excluded_from_wine_totals(self):
+        """Dry goods rows (type1=Dry Goods) do not go through parse_all_finished_goods,
+        so they never appear in wine calculations."""
+        from wine_stock_reporter.parser import parse_all_finished_goods
+        fg = _make_stock_row(item="1", type1="Finished Goods")
+        dg = _make_stock_row(item="2", type1="Dry Goods")
+        wine_rows, _ = parse_all_finished_goods([fg, dg])
+        self.assertEqual(len(wine_rows), 1)
+        self.assertEqual(wine_rows[0].raw.type1, "Finished Goods")
+
+
+if __name__ == "__main__":
+    unittest.main()
