@@ -0,0 +1,122 @@
+"""CSV loader — load, validate, and normalise the warehouse stock CSV."""
+
+from __future__ import annotations
+
+import csv
+from decimal import Decimal, InvalidOperation
+from pathlib import Path
+from typing import Optional
+
+from .models import StockRow, ValidationWarning
+
+# Required columns
+REQUIRED_COLUMNS = [
+    "Type1",
+    "Item",
+    "Description",
+    "OnHand",
+    "Warehouse",
+    "Allocated",
+    "Pending",
+    "Available",
+    "Units",
+]
+
+# Error messages — kept as constants per single-source rule
+ERR_FILE_NOT_FOUND = "Error: file not found: {path}"
+ERR_REQUIRED_COLUMN = "Error: required column '{col}' was not found in CSV."
+ERR_UNREADABLE_CSV = "Error: could not read CSV file '{path}': {reason}"
+
+
+def _parse_decimal(raw: str) -> tuple[Optional[Decimal], Optional[str]]:
+    """Parse a raw string to Decimal, stripping whitespace, commas, etc.
+
+    Returns (value, warning_message) where warning_message is None on success.
+    Returns (Decimal('0'), warning_message) on parse failure.
+    """
+    if raw is None:
+        return Decimal("0"), None
+    cleaned = raw.strip().replace(",", "")
+    if cleaned == "" or cleaned == "-":
+        return Decimal("0"), None
+    try:
+        return Decimal(cleaned), None
+    except InvalidOperation:
+        return Decimal("0"), f"Could not parse numeric value '{raw}'"
+
+
+def load_csv(path: str) -> tuple[list[StockRow], list[ValidationWarning]]:
+    """Load and validate a warehouse stock CSV file.
+
+    Args:
+        path: Path to the CSV file.
+
+    Returns:
+        (rows, warnings) — rows is a list of StockRow; warnings is a list of
+        ValidationWarning for non-fatal data issues.
+
+    Raises:
+        FileNotFoundError: if the file does not exist (caller converts to exit 1).
+        ValueError: if a required column is missing (caller converts to exit 1).
+        OSError: if the file cannot be read (caller converts to exit 1).
+    """
+    p = Path(path)
+    if not p.exists():
+        raise FileNotFoundError(ERR_FILE_NOT_FOUND.format(path=path))
+
+    try:
+        with p.open(newline="", encoding="utf-8-sig") as fh:
+            reader = csv.DictReader(fh)
+            if reader.fieldnames is None:
+                raise ValueError(ERR_REQUIRED_COLUMN.format(col=REQUIRED_COLUMNS[0]))
+
+            # Normalise header names (strip whitespace)
+            field_names = [f.strip() for f in reader.fieldnames]
+
+            for col in REQUIRED_COLUMNS:
+                if col not in field_names:
+                    raise ValueError(ERR_REQUIRED_COLUMN.format(col=col))
+
+            rows: list[StockRow] = []
+            warnings: list[ValidationWarning] = []
+
+            for raw_row in reader:
+                # Normalise keys
+                row: dict[str, str] = {k.strip(): v for k, v in raw_row.items() if k}
+
+                item = row.get("Item", "").strip()
+
+                def parse_num(field: str) -> Decimal:
+                    val, warn = _parse_decimal(row.get(field, ""))
+                    if warn:
+                        warnings.append(ValidationWarning(
+                            message=f"Non-numeric value in column '{field}' for item {item!r}: {row.get(field, '')!r}",
+                            item=item,
+                        ))
+                    return val
+
+                on_hand = parse_num("OnHand")
+                allocated = parse_num("Allocated")
+                pending = parse_num("Pending")
+                available = parse_num("Available")
+
+                stock_row = StockRow(
+                    type1=row.get("Type1", "").strip(),
+                    item=item,
+                    description=row.get("Description", "").strip(),
+                    client_stock_code=row.get("ClientStockCode", "").strip(),
+                    client_stock_description=row.get("ClientStockDescription", "").strip(),
+                    lot=row.get("Lot", "").strip(),
+                    on_hand=on_hand,
+                    warehouse=row.get("Warehouse", "").strip(),
+                    allocated=allocated,
+                    pending=pending,
+                    available=available,
+                    units=row.get("Units", "").strip(),
+                )
+                rows.append(stock_row)
+
+    except (csv.Error, UnicodeDecodeError) as exc:
+        raise OSError(ERR_UNREADABLE_CSV.format(path=path, reason=exc)) from exc
+
+    return rows, warnings
