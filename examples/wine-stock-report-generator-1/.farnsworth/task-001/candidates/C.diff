+"""Data models for the Wine Stock Report Generator."""
+
+from __future__ import annotations
+from dataclasses import dataclass, field
+from decimal import Decimal
+from typing import Optional
+
+
+# ---------------------------------------------------------------------------
+# Raw CSV row
+# ---------------------------------------------------------------------------
+
+@dataclass
+class StockRow:
+    """A single raw row from the warehouse CSV."""
+    type1: str
+    item: str
+    description: str
+    client_stock_code: str
+    client_stock_description: str
+    lot: str
+    on_hand: Decimal
+    warehouse: str
+    allocated: Decimal
+    pending: Decimal
+    available: Decimal
+    units: str
+
+
+# ---------------------------------------------------------------------------
+# Parsed finished-goods wine row
+# ---------------------------------------------------------------------------
+
+@dataclass
+class ParsedWineRow:
+    """A finished-goods row with parsed wine metadata."""
+    raw: StockRow
+
+    # Parsed from description
+    prefix: str = ""
+    vintage: str = ""          # 4-digit string e.g. "2022"
+    variety_code: str = ""
+    variety: str = ""          # mapped from variety_code
+    brand_code: str = ""
+    market: str = ""
+    bottle_size_ml: Optional[int] = None    # e.g. 750
+    pack_size: Optional[int] = None         # e.g. 12 or 6
+    extra_description: str = ""
+
+    # Calculated
+    nine_le: Optional[Decimal] = None       # None when size unknown
+
+    # Parse warnings attached to this row
+    warnings: list[str] = field(default_factory=list)
+
+
+# ---------------------------------------------------------------------------
+# Report options
+# ---------------------------------------------------------------------------
+
+@dataclass
+class ReportOptions:
+    """User-chosen (or defaulted) report configuration."""
+    basis: str = "Available"                # "OnHand" or "Available"
+    group_by: str = "variety"              # variety|vintage|market|pack_size|lot|none
+    include_dry_goods: bool = True
+    low_stock_warnings: bool = True
+    low_stock_threshold: Decimal = Decimal("10")
+    output_path: str = "stock-report.md"
+
+
+# ---------------------------------------------------------------------------
+# Validation warning
+# ---------------------------------------------------------------------------
+
+@dataclass
+class ValidationWarning:
+    """A non-fatal data quality warning."""
+    message: str
+    item: str = ""            # item identifier for context, may be empty
