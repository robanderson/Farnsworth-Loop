+++ b/wine_stock_reporter/report.py
@@ -0,0 +1,197 @@
+"""Markdown report renderer for the Wine Stock Report Generator."""
+
+from __future__ import annotations
+
+import datetime
+from decimal import Decimal
+from typing import Optional
+
+from .models import ParsedWineRow, ReportOptions, StockRow, ValidationWarning
+
+# Section heading constants (single-source per seed tip #7)
+HEADING_REPORT = "# Wine Stock Report"
+HEADING_EXEC_SUMMARY = "## Executive Summary"
+HEADING_GROUPING_PREFIX = "## Stock by "
+HEADING_DETAILED = "## Detailed Finished Goods"
+HEADING_LOW_STOCK = "## Low Stock Warnings"
+HEADING_DRY_GOODS = "## Dry Goods Summary"
+HEADING_DATA_WARNINGS = "## Data Warnings"
+
+# Sentinel for unknown 9LE
+NINE_LE_UNKNOWN = "—"
+
+
+def _fmt_decimal(val: Optional[Decimal], places: int = 2) -> str:
+    """Format a Decimal to a fixed number of decimal places, or return NINE_LE_UNKNOWN."""
+    if val is None:
+        return NINE_LE_UNKNOWN
+    return f"{val:.{places}f}"
+
+
+def _md_table_row(cells: list[str]) -> str:
+    return "| " + " | ".join(cells) + " |"
+
+
+def _md_table_separator(alignments: list[str]) -> str:
+    """alignments: list of 'left', 'right', 'center'"""
+    parts = []
+    for a in alignments:
+        if a == "right":
+            parts.append("---:")
+        elif a == "center":
+            parts.append(":---:")
+        else:
+            parts.append("---")
+    return "| " + " | ".join(parts) + " |"
+
+
+def render_report(
+    all_rows: list[StockRow],
+    wine_rows: list[ParsedWineRow],
+    dry_goods_rows: list[StockRow],
+    aggregated: list[dict],
+    low_stock_rows: list[ParsedWineRow],
+    warnings: list[ValidationWarning],
+    options: ReportOptions,
+    source_file: str,
+    generated_date: Optional[str] = None,
+) -> str:
+    """Render the complete Markdown report and return it as a string."""
+    if generated_date is None:
+        generated_date = datetime.date.today().isoformat()
+
+    lines: list[str] = []
+
+    # --- Header ---
+    lines.append(HEADING_REPORT)
+    lines.append("")
+    lines.append(f"Generated: {generated_date}")
+    lines.append(f"Source file: {source_file}")
+
+    # Warehouse(s)
+    warehouses = sorted({r.warehouse for r in all_rows if r.warehouse})
+    if warehouses:
+        lines.append(f"Warehouse: {', '.join(warehouses)}")
+    else:
+        lines.append("Warehouse: (unknown)")
+
+    lines.append(f"Stock basis: {options.basis}")
+    lines.append("")
+
+    # --- Executive Summary ---
+    lines.append(HEADING_EXEC_SUMMARY)
+    lines.append("")
+
+    fg_rows = [r for r in all_rows if r.type1 == "Finished Goods"]
+    dg_rows = [r for r in all_rows if r.type1 == "Dry Goods"]
+
+    total_wine_nine_le = sum(
+        (r.nine_le for r in wine_rows if r.nine_le is not None),
+        Decimal("0"),
+    )
+
+    def _basis_qty(r: StockRow) -> Decimal:
+        return r.on_hand if options.basis == "OnHand" else r.available
+
+    total_cases = sum((_basis_qty(r) for r in fg_rows), Decimal("0"))
+    total_allocated = sum((r.allocated for r in fg_rows), Decimal("0"))
+    total_pending = sum((r.pending for r in fg_rows), Decimal("0"))
+
+    # Lowest stock item (by 9LE)
+    with_nine_le = [r for r in wine_rows if r.nine_le is not None]
+    if with_nine_le:
+        lowest = min(with_nine_le, key=lambda r: r.nine_le)
+        lowest_str = f"{lowest.raw.item} ({_fmt_decimal(lowest.nine_le)} 9LE)"
+    else:
+        lowest_str = "N/A"
+
+    lines.append(f"- Finished Goods rows: {len(fg_rows)}")
+    lines.append(f"- Dry Goods rows: {len(dg_rows)}")
+    lines.append(f"- Total wine stock: {_fmt_decimal(total_wine_nine_le)} 9LE")
+    lines.append(f"- Total {options.basis.lower()} cases: {_fmt_decimal(total_cases)}")
+    lines.append(f"- Total allocated cases: {_fmt_decimal(total_allocated)}")
+    lines.append(f"- Total pending cases: {_fmt_decimal(total_pending)}")
+    lines.append(f"- Lowest stock item: {lowest_str}")
+    lines.append(f"- Data warnings: {len(warnings)}")
+    lines.append("")
+
+    # --- Grouping Section ---
+    if options.group_by != "none" and aggregated:
+        group_label = options.group_by.replace("_", " ").title()
+        lines.append(f"{HEADING_GROUPING_PREFIX}{group_label}")
+        lines.append("")
+        lines.append(_md_table_row([group_label, "Rows", "Cases", "9LE"]))
+        lines.append(_md_table_separator(["left", "right", "right", "right"]))
+        for entry in aggregated:
+            lines.append(_md_table_row([
+                entry["key"],
+                str(entry["rows"]),
+                _fmt_decimal(entry["cases"]),
+                _fmt_decimal(entry["nine_le"]),
+            ]))
+        lines.append("")
+
+    # --- Detailed Finished Goods ---
+    lines.append(HEADING_DETAILED)
+    lines.append("")
+    lines.append(_md_table_row(["Item", "Description", "Lot", "OnHand", "Allocated", "Pending", "Available", "Units", "9LE"]))
+    lines.append(_md_table_separator(["left", "left", "left", "right", "right", "right", "right", "left", "right"]))
+
+    for row in wine_rows:
+        r = row.raw
+        lines.append(_md_table_row([
+            r.item,
+            r.description,
+            r.lot,
+            _fmt_decimal(r.on_hand),
+            _fmt_decimal(r.allocated),
+            _fmt_decimal(r.pending),
+            _fmt_decimal(r.available),
+            r.units,
+            _fmt_decimal(row.nine_le),
+        ]))
+    lines.append("")
+
+    # --- Low Stock Warnings ---
+    if options.low_stock_warnings:
+        lines.append(HEADING_LOW_STOCK)
+        lines.append("")
+        if low_stock_rows:
+            for row in low_stock_rows:
+                lines.append(
+                    f"- Item {row.raw.item} ({row.raw.description}) "
+                    f"has only {_fmt_decimal(row.nine_le)} 9LE {options.basis.lower()}."
+                )
+        else:
+            lines.append("No low-stock items found.")
+        lines.append("")
+
+    # --- Dry Goods Summary ---
+    if options.include_dry_goods:
+        lines.append(HEADING_DRY_GOODS)
+        lines.append("")
+        if dry_goods_rows:
+            lines.append(_md_table_row(["Item", "Description", "Available", "Units"]))
+            lines.append(_md_table_separator(["left", "left", "right", "left"]))
+            for r in dry_goods_rows:
+                lines.append(_md_table_row([
+                    r.item,
+                    r.description,
+                    _fmt_decimal(r.available),
+                    r.units,
+                ]))
+        else:
+            lines.append("No dry goods rows found.")
+        lines.append("")
+
+    # --- Data Warnings ---
+    lines.append(HEADING_DATA_WARNINGS)
+    lines.append("")
+    if warnings:
+        for w in warnings:
+            lines.append(f"- {w.message}")
+    else:
+        lines.append("No data warnings.")
+    lines.append("")
+
+    return "\n".join(lines)
