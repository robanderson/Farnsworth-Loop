+"""Calculations: 9LE, aggregation, low-stock identification."""
+
+from __future__ import annotations
+
+from decimal import Decimal
+from typing import Optional
+
+from .models import ParsedWineRow, ReportOptions, StockRow
+
+
+_NINE = Decimal("9")
+_ML_PER_LITRE = Decimal("1000")
+
+
+def calculate_nine_le(
+    cases: Decimal,
+    bottle_size_ml: Optional[int],
+    pack_size: Optional[int],
+) -> Optional[Decimal]:
+    """Calculate 9-litre-equivalents for a given case quantity and bottle/pack.
+
+    Returns None when bottle_size_ml or pack_size is unknown.
+    Uses Decimal arithmetic throughout; never floats.
+    """
+    if bottle_size_ml is None or pack_size is None:
+        return None
+    litres = cases * Decimal(str(pack_size)) * Decimal(str(bottle_size_ml)) / _ML_PER_LITRE
+    return litres / _NINE
+
+
+def get_basis_qty(row: ParsedWineRow, basis: str) -> Decimal:
+    """Return the stock quantity for the chosen basis ('OnHand' or 'Available')."""
+    if basis == "OnHand":
+        return row.raw.on_hand
+    return row.raw.available
+
+
+def compute_nine_le_for_rows(
+    rows: list[ParsedWineRow],
+    basis: str,
+) -> None:
+    """Mutate each ParsedWineRow in-place to set nine_le based on the chosen basis."""
+    for row in rows:
+        qty = get_basis_qty(row, basis)
+        row.nine_le = calculate_nine_le(qty, row.bottle_size_ml, row.pack_size)
+
+
+# ---------------------------------------------------------------------------
+# Aggregation
+# ---------------------------------------------------------------------------
+
+def _group_key(row: ParsedWineRow, group_by: str) -> str:
+    """Return the grouping key for a parsed wine row."""
+    if group_by == "variety":
+        return row.variety or "Unknown"
+    if group_by == "vintage":
+        return row.vintage or "Unknown"
+    if group_by == "market":
+        return row.market or "Unknown"
+    if group_by == "pack_size":
+        return str(row.pack_size) + "p" if row.pack_size else "Unknown"
+    if group_by == "lot":
+        return row.raw.lot or "Unknown"
+    return "All"  # group_by == "none"
+
+
+def aggregate(
+    rows: list[ParsedWineRow],
+    options: ReportOptions,
+) -> list[dict]:
+    """Aggregate parsed wine rows by the chosen group_by key.
+
+    Returns a list of dicts sorted by key:
+    [{"key": str, "rows": int, "cases": Decimal, "nine_le": Decimal}, ...]
+
+    Cases are always summed (even when 9LE is unknown).
+    9LE excludes rows where nine_le is None.
+    """
+    totals: dict[str, dict] = {}
+
+    for row in rows:
+        key = _group_key(row, options.group_by)
+        if key not in totals:
+            totals[key] = {"key": key, "rows": 0, "cases": Decimal("0"), "nine_le": Decimal("0")}
+        entry = totals[key]
+        entry["rows"] += 1
+        qty = get_basis_qty(row, options.basis)
+        entry["cases"] += qty
+        if row.nine_le is not None:
+            entry["nine_le"] += row.nine_le
+
+    return sorted(totals.values(), key=lambda e: e["key"])
+
+
+def find_low_stock(
+    rows: list[ParsedWineRow],
+    options: ReportOptions,
+) -> list[ParsedWineRow]:
+    """Return rows whose 9LE is below the low-stock threshold."""
+    result = []
+    for row in rows:
+        if row.nine_le is not None and row.nine_le < options.low_stock_threshold:
+            result.append(row)
+    return result
