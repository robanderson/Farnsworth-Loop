+def _make_stock_row(
+    item: str = "100",
+    type1: str = "Finished Goods",
+    description: str = "FV 22 CHR EP NZ 750ml/12p",
+    on_hand: str = "10.00",
+    allocated: str = "0.00",
+    pending: str = "0.00",
+    available: str = "10.00",
+    units: str = "Cases",
+    lot: str = "",
+) -> StockRow:
+    return StockRow(
+        type1=type1,
+        item=item,
+        description=description,
+        client_stock_code="",
+        client_stock_description="",
+        lot=lot,
+        on_hand=Decimal(on_hand),
+        warehouse="Marlborough",
+        allocated=Decimal(allocated),
+        pending=Decimal(pending),
+        available=Decimal(available),
+        units=units,
+    )
+
+
+def _make_wine_row(
+    item: str = "100",
+    variety: str = "Chardonnay",
+    vintage: str = "2022",
+    market: str = "NZ",
+    bottle_size_ml: int = 750,
+    pack_size: int = 12,
+    available: str = "10.00",
+    nine_le: str = "10.00",
+) -> ParsedWineRow:
+    raw = _make_stock_row(item=item, available=available)
+    return ParsedWineRow(
+        raw=raw,
+        variety=variety,
+        vintage=vintage,
+        market=market,
+        bottle_size_ml=bottle_size_ml,
+        pack_size=pack_size,
+        nine_le=Decimal(nine_le),
+    )
+
+
+def _render_basic(**kwargs) -> str:
+    """Render a minimal report with sensible defaults."""
+    defaults = dict(
+        all_rows=[_make_stock_row()],
+        wine_rows=[_make_wine_row()],
+        dry_goods_rows=[],
+        aggregated=[{"key": "Chardonnay", "rows": 1, "cases": Decimal("10.00"), "nine_le": Decimal("10.00")}],
+        low_stock_rows=[],
+        warnings=[],
+        options=ReportOptions(),
+        source_file="test.csv",
+        generated_date="2026-06-12",
+    )
+    defaults.update(kwargs)
+    return render_report(**defaults)
