+++ b/wine_stock_reporter/parser.py
@@ -0,0 +1,172 @@
+"""Description parser for Finished Goods wine rows."""
+
+from __future__ import annotations
+
+import re
+from typing import Optional
+
+from .models import ParsedWineRow, StockRow, ValidationWarning
+
+# ---------------------------------------------------------------------------
+# Variety code mapping (single-source constant)
+# ---------------------------------------------------------------------------
+
+VARIETY_MAP: dict[str, str] = {
+    "CHR": "Chardonnay",
+    "SAB": "Sauvignon Blanc",
+    "PIN": "Pinot Noir",
+    "PIG": "Pinot Gris",
+    "PRO": "Rosé",
+    "RDB": "Red Blend",
+    "MXD": "Mixed / Consolidated",
+}
+
+# Warning message templates (module-level constants)
+WARN_UNKNOWN_VARIETY = "Unknown variety code '{code}' in item {item}."
+WARN_UNPARSEABLE_DESC = "Could not fully parse description for item {item}: {desc!r}"
+WARN_UNKNOWN_BOTTLE_SIZE = "Could not parse bottle size for item {item}: {desc!r}"
+WARN_UNKNOWN_PACK_SIZE = "Could not parse pack size for item {item}: {desc!r}"
+
+# ---------------------------------------------------------------------------
+# Description parsing
+#
+# Canonical format: <PREFIX> <YY> <VARIETY> <BRAND> <MARKET> <BOTTLEml>/<PACKp> [extra...]
+# e.g. FV 22 CHR EP NZ 750ml/12p
+#      FV 22 RDB EP UK 750ml/6p Legacy Red
+#
+# The parser is TOLERANT: unknown fields stay blank/Unknown; no exception raised.
+# ---------------------------------------------------------------------------
+
+# Regex for the bottle-size/pack-size token: e.g. 750ml/12p or 375ml/6p
+_SIZE_RE = re.compile(r"(\d+)ml/(\d+)p", re.IGNORECASE)
+
+# Regex for two-digit vintage (standalone token) or NV (non-vintage)
+_VINTAGE_RE = re.compile(r"^\d{2}$|^NV$")
+
+# Regex for known market codes (2–3 uppercase letters, standalone token)
+_MARKET_RE = re.compile(r"^[A-Z]{2,3}\+?$")
+
+# Known brand/label codes — we treat any ALL-CAPS 2–3 letter token that is NOT
+# a market or variety as a potential brand code.  We collect them positionally.
+
+
+def expand_vintage(raw: str) -> str:
+    """Convert a two-digit vintage string to a four-digit year string."""
+    return "20" + raw
+
+
+def _find_size_token(tokens: list[str]) -> tuple[Optional[int], Optional[int], Optional[int]]:
+    """Return (bottle_ml, pack_size, token_index) or (None, None, -1)."""
+    for i, tok in enumerate(tokens):
+        m = _SIZE_RE.fullmatch(tok)
+        if m:
+            return int(m.group(1)), int(m.group(2)), i
+    return None, None, -1
+
+
+def parse_description(row: StockRow) -> ParsedWineRow:
+    """Parse a Finished Goods Description field into structured wine metadata.
+
+    Never raises — on parse failure, returns a ParsedWineRow with warnings.
+    """
+    parsed = ParsedWineRow(raw=row)
+    desc = row.description
+    item = row.item
+    warnings: list[ValidationWarning] = []
+
+    tokens = desc.split()
+    if not tokens:
+        warnings.append(ValidationWarning(
+            message=WARN_UNPARSEABLE_DESC.format(item=item, desc=desc),
+            item=item,
+        ))
+        parsed.warnings = warnings
+        parsed.variety = "Unknown"
+        return parsed
+
+    idx = 0
+
+    # Token 0: prefix (e.g. FV)
+    parsed.prefix = tokens[idx] if idx < len(tokens) else ""
+    idx += 1
+
+    # Token 1: two-digit vintage or NV (non-vintage)
+    if idx < len(tokens) and _VINTAGE_RE.match(tokens[idx]):
+        raw_vintage = tokens[idx]
+        if raw_vintage == "NV":
+            parsed.vintage = "NV"
+        else:
+            parsed.vintage = expand_vintage(raw_vintage)
+        idx += 1
+
+    # Token 2: variety code
+    if idx < len(tokens):
+        code = tokens[idx]
+        if code.isupper() and len(code) <= 5:
+            parsed.variety_code = code
+            if code in VARIETY_MAP:
+                parsed.variety = VARIETY_MAP[code]
+            else:
+                parsed.variety = "Unknown"
+                warnings.append(ValidationWarning(
+                    message=WARN_UNKNOWN_VARIETY.format(code=code, item=item),
+                    item=item,
+                ))
+            idx += 1
+
+    # Token 3: brand/code (e.g. EP, GL, SSK, CON)
+    if idx < len(tokens):
+        tok = tokens[idx]
+        if tok.replace("-", "").isupper():
+            parsed.brand_code = tok
+            idx += 1
+
+    # Token 4: market code (e.g. NZ, UK, US, CA, AN, UC, X+, CC, CON, ANU)
+    if idx < len(tokens):
+        tok = tokens[idx]
+        # Market codes are uppercase-ish 2-4 char tokens; they may contain + or digits
+        if re.match(r"^[A-Z0-9]{1,4}\+?$", tok):
+            parsed.market = tok
+            idx += 1
+
+    # Next: find the size token (e.g. 750ml/12p) — may not be next if there's extra
+    remaining = tokens[idx:]
+    bottle_ml, pack_size, rel_idx = _find_size_token(remaining)
+
+    if bottle_ml is not None:
+        parsed.bottle_size_ml = bottle_ml
+        parsed.pack_size = pack_size
+        # Anything after the size token is extra description
+        extra_tokens = remaining[rel_idx + 1:]
+        parsed.extra_description = " ".join(extra_tokens)
+    else:
+        # Could not find size token
+        warnings.append(ValidationWarning(
+            message=WARN_UNKNOWN_BOTTLE_SIZE.format(item=item, desc=desc),
+            item=item,
+        ))
+        # Still record whatever we parsed
+        parsed.extra_description = " ".join(remaining)
+
+    # Set default variety if still unknown
+    if not parsed.variety:
+        parsed.variety = "Unknown"
+
+    parsed.warnings = warnings
+    return parsed
+
+
+def parse_all_finished_goods(
+    rows: list[StockRow],
+) -> tuple[list[ParsedWineRow], list[ValidationWarning]]:
+    """Parse all Finished Goods rows and return (parsed_rows, all_warnings)."""
+    parsed_rows: list[ParsedWineRow] = []
+    all_warnings: list[ValidationWarning] = []
+
+    for row in rows:
+        if row.type1 == "Finished Goods":
+            parsed = parse_description(row)
+            parsed_rows.append(parsed)
+            all_warnings.extend(parsed.warnings)
+
+    return parsed_rows, all_warnings
