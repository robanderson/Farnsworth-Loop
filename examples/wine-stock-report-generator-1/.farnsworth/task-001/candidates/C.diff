+"""Validation: row-level data quality checks producing non-fatal warnings."""
+
+from __future__ import annotations
+
+from decimal import Decimal
+
+from .models import ParsedWineRow, StockRow, ValidationWarning
+
+# Warning message constants (single-source per seed tip #7)
+WARN_AVAIL_GT_ONHAND = "Available ({avail}) greater than OnHand ({onhand}) for item {item}."
+WARN_NEGATIVE_STOCK = "Negative stock value in column '{col}' ({val}) for item {item}."
+WARN_UNKNOWN_TYPE1 = "Unknown Type1 value '{type1}' for item {item}."
+WARN_UNKNOWN_UNITS = "Unknown Units value '{units}' for item {item}."
+WARN_FG_NOT_CASES = "Finished Goods item {item} is measured in '{units}', expected 'Cases'."
+WARN_DG_UNEXPECTED_UNITS = "Dry Goods item {item} has unexpected units '{units}'."
+WARN_MATERIAL_MISMATCH = (
+    "Stock balance mismatch for item {item}: "
+    "OnHand({onhand}) - Allocated({alloc}) - Pending({pend}) = {calc}, "
+    "but Available = {avail}."
+)
+WARN_EMPTY_DESCRIPTION = "Empty description for item {item}."
+
+_KNOWN_TYPE1 = {"Finished Goods", "Dry Goods"}
+_KNOWN_UNITS = {"Cases", "Eaches"}
+_TOLERANCE = Decimal("0.01")
+
+
+def validate_rows(rows: list[StockRow]) -> list[ValidationWarning]:
+    """Run all row-level validation checks and return a list of warnings."""
+    warnings: list[ValidationWarning] = []
+
+    for row in rows:
+        item = row.item
+
+        # Unknown Type1
+        if row.type1 not in _KNOWN_TYPE1:
+            warnings.append(ValidationWarning(
+                message=WARN_UNKNOWN_TYPE1.format(type1=row.type1, item=item),
+                item=item,
+            ))
+
+        # Unknown Units
+        if row.units not in _KNOWN_UNITS:
+            warnings.append(ValidationWarning(
+                message=WARN_UNKNOWN_UNITS.format(units=row.units, item=item),
+                item=item,
+            ))
+
+        # Finished Goods not in Cases
+        if row.type1 == "Finished Goods" and row.units != "Cases":
+            warnings.append(ValidationWarning(
+                message=WARN_FG_NOT_CASES.format(item=item, units=row.units),
+                item=item,
+            ))
+
+        # Dry Goods in unexpected units (not Eaches or Cases)
+        if row.type1 == "Dry Goods" and row.units not in {"Eaches", "Cases"}:
+            warnings.append(ValidationWarning(
+                message=WARN_DG_UNEXPECTED_UNITS.format(item=item, units=row.units),
+                item=item,
+            ))
+
+        # Negative stock values
+        for col_name, val in [("OnHand", row.on_hand), ("Allocated", row.allocated),
+                               ("Pending", row.pending), ("Available", row.available)]:
+            if val < Decimal("0"):
+                warnings.append(ValidationWarning(
+                    message=WARN_NEGATIVE_STOCK.format(col=col_name, val=val, item=item),
+                    item=item,
+                ))
+
+        # Available > OnHand
+        if row.available > row.on_hand:
+            warnings.append(ValidationWarning(
+                message=WARN_AVAIL_GT_ONHAND.format(
+                    avail=row.available, onhand=row.on_hand, item=item
+                ),
+                item=item,
+            ))
+
+        # Material mismatch: OnHand - Allocated - Pending should equal Available
+        expected = row.on_hand - row.allocated - row.pending
+        if abs(expected - row.available) > _TOLERANCE:
+            warnings.append(ValidationWarning(
+                message=WARN_MATERIAL_MISMATCH.format(
+                    item=item,
+                    onhand=row.on_hand,
+                    alloc=row.allocated,
+                    pend=row.pending,
+                    calc=expected,
+                    avail=row.available,
+                ),
+                item=item,
+            ))
+
+        # Empty description
+        if not row.description:
+            warnings.append(ValidationWarning(
+                message=WARN_EMPTY_DESCRIPTION.format(item=item),
+                item=item,
+            ))
+
+    return warnings
