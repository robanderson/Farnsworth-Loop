+"""Tests for wine_stock_reporter.parser."""
+
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.models import StockRow
+from wine_stock_reporter.parser import (
+    parse_description,
+    parse_all_finished_goods,
+    expand_vintage,
+    VARIETY_MAP,
+    WARN_UNKNOWN_VARIETY,
+    WARN_UNPARSEABLE_DESC,
+)
+
+
+def _make_row(description: str, item: str = "999999", type1: str = "Finished Goods") -> StockRow:
+    """Build a StockRow directly from pinned values."""
+    return StockRow(
+        type1=type1,
+        item=item,
+        description=description,
+        client_stock_code="",
+        client_stock_description="",
+        lot="",
+        on_hand=Decimal("10.00"),
+        warehouse="Marlborough",
+        allocated=Decimal("0.00"),
+        pending=Decimal("0.00"),
+        available=Decimal("10.00"),
+        units="Cases",
+    )
+
+
+class TestExpandVintage(unittest.TestCase):
+    def test_expands_22_to_2022(self):
+        self.assertEqual(expand_vintage("22"), "2022")
+
+    def test_expands_20_to_2020(self):
+        self.assertEqual(expand_vintage("20"), "2020")
+
+    def test_expands_25_to_2025(self):
+        self.assertEqual(expand_vintage("25"), "2025")
+
+    def test_expands_00_to_2000(self):
+        self.assertEqual(expand_vintage("00"), "2000")
+
+
+class TestParseDescription(unittest.TestCase):
+    def test_parses_fv_22_chr_ep_nz_750ml_12p(self):
+        row = _make_row("FV 22 CHR EP NZ 750ml/12p", item="747691")
+        parsed = parse_description(row)
+        self.assertEqual(parsed.prefix, "FV")
