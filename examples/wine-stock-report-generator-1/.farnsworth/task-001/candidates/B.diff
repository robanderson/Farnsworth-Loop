+"""Data models for the Wine Stock Report Generator.
+
+All data fields are presentation-neutral: no glyphs, emoji, or markup
+embedded in model values. The rendering layer owns all presentation.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from decimal import Decimal
+from typing import Optional
+
+
+# ---------------------------------------------------------------------------
+# Raw stock row (as loaded from CSV, before description parsing)
+# ---------------------------------------------------------------------------
+
+@dataclass
+class StockRow:
+    """Represents one row of the warehouse stock CSV, with cleaned numerics."""
+
+    type1: str                    # "Finished Goods" or "Dry Goods"
+    item: str
+    description: str
+    client_stock_code: str        # may be empty
+    client_stock_description: str # may be empty
+    lot: str                      # may be empty
+    on_hand: Decimal
+    warehouse: str
+    allocated: Decimal
+    pending: Decimal
+    available: Decimal
+    units: str                    # "Cases" or "Eaches"
+
+
+# ---------------------------------------------------------------------------
+# Parsed wine row (Finished Goods only, after description parsing)
+# ---------------------------------------------------------------------------
+
+@dataclass
+class ParsedWineRow:
+    """Finished Goods row with parsed description fields attached."""
+
+    raw: StockRow
+
+    # Parsed from Description; None if unparseable
+    prefix: Optional[str] = None
+    vintage: Optional[str] = None       # Four-digit string, e.g. "2022"
+    variety_code: Optional[str] = None
+    variety: Optional[str] = None       # Full name, e.g. "Chardonnay"
+    brand_code: Optional[str] = None
+    market: Optional[str] = None
+    bottle_size_ml: Optional[int] = None
+    pack_size: Optional[int] = None
+    extra_description: Optional[str] = None
+
+    # 9LE value; None when bottle/pack size cannot be parsed
+    nine_le: Optional[Decimal] = None
+
+
+# ---------------------------------------------------------------------------
+# Report options (user configuration)
+# ---------------------------------------------------------------------------
+
+@dataclass
+class ReportOptions:
+    """All user-configurable options that control report generation."""
+
+    basis: str = "Available"          # "OnHand" or "Available"
+    group_by: str = "variety"         # variety|vintage|market|pack_size|lot|none
+    include_dry_goods: bool = True
+    low_stock_warnings: bool = True
+    low_stock_threshold: Decimal = Decimal("10")
+    output_path: str = "stock-report.md"
+
+
+# ---------------------------------------------------------------------------
+# Validation warning
+# ---------------------------------------------------------------------------
+
+@dataclass
+class ValidationWarning:
+    """A non-fatal warning produced during loading, parsing, or validation."""
+
+    message: str
+    item: Optional[str] = None    # Item number for context, if available
+
+
+# ---------------------------------------------------------------------------
+# Aggregation result (used for grouping tables)
+# ---------------------------------------------------------------------------
+
+@dataclass
+class GroupRow:
+    """One row in a grouped summary table."""
+
+    key: str          # The group label (e.g. variety name, vintage year)
+    row_count: int
+    cases: Decimal
+    nine_le: Decimal
+
+
+# ---------------------------------------------------------------------------
+# Report data bundle (all data needed to render the report)
+# ---------------------------------------------------------------------------
+
+@dataclass
+class ReportData:
+    """Aggregated data and metadata used to render the Markdown report."""
+
+    options: ReportOptions
+    source_file: str
+    warehouses: list[str]
+    finished_goods: list[ParsedWineRow] = field(default_factory=list)
+    dry_goods: list[StockRow] = field(default_factory=list)
+    warnings: list[ValidationWarning] = field(default_factory=list)
