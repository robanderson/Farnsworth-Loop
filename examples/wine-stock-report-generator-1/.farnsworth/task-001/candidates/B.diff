+"""9LE calculations and aggregation for the Wine Stock Report Generator.
+
+All arithmetic uses decimal.Decimal to avoid floating-point drift.
+Floats are only used at the formatting edge (str formatting in report.py).
+"""
+
+from __future__ import annotations
+
+from decimal import Decimal
+from typing import Optional
+
+from .models import GroupRow, ParsedWineRow, ReportOptions, StockRow
+
+# ---------------------------------------------------------------------------
+# Constants
+# ---------------------------------------------------------------------------
+
+NINE_LITRES = Decimal("9")
+ML_PER_LITRE = Decimal("1000")
+
+
+# ---------------------------------------------------------------------------
+# 9LE computation
+# ---------------------------------------------------------------------------
+
+def compute_nine_le(
+    cases: Decimal,
+    bottle_size_ml: int,
+    pack_size: int,
+) -> Decimal:
+    """Calculate 9-litre-equivalent cases.
+
+    Formula: (cases * pack_size * bottle_size_ml) / 1000 / 9
+    """
+    bottle_ml = Decimal(bottle_size_ml)
+    pack = Decimal(pack_size)
+    litres = cases * pack * bottle_ml / ML_PER_LITRE
+    return litres / NINE_LITRES
+
+
+def attach_nine_le(
+    parsed_rows: list[ParsedWineRow],
+    basis: str,
+) -> None:
+    """Attach nine_le to every ParsedWineRow in-place.
+
+    Rows with unparseable bottle/pack size get nine_le=None.
+    Uses the chosen stock basis (OnHand or Available).
+    """
+    for row in parsed_rows:
+        cases = _get_cases(row, basis)
+        if row.bottle_size_ml is not None and row.pack_size is not None:
+            row.nine_le = compute_nine_le(cases, row.bottle_size_ml, row.pack_size)
+        else:
+            row.nine_le = None
+
+
+def _get_cases(row: ParsedWineRow, basis: str) -> Decimal:
+    """Return the stock quantity for the chosen basis."""
+    if basis == "OnHand":
+        return row.raw.on_hand
+    return row.raw.available
+
+
+# ---------------------------------------------------------------------------
+# Aggregation
+# ---------------------------------------------------------------------------
+
+def aggregate_by(
+    parsed_rows: list[ParsedWineRow],
+    group_by: str,
+    basis: str,
+) -> list[GroupRow]:
+    """Aggregate finished-goods rows by the chosen grouping key.
+
+    Returns a list of GroupRow objects sorted by descending 9LE.
+    Rows whose 9LE is None contribute to case totals but not 9LE totals.
+    """
+    groups: dict[str, dict] = {}
+
+    for row in parsed_rows:
+        key = _group_key(row, group_by)
+        cases = _get_cases(row, basis)
+
+        if key not in groups:
+            groups[key] = {"row_count": 0, "cases": Decimal("0"), "nine_le": Decimal("0")}
+
+        groups[key]["row_count"] += 1
+        groups[key]["cases"] += cases
+        if row.nine_le is not None:
+            groups[key]["nine_le"] += row.nine_le
+
+    result = [
+        GroupRow(
+            key=k,
+            row_count=v["row_count"],
+            cases=v["cases"],
+            nine_le=v["nine_le"],
+        )
+        for k, v in groups.items()
+    ]
+    result.sort(key=lambda r: r.nine_le, reverse=True)
+    return result
+
+
+def _group_key(row: ParsedWineRow, group_by: str) -> str:
+    """Return the grouping key for one row."""
+    if group_by == "variety":
+        return row.variety or row.variety_code or "Unknown"
+    if group_by == "vintage":
+        return row.vintage or "Unknown"
+    if group_by == "market":
+        return row.market or "Unknown"
+    if group_by == "pack_size":
+        if row.bottle_size_ml is not None and row.pack_size is not None:
+            return f"{row.bottle_size_ml}ml/{row.pack_size}p"
+        return "Unknown"
+    if group_by == "lot":
+        return row.raw.lot or "Unknown"
+    # group_by == "none" — caller should not call this function
+    return "All"
+
+
+# ---------------------------------------------------------------------------
+# Summary totals
+# ---------------------------------------------------------------------------
+
+def compute_totals(
+    parsed_rows: list[ParsedWineRow],
+    basis: str,
+) -> dict[str, Decimal]:
+    """Compute total cases, 9LE, allocated, pending from finished goods."""
+    total_cases = Decimal("0")
+    total_nine_le = Decimal("0")
+    total_allocated = Decimal("0")
+    total_pending = Decimal("0")
+
+    for row in parsed_rows:
+        cases = _get_cases(row, basis)
+        total_cases += cases
+        if row.nine_le is not None:
+            total_nine_le += row.nine_le
+        total_allocated += row.raw.allocated
+        total_pending += row.raw.pending
+
+    return {
+        "cases": total_cases,
+        "nine_le": total_nine_le,
+        "allocated": total_allocated,
+        "pending": total_pending,
+    }
+
+
+# ---------------------------------------------------------------------------
+# Low-stock detection
+# ---------------------------------------------------------------------------
+
+def find_low_stock(
+    parsed_rows: list[ParsedWineRow],
+    threshold: Decimal,
+) -> list[ParsedWineRow]:
+    """Return rows whose 9LE is below the threshold (excluding None 9LE rows)."""
+    return [
+        row
+        for row in parsed_rows
+        if row.nine_le is not None and row.nine_le < threshold
+    ]
+
+
+def lowest_stock_item(
+    parsed_rows: list[ParsedWineRow],
+) -> Optional[str]:
+    """Return the item number of the row with the smallest 9LE, or None."""
+    candidates = [r for r in parsed_rows if r.nine_le is not None]
+    if not candidates:
+        return None
+    return min(candidates, key=lambda r: r.nine_le).raw.item  # type: ignore[return-value]
