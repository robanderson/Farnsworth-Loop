@@ -0,0 +1,234 @@
+"""Markdown report renderer for the Wine Stock Report Generator.
+
+Assembles the ReportData bundle into a Markdown document and writes
+it to the configured output path.
+
+All numeric values are rounded to 2 decimal places at this layer.
+Floats are only used for formatting; all computation uses Decimal.
+"""
+
+from __future__ import annotations
+
+import datetime
+from decimal import Decimal
+from pathlib import Path
+
+from .calculations import aggregate_by, compute_totals, find_low_stock, lowest_stock_item
+from .models import ParsedWineRow, ReportData, ReportOptions, StockRow
+
+# ---------------------------------------------------------------------------
+# Constants
+# ---------------------------------------------------------------------------
+
+NINE_LE_MISSING = "—"
+DATE_FORMAT = "%Y-%m-%d"
+
+SECTION_EXECUTIVE_SUMMARY = "## Executive Summary"
+SECTION_STOCK_GROUP = "## Stock by {group_label}"
+SECTION_DETAILED_FG = "## Detailed Finished Goods"
+SECTION_LOW_STOCK = "## Low Stock Warnings"
+SECTION_DRY_GOODS = "## Dry Goods Summary"
+SECTION_DATA_WARNINGS = "## Data Warnings"
+
+GROUP_LABEL_MAP: dict[str, str] = {
+    "variety": "Variety",
+    "vintage": "Vintage",
+    "market": "Market",
+    "pack_size": "Pack Size",
+    "lot": "Lot",
+}
+
+
+# ---------------------------------------------------------------------------
+# Public API
+# ---------------------------------------------------------------------------
+
+def render_report(data: ReportData) -> str:
+    """Render the full Markdown report and return it as a string."""
+    sections: list[str] = []
+
+    sections.append(_render_header(data))
+    sections.append(_render_executive_summary(data))
+
+    if data.options.group_by != "none":
+        sections.append(_render_group_table(data))
+
+    sections.append(_render_detailed_fg(data))
+
+    if data.options.low_stock_warnings:
+        low_stock_section = _render_low_stock(data)
+        if low_stock_section:
+            sections.append(low_stock_section)
+
+    if data.options.include_dry_goods and data.dry_goods:
+        sections.append(_render_dry_goods(data))
+
+    if data.warnings:
+        sections.append(_render_data_warnings(data))
+
+    return "\n\n".join(sections) + "\n"
+
+
+def write_report(data: ReportData) -> None:
+    """Render the report and write it to the configured output path."""
+    content = render_report(data)
+    output_path = Path(data.options.output_path)
+    output_path.write_text(content, encoding="utf-8")
+
+
+# ---------------------------------------------------------------------------
+# Section renderers
+# ---------------------------------------------------------------------------
+
+def _render_header(data: ReportData) -> str:
+    """Render the report title and metadata header."""
+    today = datetime.date.today().strftime(DATE_FORMAT)
+    source = Path(data.source_file).name
+    warehouses = ", ".join(sorted(data.warehouses)) if data.warehouses else "Unknown"
+
+    lines = [
+        "# Wine Stock Report",
+        "",
+        f"Generated: {today}",
+        f"Source file: {source}",
+        f"Warehouse: {warehouses}",
+        f"Stock basis: {data.options.basis}",
+    ]
+    return "\n".join(lines)
+
+
+def _render_executive_summary(data: ReportData) -> str:
+    """Render the Executive Summary section."""
+    opts = data.options
+    totals = compute_totals(data.finished_goods, opts.basis)
+
+    fg_count = len(data.finished_goods)
+    dg_count = len(data.dry_goods)
+    total_nine_le = totals["nine_le"]
+    total_cases = totals["cases"]
+    total_allocated = totals["allocated"]
+    total_pending = totals["pending"]
+
+    lowest = lowest_stock_item(data.finished_goods)
+    warning_count = len(data.warnings)
+
+    lines = [
+        SECTION_EXECUTIVE_SUMMARY,
+        "",
+        f"- Finished Goods rows: {fg_count}",
+        f"- Dry Goods rows: {dg_count}",
+        f"- Total wine stock: {_fmt_decimal(total_nine_le)} 9LE",
+        f"- Total available cases: {_fmt_decimal(total_cases)}",
+        f"- Total allocated cases: {_fmt_decimal(total_allocated)}",
+        f"- Total pending cases: {_fmt_decimal(total_pending)}",
+        f"- Lowest stock item: {lowest or 'N/A'}",
+        f"- Data warnings: {warning_count}",
+    ]
+    return "\n".join(lines)
+
+
+def _render_group_table(data: ReportData) -> str:
+    """Render the grouped summary table."""
+    opts = data.options
+    group_label = GROUP_LABEL_MAP.get(opts.group_by, opts.group_by.title())
+    heading = SECTION_STOCK_GROUP.format(group_label=group_label)
+
+    groups = aggregate_by(data.finished_goods, opts.group_by, opts.basis)
+
+    header = f"| {group_label} | Rows | Cases | 9LE |"
+    separator = "|---|---:|---:|---:|"
+
+    rows: list[str] = [heading, "", header, separator]
+    for grp in groups:
+        rows.append(
+            f"| {grp.key} | {grp.row_count} "
+            f"| {_fmt_decimal(grp.cases)} "
+            f"| {_fmt_decimal(grp.nine_le)} |"
+        )
+
+    return "\n".join(rows)
+
+
+def _render_detailed_fg(data: ReportData) -> str:
+    """Render the Detailed Finished Goods table."""
+    header = (
+        "| Item | Description | Lot | OnHand | Allocated | Pending | Available | Units | 9LE |"
+    )
+    separator = "|---|---|---|---:|---:|---:|---:|---|---:|"
+
+    rows: list[str] = [SECTION_DETAILED_FG, "", header, separator]
+
+    for pw in data.finished_goods:
+        raw = pw.raw
+        nine_le_str = _fmt_decimal(pw.nine_le) if pw.nine_le is not None else NINE_LE_MISSING
+        rows.append(
+            f"| {raw.item} "
+            f"| {_md_escape(raw.description)} "
+            f"| {raw.lot} "
+            f"| {_fmt_decimal(raw.on_hand)} "
+            f"| {_fmt_decimal(raw.allocated)} "
+            f"| {_fmt_decimal(raw.pending)} "
+            f"| {_fmt_decimal(raw.available)} "
+            f"| {raw.units} "
+            f"| {nine_le_str} |"
+        )
+
+    return "\n".join(rows)
+
+
+def _render_low_stock(data: ReportData) -> str:
+    """Render the Low Stock Warnings section (empty string if no warnings)."""
+    threshold = data.options.low_stock_threshold
+    low = find_low_stock(data.finished_goods, threshold)
+    if not low:
+        return ""
+
+    lines = [SECTION_LOW_STOCK, ""]
+    for pw in low:
+        lines.append(
+            f"- Item {pw.raw.item}: {_fmt_decimal(pw.nine_le)} 9LE "
+            f"(threshold: {_fmt_decimal(threshold)})"
+        )
+
+    return "\n".join(lines)
+
+
+def _render_dry_goods(data: ReportData) -> str:
+    """Render the Dry Goods Summary section."""
+    header = "| Item | Description | Available | Units |"
+    separator = "|---|---|---:|---|"
+
+    rows: list[str] = [SECTION_DRY_GOODS, "", header, separator]
+    for row in data.dry_goods:
+        rows.append(
+            f"| {row.item} "
+            f"| {_md_escape(row.description)} "
+            f"| {_fmt_decimal(row.available)} "
+            f"| {row.units} |"
+        )
+
+    return "\n".join(rows)
+
+
+def _render_data_warnings(data: ReportData) -> str:
+    """Render the Data Warnings section."""
+    lines = [SECTION_DATA_WARNINGS, ""]
+    for w in data.warnings:
+        lines.append(f"- {w.message}")
+    return "\n".join(lines)
+
+
+# ---------------------------------------------------------------------------
+# Formatting helpers
+# ---------------------------------------------------------------------------
+
+def _fmt_decimal(value: Decimal | None) -> str:
+    """Format a Decimal to 2 decimal places."""
+    if value is None:
+        return NINE_LE_MISSING
+    return f"{float(value):.2f}"
+
+
+def _md_escape(text: str) -> str:
+    """Escape pipe characters in Markdown table cells."""
+    return text.replace("|", "\\|")
diff --git a/wine_stock_reporter/validation.py b/wine_stock_reporter/validation.py
new file mode 100644
index 0000000..11c5621
--- /dev/null
+++ b/wine_stock_reporter/validation.py
@@ -0,0 +1,144 @@
+"""Row-level validation for the Wine Stock Report Generator.
+
+Checks stock rows for data quality issues and returns warnings.
+This layer handles structural/logical checks that are not about
+description parsing (which is handled in parser.py).
+"""
+
+from __future__ import annotations
+
+from decimal import Decimal
+
+from .models import StockRow, ValidationWarning
+
+# ---------------------------------------------------------------------------
+# Constants
+# ---------------------------------------------------------------------------
+
+KNOWN_TYPE1_VALUES: frozenset[str] = frozenset({"Finished Goods", "Dry Goods"})
+KNOWN_UNITS_VALUES: frozenset[str] = frozenset({"Cases", "Eaches"})
+
+FINISHED_GOODS_EXPECTED_UNITS: str = "Cases"
+DRY_GOODS_EXPECTED_UNITS: str = "Eaches"
+
+# Tolerance for the OnHand - Allocated - Pending == Available check.
+# Rounding in source systems can cause small discrepancies.
+BALANCE_TOLERANCE: Decimal = Decimal("0.05")
+
+WARN_UNKNOWN_TYPE1 = "Unknown Type1 value {value!r} for item {item}."
+WARN_UNKNOWN_UNITS = "Unknown Units value {value!r} for item {item}."
+WARN_FG_NOT_IN_CASES = (
+    "Finished Goods item {item} has units {units!r}; expected 'Cases'."
+)
+WARN_DG_UNEXPECTED_UNITS = (
+    "Dry Goods item {item} has units {units!r}; expected 'Eaches'."
+)
+WARN_AVAILABLE_GT_ON_HAND = (
+    "Available ({available}) > OnHand ({on_hand}) for item {item}."
+)
+WARN_BALANCE_MISMATCH = (
+    "Balance mismatch for item {item}: "
+    "OnHand ({on_hand}) - Allocated ({allocated}) - Pending ({pending}) "
+    "= {computed} but Available = {available} (diff {diff})."
+)
+
+
+# ---------------------------------------------------------------------------
+# Public API
+# ---------------------------------------------------------------------------
+
+def validate_rows(rows: list[StockRow]) -> list[ValidationWarning]:
+    """Validate all rows and return warnings.
+
+    Checks performed per row:
+    - unknown Type1 values
+    - unknown Units values
+    - Finished Goods rows not in Cases
+    - Dry Goods rows in unexpected units
+    - Available > OnHand
+    - material mismatch: OnHand - Allocated - Pending != Available
+      (with tolerance for rounding)
+    """
+    warnings: list[ValidationWarning] = []
+
+    for row in rows:
+        warnings.extend(_check_type1(row))
+        warnings.extend(_check_units(row))
+        warnings.extend(_check_numeric_consistency(row))
+
+    return warnings
+
+
+# ---------------------------------------------------------------------------
+# Internal checks
+# ---------------------------------------------------------------------------
+
+def _check_type1(row: StockRow) -> list[ValidationWarning]:
+    """Warn if Type1 is not a known value."""
+    if row.type1 not in KNOWN_TYPE1_VALUES:
+        return [ValidationWarning(
+            message=WARN_UNKNOWN_TYPE1.format(value=row.type1, item=row.item),
+            item=row.item,
+        )]
+    return []
+
+
+def _check_units(row: StockRow) -> list[ValidationWarning]:
+    """Warn on unknown Units, or on type/unit mismatch."""
+    result: list[ValidationWarning] = []
+
+    if row.units not in KNOWN_UNITS_VALUES:
+        result.append(ValidationWarning(
+            message=WARN_UNKNOWN_UNITS.format(value=row.units, item=row.item),
+            item=row.item,
+        ))
+        # Can't do further type-unit checks if units is unknown
+        return result
+
+    if row.type1 == "Finished Goods" and row.units != FINISHED_GOODS_EXPECTED_UNITS:
+        result.append(ValidationWarning(
+            message=WARN_FG_NOT_IN_CASES.format(item=row.item, units=row.units),
+            item=row.item,
+        ))
+
+    if row.type1 == "Dry Goods" and row.units != DRY_GOODS_EXPECTED_UNITS:
+        result.append(ValidationWarning(
+            message=WARN_DG_UNEXPECTED_UNITS.format(item=row.item, units=row.units),
+            item=row.item,
+        ))
+
+    return result
+
+
+def _check_numeric_consistency(row: StockRow) -> list[ValidationWarning]:
+    """Warn if Available > OnHand or if the balance equation doesn't hold."""
+    result: list[ValidationWarning] = []
+
+    if row.available > row.on_hand:
+        result.append(ValidationWarning(
+            message=WARN_AVAILABLE_GT_ON_HAND.format(
+                available=row.available,
+                on_hand=row.on_hand,
+                item=row.item,
+            ),
+            item=row.item,
+        ))
+
+    # OnHand - Allocated - Pending should equal Available (within tolerance)
+    computed = row.on_hand - row.allocated - row.pending
+    diff = abs(computed - row.available)
+    if diff > BALANCE_TOLERANCE:
+        result.append(ValidationWarning(
+            message=WARN_BALANCE_MISMATCH.format(
+                item=row.item,
+                on_hand=row.on_hand,
+                allocated=row.allocated,
+                pending=row.pending,
+                computed=computed,
+                available=row.available,
+                diff=diff,
+            ),
+            item=row.item,
+        ))
+
+    return result
