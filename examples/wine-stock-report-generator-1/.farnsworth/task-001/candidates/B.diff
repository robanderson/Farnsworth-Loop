+"""Tests for wine_stock_reporter.calculations."""
+
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.calculations import (
+    aggregate_by,
+    attach_nine_le,
+    compute_nine_le,
+    compute_totals,
+    find_low_stock,
+    lowest_stock_item,
+)
+from wine_stock_reporter.models import ParsedWineRow, StockRow
+
+
+def _make_stock_row(
+    item: str = "100001",
+    on_hand: str = "10.00",
+    allocated: str = "0.00",
+    pending: str = "0.00",
+    available: str = "10.00",
+    warehouse: str = "Marlborough",
+) -> StockRow:
+    return StockRow(
+        type1="Finished Goods",
+        item=item,
+        description="FV 22 CHR EP NZ 750ml/12p",
+        client_stock_code="",
+        client_stock_description="",
+        lot="W123",
+        on_hand=Decimal(on_hand),
+        warehouse=warehouse,
+        allocated=Decimal(allocated),
+        pending=Decimal(pending),
+        available=Decimal(available),
+        units="Cases",
+    )
+
+
+def _make_parsed_row(
+    item: str = "100001",
+    available: str = "10.00",
+    on_hand: str = "10.00",
+    bottle_size_ml: int | None = 750,
+    pack_size: int | None = 12,
+    variety: str | None = "Chardonnay",
+    variety_code: str | None = "CHR",
+    vintage: str | None = "2022",
+    market: str | None = "NZ",
+    lot: str = "W123",
+    nine_le: str | None = None,
+) -> ParsedWineRow:
+    raw = _make_stock_row(
+        item=item, available=available, on_hand=on_hand
+    )
+    raw.lot = lot
+    pw = ParsedWineRow(
+        raw=raw,
+        variety_code=variety_code,
+        variety=variety,
+        vintage=vintage,
+        market=market,
+        bottle_size_ml=bottle_size_ml,
+        pack_size=pack_size,
+    )
+    if nine_le is not None:
+        pw.nine_le = Decimal(nine_le)
+    return pw
+
+
+class TestComputeNineLe(unittest.TestCase):
+    def test_750ml_12pack_one_case(self):
+        # 1 case * 12 bottles * 750ml / 1000 / 9 = 1.0
+        result = compute_nine_le(Decimal("1"), 750, 12)
+        self.assertEqual(result, Decimal("1"))
+
+    def test_750ml_6pack_two_cases(self):
+        # 2 cases * 6 * 750 / 1000 / 9 = 1.0
+        result = compute_nine_le(Decimal("2"), 750, 6)
+        self.assertEqual(result, Decimal("1"))
+
+    def test_375ml_12pack(self):
+        # 1 * 12 * 375 / 1000 / 9 = 0.5
+        result = compute_nine_le(Decimal("1"), 375, 12)
+        self.assertEqual(result, Decimal("0.5"))
+
+    def test_zero_cases(self):
+        result = compute_nine_le(Decimal("0"), 750, 12)
+        self.assertEqual(result, Decimal("0"))
+
+
+class TestAttachNineLe(unittest.TestCase):
+    def test_nine_le_attached_available_basis(self):
+        pw = _make_parsed_row(available="1.00", bottle_size_ml=750, pack_size=12)
+        attach_nine_le([pw], "Available")
+        self.assertIsNotNone(pw.nine_le)
+        self.assertEqual(pw.nine_le, Decimal("1"))
+
+    def test_nine_le_attached_on_hand_basis(self):
+        pw = _make_parsed_row(on_hand="2.00", bottle_size_ml=750, pack_size=12)
+        attach_nine_le([pw], "OnHand")
+        self.assertEqual(pw.nine_le, Decimal("2"))
+
+    def test_none_when_bottle_size_missing(self):
+        pw = _make_parsed_row(bottle_size_ml=None, pack_size=12)
+        attach_nine_le([pw], "Available")
+        self.assertIsNone(pw.nine_le)
+
+    def test_none_when_pack_size_missing(self):
+        pw = _make_parsed_row(bottle_size_ml=750, pack_size=None)
+        attach_nine_le([pw], "Available")
+        self.assertIsNone(pw.nine_le)
+
+
+class TestAggregateBy(unittest.TestCase):
+    def setUp(self):
+        self.rows = [
+            _make_parsed_row(item="1", available="10.00", variety="Chardonnay", variety_code="CHR", vintage="2022", market="NZ", lot="W1", bottle_size_ml=750, pack_size=12),
+            _make_parsed_row(item="2", available="5.00", variety="Chardonnay", variety_code="CHR", vintage="2022", market="UK", lot="W2", bottle_size_ml=750, pack_size=12),
+            _make_parsed_row(item="3", available="8.00", variety="Sauvignon Blanc", variety_code="SAB", vintage="2024", market="NZ", lot="W3", bottle_size_ml=750, pack_size=12),
+        ]
+        attach_nine_le(self.rows, "Available")
+
+    def test_aggregate_by_variety(self):
+        groups = aggregate_by(self.rows, "variety", "Available")
+        keys = [g.key for g in groups]
+        self.assertIn("Chardonnay", keys)
+        self.assertIn("Sauvignon Blanc", keys)
+
+    def test_aggregate_by_vintage(self):
+        groups = aggregate_by(self.rows, "vintage", "Available")
+        keys = [g.key for g in groups]
+        self.assertIn("2022", keys)
+        self.assertIn("2024", keys)
+
+    def test_aggregate_by_market(self):
+        groups = aggregate_by(self.rows, "market", "Available")
+        keys = [g.key for g in groups]
+        self.assertIn("NZ", keys)
+        self.assertIn("UK", keys)
+
+    def test_row_counts_are_correct(self):
+        groups = aggregate_by(self.rows, "variety", "Available")
+        chr_group = next(g for g in groups if g.key == "Chardonnay")
+        self.assertEqual(chr_group.row_count, 2)
+        sab_group = next(g for g in groups if g.key == "Sauvignon Blanc")
+        self.assertEqual(sab_group.row_count, 1)
+
+    def test_cases_summed(self):
+        groups = aggregate_by(self.rows, "variety", "Available")
+        chr_group = next(g for g in groups if g.key == "Chardonnay")
+        self.assertEqual(chr_group.cases, Decimal("15.00"))
+
+    def test_sorted_by_nine_le_descending(self):
+        groups = aggregate_by(self.rows, "variety", "Available")
+        # First group should have the highest 9LE
+        nine_les = [g.nine_le for g in groups]
+        self.assertEqual(nine_les, sorted(nine_les, reverse=True))
+
+    def test_none_nine_le_excluded_from_totals(self):
+        rows = [
+            _make_parsed_row(item="1", available="10.00", bottle_size_ml=750, pack_size=12),
+            _make_parsed_row(item="2", available="5.00", bottle_size_ml=None, pack_size=None),
+        ]
+        attach_nine_le(rows, "Available")
+        groups = aggregate_by(rows, "variety", "Available")
+        # Total 9LE = only row with parseable sizes
+        total_nine_le = sum(g.nine_le for g in groups)
+        self.assertGreater(total_nine_le, Decimal("0"))
+        # Cases total should include both rows
+        total_cases = sum(g.cases for g in groups)
+        self.assertEqual(total_cases, Decimal("15.00"))
+
+
+class TestComputeTotals(unittest.TestCase):
+    def test_totals_include_nine_le_and_cases(self):
+        rows = [
+            _make_parsed_row(item="1", available="10.00", bottle_size_ml=750, pack_size=12),
+            _make_parsed_row(item="2", available="5.00", bottle_size_ml=750, pack_size=12),
+        ]
+        attach_nine_le(rows, "Available")
+        totals = compute_totals(rows, "Available")
+        self.assertEqual(totals["cases"], Decimal("15.00"))
+        self.assertGreater(totals["nine_le"], Decimal("0"))
+
+    def test_totals_skip_none_nine_le(self):
+        rows = [
+            _make_parsed_row(item="1", available="10.00", bottle_size_ml=750, pack_size=12),
+            _make_parsed_row(item="2", available="5.00", bottle_size_ml=None, pack_size=None),
+        ]
+        attach_nine_le(rows, "Available")
+        totals = compute_totals(rows, "Available")
+        # Only first row contributes to nine_le
+        self.assertEqual(totals["nine_le"], compute_nine_le(Decimal("10"), 750, 12))
+        # Both rows contribute to cases
+        self.assertEqual(totals["cases"], Decimal("15.00"))
+
+
+class TestFindLowStock(unittest.TestCase):
+    def test_finds_low_stock_rows(self):
+        rows = [
+            _make_parsed_row(item="1", available="5.00", bottle_size_ml=750, pack_size=12),
+            _make_parsed_row(item="2", available="100.00", bottle_size_ml=750, pack_size=12),
+        ]
+        attach_nine_le(rows, "Available")
+        low = find_low_stock(rows, Decimal("10"))
+        self.assertEqual(len(low), 1)
+        self.assertEqual(low[0].raw.item, "1")
+
+    def test_no_low_stock(self):
+        rows = [
+            _make_parsed_row(item="1", available="100.00", bottle_size_ml=750, pack_size=12),
+        ]
+        attach_nine_le(rows, "Available")
+        low = find_low_stock(rows, Decimal("10"))
+        self.assertEqual(low, [])
+
+    def test_none_nine_le_excluded(self):
+        rows = [
+            _make_parsed_row(item="1", available="0.00", bottle_size_ml=None, pack_size=None),
+        ]
+        attach_nine_le(rows, "Available")
+        low = find_low_stock(rows, Decimal("10"))
+        self.assertEqual(low, [])
+
+
+class TestLowestStockItem(unittest.TestCase):
+    def test_returns_item_with_minimum_nine_le(self):
+        rows = [
+            _make_parsed_row(item="1", available="10.00", bottle_size_ml=750, pack_size=12),
+            _make_parsed_row(item="2", available="1.00", bottle_size_ml=750, pack_size=12),
+            _make_parsed_row(item="3", available="5.00", bottle_size_ml=750, pack_size=12),
+        ]
+        attach_nine_le(rows, "Available")
+        result = lowest_stock_item(rows)
+        self.assertEqual(result, "2")
+
+    def test_returns_none_when_all_nine_le_are_none(self):
+        rows = [
+            _make_parsed_row(item="1", available="10.00", bottle_size_ml=None, pack_size=None),
+        ]
+        attach_nine_le(rows, "Available")
+        result = lowest_stock_item(rows)
+        self.assertIsNone(result)
+
+
+if __name__ == "__main__":
+    unittest.main()
