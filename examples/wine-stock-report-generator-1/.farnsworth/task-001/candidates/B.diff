@@ -0,0 +1,150 @@
+"""CSV loader for the Wine Stock Report Generator.
+
+Responsibilities:
+- Load CSV files from disk.
+- Validate that required columns are present.
+- Clean and normalise numeric fields.
+- Return a list of StockRow objects and any validation warnings.
+"""
+
+from __future__ import annotations
+
+import csv
+from decimal import Decimal, InvalidOperation
+from pathlib import Path
+from typing import Optional
+
+from .models import StockRow, ValidationWarning
+
+# ---------------------------------------------------------------------------
+# Constants
+# ---------------------------------------------------------------------------
+
+REQUIRED_COLUMNS: tuple[str, ...] = (
+    "Type1",
+    "Item",
+    "Description",
+    "OnHand",
+    "Warehouse",
+    "Allocated",
+    "Pending",
+    "Available",
+    "Units",
+)
+
+NUMERIC_COLUMNS: tuple[str, ...] = (
+    "OnHand",
+    "Allocated",
+    "Pending",
+    "Available",
+)
+
+ERROR_FILE_NOT_FOUND = "Error: file not found: {path}"
+ERROR_MISSING_COLUMN = "Error: required column '{column}' was not found in CSV."
+ERROR_UNREADABLE_CSV = "Error: could not read CSV file '{path}': {reason}"
+
+
+# ---------------------------------------------------------------------------
+# Public API
+# ---------------------------------------------------------------------------
+
+def load_csv(path: str) -> tuple[list[StockRow], list[ValidationWarning]]:
+    """Load a warehouse stock CSV and return rows plus any warnings.
+
+    Raises:
+        FileNotFoundError: wrapped as SystemExit by caller (exit code 1).
+        ValueError: if required columns are missing or file is unreadable.
+    """
+    csv_path = Path(path)
+    if not csv_path.exists():
+        raise FileNotFoundError(ERROR_FILE_NOT_FOUND.format(path=path))
+
+    try:
+        with csv_path.open(newline="", encoding="utf-8-sig") as fh:
+            reader = csv.DictReader(fh)
+            # DictReader reads the header on first access to fieldnames.
+            fieldnames = reader.fieldnames or []
+            _validate_columns(fieldnames, path)
+            rows, warnings = _parse_rows(reader)
+    except (OSError, csv.Error) as exc:
+        raise ValueError(ERROR_UNREADABLE_CSV.format(path=path, reason=exc)) from exc
+
+    return rows, warnings
+
+
+# ---------------------------------------------------------------------------
+# Internal helpers
+# ---------------------------------------------------------------------------
+
+def _validate_columns(fieldnames: list[str], path: str) -> None:
+    """Raise ValueError if any required column is absent."""
+    present = set(fieldnames)
+    for col in REQUIRED_COLUMNS:
+        if col not in present:
+            raise ValueError(ERROR_MISSING_COLUMN.format(column=col))
+
+
+def _parse_rows(
+    reader: csv.DictReader,
+) -> tuple[list[StockRow], list[ValidationWarning]]:
+    """Iterate DictReader rows and build StockRow objects."""
+    rows: list[StockRow] = []
+    warnings: list[ValidationWarning] = []
+
+    for raw in reader:
+        item = (raw.get("Item") or "").strip()
+        numeric_values: dict[str, Decimal] = {}
+        for col in NUMERIC_COLUMNS:
+            value, warning = _parse_numeric(raw.get(col, ""), col, item)
+            numeric_values[col] = value
+            if warning:
+                warnings.append(warning)
+
+        row = StockRow(
+            type1=(raw.get("Type1") or "").strip(),
+            item=item,
+            description=(raw.get("Description") or "").strip(),
+            client_stock_code=(raw.get("ClientStockCode") or "").strip(),
+            client_stock_description=(raw.get("ClientStockDescription") or "").strip(),
+            lot=(raw.get("Lot") or "").strip(),
+            on_hand=numeric_values["OnHand"],
+            warehouse=(raw.get("Warehouse") or "").strip(),
+            allocated=numeric_values["Allocated"],
+            pending=numeric_values["Pending"],
+            available=numeric_values["Available"],
+            units=(raw.get("Units") or "").strip(),
+        )
+        rows.append(row)
+
+    return rows, warnings
+
+
+def _parse_numeric(
+    raw: str, column: str, item: str
+) -> tuple[Decimal, Optional[ValidationWarning]]:
+    """Clean and convert a raw numeric string to Decimal.
+
+    Returns (value, warning_or_None).  Blank fields become Decimal("0").
+    Negative values are allowed but generate a warning.
+    """
+    cleaned = (raw or "").strip().replace(",", "")
+    if cleaned == "" or cleaned == "-":
+        return Decimal("0"), None
+
+    try:
+        value = Decimal(cleaned)
+    except InvalidOperation:
+        warning = ValidationWarning(
+            message=f"Non-numeric value {raw!r} in column '{column}'; treated as 0.",
+            item=item or None,
+        )
+        return Decimal("0"), warning
+
+    if value < 0:
+        warning = ValidationWarning(
+            message=f"Negative value {value} in column '{column}'.",
+            item=item or None,
+        )
+        return value, warning
+
+    return value, None
