+"""Tests for wine_stock_reporter.validation."""
+
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.models import StockRow
+from wine_stock_reporter.validation import (
+    BALANCE_TOLERANCE,
+    FINISHED_GOODS_EXPECTED_UNITS,
+    KNOWN_TYPE1_VALUES,
+    KNOWN_UNITS_VALUES,
+    WARN_AVAILABLE_GT_ON_HAND,
+    WARN_BALANCE_MISMATCH,
+    WARN_DG_UNEXPECTED_UNITS,
+    WARN_FG_NOT_IN_CASES,
+    WARN_UNKNOWN_TYPE1,
+    WARN_UNKNOWN_UNITS,
+    validate_rows,
+)
+
+
+def _make_row(
+    type1: str = "Finished Goods",
+    item: str = "100001",
+    units: str = "Cases",
+    on_hand: str = "10.00",
+    allocated: str = "0.00",
+    pending: str = "0.00",
+    available: str = "10.00",
+) -> StockRow:
+    return StockRow(
+        type1=type1,
+        item=item,
+        description="FV 22 CHR EP NZ 750ml/12p",
+        client_stock_code="",
+        client_stock_description="",
+        lot="W123",
+        on_hand=Decimal(on_hand),
+        warehouse="Marlborough",
+        allocated=Decimal(allocated),
+        pending=Decimal(pending),
+        available=Decimal(available),
+        units=units,
+    )
+
+
+class TestValidateRowsClean(unittest.TestCase):
+    def test_clean_fg_row_no_warnings(self):
+        rows = [_make_row()]
+        warnings = validate_rows(rows)
+        self.assertEqual(warnings, [])
+
+    def test_clean_dg_row_no_warnings(self):
+        rows = [_make_row(type1="Dry Goods", units="Eaches")]
+        warnings = validate_rows(rows)
+        self.assertEqual(warnings, [])
+
+    def test_no_rows_returns_empty(self):
+        warnings = validate_rows([])
+        self.assertEqual(warnings, [])
+
+
+class TestUnknownType1(unittest.TestCase):
+    def test_unknown_type1_generates_warning(self):
+        rows = [_make_row(type1="Unknown Type")]
+        warnings = validate_rows(rows)
+        self.assertTrue(len(warnings) > 0)
+        self.assertTrue(any("Unknown Type" in w.message for w in warnings))
+
+    def test_known_type1_values_constant(self):
+        self.assertIn("Finished Goods", KNOWN_TYPE1_VALUES)
+        self.assertIn("Dry Goods", KNOWN_TYPE1_VALUES)
+
+
+class TestUnknownUnits(unittest.TestCase):
+    def test_unknown_units_generates_warning(self):
+        rows = [_make_row(units="Bottles")]
+        warnings = validate_rows(rows)
+        self.assertTrue(any("Bottles" in w.message for w in warnings))
+
+    def test_known_units_values_constant(self):
+        self.assertIn("Cases", KNOWN_UNITS_VALUES)
+        self.assertIn("Eaches", KNOWN_UNITS_VALUES)
+
+
+class TestFinishedGoodsUnits(unittest.TestCase):
+    def test_fg_not_in_cases_generates_warning(self):
+        rows = [_make_row(type1="Finished Goods", units="Eaches")]
+        warnings = validate_rows(rows)
+        self.assertTrue(any("100001" in w.message for w in warnings))
+
+    def test_finished_goods_expected_units_constant(self):
+        self.assertEqual(FINISHED_GOODS_EXPECTED_UNITS, "Cases")
+
+
+class TestDryGoodsUnits(unittest.TestCase):
+    def test_dg_not_in_eaches_generates_warning(self):
+        rows = [_make_row(type1="Dry Goods", units="Cases")]
+        warnings = validate_rows(rows)
+        self.assertTrue(any("100001" in w.message for w in warnings))
+
+
+class TestAvailableGtOnHand(unittest.TestCase):
+    def test_available_exceeds_on_hand_generates_warning(self):
+        rows = [_make_row(on_hand="5.00", available="10.00")]
+        warnings = validate_rows(rows)
+        self.assertTrue(len(warnings) > 0)
+        warning_messages = [w.message for w in warnings]
+        self.assertTrue(any("Available" in m or "available" in m.lower() for m in warning_messages))
+
+    def test_available_equal_to_on_hand_no_warning(self):
+        rows = [_make_row(on_hand="10.00", allocated="0.00", pending="0.00", available="10.00")]
+        warnings = validate_rows(rows)
+        self.assertEqual(warnings, [])
+
+
+class TestBalanceMismatch(unittest.TestCase):
+    def test_balance_mismatch_generates_warning(self):
+        # OnHand=10, Allocated=0, Pending=0 should give Available=10
+        # but we set Available=7 — big mismatch
+        rows = [_make_row(on_hand="10.00", allocated="0.00", pending="0.00", available="7.00")]
+        warnings = validate_rows(rows)
+        self.assertTrue(len(warnings) > 0)
+
+    def test_small_rounding_within_tolerance_no_warning(self):
+        # OnHand=10, Allocated=0, Pending=0 => computed=10; Available=10.01 => diff=0.01
+        rows = [_make_row(on_hand="10.00", allocated="0.00", pending="0.00", available="10.01")]
+        warnings = validate_rows(rows)
+        # 0.01 < BALANCE_TOLERANCE (0.05), should be no warning
+        balance_warnings = [w for w in warnings if "Balance mismatch" in w.message or "balance" in w.message.lower()]
+        self.assertEqual(balance_warnings, [])
+
+    def test_balance_tolerance_constant_is_positive(self):
+        self.assertGreater(BALANCE_TOLERANCE, Decimal("0"))
+
+    def test_correct_allocation(self):
+        # OnHand=10, Allocated=3, Pending=1 => Available=6
+        rows = [_make_row(on_hand="10.00", allocated="3.00", pending="1.00", available="6.00")]
+        warnings = validate_rows(rows)
+        balance_warnings = [w for w in warnings if "mismatch" in w.message.lower() or "balance" in w.message.lower()]
+        self.assertEqual(balance_warnings, [])
+
+
+class TestWarningConstants(unittest.TestCase):
+    def test_warn_unknown_type1_is_string(self):
+        self.assertIsInstance(WARN_UNKNOWN_TYPE1, str)
+        self.assertIn("{value", WARN_UNKNOWN_TYPE1)
+
+    def test_warn_unknown_units_is_string(self):
+        self.assertIsInstance(WARN_UNKNOWN_UNITS, str)
+
+    def test_warn_fg_not_in_cases_is_string(self):
+        self.assertIsInstance(WARN_FG_NOT_IN_CASES, str)
+
+    def test_warn_dg_unexpected_units_is_string(self):
+        self.assertIsInstance(WARN_DG_UNEXPECTED_UNITS, str)
+
+    def test_warn_available_gt_on_hand_is_string(self):
+        self.assertIsInstance(WARN_AVAILABLE_GT_ON_HAND, str)
+
+    def test_warn_balance_mismatch_is_string(self):
+        self.assertIsInstance(WARN_BALANCE_MISMATCH, str)
+
+
+if __name__ == "__main__":
+    unittest.main()
