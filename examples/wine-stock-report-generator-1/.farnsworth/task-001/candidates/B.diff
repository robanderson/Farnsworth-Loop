+++ b/wine_stock_reporter/parser.py
@@ -0,0 +1,174 @@
+"""Description parser for Finished Goods rows.
+
+Parses the warehouse Description field to extract:
+  prefix, vintage, variety_code, brand_code, market,
+  bottle_size_ml, pack_size, extra_description.
+
+Pattern (space-separated tokens):
+  <PREFIX> <YY> <VARIETY_CODE> <BRAND_CODE> <MARKET> <BOTTLEml/PACKp> [extra...]
+
+The parser is tolerant: if any token cannot be resolved it is left as None
+and a data warning is emitted.  The parser never raises an exception.
+"""
+
+from __future__ import annotations
+
+import re
+from typing import Optional
+
+from .models import ParsedWineRow, StockRow, ValidationWarning
+
+# ---------------------------------------------------------------------------
+# Variety code mapping (section 11)
+# ---------------------------------------------------------------------------
+
+VARIETY_MAP: dict[str, str] = {
+    "CHR": "Chardonnay",
+    "SAB": "Sauvignon Blanc",
+    "PIN": "Pinot Noir",
+    "PIG": "Pinot Gris",
+    "PRO": "Rosé",
+    "RDB": "Red Blend",
+    "MXD": "Mixed / Consolidated",
+}
+
+# ---------------------------------------------------------------------------
+# Regex patterns
+# ---------------------------------------------------------------------------
+
+# Matches bottle size token like "750ml/12p" or "375ml/6p"
+_BOTTLE_PACK_RE = re.compile(r"^(\d+)ml/(\d+)p$", re.IGNORECASE)
+
+# Matches a two-digit vintage (standalone word)
+_VINTAGE_RE = re.compile(r"^\d{2}$")
+
+# Matches "NV" (non-vintage) as a vintage token
+_NV_RE = re.compile(r"^NV$", re.IGNORECASE)
+
+
+# ---------------------------------------------------------------------------
+# Public API
+# ---------------------------------------------------------------------------
+
+def parse_description(
+    row: StockRow,
+) -> tuple[ParsedWineRow, list[ValidationWarning]]:
+    """Parse a Finished Goods description and return a ParsedWineRow.
+
+    Always returns a ParsedWineRow (never raises).
+    Warnings are accumulated and returned separately.
+    """
+    parsed = ParsedWineRow(raw=row)
+    warnings: list[ValidationWarning] = []
+
+    desc = row.description.strip()
+    if not desc:
+        warnings.append(ValidationWarning(
+            message=f"Empty description for item {row.item!r}.",
+            item=row.item,
+        ))
+        return parsed, warnings
+
+    tokens = desc.split()
+    # We expect at least 6 tokens: PREFIX YY VARIETY BRAND MARKET BOTTLEml/PACKp
+    # Tokens beyond position 5 are extra_description.
+    idx = 0
+
+    # Token 0: prefix (e.g. "FV")
+    if idx < len(tokens):
+        parsed.prefix = tokens[idx]
+        idx += 1
+
+    # Token 1: vintage (two-digit year or "NV")
+    if idx < len(tokens):
+        tok = tokens[idx]
+        if _NV_RE.match(tok):
+            parsed.vintage = "NV"
+            idx += 1
+        elif _VINTAGE_RE.match(tok):
+            parsed.vintage = _expand_vintage(tok)
+            idx += 1
+        # else: leave vintage as None and don't advance; the token might be
+        # the variety code
+
+    # Token 2: variety code
+    if idx < len(tokens):
+        tok = tokens[idx]
+        # Variety codes are 2-3 uppercase letters
+        if re.match(r"^[A-Z]{2,4}$", tok):
+            parsed.variety_code = tok
+            parsed.variety = VARIETY_MAP.get(tok)
+            if parsed.variety is None:
+                warnings.append(ValidationWarning(
+                    message=f"Unknown variety code {tok!r} in item {row.item}.",
+                    item=row.item,
+                ))
+            idx += 1
+
+    # Token 3: brand/code (e.g. "EP", "GL", "SSK", "15V", "CON")
+    if idx < len(tokens):
+        tok = tokens[idx]
+        # Brand codes are short alphanumeric tokens that don't look like
+        # bottle-pack specs or pure lowercase words
+        if not _BOTTLE_PACK_RE.match(tok):
+            parsed.brand_code = tok
+            idx += 1
+
+    # Token 4: market code (e.g. "NZ", "UK", "CA", "UC", "AN", "X+")
+    if idx < len(tokens):
+        tok = tokens[idx]
+        if not _BOTTLE_PACK_RE.match(tok):
+            parsed.market = tok
+            idx += 1
+
+    # Find the bottle/pack token (may not be at position 5 due to tolerant parsing)
+    bottle_pack_idx: Optional[int] = None
+    for i in range(idx, len(tokens)):
+        if _BOTTLE_PACK_RE.match(tokens[i]):
+            bottle_pack_idx = i
+            break
+
+    if bottle_pack_idx is not None:
+        m = _BOTTLE_PACK_RE.match(tokens[bottle_pack_idx])
+        assert m is not None
+        parsed.bottle_size_ml = int(m.group(1))
+        parsed.pack_size = int(m.group(2))
+        extra_tokens = tokens[bottle_pack_idx + 1:]
+    else:
+        # Could not find bottle/pack token
+        warnings.append(ValidationWarning(
+            message=f"Could not parse bottle/pack size from description {desc!r} "
+                    f"(item {row.item}).",
+            item=row.item,
+        ))
+        extra_tokens = tokens[idx:]
+
+    if extra_tokens:
+        parsed.extra_description = " ".join(extra_tokens)
+
+    return parsed, warnings
+
+
+def parse_all_finished_goods(
+    rows: list[StockRow],
+) -> tuple[list[ParsedWineRow], list[ValidationWarning]]:
+    """Parse all Finished Goods rows; return parsed rows and all warnings."""
+    all_parsed: list[ParsedWineRow] = []
+    all_warnings: list[ValidationWarning] = []
+
+    for row in rows:
+        if row.type1 == "Finished Goods":
+            parsed, warnings = parse_description(row)
+            all_parsed.append(parsed)
+            all_warnings.extend(warnings)
+
+    return all_parsed, all_warnings
+
+
+# ---------------------------------------------------------------------------
+# Internal helpers
+# ---------------------------------------------------------------------------
+
+def _expand_vintage(two_digit: str) -> str:
+    """Expand a two-digit vintage to four digits (2000–2099)."""
+    return f"20{two_digit}"
