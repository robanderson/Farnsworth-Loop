+"""Tests for wine_stock_reporter.parser."""
+
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.models import StockRow
+from wine_stock_reporter.parser import (
+    VARIETY_MAP,
+    parse_description,
+    parse_all_finished_goods,
+)
+
+
+def _make_fg_row(description: str, item: str = "100001", **kwargs) -> StockRow:
+    """Build a Finished Goods StockRow with the given description."""
+    defaults = dict(
+        type1="Finished Goods",
+        item=item,
+        description=description,
+        client_stock_code="",
+        client_stock_description="",
+        lot="W123",
+        on_hand=Decimal("10.00"),
+        warehouse="Marlborough",
+        allocated=Decimal("0.00"),
+        pending=Decimal("0.00"),
+        available=Decimal("10.00"),
+        units="Cases",
+    )
+    defaults.update(kwargs)
+    return StockRow(**defaults)
+
+
+class TestParseDescription(unittest.TestCase):
+    def test_parses_standard_12p(self):
+        row = _make_fg_row("FV 22 CHR EP NZ 750ml/12p")
+        parsed, warnings = parse_description(row)
+        self.assertEqual(parsed.prefix, "FV")
+        self.assertEqual(parsed.vintage, "2022")
+        self.assertEqual(parsed.variety_code, "CHR")
+        self.assertEqual(parsed.variety, "Chardonnay")
+        self.assertEqual(parsed.brand_code, "EP")
+        self.assertEqual(parsed.market, "NZ")
+        self.assertEqual(parsed.bottle_size_ml, 750)
+        self.assertEqual(parsed.pack_size, 12)
+        self.assertIsNone(parsed.extra_description)
+        self.assertEqual(warnings, [])
+
+    def test_parses_standard_6p(self):
+        row = _make_fg_row("FV 22 CHR EP AN 750ml/6p")
+        parsed, warnings = parse_description(row)
+        self.assertEqual(parsed.prefix, "FV")
+        self.assertEqual(parsed.vintage, "2022")
+        self.assertEqual(parsed.variety_code, "CHR")
+        self.assertEqual(parsed.variety, "Chardonnay")
+        self.assertEqual(parsed.market, "AN")
+        self.assertEqual(parsed.bottle_size_ml, 750)
+        self.assertEqual(parsed.pack_size, 6)
+        self.assertEqual(warnings, [])
+
+    def test_parses_extra_description(self):
+        row = _make_fg_row("FV 22 RDB EP UK 750ml/6p Legacy Red")
+        parsed, warnings = parse_description(row)
+        self.assertEqual(parsed.vintage, "2022")
+        self.assertEqual(parsed.variety_code, "RDB")
+        self.assertEqual(parsed.market, "UK")
+        self.assertEqual(parsed.bottle_size_ml, 750)
+        self.assertEqual(parsed.pack_size, 6)
+        self.assertEqual(parsed.extra_description, "Legacy Red")
+        self.assertEqual(warnings, [])
+
+    def test_expands_vintage_22_to_2022(self):
+        row = _make_fg_row("FV 22 CHR EP NZ 750ml/12p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.vintage, "2022")
+
+    def test_expands_vintage_20_to_2020(self):
+        row = _make_fg_row("FV 20 CHR EP CA 750ml/12p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.vintage, "2020")
+
+    def test_expands_vintage_24_to_2024(self):
+        row = _make_fg_row("FV 24 PIN EP UK 750ml/6p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.vintage, "2024")
+
+    def test_maps_chr_to_chardonnay(self):
+        row = _make_fg_row("FV 22 CHR EP NZ 750ml/12p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.variety, VARIETY_MAP["CHR"])
+        self.assertEqual(parsed.variety, "Chardonnay")
+
+    def test_maps_sab_to_sauvignon_blanc(self):
+        row = _make_fg_row("FV 22 SAB EP NZ 750ml/12p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.variety, VARIETY_MAP["SAB"])
+        self.assertEqual(parsed.variety, "Sauvignon Blanc")
+
+    def test_maps_pin_to_pinot_noir(self):
+        row = _make_fg_row("FV 22 PIN EP NZ 750ml/12p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.variety, "Pinot Noir")
+
+    def test_maps_pig_to_pinot_gris(self):
+        row = _make_fg_row("FV 24 PIG EP UK 750ml/6p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.variety, "Pinot Gris")
+
+    def test_maps_pro_to_rose(self):
+        row = _make_fg_row("FV 24 PRO EP NZ 750ml/12p")
+        parsed, _ = parse_description(row)
+        # PRO maps to Rosé (accent char)
+        self.assertIsNotNone(parsed.variety)
+        self.assertIn("os", parsed.variety)  # Rosé contains 'os'
+
+    def test_maps_rdb_to_red_blend(self):
+        row = _make_fg_row("FV 22 RDB EP UK 750ml/6p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.variety, "Red Blend")
+
+    def test_maps_mxd_to_mixed_consolidated(self):
+        row = _make_fg_row("FV NV MXD CON 750ml/12p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.variety, "Mixed / Consolidated")
+
+    def test_unknown_variety_code_generates_warning(self):
+        row = _make_fg_row("FV 22 XYZ EP NZ 750ml/12p", item="99999")
+        parsed, warnings = parse_description(row)
+        self.assertEqual(parsed.variety_code, "XYZ")
+        self.assertIsNone(parsed.variety)
+        self.assertEqual(len(warnings), 1)
+        self.assertIn("XYZ", warnings[0].message)
+        self.assertEqual(warnings[0].item, "99999")
+
+    def test_unparseable_description_never_raises(self):
+        # An entirely garbage description should not raise
+        row = _make_fg_row("GARB@GE !!!", item="88888")
+        try:
+            parsed, warnings = parse_description(row)
+        except Exception as exc:
+            self.fail(f"parse_description raised unexpectedly: {exc}")
+
+    def test_unparseable_description_adds_warning(self):
+        row = _make_fg_row("!!!CANNOT PARSE THIS", item="77777")
+        parsed, warnings = parse_description(row)
+        # Should have some warning about inability to parse
+        self.assertTrue(len(warnings) > 0)
+
+    def test_empty_description_adds_warning(self):
+        row = _make_fg_row("", item="66666")
+        parsed, warnings = parse_description(row)
+        self.assertEqual(len(warnings), 1)
+        self.assertIn("66666", warnings[0].message)
+
+    def test_nv_vintage(self):
+        row = _make_fg_row("FV NV MXD CON 750ml/12p Stock for consol")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.vintage, "NV")
+
+    def test_375ml_pack(self):
+        row = _make_fg_row("FV 25 SAB EP UK 375ml/12p")
+        parsed, _ = parse_description(row)
+        self.assertEqual(parsed.bottle_size_ml, 375)
+        self.assertEqual(parsed.pack_size, 12)
+
+
+class TestParseAllFinishedGoods(unittest.TestCase):
+    def test_only_processes_finished_goods(self):
+        fg = _make_fg_row("FV 22 CHR EP NZ 750ml/12p", item="1", type1="Finished Goods")
+        dg = _make_fg_row("Dry Goods Label", item="2", type1="Dry Goods")
+        parsed, _ = parse_all_finished_goods([fg, dg])
+        self.assertEqual(len(parsed), 1)
+        self.assertEqual(parsed[0].raw.item, "1")
+
+    def test_returns_warnings_from_all_rows(self):
+        row1 = _make_fg_row("FV 22 XYZ EP NZ 750ml/12p", item="1")
+        row2 = _make_fg_row("FV 22 ABC EP NZ 750ml/12p", item="2")
+        _, warnings = parse_all_finished_goods([row1, row2])
+        # Each unknown code produces a warning
+        self.assertEqual(len(warnings), 2)
+
+
+if __name__ == "__main__":
+    unittest.main()
