+"""Tests for wine_stock_reporter.csv_loader."""
+
+import csv
+import os
+import tempfile
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.csv_loader import (
+    ERROR_FILE_NOT_FOUND,
+    ERROR_MISSING_COLUMN,
+    ERROR_UNREADABLE_CSV,
+    REQUIRED_COLUMNS,
+    load_csv,
+)
+from wine_stock_reporter.models import StockRow
+
+
+def _write_csv(path: str, rows: list[dict], fieldnames: list[str] | None = None) -> None:
+    """Write a list of dicts as CSV to path."""
+    if fieldnames is None:
+        fieldnames = list(rows[0].keys()) if rows else []
+    with open(path, "w", newline="", encoding="utf-8") as fh:
+        writer = csv.DictWriter(fh, fieldnames=fieldnames)
+        writer.writeheader()
+        writer.writerows(rows)
+
+
+def _sample_row(**overrides) -> dict:
+    base = {
+        "Type1": "Finished Goods",
+        "Item": "100001",
+        "Description": "FV 22 CHR EP NZ 750ml/12p",
+        "ClientStockCode": "",
+        "ClientStockDescription": "",
+        "Lot": "W123",
+        "OnHand": "10.00",
+        "Warehouse": "Marlborough",
+        "Allocated": "0.00",
+        "Pending": "0.00",
+        "Available": "10.00",
+        "Units": "Cases",
+    }
+    base.update(overrides)
+    return base
+
+
+class TestLoadCsvSuccess(unittest.TestCase):
+    def setUp(self):
+        self.tmpdir = tempfile.mkdtemp()
+        self.csv_path = os.path.join(self.tmpdir, "test.csv")
+
+    def test_basic_load_returns_stock_rows(self):
+        _write_csv(self.csv_path, [_sample_row()])
+        rows, warnings = load_csv(self.csv_path)
+        self.assertEqual(len(rows), 1)
+        self.assertIsInstance(rows[0], StockRow)
+
+    def test_numeric_fields_are_decimal(self):
+        _write_csv(self.csv_path, [_sample_row(OnHand="13.67", Available="13.67")])
+        rows, _ = load_csv(self.csv_path)
+        self.assertIsInstance(rows[0].on_hand, Decimal)
+        self.assertEqual(rows[0].on_hand, Decimal("13.67"))
+
+    def test_thousands_separator_parsed(self):
+        # Write the value without extra Python-level quotes; csv.DictWriter
+        # will apply CSV quoting around the comma automatically.
+        _write_csv(self.csv_path, [_sample_row(OnHand='2,637.00', Available='2,637.00')])
+        rows, _ = load_csv(self.csv_path)
+        self.assertEqual(rows[0].on_hand, Decimal("2637.00"))
+
+    def test_blank_numeric_becomes_zero(self):
+        _write_csv(self.csv_path, [_sample_row(Allocated="", Pending="")])
+        rows, _ = load_csv(self.csv_path)
+        self.assertEqual(rows[0].allocated, Decimal("0"))
+        self.assertEqual(rows[0].pending, Decimal("0"))
+
+    def test_optional_columns_can_be_absent(self):
+        # Rows without ClientStockCode / ClientStockDescription / Lot should still load
+        row = {
+            "Type1": "Finished Goods",
+            "Item": "100002",
+            "Description": "FV 22 CHR EP NZ 750ml/12p",
+            "OnHand": "5.00",
+            "Warehouse": "Marlborough",
+            "Allocated": "0.00",
+            "Pending": "0.00",
+            "Available": "5.00",
+            "Units": "Cases",
+        }
+        fieldnames = list(row.keys())
+        _write_csv(self.csv_path, [row], fieldnames=fieldnames)
+        rows, _ = load_csv(self.csv_path)
+        self.assertEqual(len(rows), 1)
+
+    def test_multiple_rows_loaded(self):
+        data = [_sample_row(Item="1"), _sample_row(Item="2"), _sample_row(Item="3")]
+        _write_csv(self.csv_path, data)
+        rows, _ = load_csv(self.csv_path)
+        self.assertEqual(len(rows), 3)
+
+    def test_negative_value_generates_warning(self):
+        _write_csv(self.csv_path, [_sample_row(OnHand="-5.00")])
+        rows, warnings = load_csv(self.csv_path)
+        self.assertEqual(rows[0].on_hand, Decimal("-5.00"))
+        self.assertTrue(len(warnings) > 0)
+
+    def test_non_numeric_value_becomes_zero_with_warning(self):
+        _write_csv(self.csv_path, [_sample_row(OnHand="N/A")])
+        rows, warnings = load_csv(self.csv_path)
+        self.assertEqual(rows[0].on_hand, Decimal("0"))
+        self.assertTrue(len(warnings) > 0)
+
+    def test_dash_numeric_becomes_zero(self):
+        _write_csv(self.csv_path, [_sample_row(Allocated="-")])
+        rows, _ = load_csv(self.csv_path)
+        self.assertEqual(rows[0].allocated, Decimal("0"))
+
+
+class TestLoadCsvErrors(unittest.TestCase):
+    def setUp(self):
+        self.tmpdir = tempfile.mkdtemp()
+        self.csv_path = os.path.join(self.tmpdir, "test.csv")
+
+    def test_missing_file_raises_file_not_found(self):
+        with self.assertRaises(FileNotFoundError) as ctx:
+            load_csv("/nonexistent/path/file.csv")
+        self.assertIn("Error:", str(ctx.exception))
+
+    def test_missing_required_column_raises_value_error(self):
+        # Write CSV without the "Available" column
+        row = {
+            "Type1": "Finished Goods",
+            "Item": "100001",
+            "Description": "FV 22 CHR EP NZ 750ml/12p",
+            "OnHand": "10.00",
+            "Warehouse": "Marlborough",
+            "Allocated": "0.00",
+            "Pending": "0.00",
+            "Units": "Cases",
+            # "Available" intentionally omitted
+        }
+        _write_csv(self.csv_path, [row])
+        with self.assertRaises(ValueError) as ctx:
+            load_csv(self.csv_path)
+        self.assertIn("Available", str(ctx.exception))
+
+    def test_error_message_uses_constant(self):
+        # Verify we import and use the correct constant
+        msg = ERROR_MISSING_COLUMN.format(column="Available")
+        self.assertIn("Available", msg)
+
+    def test_required_columns_constant_contains_expected(self):
+        for col in ("Type1", "Item", "Description", "OnHand", "Available", "Units"):
+            self.assertIn(col, REQUIRED_COLUMNS)
+
+
+class TestLoadCsvSampleFile(unittest.TestCase):
+    """Smoke test: load examples/stock_sample.csv from repo root."""
+
+    SAMPLE_PATH = os.path.join(
+        os.path.dirname(__file__), "..", "examples", "stock_sample.csv"
+    )
+
+    def test_sample_loads_without_error(self):
+        if not os.path.exists(self.SAMPLE_PATH):
+            self.skipTest("examples/stock_sample.csv not found")
+        rows, warnings = load_csv(self.SAMPLE_PATH)
+        # Must return at least some rows
+        self.assertGreater(len(rows), 0)
+        # All rows are StockRow instances
+        for row in rows:
+            self.assertIsInstance(row, StockRow)
+
+    def test_sample_contains_both_types(self):
+        if not os.path.exists(self.SAMPLE_PATH):
+            self.skipTest("examples/stock_sample.csv not found")
+        rows, _ = load_csv(self.SAMPLE_PATH)
+        types = {r.type1 for r in rows}
+        self.assertIn("Finished Goods", types)
+        self.assertIn("Dry Goods", types)
+
+
+if __name__ == "__main__":
+    unittest.main()
