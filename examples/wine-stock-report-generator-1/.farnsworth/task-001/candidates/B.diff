+"""Tests for wine_stock_reporter.report."""
+
+import os
+import subprocess
+import sys
+import tempfile
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.calculations import attach_nine_le
+from wine_stock_reporter.models import (
+    ParsedWineRow,
+    ReportData,
+    ReportOptions,
+    StockRow,
+    ValidationWarning,
+)
+from wine_stock_reporter.report import (
+    NINE_LE_MISSING,
+    SECTION_DATA_WARNINGS,
+    SECTION_DETAILED_FG,
+    SECTION_DRY_GOODS,
+    SECTION_EXECUTIVE_SUMMARY,
+    SECTION_LOW_STOCK,
+    render_report,
+    write_report,
+)
+
+
+def _make_stock_row(
+    type1: str = "Finished Goods",
+    item: str = "100001",
+    description: str = "FV 22 CHR EP NZ 750ml/12p",
+    on_hand: str = "10.00",
+    allocated: str = "0.00",
+    pending: str = "0.00",
+    available: str = "10.00",
+    units: str = "Cases",
+    lot: str = "W123",
+    warehouse: str = "Marlborough",
+) -> StockRow:
+    return StockRow(
+        type1=type1,
+        item=item,
+        description=description,
+        client_stock_code="",
+        client_stock_description="",
+        lot=lot,
+        on_hand=Decimal(on_hand),
+        warehouse=warehouse,
+        allocated=Decimal(allocated),
+        pending=Decimal(pending),
+        available=Decimal(available),
+        units=units,
+    )
+
+
+def _make_parsed_row(
+    item: str = "100001",
+    description: str = "FV 22 CHR EP NZ 750ml/12p",
+    available: str = "10.00",
+    on_hand: str = "10.00",
+    bottle_size_ml: int | None = 750,
+    pack_size: int | None = 12,
+    variety: str | None = "Chardonnay",
+    variety_code: str | None = "CHR",
+    vintage: str | None = "2022",
+    market: str | None = "NZ",
+) -> ParsedWineRow:
+    raw = _make_stock_row(item=item, description=description, available=available, on_hand=on_hand)
+    return ParsedWineRow(
+        raw=raw,
+        variety_code=variety_code,
+        variety=variety,
+        vintage=vintage,
+        market=market,
+        bottle_size_ml=bottle_size_ml,
+        pack_size=pack_size,
+    )
+
+
+def _make_report_data(
+    finished_goods=None,
+    dry_goods=None,
+    warnings=None,
+    options=None,
+    source_file="test.csv",
+    warehouses=None,
+) -> ReportData:
+    if finished_goods is None:
+        finished_goods = []
+    if dry_goods is None:
+        dry_goods = []
+    if warnings is None:
+        warnings = []
+    if options is None:
+        options = ReportOptions()
+    if warehouses is None:
+        warehouses = ["Marlborough"]
+    return ReportData(
+        options=options,
+        source_file=source_file,
+        warehouses=warehouses,
+        finished_goods=finished_goods,
+        dry_goods=dry_goods,
+        warnings=warnings,
+    )
+
+
+class TestRenderReportStructure(unittest.TestCase):
+    def setUp(self):
+        pw = _make_parsed_row()
+        attach_nine_le([pw], "Available")
+        self.data = _make_report_data(finished_goods=[pw])
+
+    def test_report_contains_title(self):
+        md = render_report(self.data)
+        self.assertIn("# Wine Stock Report", md)
+
+    def test_report_contains_executive_summary(self):
+        md = render_report(self.data)
+        self.assertIn(SECTION_EXECUTIVE_SUMMARY, md)
+
+    def test_report_contains_detailed_fg_section(self):
+        md = render_report(self.data)
+        self.assertIn(SECTION_DETAILED_FG, md)
+
+    def test_report_contains_metadata(self):
+        md = render_report(self.data)
+        self.assertIn("Marlborough", md)
+        self.assertIn("test.csv", md)
+
+    def test_report_ends_with_newline(self):
+        md = render_report(self.data)
+        self.assertTrue(md.endswith("\n"))
+
+
+class TestNineLeMissing(unittest.TestCase):
+    def test_nine_le_shown_as_dash_when_none(self):
+        pw = _make_parsed_row(bottle_size_ml=None, pack_size=None)
+        attach_nine_le([pw], "Available")
+        self.assertIsNone(pw.nine_le)
+        data = _make_report_data(finished_goods=[pw])
+        md = render_report(data)
+        self.assertIn(NINE_LE_MISSING, md)
+
+    def test_nine_le_missing_constant_is_dash(self):
+        self.assertEqual(NINE_LE_MISSING, "—")
+
+
+class TestGroupTable(unittest.TestCase):
+    def test_group_table_present_when_group_by_is_variety(self):
+        pw = _make_parsed_row()
+        attach_nine_le([pw], "Available")
+        data = _make_report_data(
+            finished_goods=[pw],
+            options=ReportOptions(group_by="variety"),
+        )
+        md = render_report(data)
+        self.assertIn("## Stock by Variety", md)
+
+    def test_group_table_absent_when_group_by_is_none(self):
+        pw = _make_parsed_row()
+        attach_nine_le([pw], "Available")
+        data = _make_report_data(
+            finished_goods=[pw],
+            options=ReportOptions(group_by="none"),
+        )
+        md = render_report(data)
+        self.assertNotIn("## Stock by", md)
+
+
+class TestLowStockSection(unittest.TestCase):
+    def test_low_stock_section_appears_when_enabled_and_threshold_reached(self):
+        pw = _make_parsed_row(available="0.10", bottle_size_ml=750, pack_size=12)
+        attach_nine_le([pw], "Available")
+        data = _make_report_data(
+            finished_goods=[pw],
+            options=ReportOptions(
+                low_stock_warnings=True,
+                low_stock_threshold=Decimal("10"),
+            ),
+        )
+        md = render_report(data)
+        self.assertIn(SECTION_LOW_STOCK, md)
+
+    def test_low_stock_section_absent_when_disabled(self):
+        pw = _make_parsed_row(available="0.10", bottle_size_ml=750, pack_size=12)
+        attach_nine_le([pw], "Available")
+        data = _make_report_data(
+            finished_goods=[pw],
+            options=ReportOptions(low_stock_warnings=False),
+        )
+        md = render_report(data)
+        self.assertNotIn(SECTION_LOW_STOCK, md)
+
+    def test_low_stock_section_absent_when_no_items_below_threshold(self):
+        pw = _make_parsed_row(available="1000.00", bottle_size_ml=750, pack_size=12)
+        attach_nine_le([pw], "Available")
+        data = _make_report_data(
+            finished_goods=[pw],
+            options=ReportOptions(
+                low_stock_warnings=True,
+                low_stock_threshold=Decimal("10"),
+            ),
+        )
+        md = render_report(data)
+        self.assertNotIn(SECTION_LOW_STOCK, md)
+
+
+class TestDryGoodsSection(unittest.TestCase):
+    def test_dry_goods_section_present_when_included(self):
+        dg = _make_stock_row(type1="Dry Goods", item="200001", units="Eaches", description="FV LA 24 SAB")
+        data = _make_report_data(
+            dry_goods=[dg],
+            options=ReportOptions(include_dry_goods=True),
+        )
+        md = render_report(data)
+        self.assertIn(SECTION_DRY_GOODS, md)
+
+    def test_dry_goods_section_absent_when_excluded(self):
+        dg = _make_stock_row(type1="Dry Goods", item="200001", units="Eaches", description="FV LA 24 SAB")
+        data = _make_report_data(
+            dry_goods=[dg],
+            options=ReportOptions(include_dry_goods=False),
+        )
+        md = render_report(data)
+        self.assertNotIn(SECTION_DRY_GOODS, md)
+
+
+class TestDataWarningsSection(unittest.TestCase):
+    def test_data_warnings_section_present_when_warnings_exist(self):
+        w = ValidationWarning(message="Test warning", item="100001")
+        data = _make_report_data(warnings=[w])
+        md = render_report(data)
+        self.assertIn(SECTION_DATA_WARNINGS, md)
+        self.assertIn("Test warning", md)
+
+    def test_data_warnings_section_absent_when_no_warnings(self):
+        data = _make_report_data(warnings=[])
+        md = render_report(data)
+        self.assertNotIn(SECTION_DATA_WARNINGS, md)
+
+
+class TestWriteReport(unittest.TestCase):
+    def test_write_report_creates_file(self):
+        with tempfile.TemporaryDirectory() as tmpdir:
+            out_path = os.path.join(tmpdir, "report.md")
+            pw = _make_parsed_row()
+            attach_nine_le([pw], "Available")
+            data = _make_report_data(
+                finished_goods=[pw],
+                options=ReportOptions(output_path=out_path),
+            )
+            write_report(data)
+            self.assertTrue(os.path.exists(out_path))
+            with open(out_path) as fh:
+                content = fh.read()
+            self.assertIn("# Wine Stock Report", content)
+
+
+class TestEndToEndSmoke(unittest.TestCase):
+    """Smoke test: run the CLI against the sample CSV file."""
+
+    SAMPLE_PATH = os.path.join(
+        os.path.dirname(__file__), "..", "examples", "stock_sample.csv"
+    )
+
+    def test_cli_exits_zero_and_writes_file(self):
+        if not os.path.exists(self.SAMPLE_PATH):
+            self.skipTest("examples/stock_sample.csv not found")
+
+        with tempfile.TemporaryDirectory() as tmpdir:
+            out_path = os.path.join(tmpdir, "report.md")
+            result = subprocess.run(
+                [
+                    sys.executable,
+                    "-m",
+                    "wine_stock_reporter",
+                    self.SAMPLE_PATH,
+                    "--no-interactive",
+                    "--output",
+                    out_path,
+                ],
+                capture_output=True,
+                text=True,
+                cwd=os.path.join(os.path.dirname(__file__), ".."),
+            )
+            self.assertEqual(result.returncode, 0, msg=result.stderr)
+            self.assertTrue(os.path.exists(out_path), "Output file was not created")
+            with open(out_path) as fh:
+                content = fh.read()
+            # Check structure (sections present), not totals
+            self.assertIn("# Wine Stock Report", content)
+            self.assertIn(SECTION_EXECUTIVE_SUMMARY, content)
+            self.assertIn(SECTION_DETAILED_FG, content)
+
+    def test_cli_missing_file_exits_one(self):
+        result = subprocess.run(
+            [
+                sys.executable,
+                "-m",
+                "wine_stock_reporter",
+                "/nonexistent/path/file.csv",
+                "--no-interactive",
+            ],
+            capture_output=True,
+            text=True,
+        )
+        self.assertEqual(result.returncode, 1)
+        self.assertIn("Error:", result.stderr)
+
+    def test_cli_bad_argument_exits_two(self):
+        result = subprocess.run(
+            [
+                sys.executable,
+                "-m",
+                "wine_stock_reporter",
+                "--basis",
+                "INVALID",
+            ],
+            capture_output=True,
+            text=True,
+        )
+        self.assertEqual(result.returncode, 2)
+
+
+if __name__ == "__main__":
+    unittest.main()
