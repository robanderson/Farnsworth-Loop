@@ -0,0 +1,426 @@
+"""Command-line interface for the Wine Stock Report Generator.
+
+Responsibilities:
+- Parse command-line arguments (argparse).
+- Run interactive prompts when --no-interactive is NOT specified.
+- Orchestrate loading, parsing, validation, calculation, and reporting.
+- Map all data / file errors to exit code 1 with "Error: ..." on stderr.
+- Exit code 0 on success; 2 on usage error (argparse-native).
+
+All I/O is injectable via input_fn and output_fn for testability.
+"""
+
+from __future__ import annotations
+
+import argparse
+import sys
+from decimal import Decimal, InvalidOperation
+from pathlib import Path
+from typing import Callable, Optional, TextIO
+
+from .calculations import attach_nine_le
+from .csv_loader import load_csv
+from .models import ReportData, ReportOptions, ValidationWarning
+from .parser import parse_all_finished_goods
+from .report import write_report
+from .validation import validate_rows
+
+# ---------------------------------------------------------------------------
+# Constants
+# ---------------------------------------------------------------------------
+
+DEFAULT_BASIS = "Available"
+DEFAULT_GROUP_BY = "variety"
+DEFAULT_INCLUDE_DRY_GOODS = True
+DEFAULT_LOW_STOCK_WARNINGS = True
+DEFAULT_LOW_STOCK_THRESHOLD = Decimal("10")
+DEFAULT_OUTPUT = "stock-report.md"
+
+VALID_BASIS_VALUES = ("OnHand", "Available")
+VALID_GROUP_BY_VALUES = ("variety", "vintage", "market", "pack_size", "lot", "none")
+
+PROMPT_BASIS = "1. Use OnHand or Available stock for wine totals? [{default}]: "
+PROMPT_DRY_GOODS = "2. Include Dry Goods section? [{default}]: "
+PROMPT_GROUP_BY = (
+    "3. Group primary wine summary by variety, vintage, market, "
+    "pack_size, lot, or none? [{default}]: "
+)
+PROMPT_LOW_STOCK = "4. Include low-stock warnings? [{default}]: "
+PROMPT_THRESHOLD = "5. Low-stock threshold in 9LE? [{default}]: "
+PROMPT_OUTPUT = "6. Output filename? [{default}]: "
+
+YES_VALUES = frozenset({"yes", "y", "true", "1"})
+NO_VALUES = frozenset({"no", "n", "false", "0"})
+
+
+# ---------------------------------------------------------------------------
+# Argument parser
+# ---------------------------------------------------------------------------
+
+def build_parser() -> argparse.ArgumentParser:
+    """Build and return the argument parser."""
+    parser = argparse.ArgumentParser(
+        prog="wine_stock_reporter",
+        description="Generate a Markdown wine stock report from a warehouse CSV.",
+    )
+    parser.add_argument(
+        "csv_path",
+        metavar="CSV_PATH",
+        help="Path to the warehouse stock CSV file.",
+    )
+    parser.add_argument(
+        "--basis",
+        choices=VALID_BASIS_VALUES,
+        default=None,
+        help=f"Stock basis to use for wine totals (default: {DEFAULT_BASIS}).",
+    )
+    parser.add_argument(
+        "--group-by",
+        choices=VALID_GROUP_BY_VALUES,
+        default=None,
+        dest="group_by",
+        help=f"Group the primary wine summary by this field (default: {DEFAULT_GROUP_BY}).",
+    )
+    parser.add_argument(
+        "--include-dry-goods",
+        action="store_true",
+        default=None,
+        dest="include_dry_goods",
+        help="Include the Dry Goods section in the report (default: on).",
+    )
+    parser.add_argument(
+        "--no-dry-goods",
+        action="store_false",
+        dest="include_dry_goods",
+        help="Exclude the Dry Goods section from the report.",
+    )
+    parser.add_argument(
+        "--low-stock-warnings",
+        action="store_true",
+        default=None,
+        dest="low_stock_warnings",
+        help="Include low-stock warnings in the report (default: on).",
+    )
+    parser.add_argument(
+        "--no-low-stock-warnings",
+        action="store_false",
+        dest="low_stock_warnings",
+        help="Suppress low-stock warnings.",
+    )
+    parser.add_argument(
+        "--low-stock-threshold",
+        type=str,
+        default=None,
+        dest="low_stock_threshold",
+        metavar="N",
+        help=f"9LE threshold for low-stock warnings (default: {DEFAULT_LOW_STOCK_THRESHOLD}).",
+    )
+    parser.add_argument(
+        "--output",
+        default=None,
+        dest="output_path",
+        metavar="PATH",
+        help=f"Output Markdown file path (default: {DEFAULT_OUTPUT}).",
+    )
+    parser.add_argument(
+        "--no-interactive",
+        action="store_true",
+        default=False,
+        dest="no_interactive",
+        help="Skip all interactive prompts and use defaults / CLI flags.",
+    )
+    return parser
+
+
+# ---------------------------------------------------------------------------
+# Interactive prompting
+# ---------------------------------------------------------------------------
+
+def _prompt(
+    prompt_text: str,
+    default: str,
+    validate_fn: Callable[[str], Optional[str]],
+    input_fn: Callable[[], str],
+    output_fn: Callable[..., None],
+) -> str:
+    """Prompt the user for input, re-prompting on invalid answers.
+
+    Returns the validated value (or default on empty input).
+    Raises EOFError to signal EOF (caller should use defaults for remaining).
+    """
+    while True:
+        output_fn(prompt_text.format(default=default), end="", flush=True)
+        try:
+            raw = input_fn()
+        except EOFError:
+            raise
+
+        stripped = raw.strip()
+        if stripped == "":
+            return default
+
+        error = validate_fn(stripped)
+        if error is None:
+            return stripped
+        output_fn(f"  Invalid: {error}")
+
+
+def _validate_basis(value: str) -> Optional[str]:
+    if value in VALID_BASIS_VALUES:
+        return None
+    return f"must be one of {', '.join(VALID_BASIS_VALUES)}"
+
+
+def _validate_bool(value: str) -> Optional[str]:
+    low = value.lower()
+    if low in YES_VALUES or low in NO_VALUES:
+        return None
+    return "enter yes or no"
+
+
+def _validate_group_by(value: str) -> Optional[str]:
+    if value in VALID_GROUP_BY_VALUES:
+        return None
+    return f"must be one of {', '.join(VALID_GROUP_BY_VALUES)}"
+
+
+def _validate_threshold(value: str) -> Optional[str]:
+    try:
+        d = Decimal(value)
+        if d < Decimal("0"):
+            return "threshold must be non-negative"
+        return None
+    except InvalidOperation:
+        return "must be a number (e.g. 10 or 5.5)"
+
+
+def _validate_output(value: str) -> Optional[str]:
+    # Any non-empty string is acceptable as a filename
+    if value.strip():
+        return None
+    return "output path cannot be empty"
+
+
+def _parse_bool(value: str) -> bool:
+    return value.lower() in YES_VALUES
+
+
+def _bool_default(flag: bool) -> str:
+    return "yes" if flag else "no"
+
+
+def run_interactive(
+    basis: str,
+    group_by: str,
+    include_dry_goods: bool,
+    low_stock_warnings: bool,
+    low_stock_threshold: Decimal,
+    output_path: str,
+    input_fn: Callable[[], str] = input,
+    output_fn: Callable[..., None] = print,
+) -> ReportOptions:
+    """Run the 6 interactive prompts and return ReportOptions.
+
+    On EOFError from any prompt, all remaining options take their defaults.
+    """
+    options = ReportOptions(
+        basis=basis,
+        group_by=group_by,
+        include_dry_goods=include_dry_goods,
+        low_stock_warnings=low_stock_warnings,
+        low_stock_threshold=low_stock_threshold,
+        output_path=output_path,
+    )
+
+    prompts = [
+        # (attr_name, prompt_template, default_str, validator, converter)
+        (
+            "basis",
+            PROMPT_BASIS,
+            basis,
+            _validate_basis,
+            lambda v: v,
+        ),
+        (
+            "include_dry_goods",
+            PROMPT_DRY_GOODS,
+            _bool_default(include_dry_goods),
+            _validate_bool,
+            _parse_bool,
+        ),
+        (
+            "group_by",
+            PROMPT_GROUP_BY,
+            group_by,
+            _validate_group_by,
+            lambda v: v,
+        ),
+        (
+            "low_stock_warnings",
+            PROMPT_LOW_STOCK,
+            _bool_default(low_stock_warnings),
+            _validate_bool,
+            _parse_bool,
+        ),
+        (
+            "low_stock_threshold",
+            PROMPT_THRESHOLD,
+            str(low_stock_threshold),
+            _validate_threshold,
+            Decimal,
+        ),
+        (
+            "output_path",
+            PROMPT_OUTPUT,
+            output_path,
+            _validate_output,
+            lambda v: v,
+        ),
+    ]
+
+    for attr, prompt_template, default_str, validator, converter in prompts:
+        try:
+            raw_value = _prompt(
+                prompt_template,
+                default_str,
+                validator,
+                input_fn,
+                output_fn,
+            )
+            setattr(options, attr, converter(raw_value))
+        except EOFError:
+            # On EOF accept defaults for this and all remaining questions
+            break
+
+    return options
+
+
+# ---------------------------------------------------------------------------
+# Main entry point
+# ---------------------------------------------------------------------------
+
+def main(
+    argv: Optional[list[str]] = None,
+    input_fn: Callable[[], str] = input,
+    output_fn: Callable[..., None] = print,
+    stderr: TextIO = sys.stderr,
+) -> int:
+    """Parse args, orchestrate the report pipeline, return exit code."""
+    parser = build_parser()
+    # Do NOT wrap in try/except SystemExit — argparse handles exit code 2.
+    args = parser.parse_args(argv)
+
+    # --- Load CSV ---
+    try:
+        stock_rows, load_warnings = load_csv(args.csv_path)
+    except FileNotFoundError as exc:
+        print(str(exc), file=stderr)
+        return 1
+    except ValueError as exc:
+        print(str(exc), file=stderr)
+        return 1
+
+    # --- Detect warehouses and print summary ---
+    warehouses = sorted({r.warehouse for r in stock_rows if r.warehouse})
+    fg_rows = [r for r in stock_rows if r.type1 == "Finished Goods"]
+    dg_rows = [r for r in stock_rows if r.type1 == "Dry Goods"]
+    units_set = sorted({r.units for r in stock_rows if r.units})
+
+    warehouse_str = ", ".join(warehouses) if warehouses else "Unknown"
+    units_str = ", ".join(units_set) if units_set else "Unknown"
+
+    output_fn(
+        f"Detected: {len(fg_rows)} Finished Goods rows, "
+        f"{len(dg_rows)} Dry Goods rows; "
+        f"warehouse(s): {warehouse_str}; "
+        f"units: {units_str}"
+    )
+
+    # --- Resolve options (CLI flags take precedence; prompts fill the rest) ---
+    # Start with defaults
+    basis = DEFAULT_BASIS
+    group_by = DEFAULT_GROUP_BY
+    include_dry_goods = DEFAULT_INCLUDE_DRY_GOODS
+    low_stock_warnings = DEFAULT_LOW_STOCK_WARNINGS
+    low_stock_threshold = DEFAULT_LOW_STOCK_THRESHOLD
+    output_path = DEFAULT_OUTPUT
+
+    # Apply CLI overrides
+    if args.basis is not None:
+        basis = args.basis
+    if args.group_by is not None:
+        group_by = args.group_by
+    if args.include_dry_goods is not None:
+        include_dry_goods = args.include_dry_goods
+    if args.low_stock_warnings is not None:
+        low_stock_warnings = args.low_stock_warnings
+    if args.low_stock_threshold is not None:
+        try:
+            low_stock_threshold = Decimal(args.low_stock_threshold)
+        except InvalidOperation:
+            print(
+                f"Error: --low-stock-threshold must be a number, "
+                f"got {args.low_stock_threshold!r}",
+                file=stderr,
+            )
+            return 1
+    if args.output_path is not None:
+        output_path = args.output_path
+
+    if args.no_interactive:
+        options = ReportOptions(
+            basis=basis,
+            group_by=group_by,
+            include_dry_goods=include_dry_goods,
+            low_stock_warnings=low_stock_warnings,
+            low_stock_threshold=low_stock_threshold,
+            output_path=output_path,
+        )
+    else:
+        options = run_interactive(
+            basis=basis,
+            group_by=group_by,
+            include_dry_goods=include_dry_goods,
+            low_stock_warnings=low_stock_warnings,
+            low_stock_threshold=low_stock_threshold,
+            output_path=output_path,
+            input_fn=input_fn,
+            output_fn=output_fn,
+        )
+
+    # --- Validate rows ---
+    validation_warnings = validate_rows(stock_rows)
+
+    # --- Parse finished goods descriptions ---
+    parsed_fg, parse_warnings = parse_all_finished_goods(stock_rows)
+
+    # --- Attach 9LE values ---
+    attach_nine_le(parsed_fg, options.basis)
+
+    # --- Collect dry goods ---
+    dry_goods_rows = [r for r in stock_rows if r.type1 == "Dry Goods"]
+
+    # --- Merge all warnings ---
+    all_warnings: list[ValidationWarning] = (
+        load_warnings + validation_warnings + parse_warnings
+    )
+
+    # --- Build report data ---
+    report_data = ReportData(
+        options=options,
+        source_file=args.csv_path,
+        warehouses=warehouses,
+        finished_goods=parsed_fg,
+        dry_goods=dry_goods_rows,
+        warnings=all_warnings,
+    )
+
+    # --- Write report ---
+    try:
+        write_report(report_data)
+    except OSError as exc:
+        print(f"Error: could not write report: {exc}", file=stderr)
+        return 1
+
+    output_fn(f"Report written to {options.output_path}")
+    return 0
