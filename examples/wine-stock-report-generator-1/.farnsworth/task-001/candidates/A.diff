@@ -0,0 +1,270 @@
+"""Report generation in Markdown format."""
+
+from datetime import datetime
+from decimal import Decimal
+from pathlib import Path
+from typing import List, Dict, Optional, Tuple
+
+from wine_stock_reporter.models import (
+    ParsedWineRow,
+    DryGoodsRow,
+    ReportOptions,
+    ValidationWarning,
+    ExecutiveSummary,
+)
+from wine_stock_reporter.calculations import (
+    aggregate_by_grouping,
+    calculate_totals,
+    identify_low_stock_items,
+)
+
+
+def generate_report(
+    wine_rows: List[ParsedWineRow],
+    dry_goods_rows: List[DryGoodsRow],
+    options: ReportOptions,
+    warnings: List[ValidationWarning],
+    source_file: str,
+    warehouses: List[str],
+) -> str:
+    """Generate a complete Markdown report."""
+
+    # Calculate totals for executive summary
+    set_9le_for_all(wine_rows, options.basis)
+    total_available, total_allocated, total_pending, total_9le = calculate_totals(wine_rows, options.basis)
+
+    # Find lowest stock item
+    low_stock_items = identify_low_stock_items(wine_rows, Decimal("0"), options.basis)
+    lowest_item = None
+    lowest_9le = None
+    if low_stock_items:
+        # Get the absolute lowest
+        lowest_item = low_stock_items[-1][0]  # Already sorted ascending, so last is highest
+        lowest_9le = low_stock_items[-1][1]
+        # Actually we want lowest, so use index 0
+        lowest_item = low_stock_items[0][0]
+        lowest_9le = low_stock_items[0][1]
+
+    dry_goods_count = len(dry_goods_rows) if options.include_dry_goods else 0
+
+    # Build report sections
+    sections = []
+
+    # Header
+    sections.append(_build_header(source_file, warehouses, options.basis))
+
+    # Executive summary
+    sections.append(
+        _build_executive_summary(
+            len(wine_rows),
+            dry_goods_count,
+            total_9le,
+            total_available,
+            total_allocated,
+            total_pending,
+            lowest_item,
+            lowest_9le,
+            len(warnings),
+        )
+    )
+
+    # Grouping section
+    if options.group_by != "none":
+        sections.append(_build_grouping_section(wine_rows, options.group_by, options.basis))
+
+    # Detailed finished goods
+    sections.append(_build_detailed_finished_goods(wine_rows, options.basis))
+
+    # Low-stock warnings
+    if options.low_stock_warnings:
+        low_stock = identify_low_stock_items(wine_rows, options.low_stock_threshold, options.basis)
+        sections.append(_build_low_stock_warnings(low_stock))
+
+    # Dry goods
+    if options.include_dry_goods and dry_goods_rows:
+        sections.append(_build_dry_goods_section(dry_goods_rows))
+
+    # Data warnings
+    sections.append(_build_data_warnings(warnings))
+
+    return "\n\n".join(sections)
+
+
+def set_9le_for_all(wine_rows: List[ParsedWineRow], basis: str) -> None:
+    """Set 9LE on all wine rows based on basis."""
+    for row in wine_rows:
+        if row.bottle_size_ml is not None and row.pack_size is not None:
+            try:
+                if basis == "OnHand":
+                    quantity = row.on_hand
+                else:
+                    quantity = row.available
+
+                bottle_size_litres = Decimal(row.bottle_size_ml) / Decimal("1000")
+                litres = quantity * Decimal(row.pack_size) * bottle_size_litres
+                row.nine_litre_equivalent = litres / Decimal("9")
+            except (TypeError, ZeroDivisionError):
+                row.nine_litre_equivalent = None
+
+
+def _build_header(source_file: str, warehouses: List[str], basis: str) -> str:
+    """Build the report header."""
+    gen_date = datetime.now().strftime("%Y-%m-%d")
+    warehouse_str = ", ".join(warehouses) if warehouses else "Unknown"
+    basis_label = "OnHand" if basis == "OnHand" else "Available"
+
+    header = f"""# Wine Stock Report
+
+Generated: {gen_date}
+Source file: {source_file}
+Warehouse: {warehouse_str}
+Stock basis: {basis_label}"""
+    return header
+
+
+def _build_executive_summary(
+    finished_goods_count: int,
+    dry_goods_count: int,
+    total_9le: Decimal,
+    total_available: Decimal,
+    total_allocated: Decimal,
+    total_pending: Decimal,
+    lowest_item: Optional[str],
+    lowest_9le: Optional[Decimal],
+    warnings_count: int,
+) -> str:
+    """Build the executive summary section."""
+    summary_items = [
+        f"Finished Goods rows: {finished_goods_count}",
+        f"Dry Goods rows: {dry_goods_count}",
+        f"Total wine stock: {_format_decimal(total_9le)} 9LE",
+        f"Total available cases: {_format_decimal(total_available)}",
+        f"Total allocated cases: {_format_decimal(total_allocated)}",
+        f"Total pending cases: {_format_decimal(total_pending)}",
+    ]
+
+    if lowest_item and lowest_9le is not None:
+        summary_items.append(f"Lowest stock item: {lowest_item} ({_format_decimal(lowest_9le)} 9LE)")
+
+    summary_items.append(f"Data warnings: {warnings_count}")
+
+    summary = "## Executive Summary\n\n" + "\n".join(f"- {item}" for item in summary_items)
+    return summary
+
+
+def _build_grouping_section(rows: List[ParsedWineRow], group_by: str, basis: str) -> str:
+    """Build a grouping summary section."""
+    aggregates = aggregate_by_grouping(rows, group_by, basis)
+
+    # Determine section title
+    title_map = {
+        "variety": "Stock by Variety",
+        "vintage": "Stock by Vintage",
+        "market": "Stock by Market",
+        "pack_size": "Stock by Pack Size",
+        "lot": "Stock by Lot",
+    }
+    title = title_map.get(group_by, f"Stock by {group_by}")
+
+    # Build table
+    lines = [f"## {title}", ""]
+    lines.append("| Key | Rows | Cases | 9LE |")
+    lines.append("|---|---:|---:|---:|")
+
+    for key in sorted(aggregates.keys()):
+        agg = aggregates[key]
+        rows_count = agg["rows"]
+        cases = _format_decimal(agg["cases"])
+        nine_le = _format_decimal(agg["9le"])
+        lines.append(f"| {key} | {rows_count} | {cases} | {nine_le} |")
+
+    return "\n".join(lines)
+
+
+def _build_detailed_finished_goods(rows: List[ParsedWineRow], basis: str) -> str:
+    """Build the detailed finished goods table."""
+    lines = ["## Detailed Finished Goods", ""]
+    lines.append("| Item | Description | Variety | Vintage | Market | Bottle/Pack | On Hand | Allocated | Pending | Available | Units | 9LE |")
+    lines.append("|---|---|---|---|---|---|---:|---:|---:|---:|---|---:|")
+
+    for row in rows:
+        item = row.item
+        desc = row.description[:50] + ("..." if len(row.description) > 50 else "")
+        variety = row.variety or "Unknown"
+        vintage = row.vintage_expanded or ""
+        market = row.market or ""
+        bottle_pack = f"{row.bottle_size_ml}ml/{row.pack_size}p" if row.bottle_size_ml and row.pack_size else "—"
+        on_hand = _format_decimal(row.on_hand)
+        allocated = _format_decimal(row.allocated)
+        pending = _format_decimal(row.pending)
+        available = _format_decimal(row.available)
+        units = row.units
+        nine_le = _format_decimal(row.nine_litre_equivalent) if row.nine_litre_equivalent is not None else "—"
+
+        lines.append(
+            f"| {item} | {desc} | {variety} | {vintage} | {market} | {bottle_pack} | {on_hand} | {allocated} | {pending} | {available} | {units} | {nine_le} |"
+        )
+
+    return "\n".join(lines)
+
+
+def _build_low_stock_warnings(low_stock_items: List[Tuple[str, Decimal]]) -> str:
+    """Build the low-stock warnings section."""
+    lines = ["## Low Stock Warnings", ""]
+
+    if not low_stock_items:
+        lines.append("No items below the low-stock threshold.")
+    else:
+        for item_desc, nine_le in low_stock_items:
+            lines.append(f"- {item_desc}: {_format_decimal(nine_le)} 9LE")
+
+    return "\n".join(lines)
+
+
+def _build_dry_goods_section(dry_goods_rows: List[DryGoodsRow]) -> str:
+    """Build the dry goods summary section."""
+    lines = ["## Dry Goods Summary", ""]
+    lines.append("| Item | Description | On Hand | Allocated | Pending | Available | Units |")
+    lines.append("|---|---|---:|---:|---:|---:|---|")
+
+    for row in dry_goods_rows:
+        item = row.item
+        desc = row.description[:50] + ("..." if len(row.description) > 50 else "")
+        on_hand = _format_decimal(row.on_hand)
+        allocated = _format_decimal(row.allocated)
+        pending = _format_decimal(row.pending)
+        available = _format_decimal(row.available)
+        units = row.units
+
+        lines.append(
+            f"| {item} | {desc} | {on_hand} | {allocated} | {pending} | {available} | {units} |"
+        )
+
+    return "\n".join(lines)
+
+
+def _build_data_warnings(warnings: List[ValidationWarning]) -> str:
+    """Build the data warnings section."""
+    lines = ["## Data Warnings", ""]
+
+    if not warnings:
+        lines.append("No data warnings.")
+    else:
+        for warning in warnings:
+            lines.append(f"- {warning.message}")
+
+    return "\n".join(lines)
+
+
+def _format_decimal(value: Optional[Decimal]) -> str:
+    """Format a decimal for display, rounded to 2 places."""
+    if value is None:
+        return "—"
+    # Round to 2 decimal places
+    rounded = value.quantize(Decimal("0.01"))
+    return str(rounded)
+
+
+def write_report(report_content: str, output_path: str) -> None:
+    """Write report to a file."""
+    Path(output_path).write_text(report_content, encoding="utf-8")
