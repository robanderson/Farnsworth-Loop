+                units="Cases",
+                variety="Chardonnay",
+                bottle_size_ml=750,
+                pack_size=12,
+                nine_litre_equivalent=Decimal("10"),
+            ),
+            ParsedWineRow(
+                type1="Finished Goods",
+                item="124",
+                description="FV 22 SAB EP NZ 750ml/12p",
+                lot=None,
+                on_hand=Decimal("20"),
+                warehouse="Marlborough",
+                allocated=Decimal("0"),
+                pending=Decimal("0"),
+                available=Decimal("20"),
+                units="Cases",
+                variety="Sauvignon Blanc",
