+"""Wine description parser."""
+
+import re
+from typing import Optional, Tuple, List
+
+from wine_stock_reporter.models import ParsedWineRow, RawStockRow, ValidationWarning
+
+
+VARIETY_CODE_MAP = {
+    "CHR": "Chardonnay",
+    "SAB": "Sauvignon Blanc",
+    "PIN": "Pinot Noir",
+    "PIG": "Pinot Gris",
+    "PRO": "Rosé",
+    "RDB": "Red Blend",
+    "MXD": "Mixed / Consolidated",
+}
+
+
+def parse_wine_description(raw_row: RawStockRow) -> Tuple[ParsedWineRow, List[ValidationWarning]]:
+    """
+    Parse a finished goods wine description.
+    Returns (ParsedWineRow, list of warnings).
+    """
+    warnings = []
+    parsed = ParsedWineRow(
+        type1=raw_row.type1,
+        item=raw_row.item,
+        description=raw_row.description,
+        lot=raw_row.lot,
+        on_hand=raw_row.on_hand,
+        warehouse=raw_row.warehouse,
+        allocated=raw_row.allocated,
+        pending=raw_row.pending,
+        available=raw_row.available,
+        units=raw_row.units,
+    )
+
+    desc = raw_row.description.strip()
+    if not desc:
+        warnings.append(ValidationWarning(f"Empty description for item {raw_row.item}"))
+        return parsed, warnings
+
+    # Attempt to parse: FV 22 CHR EP NZ 750ml/6p [extra]
+    # Pattern: FV <vintage> <variety_code> <brand_code> <market> <bottle_size>ml/<pack_size>p [extra description]
+    # Market can include special characters like X+, so allow any non-space sequence
+    pattern = r'^(\w+)\s+(\d+)\s+(\w+)\s+(\w+)\s+(\S+)\s+(\d+)ml/(\d+)p(?:\s+(.*))?$'
+
+    match = re.match(pattern, desc)
+    if match:
+        parsed.prefix = match.group(1)
+        vintage_str = match.group(2)
+        parsed.vintage = vintage_str
+        parsed.variety_code = match.group(3)
+        parsed.brand_code = match.group(4)
+        parsed.market = match.group(5)
+        parsed.bottle_size_ml = int(match.group(6))
+        parsed.pack_size = int(match.group(7))
+        if match.group(8):
+            parsed.extra_description = match.group(8)
+
+        # Expand vintage
+        parsed.vintage_expanded = _expand_vintage(vintage_str)
+
+        # Map variety
+        if parsed.variety_code in VARIETY_CODE_MAP:
+            parsed.variety = VARIETY_CODE_MAP[parsed.variety_code]
+        else:
+            parsed.variety = parsed.variety_code
+            warnings.append(ValidationWarning(f"Unknown variety code '{parsed.variety_code}' in item {raw_row.item}"))
+    else:
+        # Could not parse fully - mark as unknown
+        parsed.variety_code = "Unknown"
+        parsed.variety = "Unknown"
+        warnings.append(ValidationWarning(f"Could not fully parse description for item {raw_row.item}: '{desc}'"))
+
+    # Validation: check for unparseable bottle or pack size
+    if parsed.units == "Cases" and raw_row.type1 == "Finished Goods":
+        if parsed.bottle_size_ml is None:
+            warnings.append(ValidationWarning(f"Could not parse bottle size for item {raw_row.item}"))
+        if parsed.pack_size is None:
+            warnings.append(ValidationWarning(f"Could not parse pack size for item {raw_row.item}"))
+    else:
+        if raw_row.type1 == "Finished Goods" and parsed.units != "Cases":
+            warnings.append(ValidationWarning(f"Finished Goods item {raw_row.item} is not in Cases: {parsed.units}"))
+
+    # Check for suspicious conditions
+    if raw_row.available > raw_row.on_hand:
+        warnings.append(ValidationWarning(f"Available ({raw_row.available}) greater than OnHand ({raw_row.on_hand}) for item {raw_row.item}"))
+
+    on_hand_calc = raw_row.allocated + raw_row.pending + raw_row.available
+    if on_hand_calc != raw_row.on_hand:
+        warnings.append(ValidationWarning(f"Material mismatch for item {raw_row.item}: OnHand - Allocated - Pending != Available"))
+
+    return parsed, warnings
+
+
+def _expand_vintage(vintage_str: str) -> str:
+    """Expand two-digit vintage to four digits."""
+    try:
+        vintage_num = int(vintage_str)
+        if vintage_num < 100:
+            # Assume 2000-2099
+            return str(2000 + vintage_num)
+        return str(vintage_num)
+    except ValueError:
+        return vintage_str
