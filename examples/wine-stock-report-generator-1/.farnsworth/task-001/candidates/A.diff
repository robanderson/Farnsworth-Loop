+"""CSV loading and basic data cleaning."""
+
+import csv
+from decimal import Decimal, InvalidOperation
+from pathlib import Path
+from typing import Optional, List, Tuple
+
+from wine_stock_reporter.models import RawStockRow, ValidationWarning
+
+
+REQUIRED_COLUMNS = [
+    "Type1",
+    "Item",
+    "Description",
+    "OnHand",
+    "Warehouse",
+    "Allocated",
+    "Pending",
+    "Available",
+    "Units",
+]
+
+OPTIONAL_COLUMNS = [
+    "ClientStockCode",
+    "ClientStockDescription",
+    "Lot",
+]
+
+
+def parse_decimal(value: str, field_name: str = "") -> Tuple[Optional[Decimal], Optional[str]]:
+    """
+    Parse a numeric field, handling blanks, decimals, thousands separators, etc.
+    Returns (Decimal value or None, warning message or None).
+    """
+    if not value or not value.strip():
+        return Decimal("0"), None
+
+    value = value.strip()
+
+    # Remove thousands separators
+    value = value.replace(",", "")
+
+    try:
+        decimal_val = Decimal(value)
+        if decimal_val < 0:
+            return decimal_val, f"Negative value in {field_name}: {value}"
+        return decimal_val, None
+    except (InvalidOperation, ValueError):
+        return None, f"Could not parse numeric value in {field_name}: {value}"
+
+
+def load_csv(csv_path: str) -> Tuple[List[RawStockRow], List[ValidationWarning]]:
+    """
+    Load a CSV file and return parsed rows with warnings.
+    Raises: ValueError if the file is missing or required columns are missing.
+    """
+    path = Path(csv_path)
+    if not path.exists():
+        raise ValueError(f"Error: CSV file not found: {csv_path}")
+
+    rows = []
+    warnings = []
+
+    try:
+        with open(path, newline="", encoding="utf-8") as f:
+            reader = csv.DictReader(f)
+            if reader.fieldnames is None:
+                raise ValueError("CSV is empty")
+
+            # Validate required columns
+            missing_columns = [col for col in REQUIRED_COLUMNS if col not in reader.fieldnames]
+            if missing_columns:
+                raise ValueError(f"Error: required column '{missing_columns[0]}' was not found in CSV.")
+
+            for row_num, row in enumerate(reader, start=2):  # start=2 to account for header
+                try:
+                    raw_row = _parse_csv_row(row, warnings)
+                    rows.append(raw_row)
+                except ValueError as e:
+                    warnings.append(ValidationWarning(str(e)))
+                    continue
+
+    except FileNotFoundError:
+        raise ValueError(f"Error: CSV file not found: {csv_path}")
+    except Exception as e:
+        if "Error:" in str(e):
+            raise
+        raise ValueError(f"Error reading CSV: {str(e)}")
+
+    return rows, warnings
+
+
+def _parse_csv_row(row: dict, warnings: List[ValidationWarning]) -> RawStockRow:
+    """Parse a single CSV row."""
+
+    # Get optional fields
+    lot = row.get("Lot", "").strip() or None
+    client_stock_code = row.get("ClientStockCode", "").strip() or None
+    client_stock_description = row.get("ClientStockDescription", "").strip() or None
+
+    # Parse numeric fields with warnings
+    on_hand, on_hand_warn = parse_decimal(row.get("OnHand", ""), "OnHand")
+    allocated, allocated_warn = parse_decimal(row.get("Allocated", ""), "Allocated")
+    pending, pending_warn = parse_decimal(row.get("Pending", ""), "Pending")
+    available, available_warn = parse_decimal(row.get("Available", ""), "Available")
+
+    if on_hand is None:
+        on_hand = Decimal("0")
+    if allocated is None:
+        allocated = Decimal("0")
+    if pending is None:
+        pending = Decimal("0")
+    if available is None:
+        available = Decimal("0")
+
+    for warn_msg in [on_hand_warn, allocated_warn, pending_warn, available_warn]:
+        if warn_msg:
+            warnings.append(ValidationWarning(warn_msg))
+
+    return RawStockRow(
+        type1=row.get("Type1", "").strip(),
+        item=row.get("Item", "").strip(),
+        description=row.get("Description", "").strip(),
+        client_stock_code=client_stock_code,
+        client_stock_description=client_stock_description,
+        lot=lot,
+        on_hand=on_hand,
+        warehouse=row.get("Warehouse", "").strip(),
+        allocated=allocated,
+        pending=pending,
+        available=available,
+        units=row.get("Units", "").strip(),
+    )
