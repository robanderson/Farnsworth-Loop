+"""Data models for wine stock reporting."""
+
+from dataclasses import dataclass, field
+from decimal import Decimal
+from typing import Optional
+
+
+@dataclass
+class ValidationWarning:
+    """A single validation warning."""
+    message: str
+
+
+@dataclass
+class RawStockRow:
+    """A raw CSV row, with parsed numeric fields."""
+    type1: str
+    item: str
+    description: str
+    client_stock_code: Optional[str]
+    client_stock_description: Optional[str]
+    lot: Optional[str]
+    on_hand: Decimal
+    warehouse: str
+    allocated: Decimal
+    pending: Decimal
+    available: Decimal
+    units: str
+
+
+@dataclass
+class ParsedWineRow:
+    """A parsed finished goods row."""
+    type1: str
+    item: str
+    description: str
+    lot: Optional[str]
+    on_hand: Decimal
+    warehouse: str
+    allocated: Decimal
+    pending: Decimal
+    available: Decimal
+    units: str
+
+    # Parsed fields
+    prefix: Optional[str] = None
+    vintage: Optional[str] = None
+    vintage_expanded: Optional[str] = None
+    variety_code: Optional[str] = None
+    variety: Optional[str] = None
+    brand_code: Optional[str] = None
+    market: Optional[str] = None
+    bottle_size_ml: Optional[int] = None
+    pack_size: Optional[int] = None
+    extra_description: Optional[str] = None
+
+    # Calculated fields
+    nine_litre_equivalent: Optional[Decimal] = None
+
+
+@dataclass
+class DryGoodsRow:
+    """A dry goods row."""
+    item: str
+    description: str
+    available: Decimal
+    units: str
+    on_hand: Decimal
+    allocated: Decimal
+    pending: Decimal
+
+
+@dataclass
+class ReportOptions:
+    """User-selected report options."""
+    basis: str = "Available"  # Available or OnHand
+    group_by: str = "variety"  # variety, vintage, market, pack_size, lot, none
+    include_dry_goods: bool = True
+    low_stock_warnings: bool = True
+    low_stock_threshold: Decimal = Decimal("10")
+    output_path: str = "stock-report.md"
+
+
+@dataclass
+class ExecutiveSummary:
+    """Executive summary data."""
+    finished_goods_rows: int = 0
+    dry_goods_rows: int = 0
+    total_wine_9le: Decimal = Decimal("0")
+    total_available_cases: Decimal = Decimal("0")
+    total_allocated_cases: Decimal = Decimal("0")
+    total_pending_cases: Decimal = Decimal("0")
+    lowest_stock_item: Optional[str] = None
+    lowest_stock_9le: Optional[Decimal] = None
+    data_warnings_count: int = 0
