+class TestCalculations(unittest.TestCase):
+    """Tests for calculations."""
+
+    def test_9le_750ml_12p(self):
+        """Test 9LE calculation for 750ml/12p."""
+        row = ParsedWineRow(
+            type1="Finished Goods",
+            item="123",
+            description="FV 22 CHR EP NZ 750ml/12p",
+            lot=None,
+            on_hand=Decimal("48.58"),
+            warehouse="Marlborough",
+            allocated=Decimal("0"),
+            pending=Decimal("0"),
+            available=Decimal("48.58"),
+            units="Cases",
+            bottle_size_ml=750,
+            pack_size=12,
+        )
+        nine_le = calculate_9le(row)
+        # 48.58 cases * 12 * 0.75 / 9 = 48.58
+        self.assertAlmostEqual(float(nine_le), 48.58, places=2)
+
+    def test_9le_750ml_6p(self):
+        """Test 9LE calculation for 750ml/6p."""
+        row = ParsedWineRow(
+            type1="Finished Goods",
+            item="124",
+            description="FV 22 CHR EP NZ 750ml/6p",
+            lot=None,
+            on_hand=Decimal("26.67"),
+            warehouse="Marlborough",
+            allocated=Decimal("0"),
+            pending=Decimal("0"),
+            available=Decimal("26.67"),
+            units="Cases",
+            bottle_size_ml=750,
+            pack_size=6,
+        )
+        nine_le = calculate_9le(row)
+        # 26.67 cases * 6 * 0.75 / 9 = 13.335
+        self.assertAlmostEqual(float(nine_le), 13.335, places=2)
+
