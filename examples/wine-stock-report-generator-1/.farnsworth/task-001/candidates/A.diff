+"""Command-line interface."""
+
+import argparse
+import sys
+from decimal import Decimal
+from typing import Optional, Callable
+
+from wine_stock_reporter.csv_loader import load_csv
+from wine_stock_reporter.models import RawStockRow, ParsedWineRow, DryGoodsRow, ReportOptions, ValidationWarning
+from wine_stock_reporter.parser import parse_wine_description
+from wine_stock_reporter.validation import validate_raw_rows, get_warehouse_list, count_by_type, get_units_list
+from wine_stock_reporter.report import generate_report, write_report
+
+
+def create_parser() -> argparse.ArgumentParser:
+    """Create and return the argument parser."""
+    parser = argparse.ArgumentParser(
+        description="Convert warehouse stock CSV to a Markdown report.",
+        prog="wine_stock_reporter",
+    )
+    parser.add_argument("csv_path", help="Path to the stock CSV file")
+    parser.add_argument(
+        "--basis",
+        choices=["OnHand", "Available"],
+        default="Available",
+        help="Stock quantity basis (default: Available)",
+    )
+    parser.add_argument(
+        "--group-by",
+        choices=["variety", "vintage", "market", "pack_size", "lot", "none"],
+        default="variety",
+        help="Grouping dimension for summary (default: variety)",
+    )
+    parser.add_argument(
+        "--include-dry-goods",
+        action="store_true",
+        default=True,
+        dest="include_dry_goods",
+        help="Include Dry Goods section (default)",
+    )
+    parser.add_argument(
+        "--no-dry-goods",
+        action="store_false",
+        dest="include_dry_goods",
+        help="Exclude Dry Goods section",
+    )
+    parser.add_argument(
+        "--low-stock-warnings",
+        action="store_true",
+        default=True,
+        dest="low_stock_warnings",
+        help="Include low-stock warnings (default)",
+    )
+    parser.add_argument(
+        "--no-low-stock-warnings",
+        action="store_false",
+        dest="low_stock_warnings",
+        help="Exclude low-stock warnings",
+    )
+    parser.add_argument(
+        "--low-stock-threshold",
+        type=Decimal,
+        default=Decimal("10"),
+        help="Low-stock threshold in 9LE (default: 10)",
+    )
+    parser.add_argument(
+        "--output",
+        default="stock-report.md",
+        help="Output file path (default: stock-report.md)",
+    )
+    parser.add_argument(
+        "--no-interactive",
+        action="store_true",
+        help="Non-interactive mode: use all defaults, do not prompt",
+    )
+    return parser
+
+
+def main(
+    argv: Optional[list] = None,
+    input_fn: Callable = input,
+    output_fn: Callable = print,
+) -> int:
+    """
+    Main entry point.
+    Returns 0 on success, 1 on data/file error, 2 on usage error.
+    """
+    parser = create_parser()
+
+    try:
+        args = parser.parse_args(argv)
+    except SystemExit as e:
+        # argparse exits with 0 for --help, 2 for errors
+        return e.code if e.code is not None else 2
+
+    # Load CSV
+    try:
+        raw_rows, load_warnings = load_csv(args.csv_path)
+    except ValueError as e:
+        # Write error to stderr properly
+        sys.stderr.write(str(e) + "\n")
+        return 1
+
+    if not raw_rows:
+        output_fn("Error: No rows found in CSV.", file=sys.stderr)
+        return 1
+
+    # Collect all warnings
+    all_warnings = list(load_warnings)
+    validation_warnings = validate_raw_rows(raw_rows)
+    all_warnings.extend(validation_warnings)
+
+    # Get metadata
+    warehouses = get_warehouse_list(raw_rows)
+    type_counts = count_by_type(raw_rows)
+    units_list = get_units_list(raw_rows)
+
+    # Print detection summary
+    output_fn(f"Loaded {args.csv_path}.\n")
+    output_fn("Detected:")
+    for type1, count in sorted(type_counts.items()):
+        output_fn(f"- {type1} rows: {count}")
+    if warehouses:
+        output_fn(f"- Warehouse: {', '.join(warehouses)}")
+    if units_list:
+        output_fn(f"- Units: {', '.join(units_list)}")
+
+    # Prepare options
+    options = ReportOptions(
+        basis=args.basis,
+        group_by=args.group_by,
+        include_dry_goods=args.include_dry_goods,
+        low_stock_warnings=args.low_stock_warnings,
+        low_stock_threshold=args.low_stock_threshold,
+        output_path=args.output,
+    )
+
+    # Interactive mode
+    if not args.no_interactive:
+        output_fn("\nReport options:\n")
+        options = prompt_for_options(options, input_fn, output_fn)
+
+    # Separate finished goods and dry goods
+    finished_goods_raw = [row for row in raw_rows if row.type1 == "Finished Goods"]
+    dry_goods_raw = [row for row in raw_rows if row.type1 == "Dry Goods"]
+
+    # Parse wine descriptions
+    wine_rows = []
+    for raw_row in finished_goods_raw:
+        parsed_row, parse_warnings = parse_wine_description(raw_row)
+        wine_rows.append(parsed_row)
+        all_warnings.extend(parse_warnings)
+
+    # Convert dry goods to DryGoodsRow objects
+    dry_goods_rows = [
+        DryGoodsRow(
+            item=row.item,
+            description=row.description,
+            available=row.available,
+            units=row.units,
+            on_hand=row.on_hand,
+            allocated=row.allocated,
+            pending=row.pending,
+        )
+        for row in dry_goods_raw
+    ]
+
+    # Generate report
+    report_content = generate_report(
+        wine_rows=wine_rows,
+        dry_goods_rows=dry_goods_rows,
+        options=options,
+        warnings=all_warnings,
+        source_file=args.csv_path,
+        warehouses=warehouses,
+    )
+
+    # Write report
+    try:
+        write_report(report_content, options.output_path)
+    except Exception as e:
+        sys.stderr.write(f"Error: Could not write report: {str(e)}\n")
+        return 1
+
+    output_fn(f"Report written to {options.output_path}")
+    return 0
+
+
+def prompt_for_options(
+    defaults: ReportOptions,
+    input_fn: Callable = input,
+    output_fn: Callable = print,
+) -> ReportOptions:
+    """
+    Interactively prompt for report options.
+    Empty input (Enter only) uses the default.
+    EOF (empty input from pipe) accepts all remaining defaults.
+    """
+    options = ReportOptions(
+        basis=defaults.basis,
+        group_by=defaults.group_by,
+        include_dry_goods=defaults.include_dry_goods,
+        low_stock_warnings=defaults.low_stock_warnings,
+        low_stock_threshold=defaults.low_stock_threshold,
+        output_path=defaults.output_path,
+    )
+
+    prompts = [
+        ("1. Use OnHand or Available stock for wine totals?", "basis", ["OnHand", "Available"]),
+        ("2. Include Dry Goods section?", "include_dry_goods", ["yes", "no"]),
+        ("3. Group primary wine summary by?", "group_by", ["variety", "vintage", "market", "pack_size", "lot", "none"]),
+        ("4. Include low-stock warnings?", "low_stock_warnings", ["yes", "no"]),
+        ("5. Low-stock threshold in 9LE?", "low_stock_threshold", None),
+        ("6. Output filename?", "output_path", None),
+    ]
+
+    for question, field, valid_values in prompts:
+        current_value = getattr(options, field)
+        if field == "include_dry_goods":
+            default_display = "yes" if current_value else "no"
+        elif field == "low_stock_warnings":
+            default_display = "yes" if current_value else "no"
+        else:
+            default_display = str(current_value)
+
+        prompt_text = f"{question} [{default_display}]: "
+
+        try:
+            user_input = input_fn(prompt_text)
+        except EOFError:
+            # EOF: use all remaining defaults
+            break
+
+        if not user_input.strip():
+            # Empty input: keep default
+            continue
+
+        # Validate and set
+        if valid_values:
+            normalized_input = user_input.strip().lower()
+            if normalized_input not in [v.lower() for v in valid_values]:
+                output_fn(f"Invalid choice. Valid options: {', '.join(valid_values)}")
+                # Re-prompt
+                continue
+            if field == "include_dry_goods":
+                options.include_dry_goods = normalized_input == "yes"
+            elif field == "low_stock_warnings":
+                options.low_stock_warnings = normalized_input == "yes"
+            elif field == "basis":
+                options.basis = "OnHand" if normalized_input == "onhand" else "Available"
+            elif field == "group_by":
+                options.group_by = normalized_input
+        else:
+            # Free-form input
+            if field == "low_stock_threshold":
+                try:
+                    options.low_stock_threshold = Decimal(user_input.strip())
+                except:
+                    output_fn("Invalid number. Using default.")
+                    continue
+            elif field == "output_path":
+                options.output_path = user_input.strip()
+
+    return options
