+"""Validation logic for stock data."""
+
+from typing import List, Set
+
+from wine_stock_reporter.models import RawStockRow, ValidationWarning
+
+
+KNOWN_UNITS = {"Cases", "Eaches"}
+KNOWN_TYPE1 = {"Finished Goods", "Dry Goods"}
+
+
+def validate_raw_rows(rows: List[RawStockRow]) -> List[ValidationWarning]:
+    """Validate raw CSV rows and return list of warnings."""
+    warnings = []
+    seen_warehouses = set()
+    seen_units = set()
+
+    for row in rows:
+        # Check for unknown Type1
+        if row.type1 not in KNOWN_TYPE1:
+            warnings.append(ValidationWarning(f"Unknown Type1 '{row.type1}' for item {row.item}"))
+
+        # Check for unknown Units
+        if row.units not in KNOWN_UNITS:
+            warnings.append(ValidationWarning(f"Unknown units '{row.units}' for item {row.item}"))
+
+        # Track warehouses and units
+        seen_warehouses.add(row.warehouse)
+        seen_units.add(row.units)
+
+    return warnings
+
+
+def get_warehouse_list(rows: List[RawStockRow]) -> List[str]:
+    """Get sorted list of unique warehouses."""
+    warehouses = set(row.warehouse for row in rows if row.warehouse)
+    return sorted(warehouses)
+
+
+def get_units_list(rows: List[RawStockRow]) -> List[str]:
+    """Get sorted list of unique units."""
+    units = set(row.units for row in rows if row.units)
+    return sorted(units)
+
+
+def count_by_type(rows: List[RawStockRow]) -> dict:
+    """Count rows by Type1."""
+    counts = {}
+    for row in rows:
+        counts[row.type1] = counts.get(row.type1, 0) + 1
+    return counts
