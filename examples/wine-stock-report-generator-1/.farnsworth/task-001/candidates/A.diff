+class TestCSVLoader(unittest.TestCase):
+    """Tests for CSV loading."""
+
+    def test_load_valid_csv(self):
+        """Test loading a valid CSV."""
+        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
+            f.write("Type1,Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Available,Units\n")
+            f.write("Finished Goods,123,FV 22 CHR EP NZ 750ml/12p,,Test,LOT1,48.58,Marlborough,0.00,0.00,48.58,Cases\n")
+            f.flush()
+
+            rows, warnings = load_csv(f.name)
+            Path(f.name).unlink()
+
+            self.assertEqual(len(rows), 1)
+            self.assertEqual(rows[0].item, "123")
+            self.assertEqual(rows[0].on_hand, Decimal("48.58"))
+
+    def test_load_missing_file(self):
+        """Test loading a non-existent file."""
+        with self.assertRaises(ValueError) as ctx:
+            load_csv("/nonexistent/file.csv")
+        self.assertIn("Error:", str(ctx.exception))
+
+    def test_load_missing_required_column(self):
+        """Test loading CSV with missing required column."""
+        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
+            f.write("Type1,Item,Description\n")
+            f.write("Finished Goods,123,Test\n")
+            f.flush()
+
+            with self.assertRaises(ValueError) as ctx:
+                load_csv(f.name)
+
+            Path(f.name).unlink()
+            self.assertIn("Error:", str(ctx.exception))
+            self.assertIn("required column", str(ctx.exception))
+
+    def test_parse_decimal_basic(self):
+        """Test parsing decimal numbers."""
+        val, warn = parse_decimal("13.67")
+        self.assertEqual(val, Decimal("13.67"))
+        self.assertIsNone(warn)
+
+    def test_parse_decimal_with_thousands_separator(self):
+        """Test parsing numbers with thousands separator."""
+        val, warn = parse_decimal("2,216.50")
+        self.assertEqual(val, Decimal("2216.50"))
+        self.assertIsNone(warn)
+
+    def test_parse_decimal_blank(self):
+        """Test parsing blank field."""
+        val, warn = parse_decimal("")
+        self.assertEqual(val, Decimal("0"))
+        self.assertIsNone(warn)
+
+    def test_parse_decimal_negative(self):
+        """Test parsing negative value."""
+        val, warn = parse_decimal("-5.00")
+        self.assertEqual(val, Decimal("-5.00"))
+        self.assertIsNotNone(warn)
+        self.assertIn("Negative", warn)
+
