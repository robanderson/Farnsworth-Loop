+"""Stock calculations and aggregations."""
+
+from decimal import Decimal
+from typing import List, Dict, Optional, Tuple
+from collections import defaultdict
+
+from wine_stock_reporter.models import ParsedWineRow, DryGoodsRow, ReportOptions
+
+
+def calculate_9le(parsed_row: ParsedWineRow) -> Optional[Decimal]:
+    """
+    Calculate 9-litre-equivalent (9LE) for a wine row.
+    Formula: litres = quantity × pack_size × bottle_size_litres
+             9LE = litres / 9
+    Returns None if bottle_size_ml or pack_size cannot be determined.
+    """
+    if (parsed_row.bottle_size_ml is None or parsed_row.pack_size is None):
+        return None
+
+    try:
+        quantity = parsed_row.available  # Using available by default, can be switched
+        bottle_size_litres = Decimal(parsed_row.bottle_size_ml) / Decimal("1000")
+        litres = quantity * Decimal(parsed_row.pack_size) * bottle_size_litres
+        nine_le = litres / Decimal("9")
+        return nine_le
+    except (TypeError, ZeroDivisionError):
+        return None
+
+
+def set_9le_on_rows(rows: List[ParsedWineRow], basis: str = "Available") -> None:
+    """
+    Calculate and set 9LE on each row based on the specified basis.
+    Modifies rows in-place.
+    """
+    for row in rows:
+        if row.bottle_size_ml is not None and row.pack_size is not None:
+            try:
+                if basis == "OnHand":
+                    quantity = row.on_hand
+                else:
+                    quantity = row.available
+
+                bottle_size_litres = Decimal(row.bottle_size_ml) / Decimal("1000")
+                litres = quantity * Decimal(row.pack_size) * bottle_size_litres
+                row.nine_litre_equivalent = litres / Decimal("9")
+            except (TypeError, ZeroDivisionError):
+                row.nine_litre_equivalent = None
+
+
+def aggregate_by_grouping(
+    rows: List[ParsedWineRow], group_by: str, basis: str = "Available"
+) -> Dict[str, Dict[str, Decimal]]:
+    """
+    Aggregate wine rows by the specified grouping.
+    Returns dict like: {group_value: {"rows": count, "cases": total, "9le": total}, ...}
+    """
+    aggregates = defaultdict(lambda: {"rows": 0, "cases": Decimal("0"), "9le": Decimal("0")})
+
+    for row in rows:
+        # Determine the grouping key
+        if group_by == "variety":
+            key = row.variety or "Unknown"
+        elif group_by == "vintage":
+            key = row.vintage_expanded or "Unknown"
+        elif group_by == "market":
+            key = row.market or "Unknown"
+        elif group_by == "pack_size":
+            key = f"{row.bottle_size_ml}ml/{row.pack_size}p" if row.pack_size else "Unknown"
+        elif group_by == "lot":
+            key = row.lot or "No Lot"
+        else:
+            continue
+
+        # Determine quantity basis
+        if basis == "OnHand":
+            quantity = row.on_hand
+        else:
+            quantity = row.available
+
+        aggregates[key]["rows"] += 1
+        aggregates[key]["cases"] += quantity
+
+        # Add 9LE if available
+        if row.nine_litre_equivalent is not None:
+            aggregates[key]["9le"] += row.nine_litre_equivalent
+
+    return dict(aggregates)
+
+
+def calculate_totals(rows: List[ParsedWineRow], basis: str = "Available") -> Tuple[
+    Decimal,  # total_available_cases
+    Decimal,  # total_allocated_cases
+    Decimal,  # total_pending_cases
+    Decimal,  # total_9le
+]:
+    """Calculate grand totals for wine rows."""
+    total_available = Decimal("0")
+    total_allocated = Decimal("0")
+    total_pending = Decimal("0")
+    total_9le = Decimal("0")
+
+    for row in rows:
+        if basis == "OnHand":
+            total_available += row.on_hand
+        else:
+            total_available += row.available
+
+        total_allocated += row.allocated
+        total_pending += row.pending
+
+        if row.nine_litre_equivalent is not None:
+            total_9le += row.nine_litre_equivalent
+
+    return total_available, total_allocated, total_pending, total_9le
+
+
+def identify_low_stock_items(
+    rows: List[ParsedWineRow], threshold: Decimal, basis: str = "Available"
+) -> List[Tuple[str, Decimal]]:
+    """
+    Identify low-stock items (9LE below threshold).
+    Returns list of (item_description, 9le_value) tuples, sorted by 9le ascending.
+    """
+    low_stock = []
+    for row in rows:
+        if row.nine_litre_equivalent is not None and row.nine_litre_equivalent < threshold:
+            item_desc = f"{row.item} ({row.variety or 'Unknown'} {row.vintage_expanded or ''})"
+            low_stock.append((item_desc, row.nine_litre_equivalent))
+
+    # Sort by 9LE ascending
+    low_stock.sort(key=lambda x: x[1])
+    return low_stock
