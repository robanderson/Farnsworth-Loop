+"""Generate Markdown reports from processed stock data."""
+
+from datetime import datetime
+from decimal import Decimal
+from typing import Dict, List, Optional
+
+from wine_stock_reporter.models import WineRow, GroupingSummary, ReportOptions, ValidationWarning
+
+
+def generate_report(
+    wine_rows: List[WineRow],
+    grouping_summaries: Dict[str, GroupingSummary],
+    low_stock_items: List[WineRow],
+    warnings: List[ValidationWarning],
+    options: ReportOptions,
+    csv_filename: str,
+) -> str:
+    """Generate a Markdown report.
+
+    Args:
+        wine_rows: All processed WineRow objects
+        grouping_summaries: Aggregated summaries by grouping key
+        low_stock_items: Items below low-stock threshold
+        warnings: Validation warnings
+        options: Report options
+        csv_filename: Original CSV filename
+
+    Returns:
+        Markdown report as string
+    """
+    lines = []
+
+    # Header
+    lines.append("# Wine Stock Report")
+    lines.append("")
+    lines.append(f"Generated: {datetime.now().strftime('%Y-%m-%d')}")
+    lines.append(f"Source file: {csv_filename}")
+
+    # Get warehouses and units
+    warehouses = set()
+    all_units = set()
+    finished_goods_count = 0
+    dry_goods_count = 0
+
+    for row in wine_rows:
+        warehouses.add(row.warehouse)
+        all_units.add(row.units)
+        if row.type1 == "Finished Goods":
+            finished_goods_count += 1
+        elif row.type1 == "Dry Goods":
+            dry_goods_count += 1
+
+    if warehouses:
+        lines.append(f"Warehouse: {', '.join(sorted(warehouses))}")
+
+    lines.append(f"Stock basis: {options.basis}")
+    lines.append("")
+
+    # Executive Summary
+    lines.append("## Executive Summary")
+    lines.append("")
+
+    # Calculate totals for finished goods only
+    total_wine_sku_count = finished_goods_count
+    total_cases_on_hand = Decimal("0")
+    total_cases_available = Decimal("0")
+    total_cases_allocated = Decimal("0")
+    total_cases_pending = Decimal("0")
+    total_9le = Decimal("0")
+
+    for row in wine_rows:
+        if row.type1 != "Finished Goods":
+            continue
+
+        total_cases_on_hand += row.on_hand
+        total_cases_available += row.available
+        total_cases_allocated += row.allocated
+        total_cases_pending += row.pending
+
+        if row.nine_litre_equivalent:
+            total_9le += row.nine_litre_equivalent
+
+    lines.append(f"- Finished Goods rows: {total_wine_sku_count}")
+    lines.append(f"- Dry Goods rows: {dry_goods_count}")
+    lines.append(f"- Total wine stock: {_format_decimal(total_9le)} 9LE")
+    lines.append(f"- Total available cases: {_format_decimal(total_cases_available)}")
+    lines.append(f"- Total allocated cases: {_format_decimal(total_cases_allocated)}")
+    lines.append(f"- Total pending cases: {_format_decimal(total_cases_pending)}")
+
+    # Lowest stock item
+    if low_stock_items:
+        lowest = low_stock_items[0]
+        lines.append(
+            f"- Lowest stock item: {lowest.item} ({_format_decimal(lowest.nine_litre_equivalent)} 9LE)"
+        )
+
+    lines.append(f"- Data warnings: {len(warnings)}")
+    lines.append("")
+
+    # Grouping section
+    if options.group_by != "none" and grouping_summaries:
+        group_labels = {
+            "variety": "Variety",
+            "vintage": "Vintage",
+            "market": "Market",
+            "pack_size": "Pack Size",
+            "lot": "Lot",
+        }
+
+        section_title = group_labels.get(options.group_by, "Summary")
+        lines.append(f"## Stock by {section_title}")
+        lines.append("")
+
+        # Build table
+        lines.append(f"| {section_title} | Rows | Cases | 9LE |")
+        lines.append("|---|---:|---:|---:|")
+
+        for key in sorted(grouping_summaries.keys()):
+            summary = grouping_summaries[key]
+            lines.append(
+                f"| {key} | {summary.row_count} | {_format_decimal(summary.cases)} | {_format_decimal(summary.nine_litre_equivalent)} |"
+            )
+
+        lines.append("")
+
+    # Detailed Finished Goods
+    lines.append("## Detailed Finished Goods")
+    lines.append("")
+    lines.append("| Item | Description | Lot | Available | Units | 9LE |")
+    lines.append("|---|---|---|---:|---|---:|")
+
+    for row in wine_rows:
+        if row.type1 != "Finished Goods":
+            continue
+
+        lot_str = row.lot or ""
+        nine_le_str = _format_decimal(row.nine_litre_equivalent) if row.nine_litre_equivalent else "—"
+
+        # Truncate description if needed
+        desc = row.description[:60] + "..." if len(row.description) > 60 else row.description
+
+        lines.append(
+            f"| {row.item} | {desc} | {lot_str} | {_format_decimal(row.available)} | {row.units} | {nine_le_str} |"
+        )
+
+    lines.append("")
+
+    # Low Stock Warnings
+    if options.low_stock_warnings and low_stock_items:
+        lines.append("## Low Stock Warnings")
+        lines.append("")
+
+        for item in low_stock_items:
+            nine_le_str = _format_decimal(item.nine_litre_equivalent)
+            lines.append(
+                f"- Item {item.item} has only {nine_le_str} 9LE available."
+            )
+
+        lines.append("")
+
+    # Dry Goods Summary
+    if options.include_dry_goods:
+        dry_goods_rows = [r for r in wine_rows if r.type1 == "Dry Goods"]
+
+        if dry_goods_rows:
+            lines.append("## Dry Goods Summary")
+            lines.append("")
+            lines.append("| Item | Description | Available | Units |")
+            lines.append("|---|---|---:|---|")
+
+            for row in dry_goods_rows:
+                desc = row.description[:50] + "..." if len(row.description) > 50 else row.description
+                lines.append(
+                    f"| {row.item} | {desc} | {_format_decimal(row.available)} | {row.units} |"
+                )
+
+            lines.append("")
+
+    # Data Warnings
+    if warnings:
+        lines.append("## Data Warnings")
+        lines.append("")
+
+        for warning in warnings:
+            lines.append(f"- {warning.description}")
+
+        lines.append("")
+
+    return "\n".join(lines)
+
+
+def _format_decimal(value: Optional[Decimal]) -> str:
+    """Format a Decimal for display.
+
+    Args:
+        value: Decimal value or None
+
+    Returns:
+        Formatted string, right-aligned
+    """
+    if value is None:
+        return "—"
+
+    if value == int(value):
+        return str(int(value))
+
+    return f"{value:.2f}"
