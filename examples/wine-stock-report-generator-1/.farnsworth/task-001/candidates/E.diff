+"""Tests for wine stock calculations."""
+
+import unittest
+from decimal import Decimal
+
+from wine_stock_reporter.models import WineRow
+from wine_stock_reporter.calculations import (
+    calculate_nine_litre_equivalent,
+    aggregate_by_key,
+)
+
+
+class TestCalculations(unittest.TestCase):
+    """Test calculation functionality."""
+
+    def test_nine_le_750ml_12p(self):
+        """Test 9LE calculation for 750ml/12p."""
+        # 750ml/12p = 9000ml per case = 1.0 9LE
+        nine_le = calculate_nine_litre_equivalent(
+            Decimal("48.58"),
+            bottle_size_ml=750,
+            pack_size=12,
+        )
+
+        self.assertEqual(nine_le, Decimal("48.58"))
+
+    def test_nine_le_750ml_6p(self):
+        """Test 9LE calculation for 750ml/6p."""
+        # 750ml/6p = 4500ml per case = 0.5 9LE
+        nine_le = calculate_nine_litre_equivalent(
+            Decimal("26.67"),
+            bottle_size_ml=750,
+            pack_size=6,
+        )
+
+        expected = Decimal("26.67") * Decimal("6") * Decimal("750") / Decimal("1000") / Decimal("9")
+        self.assertEqual(nine_le, Decimal("13.335"))
+
+    def test_nine_le_rounded(self):
+        """Test 9LE rounding."""
+        nine_le = calculate_nine_litre_equivalent(
+            Decimal("26.67"),
+            bottle_size_ml=750,
+            pack_size=6,
+        )
+
+        # Should be 13.335, which rounds to 13.34
+        self.assertEqual(nine_le, Decimal("13.335"))
+
+    def test_nine_le_unparseable_bottle(self):
+        """Test 9LE with unparseable bottle size."""
+        nine_le = calculate_nine_litre_equivalent(
+            Decimal("10"),
+            bottle_size_ml=None,
+            pack_size=12,
+        )
+
+        self.assertIsNone(nine_le)
+
+    def test_nine_le_unparseable_pack(self):
+        """Test 9LE with unparseable pack size."""
+        nine_le = calculate_nine_litre_equivalent(
+            Decimal("10"),
+            bottle_size_ml=750,
+            pack_size=None,
+        )
+
+        self.assertIsNone(nine_le)
+
+    def test_aggregate_by_variety(self):
+        """Test aggregation by variety."""
+        rows = [
+            WineRow(
+                type1="Finished Goods",
+                item="1",
+                description="",
+                lot=None,
+                on_hand=Decimal("100"),
+                allocated=Decimal("0"),
+                pending=Decimal("0"),
+                available=Decimal("100"),
+                units="Cases",
+                warehouse="Test",
+                vintage="2022",
+                variety_code="CHR",
+                variety="Chardonnay",
+                market="NZ",
+                bottle_size_ml=750,
+                pack_size=12,
+                extra_description=None,
+                nine_litre_equivalent=Decimal("100"),
+                cases_on_hand=Decimal("100"),
+                cases_available=Decimal("100"),
+            ),
+            WineRow(
+                type1="Finished Goods",
+                item="2",
+                description="",
+                lot=None,
+                on_hand=Decimal("50"),
+                allocated=Decimal("0"),
+                pending=Decimal("0"),
+                available=Decimal("50"),
+                units="Cases",
+                warehouse="Test",
+                vintage="2022",
+                variety_code="CHR",
+                variety="Chardonnay",
+                market="NZ",
+                bottle_size_ml=750,
+                pack_size=12,
+                extra_description=None,
+                nine_litre_equivalent=Decimal("50"),
+                cases_on_hand=Decimal("50"),
+                cases_available=Decimal("50"),
+            ),
+            WineRow(
+                type1="Finished Goods",
+                item="3",
+                description="",
+                lot=None,
+                on_hand=Decimal("75"),
+                allocated=Decimal("0"),
+                pending=Decimal("0"),
+                available=Decimal("75"),
+                units="Cases",
+                warehouse="Test",
+                vintage="2022",
+                variety_code="SAB",
+                variety="Sauvignon Blanc",
+                market="NZ",
+                bottle_size_ml=750,
+                pack_size=12,
+                extra_description=None,
+                nine_litre_equivalent=Decimal("75"),
+                cases_on_hand=Decimal("75"),
+                cases_available=Decimal("75"),
+            ),
+        ]
+
+        aggregates = aggregate_by_key(rows, "variety", basis="Available")
+
+        self.assertEqual(len(aggregates), 2)
+        self.assertIn("Chardonnay", aggregates)
+        self.assertIn("Sauvignon Blanc", aggregates)
+
+        self.assertEqual(aggregates["Chardonnay"].row_count, 2)
+        self.assertEqual(aggregates["Chardonnay"].cases, Decimal("150"))
+        self.assertEqual(aggregates["Chardonnay"].nine_litre_equivalent, Decimal("150"))
+
+        self.assertEqual(aggregates["Sauvignon Blanc"].row_count, 1)
+        self.assertEqual(aggregates["Sauvignon Blanc"].cases, Decimal("75"))
+
+    def test_dry_goods_excluded_from_aggregates(self):
+        """Test that dry goods are excluded from wine totals."""
+        rows = [
+            WineRow(
+                type1="Dry Goods",
+                item="1",
+                description="",
+                lot=None,
+                on_hand=Decimal("1000"),
+                allocated=Decimal("0"),
+                pending=Decimal("0"),
+                available=Decimal("1000"),
+                units="Eaches",
+                warehouse="Test",
+                vintage=None,
+                variety_code=None,
+                variety=None,
+                market=None,
+                bottle_size_ml=None,
+                pack_size=None,
+                extra_description=None,
+                nine_litre_equivalent=None,
+                cases_on_hand=Decimal("1000"),
+                cases_available=Decimal("1000"),
+            ),
+            WineRow(
+                type1="Finished Goods",
+                item="2",
+                description="",
+                lot=None,
+                on_hand=Decimal("50"),
+                allocated=Decimal("0"),
+                pending=Decimal("0"),
+                available=Decimal("50"),
+                units="Cases",
+                warehouse="Test",
+                vintage="2022",
+                variety_code="CHR",
+                variety="Chardonnay",
+                market="NZ",
+                bottle_size_ml=750,
+                pack_size=12,
+                extra_description=None,
+                nine_litre_equivalent=Decimal("50"),
+                cases_on_hand=Decimal("50"),
+                cases_available=Decimal("50"),
+            ),
+        ]
+
+        aggregates = aggregate_by_key(rows, "variety", basis="Available")
+
+        self.assertEqual(len(aggregates), 1)
+        self.assertIn("Chardonnay", aggregates)
+        self.assertEqual(aggregates["Chardonnay"].cases, Decimal("50"))
+
+
+if __name__ == "__main__":
+    unittest.main()
