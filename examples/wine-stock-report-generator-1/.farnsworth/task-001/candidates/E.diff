+"""Tests for wine description parser."""
+
+import unittest
+
+from wine_stock_reporter.parser import parse_description
+
+
+class TestParser(unittest.TestCase):
+    """Test wine description parsing."""
+
+    def test_parse_standard_format(self):
+        """Test parsing standard format description."""
+        desc = "FV 22 CHR EP NZ 750ml/12p"
+        vintage, variety_code, variety, market, bottle_ml, pack, extra, warns = parse_description(desc)
+
+        self.assertEqual(vintage, "2022")
+        self.assertEqual(variety_code, "CHR")
+        self.assertEqual(variety, "Chardonnay")
+        self.assertEqual(market, "NZ")
+        self.assertEqual(bottle_ml, 750)
+        self.assertEqual(pack, 12)
+        self.assertIsNone(extra)
+
+    def test_parse_with_extra_description(self):
+        """Test parsing with extra description."""
+        desc = "FV 22 RDB EP UK 750ml/6p Legacy Red"
+        vintage, variety_code, variety, market, bottle_ml, pack, extra, warns = parse_description(desc)
+
+        self.assertEqual(vintage, "2022")
+        self.assertEqual(variety_code, "RDB")
+        self.assertEqual(variety, "Red Blend")
+        self.assertEqual(market, "UK")
+        self.assertEqual(bottle_ml, 750)
+        self.assertEqual(pack, 6)
+        self.assertEqual(extra, "Legacy Red")
+
+    def test_parse_750ml_6p(self):
+        """Test parsing 750ml/6p format."""
+        desc = "FV 22 CHR EP AN 750ml/6p"
+        vintage, variety_code, variety, market, bottle_ml, pack, extra, warns = parse_description(desc)
+
+        self.assertEqual(bottle_ml, 750)
+        self.assertEqual(pack, 6)
+
+    def test_expand_two_digit_vintage(self):
+        """Test expanding two-digit vintage to four digits."""
+        desc = "FV 22 CHR EP NZ 750ml/12p"
+        vintage, _, _, _, _, _, _, _ = parse_description(desc)
+
+        self.assertEqual(vintage, "2022")
+
+    def test_expand_various_vintages(self):
+        """Test expanding various two-digit vintages."""
+        test_cases = [
+            ("FV 20 CHR EP NZ 750ml/12p", "2020"),
+            ("FV 21 CHR EP NZ 750ml/12p", "2021"),
+            ("FV 23 CHR EP NZ 750ml/12p", "2023"),
+            ("FV 24 CHR EP NZ 750ml/12p", "2024"),
+            ("FV 25 CHR EP NZ 750ml/12p", "2025"),
+        ]
+
+        for desc, expected_vintage in test_cases:
+            vintage, _, _, _, _, _, _, _ = parse_description(desc)
+            self.assertEqual(vintage, expected_vintage)
+
+    def test_variety_mapping(self):
+        """Test variety code mapping."""
+        test_cases = [
+            ("CHR", "Chardonnay"),
+            ("SAB", "Sauvignon Blanc"),
+            ("PIN", "Pinot Noir"),
+            ("PIG", "Pinot Gris"),
+            ("PRO", "Rosé"),
+            ("RDB", "Red Blend"),
+            ("MXD", "Mixed / Consolidated"),
+        ]
+
+        for code, expected_variety in test_cases:
+            desc = f"FV 22 {code} EP NZ 750ml/12p"
+            _, variety_code, variety, _, _, _, _, _ = parse_description(desc)
+
+            self.assertEqual(variety_code, code)
+            self.assertEqual(variety, expected_variety)
+
+    def test_unknown_variety_code(self):
+        """Test that unknown variety codes are handled."""
+        desc = "FV 22 ABC EP NZ 750ml/12p"
+        _, variety_code, variety, _, _, _, _, _ = parse_description(desc)
+
+        self.assertEqual(variety_code, "ABC")
+        self.assertIsNone(variety)
+
+    def test_unparseable_description(self):
+        """Test that unparseable descriptions don't crash."""
+        desc = "Some random text that doesn't match format"
+        vintage, variety_code, variety, market, bottle_ml, pack, extra, warns = parse_description(desc)
+
+        # All should be None
+        self.assertIsNone(vintage)
+        self.assertIsNone(variety_code)
+
+    def test_empty_description(self):
+        """Test empty description."""
+        vintage, variety_code, variety, market, bottle_ml, pack, extra, warns = parse_description("")
+
+        self.assertIsNone(vintage)
+        self.assertIsNone(variety_code)
+
+
+if __name__ == "__main__":
+    unittest.main()
