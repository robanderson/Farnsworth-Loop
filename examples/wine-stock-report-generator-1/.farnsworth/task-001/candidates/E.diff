+"""Calculate 9LE, aggregations, and derived metrics."""
+
+from decimal import Decimal
+from typing import Dict, List, Optional
+
+from wine_stock_reporter.models import WineRow, GroupingSummary, ValidationWarning
+
+# 9LE = (quantity * pack_size * bottle_size_ml) / (9 * 1000)
+# For 750ml/12p: (1 * 12 * 750) / 9000 = 9000 / 9000 = 1.0
+# For 750ml/6p: (1 * 6 * 750) / 9000 = 4500 / 9000 = 0.5
+
+
+def calculate_nine_litre_equivalent(
+    cases: Decimal,
+    bottle_size_ml: Optional[int],
+    pack_size: Optional[int],
+    warnings: Optional[List[ValidationWarning]] = None,
+) -> Optional[Decimal]:
+    """Calculate 9-litre-equivalent from cases, bottle size, and pack size.
+
+    Args:
+        cases: Number of cases
+        bottle_size_ml: Bottle size in milliliters
+        pack_size: Number of bottles per pack
+
+    Returns:
+        9LE as Decimal, or None if cannot calculate
+    """
+    if bottle_size_ml is None or pack_size is None:
+        return None
+
+    if cases is None or cases == Decimal("0"):
+        return Decimal("0")
+
+    # Formula: 9LE = (cases * pack_size * bottle_size_ml) / 9000
+    litres = cases * pack_size * Decimal(bottle_size_ml) / Decimal("1000")
+    nine_le = litres / Decimal("9")
+
+    return nine_le
+
+
+def process_wine_rows(
+    raw_rows: List,
+    basis: str = "Available",
+    include_dry_goods: bool = True,
+) -> tuple[List[WineRow], List[ValidationWarning]]:
+    """Process raw stock rows into wine rows with calculations.
+
+    Args:
+        raw_rows: Raw StockRow objects from CSV loader
+        basis: "OnHand" or "Available"
+        include_dry_goods: Whether to include dry goods rows
+
+    Returns:
+        Tuple of (wine_rows, warnings)
+    """
+    from wine_stock_reporter.parser import parse_description
+    from wine_stock_reporter.validation import validate_row
+
+    wine_rows = []
+    warnings = []
+
+    for raw_row in raw_rows:
+        # Handle dry goods
+        if raw_row.type1 == "Dry Goods":
+            if include_dry_goods:
+                wine_rows.append(WineRow(
+                    type1=raw_row.type1,
+                    item=raw_row.item,
+                    description=raw_row.description,
+                    lot=raw_row.lot,
+                    on_hand=raw_row.on_hand,
+                    allocated=raw_row.allocated,
+                    pending=raw_row.pending,
+                    available=raw_row.available,
+                    units=raw_row.units,
+                    warehouse=raw_row.warehouse,
+                    vintage=None,
+                    variety_code=None,
+                    variety=None,
+                    market=None,
+                    bottle_size_ml=None,
+                    pack_size=None,
+                    extra_description=None,
+                    nine_litre_equivalent=None,
+                    cases_on_hand=raw_row.on_hand,
+                    cases_available=raw_row.available,
+                ))
+            continue
+
+        # Parse finished goods
+        vintage, variety_code, variety, market, bottle_size_ml, pack_size, extra_description, parse_warnings = parse_description(raw_row.description)
+
+        # Choose basis
+        cases_basis = raw_row.available if basis == "Available" else raw_row.on_hand
+
+        # Calculate 9LE only for finished goods
+        nine_le = calculate_nine_litre_equivalent(
+            cases_basis,
+            bottle_size_ml,
+            pack_size,
+            warnings
+        )
+
+        wine_row = WineRow(
+            type1=raw_row.type1,
+            item=raw_row.item,
+            description=raw_row.description,
+            lot=raw_row.lot,
+            on_hand=raw_row.on_hand,
+            allocated=raw_row.allocated,
+            pending=raw_row.pending,
+            available=raw_row.available,
+            units=raw_row.units,
+            warehouse=raw_row.warehouse,
+            vintage=vintage,
+            variety_code=variety_code,
+            variety=variety,
+            market=market,
+            bottle_size_ml=bottle_size_ml,
+            pack_size=pack_size,
+            extra_description=extra_description,
+            nine_litre_equivalent=nine_le,
+            cases_on_hand=raw_row.on_hand,
+            cases_available=raw_row.available,
+        )
+
+        wine_rows.append(wine_row)
+
+        # Add parse warnings
+        for w in parse_warnings:
+            warnings.append(ValidationWarning(
+                item_id=raw_row.item,
+                description=w
+            ))
+
+        # Validate row
+        row_warnings = validate_row(wine_row, raw_row)
+        warnings.extend(row_warnings)
+
+    return wine_rows, warnings
+
+
+def aggregate_by_key(
+    wine_rows: List[WineRow],
+    group_key: str,
+    basis: str = "Available",
+) -> Dict[str, GroupingSummary]:
+    """Aggregate wine rows by a grouping key.
+
+    Args:
+        wine_rows: List of WineRow objects
+        group_key: "variety", "vintage", "market", "pack_size", "lot", or "none"
+        basis: "OnHand" or "Available"
+
+    Returns:
+        Dictionary mapping grouping key to GroupingSummary
+    """
+    if group_key == "none":
+        return {}
+
+    aggregates: Dict[str, GroupingSummary] = {}
+
+    for row in wine_rows:
+        # Skip dry goods from totals
+        if row.type1 == "Dry Goods":
+            continue
+
+        # Skip rows without parseable metrics
+        if row.bottle_size_ml is None or row.pack_size is None:
+            continue
+
+        # Get grouping value
+        if group_key == "variety":
+            key_value = row.variety or row.variety_code or "Unknown"
+        elif group_key == "vintage":
+            key_value = row.vintage or "Unknown"
+        elif group_key == "market":
+            key_value = row.market or "Unknown"
+        elif group_key == "pack_size":
+            key_value = f"{row.bottle_size_ml}ml/{row.pack_size}p"
+        elif group_key == "lot":
+            key_value = row.lot or "Unknown"
+        else:
+            continue
+
+        if key_value not in aggregates:
+            aggregates[key_value] = GroupingSummary(
+                key=key_value,
+                row_count=0,
+                cases=Decimal("0"),
+                nine_litre_equivalent=Decimal("0"),
+            )
+
+        summary = aggregates[key_value]
+        summary.row_count += 1
+
+        # Add cases
+        cases_val = row.cases_available if basis == "Available" else row.cases_on_hand
+        summary.cases += cases_val
+
+        # Add 9LE
+        if row.nine_litre_equivalent:
+            summary.nine_litre_equivalent += row.nine_litre_equivalent
+
+    return aggregates
+
+
+def get_low_stock_items(
+    wine_rows: List[WineRow],
+    threshold: Decimal,
+    basis: str = "Available",
+) -> List[WineRow]:
+    """Get items below low-stock threshold.
+
+    Args:
+        wine_rows: List of WineRow objects
+        threshold: Low-stock threshold in 9LE
+        basis: "OnHand" or "Available"
+
+    Returns:
+        List of WineRow items below threshold
+    """
+    low_stock = []
+
+    for row in wine_rows:
+        # Skip dry goods
+        if row.type1 == "Dry Goods":
+            continue
+
+        # Skip rows without 9LE
+        if row.nine_litre_equivalent is None:
+            continue
+
+        if row.nine_litre_equivalent < threshold:
+            low_stock.append(row)
+
+    return sorted(low_stock, key=lambda r: r.nine_litre_equivalent or Decimal("999"))
