+"""Command-line interface and interactive prompting."""
+
+import argparse
+import sys
+from decimal import Decimal
+from pathlib import Path
+from typing import Callable, Optional
+
+from wine_stock_reporter.calculations import (
+    aggregate_by_key,
+    get_low_stock_items,
+    process_wine_rows,
+)
+from wine_stock_reporter.csv_loader import load_csv
+from wine_stock_reporter.models import ReportOptions
+from wine_stock_reporter.report import generate_report
+
+
+def main(
+    argv: Optional[list] = None,
+    input_fn: Callable = input,
+    output_fn: Callable = print,
+) -> int:
+    """Main entry point for the CLI.
+
+    Args:
+        argv: Command-line arguments (defaults to sys.argv[1:])
+        input_fn: Function for reading user input (default: input)
+        output_fn: Function for printing output (default: print)
+
+    Returns:
+        Exit code (0 = success, 1 = data/file error, 2 = usage error)
+    """
+    parser = argparse.ArgumentParser(
+        prog="wine_stock_reporter",
+        description="Convert warehouse stock CSV into a Markdown report",
+    )
+
+    parser.add_argument("csv_path", help="Path to stock CSV file")
+    parser.add_argument(
+        "--basis",
+        choices=["OnHand", "Available"],
+        default="Available",
+        help="Stock basis for wine totals (default: Available)",
+    )
+    parser.add_argument(
+        "--group-by",
+        choices=["variety", "vintage", "market", "pack_size", "lot", "none"],
+        default="variety",
+        help="Grouping for summary table (default: variety)",
+    )
+    parser.add_argument(
+        "--include-dry-goods",
+        action="store_true",
+        dest="include_dry_goods",
+        default=True,
+        help="Include dry goods (default: True)",
+    )
+    parser.add_argument(
+        "--no-dry-goods",
+        action="store_false",
+        dest="include_dry_goods",
+        help="Exclude dry goods",
+    )
+    parser.add_argument(
+        "--low-stock-warnings",
+        action="store_true",
+        dest="low_stock_warnings",
+        default=True,
+        help="Show low-stock warnings (default: True)",
+    )
+    parser.add_argument(
+        "--no-low-stock-warnings",
+        action="store_false",
+        dest="low_stock_warnings",
+        help="Disable low-stock warnings",
+    )
+    parser.add_argument(
+        "--low-stock-threshold",
+        type=float,
+        default=10.0,
+        help="Low-stock threshold in 9LE (default: 10)",
+    )
+    parser.add_argument(
+        "--output",
+        default="stock-report.md",
+        help="Output filename (default: stock-report.md)",
+    )
+    parser.add_argument(
+        "--no-interactive",
+        action="store_true",
+        help="Skip interactive prompts",
+    )
+
+    # Parse arguments
+    try:
+        args = parser.parse_args(argv)
+    except SystemExit as e:
+        # SystemExit from argparse: exit code 0 for --help, 2 for errors
+        return e.code if e.code is not None else 0
+
+    csv_path = args.csv_path
+
+    # Load CSV
+    try:
+        stock_rows, csv_warnings = load_csv(csv_path)
+    except FileNotFoundError:
+        output_fn(f"Error: file not found: {csv_path}", file=sys.stderr)
+        return 1
+    except ValueError as e:
+        output_fn(f"Error: {str(e)}", file=sys.stderr)
+        return 1
+    except Exception as e:
+        output_fn(f"Error: {str(e)}", file=sys.stderr)
+        return 1
+
+    # Build report options
+    options = ReportOptions(
+        basis=args.basis,
+        group_by=args.group_by,
+        include_dry_goods=args.include_dry_goods,
+        low_stock_warnings=args.low_stock_warnings,
+        low_stock_threshold=Decimal(str(args.low_stock_threshold)),
+        output_path=args.output,
+    )
+
+    # Interactive mode (unless --no-interactive)
+    if not args.no_interactive:
+        # Show detection summary
+        types_found = set(r.type1 for r in stock_rows)
+        warehouses_found = set(r.warehouse for r in stock_rows)
+        units_found = set(r.units for r in stock_rows)
+
+        output_fn(f"Loaded {csv_path}.")
+        output_fn("")
+        output_fn("Detected:")
+        for t in sorted(types_found):
+            output_fn(f"- {t} rows")
+        if warehouses_found:
+            output_fn(f"- Warehouse: {', '.join(sorted(warehouses_found))}")
+        if units_found:
+            output_fn(f"- Units: {', '.join(sorted(units_found))}")
+        output_fn("")
+        output_fn("Report options:")
+        output_fn("")
+
+        # Question 1: Basis
+        ans = _prompt_choice(
+            "1. Use OnHand or Available stock for wine totals?",
+            ["OnHand", "Available"],
+            "Available",
+            input_fn,
+            output_fn,
+        )
+        if ans:
+            options.basis = ans
+
+        # Question 2: Dry goods
+        ans = _prompt_yes_no(
+            "2. Include Dry Goods section?",
+            True,
+            input_fn,
+            output_fn,
+        )
+        if ans is not None:
+            options.include_dry_goods = ans
+
+        # Question 3: Group by
+        ans = _prompt_choice(
+            "3. Group primary wine summary by variety, vintage, market, pack_size, lot, or none?",
+            ["variety", "vintage", "market", "pack_size", "lot", "none"],
+            "variety",
+            input_fn,
+            output_fn,
+        )
+        if ans:
+            options.group_by = ans
+
+        # Question 4: Low stock warnings
+        ans = _prompt_yes_no(
+            "4. Include low-stock warnings?",
+            True,
+            input_fn,
+            output_fn,
+        )
+        if ans is not None:
+            options.low_stock_warnings = ans
+
+        # Question 5: Low stock threshold
+        threshold = _prompt_decimal(
+            "5. Low-stock threshold in 9LE?",
+            Decimal("10"),
+            input_fn,
+            output_fn,
+        )
+        if threshold is not None:
+            options.low_stock_threshold = threshold
+
+        # Question 6: Output filename
+        ans = _prompt_string(
+            "6. Output filename?",
+            "stock-report.md",
+            input_fn,
+            output_fn,
+        )
+        if ans:
+            options.output_path = ans
+
+        output_fn("")
+
+    # Process wine rows
+    wine_rows, process_warnings = process_wine_rows(
+        stock_rows,
+        basis=options.basis,
+        include_dry_goods=options.include_dry_goods,
+    )
+
+    # Combine warnings
+    all_warnings = csv_warnings + process_warnings
+
+    # Aggregate
+    grouping_summaries = aggregate_by_key(
+        wine_rows,
+        options.group_by,
+        basis=options.basis,
+    )
+
+    # Get low stock
+    low_stock_items = get_low_stock_items(
+        wine_rows,
+        options.low_stock_threshold,
+        basis=options.basis,
+    )
+
+    # Generate report
+    report_text = generate_report(
+        wine_rows,
+        grouping_summaries,
+        low_stock_items,
+        all_warnings,
+        options,
+        Path(csv_path).name,
+    )
+
+    # Write report
+    try:
+        with open(options.output_path, 'w', encoding='utf-8') as f:
+            f.write(report_text)
+    except Exception as e:
+        output_fn(f"Error: could not write report: {str(e)}", file=sys.stderr)
+        return 1
+
+    output_fn(f"Report written to {options.output_path}")
+
+    return 0
+
+
+def _prompt_choice(
+    question: str,
+    choices: list,
+    default: str,
+    input_fn: Callable,
+    output_fn: Callable,
+) -> Optional[str]:
+    """Prompt for a choice from a list.
+
+    Args:
+        question: Question to ask
+        choices: List of valid choices
+        default: Default choice
+        input_fn: Function to read input
+        output_fn: Function to write output
+
+    Returns:
+        Chosen value or None on EOF
+    """
+    while True:
+        output_fn(f"{question} [{default}] ", end="")
+        output_fn("", flush=True)
+
+        try:
+            response = input_fn()
+        except EOFError:
+            return None
+
+        if not response.strip():
+            return default
+
+        if response.strip() in choices:
+            return response.strip()
+
+        output_fn(f"Please choose one of: {', '.join(choices)}")
+
+
+def _prompt_yes_no(
+    question: str,
+    default: bool,
+    input_fn: Callable,
+    output_fn: Callable,
+) -> Optional[bool]:
+    """Prompt for yes/no.
+
+    Args:
+        question: Question to ask
+        default: Default (True for yes, False for no)
+        input_fn: Function to read input
+        output_fn: Function to write output
+
+    Returns:
+        Boolean or None on EOF
+    """
+    default_str = "yes" if default else "no"
+
+    while True:
+        output_fn(f"{question} [{default_str}] ", end="")
+        output_fn("", flush=True)
+
+        try:
+            response = input_fn()
+        except EOFError:
+            return None
+
+        if not response.strip():
+            return default
+
+        response = response.strip().lower()
+        if response in ("yes", "y"):
+            return True
+        elif response in ("no", "n"):
+            return False
+
+        output_fn("Please answer yes or no (or press Enter for default)")
+
+
+def _prompt_decimal(
+    question: str,
+    default: Decimal,
+    input_fn: Callable,
+    output_fn: Callable,
+) -> Optional[Decimal]:
+    """Prompt for a decimal number.
+
+    Args:
+        question: Question to ask
+        default: Default value
+        input_fn: Function to read input
+        output_fn: Function to write output
+
+    Returns:
+        Decimal value or None on EOF
+    """
+    while True:
+        output_fn(f"{question} [{default}] ", end="")
+        output_fn("", flush=True)
+
+        try:
+            response = input_fn()
+        except EOFError:
+            return None
+
+        if not response.strip():
+            return default
+
+        try:
+            return Decimal(response.strip())
+        except Exception:
+            output_fn("Please enter a valid number")
+
+
+def _prompt_string(
+    question: str,
+    default: str,
+    input_fn: Callable,
+    output_fn: Callable,
+) -> Optional[str]:
+    """Prompt for a string.
+
+    Args:
+        question: Question to ask
+        default: Default value
+        input_fn: Function to read input
+        output_fn: Function to write output
+
+    Returns:
+        String value or None on EOF
+    """
+    output_fn(f"{question} [{default}] ", end="")
+    output_fn("", flush=True)
+
+    try:
+        response = input_fn()
+    except EOFError:
+        return None
+
+    if not response.strip():
+        return default
+
+    return response.strip()
