+"""Parse wine description strings and extract metadata."""
+
+import re
+from typing import Optional, Tuple
+
+VARIETY_MAPPING = {
+    "CHR": "Chardonnay",
+    "SAB": "Sauvignon Blanc",
+    "PIN": "Pinot Noir",
+    "PIG": "Pinot Gris",
+    "PRO": "Rosé",
+    "RDB": "Red Blend",
+    "MXD": "Mixed / Consolidated",
+}
+
+
+def parse_description(description: str) -> Tuple[
+    Optional[str],  # vintage
+    Optional[str],  # variety_code
+    Optional[str],  # variety
+    Optional[str],  # market
+    Optional[int],  # bottle_size_ml
+    Optional[int],  # pack_size
+    Optional[str],  # extra_description
+    list,  # warnings
+]:
+    """Parse a wine description string.
+
+    Expected format: FV YY VARIETY BRAND MARKET BOTTLEml/PACKp [extra]
+
+    Args:
+        description: Description string to parse
+
+    Returns:
+        Tuple of (vintage, variety_code, variety, market, bottle_size_ml, pack_size, extra_description, warnings)
+    """
+    warnings = []
+
+    if not description or not description.strip():
+        return None, None, None, None, None, None, None, warnings
+
+    parts = description.split()
+
+    if len(parts) < 6:
+        # Not enough parts for standard format
+        return None, None, None, None, None, None, None, warnings
+
+    # Parse parts
+    prefix = parts[0]  # Should be "FV"
+
+    # Only proceed if the description starts with "FV"
+    if prefix != "FV":
+        return None, None, None, None, None, None, None, warnings
+
+    vintage_str = parts[1]
+    variety_code = parts[2]
+    brand_code = parts[3]  # Usually EP, GL, etc
+    market = parts[4]
+
+    # Parse bottle/pack from next part
+    bottle_pack = parts[5]
+    bottle_size_ml, pack_size = _parse_bottle_pack(bottle_pack, warnings)
+
+    # Everything after bottle/pack is extra description
+    extra_description = " ".join(parts[6:]) if len(parts) > 6 else None
+
+    # Expand vintage
+    vintage = _expand_vintage(vintage_str)
+
+    # Map variety
+    variety = VARIETY_MAPPING.get(variety_code)
+
+    return vintage, variety_code, variety, market, bottle_size_ml, pack_size, extra_description, warnings
+
+
+def _expand_vintage(vintage_str: str) -> Optional[str]:
+    """Expand two-digit vintage to four digits.
+
+    Args:
+        vintage_str: Vintage string (e.g., "22")
+
+    Returns:
+        Four-digit vintage year (e.g., "2022") or None if not parseable
+    """
+    if not vintage_str or not vintage_str.isdigit():
+        return None
+
+    if len(vintage_str) == 4:
+        return vintage_str
+    elif len(vintage_str) == 2:
+        return f"20{vintage_str}"
+    else:
+        return None
+
+
+def _parse_bottle_pack(bottle_pack_str: str, warnings: list) -> Tuple[Optional[int], Optional[int]]:
+    """Parse bottle size and pack size from string like "750ml/12p".
+
+    Args:
+        bottle_pack_str: String like "750ml/12p"
+        warnings: List to append warnings to
+
+    Returns:
+        Tuple of (bottle_size_ml, pack_size) or (None, None) if unparseable
+    """
+    if not bottle_pack_str:
+        return None, None
+
+    # Match pattern like 750ml/12p or 375ml/12p
+    match = re.match(r'^(\d+)ml/(\d+)p$', bottle_pack_str)
+    if match:
+        bottle_ml = int(match.group(1))
+        pack = int(match.group(2))
+        return bottle_ml, pack
+
+    # Try variations
+    match = re.match(r'^(\d+)ml/(\d+)$', bottle_pack_str)
+    if match:
+        bottle_ml = int(match.group(1))
+        pack = int(match.group(2))
+        return bottle_ml, pack
+
+    return None, None
