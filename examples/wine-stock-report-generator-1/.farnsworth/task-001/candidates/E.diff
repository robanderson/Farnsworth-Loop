+++ b/wine_stock_reporter/csv_loader.py
@@ -0,0 +1,182 @@
+"""Load and parse CSV stock data."""
+
+import csv
+from decimal import Decimal, InvalidOperation
+from pathlib import Path
+from typing import List, Tuple
+
+from wine_stock_reporter.models import StockRow, ValidationWarning
+
+REQUIRED_COLUMNS = [
+    "Type1",
+    "Item",
+    "Description",
+    "OnHand",
+    "Warehouse",
+    "Allocated",
+    "Pending",
+    "Available",
+    "Units",
+]
+
+OPTIONAL_COLUMNS = [
+    "ClientStockCode",
+    "ClientStockDescription",
+    "Lot",
+]
+
+
+def load_csv(csv_path: str) -> Tuple[List[StockRow], List[ValidationWarning]]:
+    """Load CSV file and return rows with warnings.
+
+    Args:
+        csv_path: Path to CSV file
+
+    Returns:
+        Tuple of (list of StockRow, list of ValidationWarning)
+
+    Raises:
+        FileNotFoundError: If CSV file does not exist
+        ValueError: If required columns are missing
+    """
+    path = Path(csv_path)
+
+    if not path.exists():
+        raise FileNotFoundError(f"CSV file not found: {csv_path}")
+
+    rows = []
+    warnings = []
+
+    try:
+        with open(path, 'r', encoding='utf-8') as f:
+            reader = csv.DictReader(f)
+
+            # Check for required columns
+            if reader.fieldnames is None:
+                raise ValueError("CSV file is empty")
+
+            missing = [col for col in REQUIRED_COLUMNS if col not in reader.fieldnames]
+            if missing:
+                missing_str = "', '".join(missing)
+                raise ValueError(f"required column '{missing[0]}' was not found in CSV")
+
+            for row_dict in reader:
+                try:
+                    stock_row = _parse_row(row_dict, warnings)
+                    if stock_row:
+                        rows.append(stock_row)
+                except Exception as e:
+                    # Don't crash on individual row parse errors; just warn
+                    warnings.append(ValidationWarning(
+                        item_id=row_dict.get("Item", "unknown"),
+                        description=f"Row parsing error: {str(e)}"
+                    ))
+
+    except FileNotFoundError:
+        raise
+    except ValueError:
+        raise
+    except Exception as e:
+        raise ValueError(f"Error reading CSV: {str(e)}")
+
+    return rows, warnings
+
+
+def _parse_row(row_dict: dict, warnings: List[ValidationWarning]) -> StockRow:
+    """Parse a single CSV row into a StockRow.
+
+    Args:
+        row_dict: Dictionary from CSV reader
+        warnings: List to append validation warnings to
+
+    Returns:
+        StockRow or None if row should be skipped
+    """
+    item = row_dict.get("Item", "").strip()
+
+    # Parse numeric fields
+    on_hand = _parse_numeric(row_dict.get("OnHand", ""), item, "OnHand", warnings)
+    allocated = _parse_numeric(row_dict.get("Allocated", ""), item, "Allocated", warnings)
+    pending = _parse_numeric(row_dict.get("Pending", ""), item, "Pending", warnings)
+    available = _parse_numeric(row_dict.get("Available", ""), item, "Available", warnings)
+
+    # Warn about negative values
+    for value, field_name in [
+        (on_hand, "OnHand"),
+        (allocated, "Allocated"),
+        (pending, "Pending"),
+        (available, "Available"),
+    ]:
+        if value < 0:
+            warnings.append(ValidationWarning(
+                item_id=item,
+                description=f"Negative value in {field_name}: {value}"
+            ))
+
+    # Warn if Available > OnHand
+    if available > on_hand:
+        warnings.append(ValidationWarning(
+            item_id=item,
+            description=f"Available ({available}) greater than OnHand ({on_hand})"
+        ))
+
+    # Warn if OnHand - Allocated - Pending != Available
+    expected_available = on_hand - allocated - pending
+    if expected_available != available:
+        warnings.append(ValidationWarning(
+            item_id=item,
+            description=f"OnHand - Allocated - Pending = {expected_available}, but Available = {available}"
+        ))
+
+    return StockRow(
+        type1=row_dict.get("Type1", "").strip(),
+        item=item,
+        description=row_dict.get("Description", "").strip(),
+        client_stock_code=_optional_str(row_dict.get("ClientStockCode", "")),
+        client_stock_description=_optional_str(row_dict.get("ClientStockDescription", "")),
+        lot=_optional_str(row_dict.get("Lot", "")),
+        on_hand=on_hand,
+        warehouse=row_dict.get("Warehouse", "").strip(),
+        allocated=allocated,
+        pending=pending,
+        available=available,
+        units=row_dict.get("Units", "").strip(),
+    )
+
+
+def _parse_numeric(value: str, item_id: str, field_name: str, warnings: List[ValidationWarning]) -> Decimal:
+    """Parse a numeric field, handling decimals, thousands separators, etc.
+
+    Args:
+        value: String value to parse
+        item_id: Item ID for warning context
+        field_name: Field name for warning context
+        warnings: List to append warnings to
+
+    Returns:
+        Decimal value, or Decimal(0) if empty/unparseable
+    """
+    if not value or not value.strip():
+        return Decimal("0")
+
+    # Remove whitespace
+    value = value.strip()
+
+    # Remove thousands separators
+    value = value.replace(",", "")
+
+    try:
+        return Decimal(value)
+    except InvalidOperation:
+        warnings.append(ValidationWarning(
+            item_id=item_id,
+            description=f"Non-numeric value in {field_name}: '{value}'"
+        ))
+        return Decimal("0")
+
+
+def _optional_str(value: str) -> str:
+    """Convert string to optional, returning None if empty."""
+    if not value or not value.strip():
+        return None
+    return value.strip()
