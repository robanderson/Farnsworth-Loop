+"""Tests for CSV loader."""
+
+import tempfile
+import unittest
+from decimal import Decimal
+from pathlib import Path
+
+from wine_stock_reporter.csv_loader import load_csv
+
+
+class TestCSVLoader(unittest.TestCase):
+    """Test CSV loading functionality."""
+
+    def test_load_valid_csv(self):
+        """Test loading a valid CSV file."""
+        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
+            f.write(
+                "Type1,Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Available,Units\n"
+                "Finished Goods,123,Test Item,,,,10.00,Warehouse1,0.00,0.00,10.00,Cases\n"
+            )
+            f.flush()
+
+            rows, warnings = load_csv(f.name)
+
+            self.assertEqual(len(rows), 1)
+            self.assertEqual(rows[0].item, "123")
+            self.assertEqual(rows[0].on_hand, Decimal("10"))
+            self.assertEqual(rows[0].available, Decimal("10"))
+
+            Path(f.name).unlink()
+
+    def test_missing_required_column(self):
+        """Test that missing required columns raise ValueError."""
+        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
+            f.write(
+                "Type1,Item,Description\n"
+                "Finished Goods,123,Test Item\n"
+            )
+            f.flush()
+
+            with self.assertRaises(ValueError) as cm:
+                load_csv(f.name)
+
+            self.assertIn("required column", str(cm.exception))
+
+            Path(f.name).unlink()
+
+    def test_file_not_found(self):
+        """Test that missing file raises FileNotFoundError."""
+        with self.assertRaises(FileNotFoundError):
+            load_csv("/nonexistent/path/file.csv")
+
+    def test_parse_decimal_numbers(self):
+        """Test parsing decimal numbers."""
+        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
+            f.write(
+                "Type1,Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Available,Units\n"
+                "Finished Goods,123,Test Item,,,,13.67,Warehouse1,0.00,0.00,13.67,Cases\n"
+            )
+            f.flush()
+
+            rows, warnings = load_csv(f.name)
+
+            self.assertEqual(rows[0].on_hand, Decimal("13.67"))
+
+            Path(f.name).unlink()
+
+    def test_parse_thousands_separator(self):
+        """Test parsing numbers with thousands separators."""
+        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
+            f.write(
+                "Type1,Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Available,Units\n"
+                'Finished Goods,123,Test Item,,,,"2,216.50",Warehouse1,0.00,0.00,"2,216.50",Cases\n'
+            )
+            f.flush()
+
+            rows, warnings = load_csv(f.name)
+
+            self.assertEqual(rows[0].on_hand, Decimal("2216.50"))
+            self.assertEqual(rows[0].available, Decimal("2216.50"))
+
+            Path(f.name).unlink()
+
+    def test_blank_nullable_fields(self):
+        """Test that blank numeric fields are handled."""
+        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
+            f.write(
+                "Type1,Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Available,Units\n"
+                "Finished Goods,123,Test Item,,,,10.00,Warehouse1,,,10.00,Cases\n"
+            )
+            f.flush()
+
+            rows, warnings = load_csv(f.name)
+
+            self.assertEqual(len(rows), 1)
+            self.assertEqual(rows[0].allocated, Decimal("0"))
+            self.assertEqual(rows[0].pending, Decimal("0"))
+
+            Path(f.name).unlink()
+
+    def test_negative_value_warning(self):
+        """Test that negative values generate warnings."""
+        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
+            f.write(
+                "Type1,Item,Description,ClientStockCode,ClientStockDescription,Lot,OnHand,Warehouse,Allocated,Pending,Available,Units\n"
+                "Finished Goods,123,Test Item,,,,10.00,Warehouse1,0.00,0.00,-5.00,Cases\n"
+            )
+            f.flush()
+
+            rows, warnings = load_csv(f.name)
+
+            # Should have at least one warning about negative value
+            self.assertGreaterEqual(len(warnings), 1)
+            # Check for negative value warning
+            negative_warnings = [w for w in warnings if "Negative" in w.description]
+            self.assertEqual(len(negative_warnings), 1)
+            self.assertIn("Available", negative_warnings[0].description)
+
+            Path(f.name).unlink()
+
+
+if __name__ == "__main__":
+    unittest.main()
