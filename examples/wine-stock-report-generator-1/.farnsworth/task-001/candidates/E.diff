+"""Data models for wine stock reporting."""
+
+from dataclasses import dataclass, field
+from decimal import Decimal
+from typing import Optional
+
+
+@dataclass
+class StockRow:
+    """Raw stock data from CSV."""
+    type1: str
+    item: str
+    description: str
+    client_stock_code: Optional[str]
+    client_stock_description: Optional[str]
+    lot: Optional[str]
+    on_hand: Decimal
+    warehouse: str
+    allocated: Decimal
+    pending: Decimal
+    available: Decimal
+    units: str
+
+
+@dataclass
+class WineRow:
+    """Parsed wine stock row with calculated metrics."""
+    type1: str
+    item: str
+    description: str
+    lot: Optional[str]
+    on_hand: Decimal
+    allocated: Decimal
+    pending: Decimal
+    available: Decimal
+    units: str
+    warehouse: str
+
+    # Parsed fields
+    vintage: Optional[str]
+    variety_code: Optional[str]
+    variety: Optional[str]
+    market: Optional[str]
+    bottle_size_ml: Optional[int]
+    pack_size: Optional[int]
+    extra_description: Optional[str]
+
+    # Calculated fields
+    nine_litre_equivalent: Optional[Decimal] = None
+    cases_on_hand: Optional[Decimal] = None
+    cases_available: Optional[Decimal] = None
+
+
+@dataclass
+class ReportOptions:
+    """User-selected report options."""
+    basis: str = "Available"  # OnHand or Available
+    group_by: str = "variety"  # variety, vintage, market, pack_size, lot, none
+    include_dry_goods: bool = True
+    low_stock_warnings: bool = True
+    low_stock_threshold: Decimal = Decimal("10")
+    output_path: str = "stock-report.md"
+
+
+@dataclass
+class ValidationWarning:
+    """Data quality warning."""
+    item_id: str
+    description: str
+    severity: str = "warning"  # warning, error
+
+
+@dataclass
+class GroupingSummary:
+    """Summary for a grouping category."""
+    key: str
+    row_count: int
+    cases: Decimal
+    nine_litre_equivalent: Decimal
