+"""Validate stock data and generate warnings."""
+
+from typing import List
+
+from wine_stock_reporter.models import WineRow, ValidationWarning, StockRow
+
+
+def validate_row(wine_row: WineRow, raw_row: StockRow) -> List[ValidationWarning]:
+    """Validate a single wine row and return warnings.
+
+    Args:
+        wine_row: Parsed WineRow
+        raw_row: Original StockRow
+
+    Returns:
+        List of ValidationWarning objects
+    """
+    warnings = []
+
+    # Check for empty description
+    if not wine_row.description or not wine_row.description.strip():
+        warnings.append(ValidationWarning(
+            item_id=wine_row.item,
+            description="Empty description"
+        ))
+
+    # Check units
+    if wine_row.units not in ("Cases", "Eaches"):
+        warnings.append(ValidationWarning(
+            item_id=wine_row.item,
+            description=f"Unknown units: {wine_row.units}"
+        ))
+
+    # For finished goods, check that units are Cases
+    if wine_row.type1 == "Finished Goods" and wine_row.units != "Cases":
+        warnings.append(ValidationWarning(
+            item_id=wine_row.item,
+            description=f"Finished Goods row not measured in Cases: {wine_row.units}"
+        ))
+
+    # Check for unparseable bottle/pack size
+    if wine_row.type1 == "Finished Goods":
+        if wine_row.bottle_size_ml is None:
+            warnings.append(ValidationWarning(
+                item_id=wine_row.item,
+                description=f"Could not parse bottle size from: {wine_row.description}"
+            ))
+        if wine_row.pack_size is None:
+            warnings.append(ValidationWarning(
+                item_id=wine_row.item,
+                description=f"Could not parse pack size from: {wine_row.description}"
+            ))
+
+    # Check for unknown variety code
+    if wine_row.type1 == "Finished Goods" and wine_row.variety_code:
+        from wine_stock_reporter.parser import VARIETY_MAPPING
+        if wine_row.variety_code not in VARIETY_MAPPING:
+            warnings.append(ValidationWarning(
+                item_id=wine_row.item,
+                description=f"Unknown variety code: {wine_row.variety_code}"
+            ))
+
+    return warnings
