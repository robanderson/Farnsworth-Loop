@@ -0,0 +1,238 @@
+"""Tests for the Word Garden UI rendering and main loop."""
+
+from __future__ import annotations
+
+import unittest
+
+from word_garden import main as main_module
+from word_garden import ui
+from word_garden.game import GameState
+
+
+def _state(secret, guessed=(), water=6, weeds=0, max_water=6,
+           message="", game_over=False, won=False):
+    return GameState(
+        secret_word=secret,
+        guessed_letters=set(guessed),
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=max_water,
+        status_message=message,
+        game_over=game_over,
+        won=won,
+    )
+
+
+def _is_ascii(text):
+    return all(ord(ch) < 128 for ch in text)
+
+
+class RenderTests(unittest.TestCase):
+    def test_emoji_render_has_labels_and_counts(self):
+        st = _state("GARDEN", guessed={"A"}, water=5, weeds=1, max_water=6,
+                    message="No match. A weed appears.")
+        out = ui.render(st, ascii_mode=False)
+        # Title and core sections present.
+        self.assertIn("Word Garden", out)
+        self.assertIn("Word:", out)
+        self.assertIn("Guessed:", out)
+        # Accessibility: labels AND counts, not symbols alone.
+        self.assertIn("Water:", out)
+        self.assertIn("5/6", out)
+        self.assertIn("Weeds:", out)
+        self.assertIn("1/6", out)
+        # Previous status message shown.
+        self.assertIn("No match. A weed appears.", out)
+        # Masked word reflects the guess.
+        self.assertIn("_ A _ _ _ _", out)
+        # Guessed letters listed.
+        self.assertIn("A", out)
+
+    def test_ascii_render_is_pure_ascii(self):
+        st = _state("GARDEN", guessed={"A", "E"}, water=4, weeds=2,
+                    message="Good guess! The garden grows.")
+        out = ui.render(st, ascii_mode=True)
+        self.assertTrue(_is_ascii(out), "ascii mode must contain no non-ASCII")
+        self.assertIn("Water:", out)
+        self.assertIn("4/6", out)
+        self.assertIn("Weeds:", out)
+        self.assertIn("2/6", out)
+        self.assertIn("Word Garden", out)
+
+    def test_emoji_render_contains_non_ascii(self):
+        # Positive assertion that emoji mode actually uses emoji glyphs.
+        st = _state("GARDEN")
+        out = ui.render(st, ascii_mode=False)
+        self.assertFalse(_is_ascii(out))
+
+    def test_sorted_guessed_letters(self):
+        st = _state("GARDEN", guessed={"R", "A", "G"})
+        out = ui.render(st)
+        self.assertIn("A G R", out)
+
+
+class GrowthStageTests(unittest.TestCase):
+    def test_stage_start(self):
+        st = _state("GARDEN")
+        self.assertEqual(ui.growth_stage(st), "start")
+
+    def test_stage_progress(self):
+        # GARDEN has 6 unique letters; reveal one -> 5 missing -> progress.
+        st = _state("GARDEN", guessed={"A"})
+        self.assertEqual(ui.growth_stage(st), "progress")
+
+    def test_stage_near_win(self):
+        # Reveal all but two -> near-win.
+        st = _state("GARDEN", guessed={"G", "A", "R", "D"})
+        self.assertEqual(ui.growth_stage(st), "near-win")
+
+    def test_stage_win(self):
+        st = _state("GARDEN", guessed=set("GARDEN"),
+                    game_over=True, won=True)
+        self.assertEqual(ui.growth_stage(st), "win")
+
+    def test_stage_loss(self):
+        st = _state("GARDEN", guessed={"Z"}, water=0, weeds=6,
+                    game_over=True, won=False)
+        self.assertEqual(ui.growth_stage(st), "loss")
+
+
+class ScreenTests(unittest.TestCase):
+    def test_win_screen(self):
+        st = _state("GARDEN", guessed=set("GARDEN"),
+                    game_over=True, won=True)
+        out = ui.win_screen(st)
+        self.assertIn("Bloom", out)
+        self.assertIn("GARDEN", out)
+        self.assertIn("thriving", out)
+
+    def test_win_screen_ascii(self):
+        st = _state("GARDEN", guessed=set("GARDEN"),
+                    game_over=True, won=True)
+        out = ui.win_screen(st, ascii_mode=True)
+        self.assertTrue(_is_ascii(out))
+        self.assertIn("GARDEN", out)
+
+    def test_loss_screen_reveals_word(self):
+        st = _state("GARDEN", water=0, game_over=True, won=False)
+        out = ui.loss_screen(st)
+        self.assertIn("GARDEN", out)
+        self.assertIn("ran out of water", out)
+
+    def test_loss_screen_ascii(self):
+        st = _state("GARDEN", water=0, game_over=True, won=False)
+        out = ui.loss_screen(st, ascii_mode=True)
+        self.assertTrue(_is_ascii(out))
+        self.assertIn("GARDEN", out)
+
+
+class _Scripted:
+    """A callable that yields scripted inputs in order, then raises EOF."""
+
+    def __init__(self, inputs):
+        self._inputs = list(inputs)
+        self._i = 0
+
+    def __call__(self, prompt=""):
+        if self._i >= len(self._inputs):
+            raise EOFError
+        value = self._inputs[self._i]
+        self._i += 1
+        return value
+
+
+class MainLoopTests(unittest.TestCase):
+    def _run(self, argv, inputs):
+        captured = []
+        rc = main_module.main(
+            argv,
+            input_fn=_Scripted(inputs),
+            output_fn=captured.append,
+        )
+        return rc, "\n".join(captured)
+
+    def test_end_to_end_win(self):
+        # easy difficulty narrows the pool; pin nothing but guess the alphabet
+        # for a known easy word. Use GARDEN via normal would be random, so
+        # drive a win by guessing every letter A-Z (correct ones reveal,
+        # wrong ones cost water=6 on normal -> may lose). To guarantee a win
+        # regardless of word, guess letters in a frequency-safe order is not
+        # reliable; instead run on easy (water 8) and feed all 26 letters.
+        # A surer approach: scripted full alphabet on easy where words are
+        # short (4-6) so unique wrong guesses stay under the water budget is
+        # still not guaranteed. So we patch new_game via argv-independent path:
+        # drive through the public loop with a deterministic word.
+        # We instead exercise main() with a monkeypatched new_game.
+        import word_garden.main as m
+        from word_garden.game import GameState as GS
+
+        orig = m.new_game
+        m.new_game = lambda difficulty: GS(
+            secret_word="GARDEN", guessed_letters=set(),
+            remaining_water=6, weed_count=0, max_water=6,
+        )
+        try:
+            rc, out = self._run(
+                ["--difficulty", "normal"],
+                ["g", "a", "r", "d", "e", "n"],
+            )
+        finally:
+            m.new_game = orig
+        self.assertEqual(rc, 0)
+        self.assertIn("Bloom", out)
+        self.assertIn("GARDEN", out)
+
+    def test_end_to_end_loss(self):
+        import word_garden.main as m
+        from word_garden.game import GameState as GS
+
+        orig = m.new_game
+        m.new_game = lambda difficulty: GS(
+            secret_word="GARDEN", guessed_letters=set(),
+            remaining_water=3, weed_count=0, max_water=3,
+        )
+        try:
+            rc, out = self._run(
+                ["--difficulty", "normal"],
+                ["x", "y", "z"],
+            )
+        finally:
+            m.new_game = orig
+        self.assertEqual(rc, 0)
+        self.assertIn("ran out of water", out)
+        self.assertIn("GARDEN", out)
+
+    def test_invalid_input_does_not_consume_water(self):
+        import word_garden.main as m
+        from word_garden.game import GameState as GS
+
+        orig = m.new_game
+        m.new_game = lambda difficulty: GS(
+            secret_word="GARDEN", guessed_letters=set(),
+            remaining_water=6, weed_count=0, max_water=6,
+        )
+        try:
+            # "apple" (too long), "7" (not letter), "" (empty), then win.
+            rc, out = self._run(
+                ["--ascii"],
+                ["apple", "7", "", "g", "a", "r", "d", "e", "n"],
+            )
+        finally:
+            m.new_game = orig
+        self.assertEqual(rc, 0)
+        # Validation messages appeared.
+        self.assertIn("single letter", out)
+        self.assertIn("not a letter", out)
+        # Still won despite invalid inputs (no water consumed by them).
+        self.assertIn("Bloom", out)
+        # ASCII run -> the loop output is pure ASCII.
+        self.assertTrue(_is_ascii(out))
+
+    def test_eof_exits_cleanly(self):
+        rc, out = self._run(["--difficulty", "easy"], [])
+        self.assertEqual(rc, 0)
+        self.assertIn("Goodbye", out)
+
+
+if __name__ == "__main__":
+    unittest.main()
