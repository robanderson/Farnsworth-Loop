+"""Entry point and main loop for Word Garden — the only I/O module.
+
+All terminal interaction lives here. Rendering is delegated to ``ui`` and game
+logic to ``game``/``words``. See SPEC.md sections 6, 15, 20, 21.
+"""
+
+from __future__ import annotations
+
+import argparse
+from typing import Callable, Sequence
+
+from . import ui
+from .game import GameState, apply_guess, new_game, validate_guess
+
+PROMPT = "Guess a letter: "
+GOODBYE = "Thanks for tending the garden. Goodbye!"
+
+
+def _parse_args(argv: Sequence[str] | None) -> argparse.Namespace:
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description=(
+            "Word Garden — a friendly terminal word-guessing game. "
+            "Guess the hidden word before the garden runs out of water."
+        ),
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty (default: normal).",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        dest="ascii_mode",
+        help="Use plain ASCII visuals instead of emoji.",
+    )
+    return parser.parse_args(argv)
+
+
+def _play(
+    state: GameState,
+    ascii_mode: bool,
+    input_fn: Callable[[str], str],
+    output_fn: Callable[[str], None],
+) -> int:
+    """Run the guess loop until the game is over. Returns the exit code."""
+    while not state.game_over:
+        output_fn(ui.render(state, ascii_mode=ascii_mode))
+        output_fn("")
+
+        raw = input_fn(PROMPT)
+
+        letter, message = validate_guess(raw)
+        if letter is None:
+            # Invalid input: show the message, re-prompt, no turn consumed.
+            output_fn("")
+            output_fn(message)
+            output_fn("")
+            continue
+
+        state = apply_guess(state, letter)
+
+    output_fn("")
+    if state.won:
+        output_fn(ui.win_screen(state, ascii_mode=ascii_mode))
+    else:
+        output_fn(ui.loss_screen(state, ascii_mode=ascii_mode))
+    return 0
+
+
+def main(
+    argv: Sequence[str] | None = None,
+    *,
+    input_fn: Callable[[str], str] = input,
+    output_fn: Callable[[str], None] = print,
+) -> int:
+    """Start a new game and run it to completion.
+
+    Reads input via ``input_fn`` and writes via ``output_fn`` (injectable for
+    testing). Handles EOF and Ctrl-C gracefully with exit code 0.
+    """
+    args = _parse_args(argv)
+    state = new_game(args.difficulty)
+
+    try:
+        return _play(state, args.ascii_mode, input_fn, output_fn)
+    except (EOFError, KeyboardInterrupt):
+        output_fn("")
+        output_fn(GOODBYE)
+        return 0
