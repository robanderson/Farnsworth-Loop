index 0000000..e9c7a74
--- /dev/null
+++ b/word_garden/ui.py
@@ -0,0 +1,150 @@
+"""Pure rendering for Word Garden — no I/O.
+
+Every function returns a string; nothing here calls ``print`` or ``input``.
+See SPEC.md sections 5, 9, 10, 18. The only module that touches stdin/stdout
+is ``word_garden.main``.
+"""
+
+from __future__ import annotations
+
+from .game import GameState, display_word, is_won
+
+TITLE = "Word Garden"
+
+# Growth-stage glyphs (SPEC.md section 10 table).
+_STAGE_EMOJI = {
+    "start": "\U0001f331",  # seedling
+    "progress": "\U0001f33f",  # herb
+    "near-win": "\U0001f337",  # tulip
+    "win": "\U0001f33b",  # sunflower
+    "loss": "\U0001f940",  # wilted flower
+}
+_STAGE_ASCII = {
+    "start": "*",
+    "progress": "*",
+    "near-win": "*",
+    "win": "*",
+    "loss": "x",
+}
+
+# Friendly one-line label for each stage (text accompanies every symbol).
+_STAGE_LABEL = {
+    "start": "A fresh seedling waits in the soil.",
+    "progress": "The garden is growing nicely.",
+    "near-win": "Almost in bloom!",
+    "win": "In full bloom!",
+    "loss": "The garden has wilted.",
+}
+
+# Symbols for the water/weed meters.
+_WATER_EMOJI = "\U0001f4a7"  # droplet
+_WEED_EMOJI = "\U0001f33f"  # herb
+_WATER_ASCII = "*"
+_WEED_ASCII = "-"
+
+# Title decoration (a seedling for emoji mode, a marker for ascii mode).
+_TITLE_EMOJI = "\U0001f331"
+
+
+def _glyphs(symbol: str, count: int) -> str:
+    """Return ``count`` copies of ``symbol`` (never negative)."""
+    return symbol * max(0, count)
+
+
+def growth_stage(state: GameState) -> str:
+    """Classify garden growth from game progress (SPEC.md section 10).
+
+    Stages: ``loss`` and ``win`` when the game is over, otherwise driven by how
+    much of the word is revealed: ``start`` (nothing yet), ``near-win`` (only a
+    couple of letters missing), and ``progress`` in between.
+    """
+    if state.game_over:
+        return "win" if state.won else "loss"
+
+    secret = set(state.secret_word)
+    revealed = {ch for ch in secret if ch in state.guessed_letters}
+    total = len(secret)
+    if total == 0:
+        return "start"
+
+    if not revealed:
+        return "start"
+
+    missing = total - len(revealed)
+    if missing <= 2:
+        return "near-win"
+    return "progress"
+
+
+def _stage_line(state: GameState, ascii_mode: bool) -> str:
+    stage = growth_stage(state)
+    glyph = (_STAGE_ASCII if ascii_mode else _STAGE_EMOJI)[stage]
+    return f"Garden: {glyph}  {_STAGE_LABEL[stage]}"
+
+
+def _meter_line(label: str, count: int, total: int, symbol: str) -> str:
+    """One accessible meter line: text label + count + symbols.
+
+    e.g. ``Water:  4/6  symbolsymbol...`` — the label and the ``count/total``
+    are always present so the line is meaningful without the symbols.
+    """
+    return f"{label} {count}/{total}  {_glyphs(symbol, count)}".rstrip()
+
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the full turn display (SPEC.md sections 5, 9, 18).
+
+    Order: title, garden status, masked word, guessed letters, water, weeds,
+    and the previous turn's status message.
+    """
+    water_symbol = _WATER_ASCII if ascii_mode else _WATER_EMOJI
+    weed_symbol = _WEED_ASCII if ascii_mode else _WEED_EMOJI
+
+    if ascii_mode:
+        title = f"* {TITLE} *"
+    else:
+        title = f"{_TITLE_EMOJI} {TITLE}"
+
+    guessed = " ".join(sorted(state.guessed_letters))
+
+    lines = [
+        title,
+        "",
+        _stage_line(state, ascii_mode),
+        "",
+        f"Word:     {display_word(state)}",
+        f"Guessed:  {guessed}".rstrip(),
+        _meter_line("Water: ", state.remaining_water, state.max_water, water_symbol),
+        _meter_line("Weeds: ", state.weed_count, state.max_water, weed_symbol),
+    ]
+
+    if state.status_message:
+        lines.extend(["", state.status_message])
+
+    return "\n".join(lines)
+
+
+def win_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the win screen (SPEC.md section 6.6)."""
+    glyph = (_STAGE_ASCII if ascii_mode else _STAGE_EMOJI)["win"]
+    return "\n".join(
+        [
+            f"{glyph} Bloom!",
+            "",
+            f"You guessed the word: {state.secret_word}",
+            "The garden is thriving.",
+        ]
+    )
+
+
+def loss_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the loss screen, revealing the word (SPEC.md section 6.7)."""
+    glyph = (_STAGE_ASCII if ascii_mode else _STAGE_EMOJI)["loss"]
+    return "\n".join(
+        [
+            f"{glyph} The garden ran out of water.",
+            "",
+            f"The word was: {state.secret_word}",
+            "Try again and grow a new garden.",
+        ]
+    )
