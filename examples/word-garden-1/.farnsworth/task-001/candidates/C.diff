+"""Word list and word selection for Word Garden."""
+
+import random
+
+# The 10-word list from SPEC.md section 8, uppercase
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+
+def water_for(difficulty="normal") -> int:
+    """Return starting water level for the given difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+
+    Returns:
+        Starting water level.
+
+    Raises:
+        ValueError: If difficulty is not recognized.
+    """
+    water_levels = {
+        "easy": 8,
+        "normal": 6,
+        "hard": 4,
+    }
+
+    if difficulty not in water_levels:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    return water_levels[difficulty]
+
+
+def select_word(difficulty="normal", rng=None) -> str:
+    """Select a random word filtered by difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic testing.
+             If None, uses module-level random functions.
+
+    Returns:
+        A random word matching the difficulty criteria.
+
+    Raises:
+        ValueError: If difficulty is not recognized.
+    """
+    if difficulty not in ("easy", "normal", "hard"):
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    # Filter words by difficulty criteria from SPEC.md section 7
+    if difficulty == "easy":
+        # Easy: length 4-6
+        filtered = [w for w in WORDS if 4 <= len(w) <= 6]
+    elif difficulty == "normal":
+        # Normal: length 5-8
+        filtered = [w for w in WORDS if 5 <= len(w) <= 8]
+    else:  # hard
+        # Hard: length 7+
+        filtered = [w for w in WORDS if len(w) >= 7]
+
+    if not filtered:
+        raise ValueError(f"No words available for difficulty: {difficulty}")
+
+    if rng is None:
+        return random.choice(filtered)
+    else:
+        return rng.choice(filtered)
