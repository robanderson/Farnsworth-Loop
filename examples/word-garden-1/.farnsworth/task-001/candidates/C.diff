+"""Tests for game logic."""
+
+import unittest
+from word_garden.game import (
+    GameState,
+    new_game,
+    validate_guess,
+    apply_guess,
+    display_word,
+    is_won,
+    is_lost,
+)
+
+
+class TestValidateGuess(unittest.TestCase):
+    """Test input validation."""
+
+    def test_valid_single_letter_lowercase(self):
+        """Test that lowercase letters are normalized to uppercase."""
+        letter, message = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(message, "")
+
+    def test_valid_single_letter_uppercase(self):
+        """Test that uppercase letters are accepted."""
+        letter, message = validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(message, "")
+
+    def test_valid_with_whitespace(self):
+        """Test that whitespace is trimmed."""
+        letter, message = validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(message, "")
+
+    def test_invalid_empty(self):
+        """Test that empty input is rejected."""
+        letter, message = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertIn("single letter", message.lower())
+
+    def test_invalid_multiple_characters(self):
+        """Test that multiple characters are rejected."""
+        letter, message = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertIn("single letter", message.lower())
+
+    def test_invalid_number(self):
+        """Test that numbers are rejected."""
+        letter, message = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertIn("not a letter", message.lower())
+
+    def test_invalid_symbol(self):
+        """Test that symbols are rejected."""
+        letter, message = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertIn("not a letter", message.lower())
+
+
+class TestDisplayWord(unittest.TestCase):
+    """Test word masking display."""
+
+    def test_display_all_unguessed(self):
+        """Test display with no guessed letters."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        result = display_word(state)
+        self.assertEqual(result, "_ _ _ _ _ _")
+
+    def test_display_partial_guess(self):
+        """Test display with some letters guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "E"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        result = display_word(state)
+        self.assertEqual(result, "G A R _ E _")
+
+    def test_display_all_guessed(self):
+        """Test display with all letters guessed."""
+        state = GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        result = display_word(state)
+        self.assertEqual(result, "G A R D E N")
+
+
+class TestCorrectGuess(unittest.TestCase):
+    """Test correct guess behavior."""
+
+    def test_correct_guess_reveals_letter(self):
+        """Test that a correct guess reveals the letter."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.guessed_letters = set()
+
+        new_state = apply_guess(state, "G")
+
+        self.assertIn("G", new_state.guessed_letters)
+        self.assertEqual(new_state.status_message, "Good guess! The garden grows.")
+
+    def test_correct_guess_no_water_change(self):
+        """Test that a correct guess doesn't change water."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        original_water = state.remaining_water
+
+        new_state = apply_guess(state, "G")
+
+        self.assertEqual(new_state.remaining_water, original_water)
+
+    def test_correct_guess_no_weed_change(self):
+        """Test that a correct guess doesn't add weeds."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        original_weeds = state.weed_count
+
+        new_state = apply_guess(state, "G")
+
+        self.assertEqual(new_state.weed_count, original_weeds)
+
+
+class TestIncorrectGuess(unittest.TestCase):
+    """Test incorrect guess behavior."""
+
+    def test_incorrect_guess_reduces_water(self):
+        """Test that an incorrect guess reduces water by 1."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        original_water = state.remaining_water
+
+        new_state = apply_guess(state, "Z")
+
+        self.assertEqual(new_state.remaining_water, original_water - 1)
+
+    def test_incorrect_guess_increases_weeds(self):
+        """Test that an incorrect guess increases weeds by 1."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        original_weeds = state.weed_count
+
+        new_state = apply_guess(state, "Z")
+
+        self.assertEqual(new_state.weed_count, original_weeds + 1)
+
+    def test_incorrect_guess_records_letter(self):
+        """Test that an incorrect guess records the letter."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+
+        new_state = apply_guess(state, "Z")
+
+        self.assertIn("Z", new_state.guessed_letters)
+
+    def test_incorrect_guess_message(self):
+        """Test the message for an incorrect guess."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+
+        new_state = apply_guess(state, "Z")
+
+        self.assertIn("No match", new_state.status_message)
+
+
+class TestRepeatedGuess(unittest.TestCase):
+    """Test repeated guess behavior."""
+
+    def test_repeated_guess_no_water_change(self):
+        """Test that a repeated guess doesn't change water."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.guessed_letters = {"A"}
+        original_water = state.remaining_water
+
+        new_state = apply_guess(state, "A")
+
+        self.assertEqual(new_state.remaining_water, original_water)
+
+    def test_repeated_guess_no_weed_change(self):
+        """Test that a repeated guess doesn't add weeds."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.guessed_letters = {"A"}
+        original_weeds = state.weed_count
+
+        new_state = apply_guess(state, "A")
+
+        self.assertEqual(new_state.weed_count, original_weeds)
+
+    def test_repeated_guess_message(self):
+        """Test the message for a repeated guess."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.guessed_letters = {"A"}
+
+        new_state = apply_guess(state, "A")
+
+        self.assertIn("already guessed", new_state.status_message)
+
+
+class TestWinCondition(unittest.TestCase):
+    """Test win detection."""
+
+    def test_win_detected(self):
+        """Test that winning is detected when all letters are guessed."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.guessed_letters = {"G", "A", "R", "D", "E", "N"}
+
+        self.assertTrue(is_won(state))
+
+    def test_win_sets_game_over(self):
+        """Test that a winning guess sets game_over and won."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.guessed_letters = {"G", "A", "R", "D", "E"}
+        original_water = state.remaining_water
+
+        new_state = apply_guess(state, "N")
+
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+        self.assertEqual(new_state.remaining_water, original_water)
+
+    def test_not_won_with_missing_letters(self):
+        """Test that the game is not won if letters are still missing."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.guessed_letters = {"G", "A", "R", "D", "E"}
+
+        self.assertFalse(is_won(state))
+
+
+class TestLossCondition(unittest.TestCase):
+    """Test loss detection."""
+
+    def test_loss_detected_at_zero_water(self):
+        """Test that losing is detected when water reaches 0."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.remaining_water = 0
+        state.guessed_letters = set()
+
+        self.assertTrue(is_lost(state))
+
+    def test_loss_sets_game_over(self):
+        """Test that running out of water sets game_over."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.remaining_water = 1
+        state.guessed_letters = set()
+
+        new_state = apply_guess(state, "Z")
+
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+        self.assertEqual(new_state.remaining_water, 0)
+
+    def test_not_lost_with_water_remaining(self):
+        """Test that the game is not lost if water remains."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.remaining_water = 1
+
+        self.assertFalse(is_lost(state))
+
+    def test_not_lost_if_won(self):
+        """Test that a won game is not considered lost."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.remaining_water = 0
+        state.guessed_letters = {"G", "A", "R", "D", "E", "N"}
+
+        self.assertFalse(is_lost(state))
+
+
+class TestGameOverBehavior(unittest.TestCase):
+    """Test behavior after game is over."""
+
+    def test_guess_after_game_over_no_op(self):
+        """Test that guessing after game is over doesn't change state."""
+        state = new_game(difficulty="normal")
+        state.secret_word = "GARDEN"
+        state.game_over = True
+        state.won = True
+        original_water = state.remaining_water
+        original_weeds = state.weed_count
+        original_guessed = state.guessed_letters.copy()
+
+        new_state = apply_guess(state, "Z")
+
+        self.assertEqual(new_state.remaining_water, original_water)
+        self.assertEqual(new_state.weed_count, original_weeds)
+        self.assertEqual(new_state.guessed_letters, original_guessed)
+        self.assertIn("already over", new_state.status_message.lower())
+
+
+class TestNewGame(unittest.TestCase):
+    """Test game initialization."""
+
+    def test_new_game_creates_valid_state(self):
+        """Test that new_game creates a valid initial state."""
+        state = new_game(difficulty="normal")
+
+        self.assertIsNotNone(state.secret_word)
+        self.assertEqual(len(state.guessed_letters), 0)
+        self.assertEqual(state.remaining_water, state.max_water)
+        self.assertEqual(state.weed_count, 0)
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_initial_water(self):
+        """Test that new_game sets correct initial water."""
+        state = new_game(difficulty="normal")
+        # Normal difficulty should have 6 water
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+
+
+if __name__ == "__main__":
+    unittest.main()
