+"""Core game logic for Word Garden."""
+
+from dataclasses import dataclass, field
+from typing import Optional
+from word_garden import words
+
+
+@dataclass
+class GameState:
+    """The complete state of a Word Garden game.
+
+    Attributes:
+        secret_word: The word being guessed (uppercase).
+        guessed_letters: Set of letters that have been guessed.
+        remaining_water: Current water level.
+        weed_count: Current number of weeds.
+        max_water: Maximum water (starting level).
+        status_message: Message about the last action.
+        game_over: Whether the game has ended (win or loss).
+        won: Whether the game was won (only True if game_over is True).
+    """
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty="normal", rng=None) -> GameState:
+    """Create a new game with the given difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic testing.
+
+    Returns:
+        A new GameState ready to play.
+    """
+    secret_word = words.select_word(difficulty=difficulty, rng=rng)
+    max_water = words.water_for(difficulty=difficulty)
+
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=set(),
+        remaining_water=max_water,
+        weed_count=0,
+        max_water=max_water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[Optional[str], str]:
+    """Validate a single letter guess from user input.
+
+    Args:
+        input_text: The raw input from the user.
+
+    Returns:
+        A tuple (letter, message) where:
+        - If valid: (letter_uppercase, "")
+        - If invalid: (None, error_message)
+
+    Note:
+        This function does not check game state (e.g., repeated guesses).
+        It only validates the format of the input.
+    """
+    # Trim whitespace and convert to uppercase
+    trimmed = input_text.strip().upper()
+
+    # Check if empty
+    if not trimmed:
+        return (None, "Please enter a single letter.")
+
+    # Check if multiple characters
+    if len(trimmed) != 1:
+        return (None, "Please enter a single letter.")
+
+    # Check if alphabetic
+    if not trimmed.isalpha():
+        return (None, "That is not a letter.")
+
+    return (trimmed, "")
+
+
+def display_word(state: GameState) -> str:
+    """Display the word with unguessed letters masked.
+
+    Args:
+        state: The current game state.
+
+    Returns:
+        A string with guessed letters shown and unguessed letters as _.
+        Letters are space-separated (e.g., "G _ R _ E _").
+    """
+    display = []
+    for letter in state.secret_word:
+        if letter in state.guessed_letters:
+            display.append(letter)
+        else:
+            display.append("_")
+
+    return " ".join(display)
+
+
+def is_won(state: GameState) -> bool:
+    """Check if the game is won (all letters guessed).
+
+    Args:
+        state: The current game state.
+
+    Returns:
+        True if all letters in the secret word have been guessed.
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Check if the game is lost (water at 0).
+
+    Args:
+        state: The current game state.
+
+    Returns:
+        True if water has reached 0 and the game is not won.
+    """
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a single validated uppercase letter guess to the game state.
+
+    Args:
+        state: The current game state.
+        letter: A single uppercase alphabetic character.
+
+    Returns:
+        A new GameState with the guess applied.
+
+    Rules:
+        - If the game is already over, returns state unchanged with a message.
+        - If the letter was already guessed, no water/weed change, message says so.
+        - If the letter is in the secret word, add it to guessed_letters,
+          no water/weed change, show positive message.
+        - If the letter is not in the secret word, decrease water by 1,
+          increase weeds by 1, add to guessed_letters, show warning message.
+        - Update game_over and won when a guess ends the game.
+    """
+    # Check if game is already over
+    if state.game_over:
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters.copy(),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="The game is already over.",
+            game_over=True,
+            won=state.won,
+        )
+        return new_state
+
+    # Check if letter was already guessed
+    if letter in state.guessed_letters:
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters.copy(),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=f"You already guessed {letter}. Try another letter.",
+            game_over=state.game_over,
+            won=state.won,
+        )
+        return new_state
+
+    # Add the letter to guessed letters
+    new_guessed = state.guessed_letters.copy()
+    new_guessed.add(letter)
+
+    # Check if letter is in the secret word
+    if letter in state.secret_word:
+        # Correct guess
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="Good guess! The garden grows.",
+            game_over=False,
+            won=False,
+        )
+    else:
+        # Incorrect guess
+        new_water = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_water,
+            weed_count=new_weeds,
+            max_water=state.max_water,
+            status_message="No match. A weed appears.",
+            game_over=False,
+            won=False,
+        )
+
+    # Check for win or loss after applying the guess
+    if is_won(new_state):
+        new_state.game_over = True
+        new_state.won = True
+    elif is_lost(new_state):
+        new_state.game_over = True
+        new_state.won = False
+
+    return new_state
