+"""Tests for word selection and word list."""
+
+import unittest
+import random
+from word_garden.words import WORDS, select_word, water_for
+
+
+class TestWordList(unittest.TestCase):
+    """Test the word list."""
+
+    def test_words_is_10_items(self):
+        """Test that WORDS contains exactly 10 words."""
+        self.assertEqual(len(WORDS), 10)
+
+    def test_words_are_uppercase(self):
+        """Test that all words are uppercase."""
+        for word in WORDS:
+            self.assertEqual(word, word.upper())
+
+    def test_words_are_strings(self):
+        """Test that all words are strings."""
+        for word in WORDS:
+            self.assertIsInstance(word, str)
+
+
+class TestWaterFor(unittest.TestCase):
+    """Test water level lookup."""
+
+    def test_water_for_easy(self):
+        """Test that easy difficulty returns 8 water."""
+        self.assertEqual(water_for("easy"), 8)
+
+    def test_water_for_normal(self):
+        """Test that normal difficulty returns 6 water."""
+        self.assertEqual(water_for("normal"), 6)
+
+    def test_water_for_hard(self):
+        """Test that hard difficulty returns 4 water."""
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_water_for_default(self):
+        """Test that default difficulty is normal."""
+        self.assertEqual(water_for(), 6)
+
+    def test_water_for_invalid_raises_error(self):
+        """Test that unknown difficulty raises ValueError."""
+        with self.assertRaises(ValueError):
+            water_for("impossible")
+
+
+class TestSelectWord(unittest.TestCase):
+    """Test word selection."""
+
+    def test_select_word_returns_string(self):
+        """Test that select_word returns a string."""
+        word = select_word(difficulty="normal")
+        self.assertIsInstance(word, str)
+
+    def test_select_word_returns_from_words(self):
+        """Test that select_word returns a word from the list."""
+        word = select_word(difficulty="normal")
+        self.assertIn(word, WORDS)
+
+    def test_select_word_easy_filters_length(self):
+        """Test that easy difficulty selects words of length 4-6."""
+        # Run multiple times to ensure filtering works
+        for _ in range(10):
+            word = select_word(difficulty="easy")
+            self.assertTrue(4 <= len(word) <= 6, f"Word {word} not in length range 4-6")
+
+    def test_select_word_normal_filters_length(self):
+        """Test that normal difficulty selects words of length 5-8."""
+        # Run multiple times to ensure filtering works
+        for _ in range(10):
+            word = select_word(difficulty="normal")
+            self.assertTrue(5 <= len(word) <= 8, f"Word {word} not in length range 5-8")
+
+    def test_select_word_hard_filters_length(self):
+        """Test that hard difficulty selects words of length 7+."""
+        # Run multiple times to ensure filtering works
+        for _ in range(10):
+            word = select_word(difficulty="hard")
+            self.assertTrue(len(word) >= 7, f"Word {word} has length less than 7")
+
+    def test_select_word_default(self):
+        """Test that default difficulty is normal."""
+        word = select_word()
+        self.assertTrue(5 <= len(word) <= 8)
+
+    def test_select_word_invalid_raises_error(self):
+        """Test that unknown difficulty raises ValueError."""
+        with self.assertRaises(ValueError):
+            select_word(difficulty="impossible")
+
+    def test_select_word_with_rng(self):
+        """Test that select_word uses provided random instance."""
+        rng1 = random.Random(42)
+        rng2 = random.Random(42)
+
+        word1 = select_word(difficulty="normal", rng=rng1)
+        word2 = select_word(difficulty="normal", rng=rng2)
+
+        # With same seed, should get same word
+        self.assertEqual(word1, word2)
+
+    def test_select_word_different_seeds(self):
+        """Test that different seeds can produce different words."""
+        rng1 = random.Random(1)
+        rng2 = random.Random(2)
+
+        word1 = select_word(difficulty="normal", rng=rng1)
+        word2 = select_word(difficulty="normal", rng=rng2)
+
+        # Different seeds should often produce different words
+        # (though theoretically could be the same)
+        # We'll just verify they're both valid
+        self.assertIn(word1, WORDS)
+        self.assertIn(word2, WORDS)
+
+
+if __name__ == "__main__":
+    unittest.main()
