+"""Core game logic for Word Garden."""
+
+from __future__ import annotations
+
+import random
+from dataclasses import dataclass, field
+
+from word_garden import words as _words
+
+
+@dataclass
+class GameState:
+    """Complete state of one Word Garden game session."""
+
+    secret_word: str
+    guessed_letters: set[str]
+    remaining_water: int
+    weed_count: int
+    max_water: int
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng: random.Random | None = None) -> GameState:
+    """Create and return a fresh GameState for the given difficulty.
+
+    Parameters
+    ----------
+    difficulty:
+        ``"easy"``, ``"normal"``, or ``"hard"`` — passed through to
+        :func:`words.select_word` and :func:`words.water_for`.
+    rng:
+        Optional :class:`random.Random` instance for deterministic tests.
+    """
+    word = _words.select_word(difficulty=difficulty, rng=rng).upper()
+    water = _words.water_for(difficulty=difficulty)
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[str | None, str]:
+    """Validate raw player input independent of game state.
+
+    Returns
+    -------
+    ``(letter, "")``
+        The normalised (uppercase, stripped) letter when input is valid.
+    ``(None, message)``
+        A ``None`` sentinel and a specific, helpful message when invalid.
+    """
+    if not isinstance(input_text, str):
+        return None, "Please enter a single letter."
+
+    stripped = input_text.strip()
+
+    if stripped == "":
+        return None, "Please enter a single letter."
+
+    if len(stripped) > 1:
+        return None, "Please enter a single letter."
+
+    letter = stripped.upper()
+
+    if not letter.isalpha():
+        return None, "That is not a letter."
+
+    return letter, ""
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply one already-validated uppercase letter to *state*.
+
+    The caller is responsible for passing a letter that has already been
+    approved by :func:`validate_guess`.  This function:
+
+    - Returns a no-op GameState with a message if the game is already over.
+    - Records the letter as a repeated guess (no water/weed penalty) if it
+      has been tried before.
+    - Reveals the letter (no water/weed change) if it is in the secret word.
+    - Deducts 1 water and adds 1 weed if the letter is not in the word.
+    - Updates ``game_over`` and ``won`` when a terminal condition is reached.
+    """
+    # Guessing after game over is a no-op
+    if state.game_over:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=set(state.guessed_letters),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="The game is already over.",
+            game_over=True,
+            won=state.won,
+        )
+
+    # Repeated guess
+    if letter in state.guessed_letters:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=set(state.guessed_letters),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=f"You already guessed {letter}. Try another letter.",
+            game_over=False,
+            won=False,
+        )
+
+    new_guessed = set(state.guessed_letters) | {letter}
+
+    if letter in state.secret_word:
+        # Correct guess
+        new_water = state.remaining_water
+        new_weeds = state.weed_count
+        message = "Good guess! The garden grows."
+    else:
+        # Incorrect guess
+        new_water = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+        message = "No match. A weed appears."
+
+    # Evaluate terminal conditions
+    all_revealed = all(ch in new_guessed for ch in state.secret_word)
+    game_over = all_revealed or new_water == 0
+    won = all_revealed and new_water >= 0
+
+    # Override message for terminal states
+    if won:
+        message = f"You guessed the word: {state.secret_word}. The garden is thriving."
+    elif game_over:
+        message = f"The garden ran out of water. The word was: {state.secret_word}."
+
+    return GameState(
+        secret_word=state.secret_word,
+        guessed_letters=new_guessed,
+        remaining_water=new_water,
+        weed_count=new_weeds,
+        max_water=state.max_water,
+        status_message=message,
+        game_over=game_over,
+        won=won,
+    )
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word with guessed letters revealed, space-separated.
+
+    Example: ``G _ R _ E _``
+    """
+    return " ".join(
+        ch if ch in state.guessed_letters else "_"
+        for ch in state.secret_word
+    )
+
+
+def is_won(state: GameState) -> bool:
+    """Return True when every letter in the secret word has been guessed."""
+    return all(ch in state.guessed_letters for ch in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Return True when water has reached zero and the word is not fully revealed."""
+    return state.remaining_water == 0 and not is_won(state)
