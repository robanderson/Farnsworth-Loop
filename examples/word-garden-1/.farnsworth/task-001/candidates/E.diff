+"""Word list and word selection for Word Garden."""
+
+import random as _random
+
+# The 10-word list from SPEC.md section 8, all uppercase
+WORDS: list[str] = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty table from SPEC.md section 7
+_DIFFICULTY: dict[str, dict] = {
+    "easy":   {"water": 8, "min_len": 4, "max_len": 6},
+    "normal": {"water": 6, "min_len": 5, "max_len": 8},
+    "hard":   {"water": 4, "min_len": 7, "max_len": None},
+}
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return the starting water count for the given difficulty.
+
+    Raises ValueError for unknown difficulty strings.
+    """
+    if difficulty not in _DIFFICULTY:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose from: {', '.join(_DIFFICULTY)}"
+        )
+    return _DIFFICULTY[difficulty]["water"]
+
+
+def select_word(difficulty: str = "normal", rng: _random.Random | None = None) -> str:
+    """Return a random word matching the given difficulty constraints.
+
+    Parameters
+    ----------
+    difficulty:
+        One of ``"easy"``, ``"normal"``, or ``"hard"``.
+    rng:
+        An optional ``random.Random`` instance for deterministic selection.
+        When ``None`` the module-level ``random`` functions are used.
+
+    Raises
+    ------
+    ValueError
+        If *difficulty* is not a recognised key.
+    ValueError
+        If no words in ``WORDS`` match the length constraints for the
+        requested difficulty (should not happen with the default word list,
+        but prevents a silent failure if the list is customised).
+    """
+    if difficulty not in _DIFFICULTY:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose from: {', '.join(_DIFFICULTY)}"
+        )
+
+    cfg = _DIFFICULTY[difficulty]
+    min_len: int = cfg["min_len"]
+    max_len: int | None = cfg["max_len"]
+
+    candidates = [
+        w for w in WORDS
+        if len(w) >= min_len and (max_len is None or len(w) <= max_len)
+    ]
+
+    if not candidates:
+        raise ValueError(
+            f"No words available for difficulty {difficulty!r} "
+            f"(length {min_len}–{max_len or '∞'})."
+        )
+
+    if rng is not None:
+        return rng.choice(candidates)
+    return _random.choice(candidates)
