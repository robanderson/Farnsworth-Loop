+"""Tests for word_garden.words — word list and word selection."""
+
+import random
+import unittest
+
+from word_garden.words import WORDS, select_word, water_for
+
+
+class TestWordList(unittest.TestCase):
+    """Basic sanity checks on the WORDS constant."""
+
+    def test_words_is_list(self):
+        self.assertIsInstance(WORDS, list)
+
+    def test_words_has_ten_entries(self):
+        self.assertEqual(len(WORDS), 10)
+
+    def test_words_are_uppercase(self):
+        for word in WORDS:
+            self.assertEqual(word, word.upper(), f"{word!r} is not uppercase")
+
+    def test_words_are_nonempty_strings(self):
+        for word in WORDS:
+            self.assertIsInstance(word, str)
+            self.assertTrue(len(word) > 0)
+
+
+class TestWaterFor(unittest.TestCase):
+    """Tests for water_for()."""
+
+    def test_easy_water(self):
+        self.assertEqual(water_for("easy"), 8)
+
+    def test_normal_water(self):
+        self.assertEqual(water_for("normal"), 6)
+
+    def test_hard_water(self):
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            water_for("legendary")
+
+
+class TestSelectWord(unittest.TestCase):
+    """Tests for select_word() — SPEC section 16 case 10."""
+
+    def _fixed_rng(self, seed: int = 42) -> random.Random:
+        return random.Random(seed)
+
+    # ------------------------------------------------------------------ easy
+    def test_easy_returns_string(self):
+        word = select_word("easy", rng=self._fixed_rng())
+        self.assertIsInstance(word, str)
+
+    def test_easy_length_constraint(self):
+        """Easy words must be between 4 and 6 characters inclusive."""
+        rng = self._fixed_rng()
+        for _ in range(20):
+            word = select_word("easy", rng=rng)
+            self.assertGreaterEqual(len(word), 4, f"{word!r} too short for easy")
+            self.assertLessEqual(len(word), 6, f"{word!r} too long for easy")
+
+    def test_easy_word_is_uppercase(self):
+        word = select_word("easy", rng=self._fixed_rng())
+        self.assertEqual(word, word.upper())
+
+    def test_easy_word_in_words_list(self):
+        word = select_word("easy", rng=self._fixed_rng())
+        self.assertIn(word, WORDS)
+
+    # ---------------------------------------------------------------- normal
+    def test_normal_returns_string(self):
+        word = select_word("normal", rng=self._fixed_rng())
+        self.assertIsInstance(word, str)
+
+    def test_normal_length_constraint(self):
+        """Normal words must be between 5 and 8 characters inclusive."""
+        rng = self._fixed_rng()
+        for _ in range(20):
+            word = select_word("normal", rng=rng)
+            self.assertGreaterEqual(len(word), 5, f"{word!r} too short for normal")
+            self.assertLessEqual(len(word), 8, f"{word!r} too long for normal")
+
+    def test_normal_word_is_uppercase(self):
+        word = select_word("normal", rng=self._fixed_rng())
+        self.assertEqual(word, word.upper())
+
+    def test_normal_word_in_words_list(self):
+        word = select_word("normal", rng=self._fixed_rng())
+        self.assertIn(word, WORDS)
+
+    # ------------------------------------------------------------------ hard
+    def test_hard_returns_string(self):
+        word = select_word("hard", rng=self._fixed_rng())
+        self.assertIsInstance(word, str)
+
+    def test_hard_length_constraint(self):
+        """Hard words must be 7 or more characters long."""
+        rng = self._fixed_rng()
+        for _ in range(20):
+            word = select_word("hard", rng=rng)
+            self.assertGreaterEqual(len(word), 7, f"{word!r} too short for hard")
+
+    def test_hard_word_is_uppercase(self):
+        word = select_word("hard", rng=self._fixed_rng())
+        self.assertEqual(word, word.upper())
+
+    def test_hard_word_in_words_list(self):
+        word = select_word("hard", rng=self._fixed_rng())
+        self.assertIn(word, WORDS)
+
+    # ------------------------------------------------------- error handling
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            select_word("legendary")
+
+    def test_deterministic_with_fixed_rng(self):
+        """Same seed must always yield the same word."""
+        word1 = select_word("normal", rng=random.Random(99))
+        word2 = select_word("normal", rng=random.Random(99))
+        self.assertEqual(word1, word2)
+
+    def test_no_rng_still_returns_valid_word(self):
+        """Default (no rng) must still return a valid word from the list."""
+        word = select_word("normal")
+        self.assertIn(word, WORDS)
