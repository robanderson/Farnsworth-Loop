+"""Tests for word_garden.game — all ten SPEC section 16 cases plus extras."""
+
+import random
+import unittest
+from dataclasses import fields
+
+from word_garden.game import (
+    GameState,
+    apply_guess,
+    display_word,
+    is_lost,
+    is_won,
+    new_game,
+    validate_guess,
+)
+from word_garden.words import WORDS
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+def _state_with_word(word: str, water: int = 6) -> GameState:
+    """Return a fresh GameState pinned to *word* for deterministic testing."""
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+# ---------------------------------------------------------------------------
+# GameState structure
+# ---------------------------------------------------------------------------
+
+class TestGameStateStructure(unittest.TestCase):
+    """Verify the dataclass field contract from SPEC section 12."""
+
+    def test_field_names(self):
+        required = {
+            "secret_word", "guessed_letters", "remaining_water",
+            "weed_count", "max_water", "status_message", "game_over", "won",
+        }
+        actual = {f.name for f in fields(GameState)}
+        self.assertEqual(actual, required)
+
+    def test_status_message_default_empty(self):
+        state = _state_with_word("GARDEN")
+        self.assertEqual(state.status_message, "")
+
+    def test_game_over_default_false(self):
+        state = _state_with_word("GARDEN")
+        self.assertFalse(state.game_over)
+
+    def test_won_default_false(self):
+        state = _state_with_word("GARDEN")
+        self.assertFalse(state.won)
+
+
+# ---------------------------------------------------------------------------
+# new_game
+# ---------------------------------------------------------------------------
+
+class TestNewGame(unittest.TestCase):
+    def test_returns_game_state(self):
+        state = new_game()
+        self.assertIsInstance(state, GameState)
+
+    def test_word_is_uppercase(self):
+        state = new_game()
+        self.assertEqual(state.secret_word, state.secret_word.upper())
+
+    def test_word_is_in_word_list(self):
+        state = new_game(rng=random.Random(1))
+        self.assertIn(state.secret_word, WORDS)
+
+    def test_zero_weeds_at_start(self):
+        state = new_game()
+        self.assertEqual(state.weed_count, 0)
+
+    def test_no_guessed_letters_at_start(self):
+        state = new_game()
+        self.assertEqual(len(state.guessed_letters), 0)
+
+    def test_remaining_water_equals_max_at_start(self):
+        state = new_game(difficulty="normal")
+        self.assertEqual(state.remaining_water, state.max_water)
+        self.assertEqual(state.remaining_water, 6)
+
+    def test_easy_water_is_eight(self):
+        state = new_game(difficulty="easy")
+        self.assertEqual(state.max_water, 8)
+        self.assertEqual(state.remaining_water, 8)
+
+    def test_hard_water_is_four(self):
+        state = new_game(difficulty="hard")
+        self.assertEqual(state.max_water, 4)
+        self.assertEqual(state.remaining_water, 4)
+
+    def test_rng_injection_is_deterministic(self):
+        state1 = new_game(rng=random.Random(7))
+        state2 = new_game(rng=random.Random(7))
+        self.assertEqual(state1.secret_word, state2.secret_word)
+
+
+# ---------------------------------------------------------------------------
+# validate_guess — SPEC section 14 / section 16 cases 5–6
+# ---------------------------------------------------------------------------
+
+class TestValidateGuess(unittest.TestCase):
+    """Case 5: invalid input is rejected; case 6: lowercase is normalised."""
+
+    # --- valid inputs -------------------------------------------------------
+
+    def test_valid_lowercase_returns_uppercase_letter(self):
+        letter, msg = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_valid_uppercase_returns_same(self):
+        letter, msg = validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+    def test_valid_with_surrounding_whitespace(self):
+        """Case 6: leading/trailing spaces must be stripped and letter uppercased."""
+        letter, msg = validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(msg, "")
+
+    # --- invalid inputs — must return (None, specific_message) -------------
+
+    def test_empty_string_is_rejected(self):
+        """Case 5: empty input yields None and a message."""
+        letter, msg = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_whitespace_only_is_rejected(self):
+        letter, msg = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_multi_character_word_is_rejected(self):
+        letter, msg = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_digit_is_rejected(self):
+        """Case 5: digits are not letters."""
+        letter, msg = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_symbol_is_rejected(self):
+        """Case 5: symbols are not letters."""
+        letter, msg = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_invalid_does_not_mutate_state(self):
+        """Invalid input must never mutate game state (validated by the caller)."""
+        state = _state_with_word("GARDEN")
+        letter, msg = validate_guess("99")
+        self.assertIsNone(letter)
+        # The state is unchanged — validate_guess is pure, no state passed
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(len(state.guessed_letters), 0)
+
+
+# ---------------------------------------------------------------------------
+# apply_guess — SPEC section 16 cases 1–4
+# ---------------------------------------------------------------------------
+
+class TestApplyGuessCorrect(unittest.TestCase):
+    """Case 1: a correct guess reveals matching letters."""
+
+    def setUp(self):
+        self.state = _state_with_word("GARDEN")
+
+    def test_correct_letter_added_to_guessed(self):
+        new = apply_guess(self.state, "G")
+        self.assertIn("G", new.guessed_letters)
+
+    def test_correct_guess_does_not_reduce_water(self):
+        new = apply_guess(self.state, "G")
+        self.assertEqual(new.remaining_water, self.state.remaining_water)
+
+    def test_correct_guess_does_not_add_weeds(self):
+        new = apply_guess(self.state, "G")
+        self.assertEqual(new.weed_count, self.state.weed_count)
+
+    def test_correct_guess_sets_positive_message(self):
+        new = apply_guess(self.state, "G")
+        self.assertGreater(len(new.status_message), 0)
+
+    def test_correct_guess_reveals_in_display(self):
+        new = apply_guess(self.state, "G")
+        displayed = display_word(new)
+        self.assertTrue(displayed.startswith("G"))
+
+
+class TestApplyGuessIncorrect(unittest.TestCase):
+    """Cases 2–3: wrong guess costs 1 water, adds 1 weed, records the letter."""
+
+    def setUp(self):
+        self.state = _state_with_word("GARDEN")
+        self.new = apply_guess(self.state, "Z")  # Z is not in GARDEN
+
+    def test_wrong_guess_reduces_water_by_one(self):
+        """Case 2: water decreases by exactly 1."""
+        self.assertEqual(self.new.remaining_water, self.state.remaining_water - 1)
+
+    def test_wrong_guess_increases_weeds_by_one(self):
+        """Case 3: weed count increases by exactly 1."""
+        self.assertEqual(self.new.weed_count, self.state.weed_count + 1)
+
+    def test_wrong_guess_letter_recorded(self):
+        self.assertIn("Z", self.new.guessed_letters)
+
+    def test_wrong_guess_sets_message(self):
+        self.assertGreater(len(self.new.status_message), 0)
+
+    def test_original_state_not_mutated(self):
+        """apply_guess must return a new state and not change the original."""
+        self.assertEqual(self.state.remaining_water, 6)
+        self.assertEqual(self.state.weed_count, 0)
+        self.assertNotIn("Z", self.state.guessed_letters)
+
+
+class TestApplyGuessRepeated(unittest.TestCase):
+    """Case 4: repeated guess does not reduce water or increase weeds."""
+
+    def setUp(self):
+        state = _state_with_word("GARDEN")
+        self.after_first = apply_guess(state, "G")
+        self.after_repeat = apply_guess(self.after_first, "G")
+
+    def test_repeated_guess_water_unchanged(self):
+        """Case 4: no water penalty for repeating a guess."""
+        self.assertEqual(
+            self.after_repeat.remaining_water,
+            self.after_first.remaining_water,
+        )
+
+    def test_repeated_guess_weeds_unchanged(self):
+        self.assertEqual(
+            self.after_repeat.weed_count,
+            self.after_first.weed_count,
+        )
+
+    def test_repeated_guess_message_mentions_letter(self):
+        self.assertIn("G", self.after_repeat.status_message)
+
+    def test_repeated_guess_letter_still_in_guessed(self):
+        self.assertIn("G", self.after_repeat.guessed_letters)
+
+
+class TestApplyGuessAfterGameOver(unittest.TestCase):
+    """Guessing after game_over is a no-op with a message."""
+
+    def _lose_game(self) -> GameState:
+        state = _state_with_word("GARDEN", water=1)
+        return apply_guess(state, "Z")  # wrong guess drains last water
+
+    def test_no_op_after_loss(self):
+        lost = self._lose_game()
+        self.assertTrue(lost.game_over)
+        before_water = lost.remaining_water
+        after = apply_guess(lost, "A")
+        self.assertEqual(after.remaining_water, before_water)
+        self.assertEqual(after.weed_count, lost.weed_count)
+
+    def test_message_set_after_game_over(self):
+        lost = self._lose_game()
+        after = apply_guess(lost, "A")
+        self.assertGreater(len(after.status_message), 0)
+
+
+# ---------------------------------------------------------------------------
+# Win / loss detection — SPEC section 16 cases 7–8
+# ---------------------------------------------------------------------------
+
+class TestWinDetection(unittest.TestCase):
+    """Case 7: game correctly detects a win."""
+
+    def test_is_won_false_at_start(self):
+        state = _state_with_word("CAT")
+        self.assertFalse(is_won(state))
+
+    def test_is_won_true_when_all_letters_guessed(self):
+        state = _state_with_word("CAT")
+        for letter in "CAT":
+            state = apply_guess(state, letter)
+        self.assertTrue(is_won(state))
+
+    def test_game_over_true_on_win(self):
+        state = _state_with_word("CAT")
+        for letter in "CAT":
+            state = apply_guess(state, letter)
+        self.assertTrue(state.game_over)
+
+    def test_won_true_on_win(self):
+        state = _state_with_word("CAT")
+        for letter in "CAT":
+            state = apply_guess(state, letter)
+        self.assertTrue(state.won)
+
+    def test_water_unchanged_on_win_by_correct_only(self):
+        """Winning without any wrong guesses must leave water at max."""
+        state = _state_with_word("CAT", water=6)
+        for letter in "CAT":
+            state = apply_guess(state, letter)
+        self.assertEqual(state.remaining_water, 6)
+
+
+class TestLossDetection(unittest.TestCase):
+    """Case 8: game correctly detects a loss."""
+
+    def test_is_lost_false_at_start(self):
+        state = _state_with_word("GARDEN")
+        self.assertFalse(is_lost(state))
+
+    def test_is_lost_true_when_water_zero_and_word_not_revealed(self):
+        state = _state_with_word("GARDEN", water=2)
+        state = apply_guess(state, "Z")
+        state = apply_guess(state, "X")
+        self.assertTrue(is_lost(state))
+
+    def test_game_over_true_on_loss(self):
+        state = _state_with_word("GARDEN", water=1)
+        state = apply_guess(state, "Z")
+        self.assertTrue(state.game_over)
+
+    def test_won_false_on_loss(self):
+        state = _state_with_word("GARDEN", water=1)
+        state = apply_guess(state, "Z")
+        self.assertFalse(state.won)
+
+    def test_weed_count_matches_wrong_guesses(self):
+        state = _state_with_word("GARDEN", water=3)
+        state = apply_guess(state, "Z")
+        state = apply_guess(state, "X")
+        self.assertEqual(state.weed_count, 2)
+
+    def test_is_lost_false_when_water_zero_but_word_won(self):
+        """Edge: if last guess is correct AND water happened to be 0 (impossible
+        in normal play but ensure logic is correct)."""
+        state = GameState(
+            secret_word="A",
+            guessed_letters=set(),
+            remaining_water=1,
+            weed_count=0,
+            max_water=1,
+        )
+        state = apply_guess(state, "A")  # correct; water stays at 1
+        self.assertFalse(is_lost(state))
+        self.assertTrue(is_won(state))
+
+
+# ---------------------------------------------------------------------------
+# display_word — SPEC section 16 case 9
+# ---------------------------------------------------------------------------
+
+class TestDisplayWord(unittest.TestCase):
+    """Case 9: masked word display."""
+
+    def test_all_masked_at_start(self):
+        state = _state_with_word("GARDEN")
+        self.assertEqual(display_word(state), "_ _ _ _ _ _")
+
+    def test_correct_letter_revealed(self):
+        state = _state_with_word("GARDEN")
+        state = apply_guess(state, "G")
+        displayed = display_word(state)
+        self.assertTrue(displayed.startswith("G"))
+        self.assertIn("_", displayed)
+
+    def test_all_revealed_when_won(self):
+        state = _state_with_word("CAT")
+        for letter in "CAT":
+            state = apply_guess(state, letter)
+        self.assertEqual(display_word(state), "C A T")
+
+    def test_format_is_space_separated(self):
+        """Characters must be separated by single spaces."""
+        state = _state_with_word("AB")
+        result = display_word(state)
+        parts = result.split(" ")
+        self.assertEqual(len(parts), 2)
+
+    def test_multiple_occurrences_all_revealed(self):
+        """When a letter appears multiple times, all positions are revealed."""
+        state = _state_with_word("SEEDLING")
+        state = apply_guess(state, "E")
+        displayed = display_word(state)
+        # SEEDLING -> S E E D L I N G, positions 1 and 2 are E
+        parts = displayed.split(" ")
+        self.assertEqual(parts[1], "E")
+        self.assertEqual(parts[2], "E")
