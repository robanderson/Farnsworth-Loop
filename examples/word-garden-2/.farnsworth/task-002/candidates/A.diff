+"""Main game loop and entry point for Word Garden.
+
+This is the only module that performs I/O (input/output). It orchestrates
+the game loop: rendering state, prompting for input, validating it, applying
+guesses, and showing the final screen.
+
+For testability, accepts injectable input_fn and output_fn (default to
+builtins input() and print()).
+
+See task-002 requirements.
+"""
+
+import argparse
+import sys
+from typing import Callable
+
+from word_garden import (
+    GameState,
+    apply_guess,
+    new_game,
+    validate_guess,
+)
+from word_garden.ui import loss_screen, render, win_screen
+
+
+def main(
+    argv: list[str] | None = None,
+    input_fn: Callable[[str], str] | None = None,
+    output_fn: Callable[[str], None] | None = None,
+) -> int:
+    """Run the Word Garden game loop.
+
+    Args:
+        argv: Command-line arguments (defaults to sys.argv[1:]).
+        input_fn: Function to read a line (defaults to input).
+        output_fn: Function to output text (defaults to print).
+
+    Returns:
+        Exit code (0 on success, including EOF/Ctrl-C).
+
+    Supports argparse with:
+        --difficulty {easy,normal,hard} (default: normal)
+        --ascii (use ASCII mode instead of emoji)
+    """
+    if input_fn is None:
+        input_fn = input
+    if output_fn is None:
+        output_fn = print
+
+    # Parse command-line arguments
+    parser = argparse.ArgumentParser(description="Word Garden: a word-guessing game")
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Game difficulty (default: normal)",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        help="Use ASCII mode (no emoji)",
+    )
+
+    try:
+        args = parser.parse_args(argv)
+    except SystemExit:
+        # argparse exits on error; we want to exit cleanly with code 0
+        return 0
+
+    ascii_mode = args.ascii
+    difficulty = args.difficulty
+
+    # Start a new game
+    try:
+        state = new_game(difficulty)
+    except ValueError as e:
+        output_fn(f"Error: {e}")
+        return 1
+
+    # Main game loop
+    try:
+        while not state.game_over:
+            # Render the current state
+            output_fn(render(state, ascii_mode=ascii_mode))
+            output_fn("")
+
+            # Prompt for input
+            try:
+                user_input = input_fn("Guess a letter: ")
+            except EOFError:
+                # Ctrl-D (EOF): exit cleanly
+                output_fn("")
+                output_fn("Goodbye! Thanks for playing Word Garden.")
+                return 0
+
+            # Validate the input
+            letter, error_msg = validate_guess(user_input)
+            if error_msg:
+                # Invalid input: show error and re-prompt without consuming a turn
+                output_fn(error_msg)
+                output_fn("")
+                continue
+
+            # Apply the validated guess
+            state = apply_guess(state, letter)
+
+        # Game is over: show final screen
+        output_fn(render(state, ascii_mode=ascii_mode))
+        output_fn("")
+
+        if state.won:
+            output_fn(win_screen(state, ascii_mode=ascii_mode))
+        else:
+            output_fn(loss_screen(state, ascii_mode=ascii_mode))
+
+        return 0
+
+    except KeyboardInterrupt:
+        # Ctrl-C: exit cleanly
+        output_fn("")
+        output_fn("Goodbye! Thanks for playing Word Garden.")
+        return 0
