+def make_state(secret_word="GARDEN", water=6, guessed=None, won=False, game_over=False, status_message=""):
+    """Build a test GameState with specified parameters."""
+    if guessed is None:
+        guessed = set()
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=guessed,
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+        status_message=status_message,
+        game_over=game_over,
+        won=won,
+    )
+
+
+class RenderEmojiModeTests(unittest.TestCase):
+    """Test render() with default emoji mode."""
+
+    def test_render_includes_title(self):
+        state = make_state()
+        output = render(state, ascii_mode=False)
+        self.assertIn("Word Garden", output)
+
+    def test_render_includes_plant_emoji(self):
+        state = make_state()
+        output = render(state, ascii_mode=False)
+        # Should contain at least one emoji plant
+        self.assertIn("🌱", output)
+
+    def test_render_includes_masked_word(self):
+        state = make_state("GARDEN")
+        output = render(state, ascii_mode=False)
+        self.assertIn("Word:", output)
+        self.assertIn("_ _ _ _ _ _", output)
+
+    def test_render_includes_guessed_letters(self):
+        state = make_state("GARDEN", guessed={"A", "E", "G"})
+        output = render(state, ascii_mode=False)
+        self.assertIn("Guessed:", output)
+        # Letters should be sorted and space-separated
+        self.assertIn("A", output)
+        self.assertIn("E", output)
+        self.assertIn("G", output)
+
+    def test_render_includes_water_label_and_count(self):
+        state = make_state(water=4)
+        output = render(state, ascii_mode=False)
+        self.assertIn("Water:", output)
+        self.assertIn("4/4", output)
+        # Should have emoji water droplets
+        self.assertIn("💧", output)
+
+    def test_render_includes_weeds_label_and_count(self):
+        state = make_state()
+        state.weed_count = 2
+        output = render(state, ascii_mode=False)
+        self.assertIn("Weeds:", output)
+        self.assertIn("2", output)
+        # Should have emoji weeds
+        self.assertIn("🌿", output)
+
+    def test_render_includes_status_message(self):
+        state = make_state(status_message="Good guess! The garden grows.")
+        output = render(state, ascii_mode=False)
+        self.assertIn("Good guess! The garden grows.", output)
+
+    def test_render_shows_water_and_weeds_with_counts(self):
+        """Accessibility test: both labels and counts are present."""
+        state = make_state(water=3)
+        state.weed_count = 1
+        output = render(state, ascii_mode=False)
+        # Water: label + count
+        self.assertIn("Water:", output)
+        self.assertIn("3/3", output)
+        # Weeds: label + count
+        self.assertIn("Weeds:", output)
+        self.assertIn("1", output)
