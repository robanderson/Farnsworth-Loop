+"""Terminal UI rendering for Word Garden (pure rendering, no I/O).
+
+This module renders game state to strings suitable for display in a terminal.
+It supports both emoji and ASCII modes for accessibility. No input() or print()
+calls here; everything returns strings for the I/O module to handle.
+
+See SPEC.md sections 9, 10, 18 and task-002.
+"""
+
+from word_garden.game import GameState, display_word
+
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the full turn display per SPEC.md section 9.
+
+    Shows the game title, plant growth stage (per section 10), masked word,
+    guessed letters, water, weeds, and the previous turn's status message.
+
+    When ascii_mode=True, uses ASCII fallback; when False, uses emoji.
+    Accessibility per section 18: water and weeds always carry text labels
+    AND numeric counts, never symbols alone.
+
+    Returns a formatted string ready to print.
+    """
+    lines = []
+
+    # Title with plant emoji
+    plant_emoji = _get_plant_emoji(state, ascii_mode)
+    lines.append(f"{plant_emoji} Word Garden")
+    lines.append("")
+
+    # Word display
+    word_display = display_word(state)
+    lines.append(f"Word:     {word_display}")
+
+    # Guessed letters (sorted, space-separated)
+    if state.guessed_letters:
+        guessed_str = " ".join(sorted(state.guessed_letters))
+        lines.append(f"Guessed:  {guessed_str}")
+    else:
+        lines.append("Guessed:")
+
+    # Water display (with label and count)
+    water_display = _format_water(state.remaining_water, state.max_water, ascii_mode)
+    lines.append(f"Water:   {water_display}")
+
+    # Weeds display (with label and count)
+    weeds_display = _format_weeds(state.weed_count, ascii_mode)
+    lines.append(f"Weeds:   {weeds_display}")
+
+    # Status message from previous turn
+    if state.status_message:
+        lines.append("")
+        lines.append(state.status_message)
+
+    return "\n".join(lines)
+
+
+def win_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the win screen per SPEC.md section 6.6.
+
+    Shows a celebratory message with the revealed word.
+    """
+    lines = []
+    bloom_emoji = "🌻" if not ascii_mode else "*"
+    lines.append(f"{bloom_emoji} Bloom!")
+    lines.append("")
+    lines.append(f"You guessed the word: {state.secret_word}")
+    lines.append("The garden is thriving.")
+    return "\n".join(lines)
+
+
+def loss_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Render the loss screen per SPEC.md section 6.7.
+
+    Shows a sympathetic message and reveals the secret word.
+    """
+    lines = []
+    wilted_emoji = "🥀" if not ascii_mode else "*"
+    lines.append(f"{wilted_emoji} The garden ran out of water.")
+    lines.append("")
+    lines.append(f"The word was: {state.secret_word}")
+    lines.append("Try again and grow a new garden.")
+    return "\n".join(lines)
+
+
+def _get_plant_emoji(state: GameState, ascii_mode: bool) -> str:
+    """Return the plant emoji based on game progress per SPEC.md section 10.
+
+    Growth stages:
+    - Start (0% progress): 🌱
+    - Progress (partial reveal): 🌿
+    - Near win (almost fully revealed): 🌷
+    - Win: 🌻
+    - Loss: 🥀
+    """
+    if ascii_mode:
+        return "*"
+
+    # Calculate progress: how many letters revealed vs. total
+    total_letters = len(state.secret_word)
+    guessed_count = sum(1 for letter in state.secret_word
+                       if letter in state.guessed_letters)
+
+    if state.won:
+        return "🌻"
+    elif state.game_over:  # Lost
+        return "🥀"
+
+    # Progress-based stages while game is ongoing
+    if guessed_count == 0:
+        return "🌱"  # Start: no letters guessed yet
+    elif guessed_count >= total_letters - 1:
+        return "🌷"  # Near win: one letter or fewer remaining
+    else:
+        return "🌿"  # Progress: some letters guessed
+
+
+def _format_water(remaining: int, max_water: int, ascii_mode: bool) -> str:
+    """Format water display with label and count, plus visual indicator.
+
+    Example: 'Water: 4/6 💧💧💧💧' (emoji mode)
+    or       'Water: 4/6 [****]' (ASCII mode)
+    """
+    if ascii_mode:
+        filled = "[" + "*" * remaining + "]"
+    else:
+        filled = "💧" * remaining
+
+    return f"{remaining}/{max_water} {filled}"
+
+
+def _format_weeds(count: int, ascii_mode: bool) -> str:
+    """Format weeds display with label and count, plus visual indicator.
+
+    Example: 'Weeds: 2 🌿🌿' (emoji mode)
+    or       'Weeds: 2 [--]' (ASCII mode)
+    """
+    if ascii_mode:
+        visual = "[" + "-" * count + "]"
+    else:
+        visual = "🌿" * count
+
+    return f"{count} {visual}"
