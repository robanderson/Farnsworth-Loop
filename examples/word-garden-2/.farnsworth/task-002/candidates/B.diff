+"""Tests for word_garden.ui (rendering) and word_garden.main (game loop).
+
+Covers SPEC.md sections 9, 10, 15, 18 and task-002 acceptance criteria.
+"""
+
+from __future__ import annotations
+
+import random
+import unittest
+
+from word_garden.game import GameState, apply_guess, new_game
+from word_garden.ui import loss_screen, render, win_screen
+from word_garden.main import main
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+def make_state(secret_word: str = "GARDEN", water: int = 6) -> GameState:
+    """Build a known GameState without relying on random selection."""
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+def scripted_main(inputs: list[str], difficulty: str = "normal") -> tuple[int, list[str]]:
+    """Run main() with a scripted sequence of inputs, capturing output.
+
+    Returns (exit_code, list_of_output_lines).
+    Raises EOFError automatically after the inputs are exhausted to simulate
+    Ctrl-D if the game hasn't ended yet.
+    """
+    inputs_iter = iter(inputs)
+    captured: list[str] = []
+
+    def fake_input(prompt: str = "") -> str:
+        try:
+            return next(inputs_iter)
+        except StopIteration:
+            raise EOFError
+
+    def fake_print(*args, **kwargs) -> None:
+        sep = kwargs.get("sep", " ")
+        end = kwargs.get("end", "\n")
+        text = sep.join(str(a) for a in args)
+        captured.append(text)
+
+    code = main(
+        argv=["--difficulty", difficulty],
+        input_fn=fake_input,
+        output_fn=fake_print,
+    )
+    return code, captured
+
+
+# ---------------------------------------------------------------------------
+# render() — emoji mode
+# ---------------------------------------------------------------------------
+
+class RenderEmojiModeTests(unittest.TestCase):
+    """Basic structure and accessibility requirements (SPEC.md 9, 18)."""
+
+    def test_contains_title(self):
+        state = make_state("GARDEN")
+        output = render(state)
+        self.assertIn("Word Garden", output)
+
+    def test_contains_masked_word(self):
+        state = make_state("GARDEN")
+        output = render(state)
+        # All blanks at start.
+        self.assertIn("_ _ _ _ _ _", output)
+
+    def test_water_label_and_count(self):
+        state = make_state("GARDEN", water=6)
+        output = render(state)
+        # Accessibility: text label plus numeric fraction.
+        self.assertIn("Water:", output)
+        self.assertIn("6/6", output)
+
+    def test_weed_label_and_count(self):
+        state = make_state("GARDEN", water=6)
+        output = render(state)
+        self.assertIn("Weeds:", output)
+        self.assertIn("0", output)
