+            guessed_letters=set(),
+            remaining_water=6,
+            weed_count=0,
+            max_water=6,
+        )
+        wg_main.new_game = lambda difficulty: test_state
+
+        captured: list[str] = []
+        inputs_iter = iter(["C", "A", "T"])
+
+        def fake_input(prompt: str = "") -> str:
+            try:
+                return next(inputs_iter)
+            except StopIteration:
+                raise EOFError
+
+        def fake_print(*args, **kwargs) -> None:
+            captured.append(" ".join(str(a) for a in args))
+
+        try:
+            code = wg_main.main(argv=[], input_fn=fake_input, output_fn=fake_print)
