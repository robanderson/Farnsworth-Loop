+"""Main game loop for Word Garden — the only I/O module.
+
+Entry point: :func:`main`. Use ``python3 -m word_garden`` to play.
+See SPEC.md sections 15, 20, 21.
+"""
+
+from __future__ import annotations
+
+import argparse
+import sys
+from typing import Callable
+
+from word_garden.game import apply_guess, new_game, validate_guess
+from word_garden.ui import loss_screen, render, win_screen
+
+
+def main(
+    argv: list[str] | None = None,
+    input_fn: Callable[..., str] = input,
+    output_fn: Callable[..., None] = print,
+) -> int:
+    """Run one game session, returning an exit code (0 = clean exit).
+
+    *argv* is forwarded to argparse; ``None`` uses ``sys.argv[1:]``.
+    *input_fn* and *output_fn* are injectable for testing.
+    """
+    parser = argparse.ArgumentParser(
+        prog="word_garden",
+        description="Word Garden — a friendly terminal word-guessing game.",
+    )
+    parser.add_argument(
+        "--difficulty",
+        choices=["easy", "normal", "hard"],
+        default="normal",
+        help="Difficulty level (default: normal).",
+    )
+    parser.add_argument(
+        "--ascii",
+        action="store_true",
+        default=False,
+        dest="ascii_mode",
+        help="Use ASCII fallback instead of emoji.",
+    )
+    args = parser.parse_args(argv)
+
+    state = new_game(args.difficulty)
+
+    try:
+        while not state.game_over:
+            output_fn(render(state, ascii_mode=args.ascii_mode))
+            output_fn("")
+
+            try:
+                raw = input_fn("Guess a letter: ")
+            except EOFError:
+                output_fn("")
+                output_fn("Goodbye! Come back and grow a new garden soon.")
+                return 0
+
+            letter, error = validate_guess(raw)
+            if letter is None:
+                output_fn(error)
+                continue
+
+            apply_guess(state, letter)
+
+        # Game ended — show the final screen.
+        if state.won:
+            output_fn(win_screen(state, ascii_mode=args.ascii_mode))
+        else:
+            output_fn(loss_screen(state, ascii_mode=args.ascii_mode))
+
+    except KeyboardInterrupt:
+        output_fn("")
+        output_fn("Goodbye! Come back and grow a new garden soon.")
+        return 0
+
+    return 0
+
+
+if __name__ == "__main__":  # pragma: no cover
+    sys.exit(main())
