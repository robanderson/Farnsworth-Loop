+"""Terminal UI rendering for Word Garden.
+
+Pure rendering — no I/O. Every function returns a string.
+See SPEC.md sections 5, 9, 10, 15, 18.
+"""
+
+from __future__ import annotations
+
+from word_garden.game import GameState, display_word
+
+# ---------------------------------------------------------------------------
+# Growth-stage glyphs
+# ---------------------------------------------------------------------------
+
+_STAGE_EMOJI = {
+    "start": "🌱",
+    "progress": "🌿",
+    "near_win": "🌷",
+    "win": "🌻",
+    "loss": "🥀",
+}
+
+_STAGE_ASCII = {
+    "start": ".",
+    "progress": "*",
+    "near_win": "+",
+    "win": "@",
+    "loss": "X",
+}
+
+_WATER_EMOJI = "💧"
+_WEED_EMOJI = "🌿"
+
+
+def _growth_stage(state: GameState) -> str:
+    """Return the growth stage key for the current state."""
+    if state.game_over and state.won:
+        return "win"
+    if state.game_over and not state.won:
+        return "loss"
+
+    # Fraction of letters revealed out of unique letters in the word.
+    unique_letters = set(state.secret_word)
+    revealed = unique_letters & state.guessed_letters
+    if not unique_letters:
+        fraction = 0.0
+    else:
+        fraction = len(revealed) / len(unique_letters)
+
+    if fraction == 0.0:
+        return "start"
+    elif fraction >= 0.75:
+        return "near_win"
+    else:
+        return "progress"
+
+
+def render(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the full turn display for *state* (SPEC.md section 9).
+
+    Order: title, plant/garden status, masked word, guessed letters, water,
+    weeds, previous turn status message. The ``ascii_mode`` flag switches
+    between emoji and ASCII fallback (SPEC.md section 10 / 18).
+    """
+    stage_key = _growth_stage(state)
+
+    if ascii_mode:
+        glyphs = _STAGE_ASCII
+        title = "Word Garden"
+        plant_label = f"Plant:  {glyphs[stage_key]}"
+        water_symbols = "[" + "*" * state.remaining_water + "]"
+        weed_symbols = "[" + "-" * state.weed_count + "]"
+    else:
+        glyphs = _STAGE_EMOJI
+        title = f"{glyphs['start']} Word Garden"
+        plant_label = f"Plant:  {glyphs[stage_key]}"
+        water_symbols = _WATER_EMOJI * state.remaining_water
+        weed_symbols = _WEED_EMOJI * state.weed_count
+
+    word_display = display_word(state)
+
+    guessed_sorted = " ".join(sorted(state.guessed_letters))
+
+    # Accessibility (SPEC.md section 18): always include text label + count.
+    water_line = (
+        f"Water:  {state.remaining_water}/{state.max_water} {water_symbols}".rstrip()
+    )
+    weed_line = (
+        f"Weeds:  {state.weed_count} {weed_symbols}".rstrip()
+    )
+
+    lines = [
+        title,
+        "",
+        plant_label,
+        "",
+        f"Word:      {word_display}",
+        f"Guessed:   {guessed_sorted}",
+        water_line,
+        weed_line,
+    ]
+
+    if state.status_message:
+        lines.append("")
+        lines.append(state.status_message)
+
+    return "\n".join(lines)
+
+
+def win_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the win screen (SPEC.md section 6.6)."""
+    if ascii_mode:
+        header = "@  Bloom!"
+    else:
+        header = "🌻 Bloom!"
+
+    return "\n".join([
+        header,
+        "",
+        f"You guessed the word: {state.secret_word}",
+        "The garden is thriving.",
+    ])
+
+
+def loss_screen(state: GameState, ascii_mode: bool = False) -> str:
+    """Return the loss screen (SPEC.md section 6.7), revealing the word."""
+    if ascii_mode:
+        header = "X  The garden ran out of water."
+    else:
+        header = "🥀 The garden ran out of water."
+
+    return "\n".join([
+        header,
+        "",
+        f"The word was: {state.secret_word}",
+        "Try again and grow a new garden.",
+    ])
