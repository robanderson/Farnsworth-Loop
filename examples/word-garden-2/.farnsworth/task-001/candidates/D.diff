+"""Tests for word selection and difficulty management."""
+
+import random
+import unittest
+
+from word_garden import words
+
+
+class TestWords(unittest.TestCase):
+    """Test word selection and difficulty."""
+
+    def test_words_list_exists(self):
+        """Test that WORDS list is defined."""
+        self.assertIsNotNone(words.WORDS)
+        self.assertEqual(len(words.WORDS), 10)
+
+    def test_all_words_uppercase(self):
+        """Test that all words in WORDS are uppercase."""
+        for word in words.WORDS:
+            self.assertEqual(word, word.upper())
+
+    def test_water_for_easy(self):
+        """Test water_for returns 8 for easy difficulty."""
+        self.assertEqual(words.water_for("easy"), 8)
+
+    def test_water_for_normal(self):
+        """Test water_for returns 6 for normal difficulty."""
+        self.assertEqual(words.water_for("normal"), 6)
+
+    def test_water_for_hard(self):
+        """Test water_for returns 4 for hard difficulty."""
+        self.assertEqual(words.water_for("hard"), 4)
+
+    def test_water_for_default(self):
+        """Test water_for defaults to normal (6)."""
+        self.assertEqual(words.water_for(), 6)
+
+    def test_water_for_unknown_difficulty(self):
+        """Test water_for raises ValueError for unknown difficulty."""
+        with self.assertRaises(ValueError):
+            words.water_for("impossible")
+
+    def test_select_word_easy(self):
+        """Test select_word returns valid word for easy difficulty."""
+        word = words.select_word("easy")
+        self.assertIn(word, words.WORDS)
+        self.assertGreaterEqual(len(word), 4)
+        self.assertLessEqual(len(word), 6)
+
+    def test_select_word_normal(self):
+        """Test select_word returns valid word for normal difficulty."""
+        word = words.select_word("normal")
+        self.assertIn(word, words.WORDS)
+        self.assertGreaterEqual(len(word), 5)
+        self.assertLessEqual(len(word), 8)
+
+    def test_select_word_hard(self):
+        """Test select_word returns valid word for hard difficulty."""
+        word = words.select_word("hard")
+        self.assertIn(word, words.WORDS)
+        self.assertGreaterEqual(len(word), 7)
+
+    def test_select_word_default(self):
+        """Test select_word defaults to normal difficulty."""
+        word = words.select_word()
+        self.assertIn(word, words.WORDS)
+        self.assertGreaterEqual(len(word), 5)
+        self.assertLessEqual(len(word), 8)
+
+    def test_select_word_unknown_difficulty(self):
+        """Test select_word raises ValueError for unknown difficulty."""
+        with self.assertRaises(ValueError):
+            words.select_word("impossible")
+
+    def test_select_word_deterministic_with_rng(self):
+        """Test select_word with injected RNG is deterministic."""
+        rng1 = random.Random(42)
+        rng2 = random.Random(42)
+        word1 = words.select_word("normal", rng=rng1)
+        word2 = words.select_word("normal", rng=rng2)
+        self.assertEqual(word1, word2)
+
+    def test_select_word_different_seeds(self):
+        """Test select_word with different seeds can produce different words."""
+        rng1 = random.Random(1)
+        rng2 = random.Random(2)
+        word1 = words.select_word("normal", rng=rng1)
+        word2 = words.select_word("normal", rng=rng2)
+        # Not guaranteed to be different, but statistically likely
+        # This test just ensures both are valid
+        self.assertIn(word1, words.WORDS)
+        self.assertIn(word2, words.WORDS)
+
+    def test_select_word_multiple_calls_randomized(self):
+        """Test that select_word without RNG produces randomness."""
+        # Sample multiple words and verify they're in the word list
+        words_selected = [words.select_word("normal") for _ in range(10)]
+        for word in words_selected:
+            self.assertIn(word, words.WORDS)
+
+
+if __name__ == "__main__":
+    unittest.main()
