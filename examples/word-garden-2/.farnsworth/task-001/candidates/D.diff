+"""Core game logic for Word Garden."""
+
+from dataclasses import dataclass, field
+from typing import Optional
+
+from . import words
+
+
+@dataclass
+class GameState:
+    """Represents the state of a Word Garden game."""
+
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty="normal", rng=None) -> GameState:
+    """
+    Create a new game state.
+
+    Args:
+        difficulty: "easy", "normal", or "hard"
+        rng: Optional random.Random instance for deterministic tests.
+
+    Returns:
+        A GameState with the secret word selected and initial values set.
+    """
+    secret_word = words.select_word(difficulty=difficulty, rng=rng).upper()
+    water = words.water_for(difficulty=difficulty)
+
+    return GameState(
+        secret_word=secret_word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[Optional[str], str]:
+    """
+    Validate user input and return a letter or error message.
+
+    Args:
+        input_text: Raw input from the user.
+
+    Returns:
+        A tuple (letter, message) where:
+        - If valid: (uppercase_letter, "")
+        - If invalid: (None, specific_error_message)
+
+    Validation rules:
+    - Must be exactly one alphabetic character
+    - Leading/trailing whitespace is trimmed
+    - Lowercase is converted to uppercase
+    """
+    # Trim whitespace
+    trimmed = input_text.strip()
+
+    # Check for empty input
+    if not trimmed:
+        return None, "Please enter a single letter."
+
+    # Check for exactly one character
+    if len(trimmed) > 1:
+        return None, "Please enter a single letter."
+
+    # Check if it's alphabetic
+    if not trimmed.isalpha():
+        return None, "That is not a letter."
+
+    # Valid: return uppercase letter
+    return trimmed.upper(), ""
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """
+    Apply a validated letter guess to the game state.
+
+    Args:
+        state: Current game state.
+        letter: An uppercase letter.
+
+    Returns:
+        A new GameState with the guess applied.
+
+    Rules per SPEC.md sections 6.3-6.5:
+    - Correct guess: reveals letters, no water/weed change
+    - Incorrect guess: water -1, weeds +1
+    - Repeated guess: no changes, message only
+    - Guessing after game over: no-op with message
+    """
+    # If game is already over, return no-op with message
+    if state.game_over:
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters.copy(),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="Game is over.",
+            game_over=True,
+            won=state.won,
+        )
+        return new_state
+
+    # Check for repeated guess
+    if letter in state.guessed_letters:
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters.copy(),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=f"You already guessed {letter}. Try another letter.",
+            game_over=state.game_over,
+            won=state.won,
+        )
+        return new_state
+
+    # Add letter to guessed set
+    new_guessed = state.guessed_letters.copy()
+    new_guessed.add(letter)
+
+    # Check if the letter is in the secret word
+    if letter in state.secret_word:
+        # Correct guess
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="Good guess! The garden grows.",
+            game_over=False,
+            won=False,
+        )
+    else:
+        # Incorrect guess: reduce water, increase weeds
+        new_remaining_water = state.remaining_water - 1
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_remaining_water,
+            weed_count=state.weed_count + 1,
+            max_water=state.max_water,
+            status_message="No match. A weed appears.",
+            game_over=False,
+            won=False,
+        )
+
+    # Check win/loss conditions after the guess
+    if is_won(new_state):
+        new_state.won = True
+        new_state.game_over = True
+    elif is_lost(new_state):
+        new_state.game_over = True
+
+    return new_state
+
+
+def display_word(state: GameState) -> str:
+    """
+    Return the display string for the secret word.
+
+    Guessed letters are revealed, unguessed letters are masked with _.
+    Letters are space-separated, e.g. "G _ R _ E _"
+
+    Args:
+        state: Current game state.
+
+    Returns:
+        Masked word as a space-separated string.
+    """
+    result = []
+    for char in state.secret_word:
+        if char in state.guessed_letters:
+            result.append(char)
+        else:
+            result.append("_")
+    return " ".join(result)
+
+
+def is_won(state: GameState) -> bool:
+    """
+    Check if the player has won.
+
+    Win condition: all letters of the secret word have been guessed.
+
+    Args:
+        state: Current game state.
+
+    Returns:
+        True if the word is fully revealed, False otherwise.
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """
+    Check if the player has lost.
+
+    Loss condition: water reached 0 before the word is fully revealed.
+
+    Args:
+        state: Current game state.
+
+    Returns:
+        True if water is 0 and word is not won, False otherwise.
+    """
+    return state.remaining_water <= 0 and not is_won(state)
