+"""Tests for core game logic."""
+
+import random
+import unittest
+
+from word_garden import game, words
+
+
+class TestNewGame(unittest.TestCase):
+    """Test game initialization."""
+
+    def test_new_game_creates_state(self):
+        """Test new_game creates a GameState."""
+        state = game.new_game()
+        self.assertIsInstance(state, game.GameState)
+
+    def test_new_game_sets_secret_word(self):
+        """Test new_game sets a valid secret word."""
+        state = game.new_game()
+        self.assertIn(state.secret_word, words.WORDS)
+
+    def test_new_game_initializes_empty_guesses(self):
+        """Test new_game starts with no guessed letters."""
+        state = game.new_game()
+        self.assertEqual(state.guessed_letters, set())
+
+    def test_new_game_initializes_water(self):
+        """Test new_game sets correct water level for difficulty."""
+        state_easy = game.new_game("easy")
+        self.assertEqual(state_easy.remaining_water, 8)
+        self.assertEqual(state_easy.max_water, 8)
+
+        state_normal = game.new_game("normal")
+        self.assertEqual(state_normal.remaining_water, 6)
+        self.assertEqual(state_normal.max_water, 6)
+
+        state_hard = game.new_game("hard")
+        self.assertEqual(state_hard.remaining_water, 4)
+        self.assertEqual(state_hard.max_water, 4)
+
+    def test_new_game_initializes_zero_weeds(self):
+        """Test new_game starts with no weeds."""
+        state = game.new_game()
+        self.assertEqual(state.weed_count, 0)
+
+    def test_new_game_not_game_over(self):
+        """Test new_game doesn't start with game_over."""
+        state = game.new_game()
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_with_rng(self):
+        """Test new_game with injected RNG."""
+        rng = random.Random(42)
+        state = game.new_game("normal", rng=rng)
+        self.assertIsInstance(state, game.GameState)
+        self.assertIn(state.secret_word, words.WORDS)
+
