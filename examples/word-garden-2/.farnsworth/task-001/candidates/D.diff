+"""Word selection and difficulty management for Word Garden."""
+
+import random
+
+# The 10-word list from SPEC.md section 8, uppercase
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty levels per SPEC.md section 7
+# Format: (water, min_length, max_length)
+DIFFICULTY_LEVELS = {
+    "easy": (8, 4, 6),
+    "normal": (6, 5, 8),
+    "hard": (4, 7, float("inf")),
+}
+
+
+def water_for(difficulty="normal") -> int:
+    """Return the starting water level for a given difficulty."""
+    if difficulty not in DIFFICULTY_LEVELS:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+    return DIFFICULTY_LEVELS[difficulty][0]
+
+
+def select_word(difficulty="normal", rng=None) -> str:
+    """
+    Select a random word filtered by difficulty.
+
+    Args:
+        difficulty: "easy", "normal", or "hard"
+        rng: Optional random.Random instance for deterministic tests.
+             If None, uses the module-level random functions.
+
+    Returns:
+        A word from WORDS that matches the difficulty criteria.
+
+    Raises:
+        ValueError: If difficulty is unknown.
+    """
+    if difficulty not in DIFFICULTY_LEVELS:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    _, min_len, max_len = DIFFICULTY_LEVELS[difficulty]
+
+    # Filter words by length
+    candidates = [w for w in WORDS if min_len <= len(w) <= max_len]
+
+    if not candidates:
+        raise ValueError(f"No words available for difficulty: {difficulty}")
+
+    # Use provided RNG or module-level random
+    if rng is None:
+        return random.choice(candidates)
+    else:
+        return rng.choice(candidates)
