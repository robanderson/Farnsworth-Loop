+class TestValidateGuess(unittest.TestCase):
+    """Test input validation."""
+
+    def test_validate_single_letter_lowercase(self):
+        """Test validation of lowercase single letter."""
+        letter, msg = game.validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_validate_single_letter_uppercase(self):
+        """Test validation of uppercase single letter."""
+        letter, msg = game.validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+    def test_validate_letter_with_spaces(self):
+        """Test validation trims whitespace."""
+        letter, msg = game.validate_guess("  a  ")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_validate_empty_input(self):
+        """Test validation rejects empty input."""
+        letter, msg = game.validate_guess("")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, "Please enter a single letter.")
+
+    def test_validate_multiple_letters(self):
+        """Test validation rejects multiple letters."""
+        letter, msg = game.validate_guess("abc")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, "Please enter a single letter.")
+
+    def test_validate_single_letter_word(self):
+        """Test validation rejects words."""
+        letter, msg = game.validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, "Please enter a single letter.")
+
+    def test_validate_digit(self):
+        """Test validation rejects digits."""
+        letter, msg = game.validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, "That is not a letter.")
+
+    def test_validate_symbol(self):
+        """Test validation rejects symbols."""
+        letter, msg = game.validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, "That is not a letter.")
+
+    def test_validate_mixed_input(self):
+        """Test validation rejects mixed alphanumeric."""
+        letter, msg = game.validate_guess("a1")
+        self.assertIsNone(letter)
+        self.assertEqual(msg, "Please enter a single letter.")
+
