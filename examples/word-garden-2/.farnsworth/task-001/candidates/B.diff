+"""Core game logic for Word Garden."""
+
+from dataclasses import dataclass, field
+from typing import Optional
+
+from word_garden import words
+
+
+@dataclass
+class GameState:
+    """The state of a Word Garden game.
+
+    Attributes:
+        secret_word: The uppercase word to be guessed.
+        guessed_letters: The set of uppercase letters already guessed.
+        remaining_water: Current water level.
+        weed_count: Current number of weeds.
+        max_water: The starting water level for this game.
+        status_message: Feedback message from the last action.
+        game_over: True if the game has ended (win or loss).
+        won: True if the player has won.
+    """
+
+    secret_word: str
+    guessed_letters: set[str] = field(default_factory=set)
+    remaining_water: int = 0
+    weed_count: int = 0
+    max_water: int = 0
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng=None) -> GameState:
+    """Create a new game with a random word.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic testing.
+
+    Returns:
+        A new GameState with the given difficulty settings.
+    """
+    word = words.select_word(difficulty=difficulty, rng=rng)
+    max_water = words.water_for(difficulty=difficulty)
+
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=max_water,
+        weed_count=0,
+        max_water=max_water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[Optional[str], str]:
+    """Validate a user's letter guess.
+
+    Does not consult game state; only validates input format.
+
+    Args:
+        input_text: Raw user input.
+
+    Returns:
+        A tuple (letter, message) where:
+        - If valid: (letter, "") with letter in uppercase
+        - If invalid: (None, message) with a helpful error message
+    """
+    # Trim whitespace
+    trimmed = input_text.strip()
+
+    # Check empty
+    if not trimmed:
+        return None, "Please enter a single letter."
+
+    # Convert to uppercase
+    upper = trimmed.upper()
+
+    # Check single character
+    if len(upper) != 1:
+        return None, "Please enter a single letter."
+
+    # Check alphabetic
+    if not upper.isalpha():
+        return None, "That is not a letter."
+
+    return upper, ""
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word, space-separated.
+
+    Guessed letters are revealed; unguessed letters are shown as _.
+
+    Args:
+        state: The current game state.
+
+    Returns:
+        A string like "G _ R _ E _".
+    """
+    result = []
+    for letter in state.secret_word:
+        if letter in state.guessed_letters:
+            result.append(letter)
+        else:
+            result.append("_")
+    return " ".join(result)
+
+
+def is_won(state: GameState) -> bool:
+    """Check if the player has won.
+
+    Win condition: all letters of the secret word have been guessed.
+
+    Args:
+        state: The current game state.
+
+    Returns:
+        True if the player has won.
+    """
+    return all(letter in state.guessed_letters for letter in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Check if the player has lost.
+
+    Loss condition: water is at 0 and not all letters have been guessed.
+
+    Args:
+        state: The current game state.
+
+    Returns:
+        True if the player has lost.
+    """
+    return state.remaining_water <= 0 and not is_won(state)
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a validated guess to the game state.
+
+    Assumes letter is already validated (uppercase, single alphabetic char).
+    Updates state based on whether the guess is correct, wrong, or repeated.
+
+    Args:
+        state: The current game state.
+        letter: An uppercase alphabetic character.
+
+    Returns:
+        A new GameState with the guess applied.
+    """
+    # If game is already over, don't accept further guesses
+    if state.game_over:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="Game is over. Start a new game to play again.",
+            game_over=state.game_over,
+            won=state.won,
+        )
+
+    # Check if already guessed
+    if letter in state.guessed_letters:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=state.guessed_letters,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=f"You already guessed {letter}. Try another letter.",
+            game_over=state.game_over,
+            won=state.won,
+        )
+
+    # Add letter to guessed set
+    new_guessed = state.guessed_letters | {letter}
+
+    # Check if correct
+    if letter in state.secret_word:
+        # Correct guess: no water/weed change, friendly message
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="Good guess! The garden grows.",
+            game_over=False,
+            won=False,
+        )
+    else:
+        # Wrong guess: water -1, weeds +1
+        new_water = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+
+        new_state = GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_water,
+            weed_count=new_weeds,
+            max_water=state.max_water,
+            status_message="No match. A weed appears.",
+            game_over=False,
+            won=False,
+        )
+
+    # Check win/loss conditions
+    if is_won(new_state):
+        new_state.game_over = True
+        new_state.won = True
+    elif is_lost(new_state):
+        new_state.game_over = True
+        new_state.won = False
+
+    return new_state
