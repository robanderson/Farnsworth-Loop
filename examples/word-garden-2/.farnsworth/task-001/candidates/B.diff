+"""Word selection and difficulty management for Word Garden."""
+
+import random
+
+# The 10-word list from SPEC.md section 8, in uppercase
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty table from SPEC.md section 7
+# Format: difficulty -> (water, min_length, max_length)
+_DIFFICULTY_TABLE = {
+    "easy": (8, 4, 6),
+    "normal": (6, 5, 8),
+    "hard": (4, 7, float("inf")),
+}
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return the starting water for a given difficulty level.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+
+    Returns:
+        The starting water amount.
+
+    Raises:
+        ValueError: If difficulty is not recognized.
+    """
+    if difficulty not in _DIFFICULTY_TABLE:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+    return _DIFFICULTY_TABLE[difficulty][0]
+
+
+def select_word(difficulty: str = "normal", rng: random.Random | None = None) -> str:
+    """Select a random word from WORDS filtered by difficulty.
+
+    Args:
+        difficulty: One of "easy", "normal", or "hard".
+        rng: Optional random.Random instance for deterministic testing.
+             If None, uses the module-level random functions.
+
+    Returns:
+        A word from WORDS that matches the difficulty constraints.
+
+    Raises:
+        ValueError: If difficulty is not recognized or no words match the constraints.
+    """
+    if difficulty not in _DIFFICULTY_TABLE:
+        raise ValueError(f"Unknown difficulty: {difficulty}")
+
+    if rng is None:
+        rng = random
+
+    water, min_len, max_len = _DIFFICULTY_TABLE[difficulty]
+
+    # Filter words by length
+    candidates = [w for w in WORDS if min_len <= len(w) <= max_len]
+
+    if not candidates:
+        raise ValueError(f"No words available for difficulty: {difficulty}")
+
+    return rng.choice(candidates)
