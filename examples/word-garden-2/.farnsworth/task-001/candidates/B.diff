+"""Tests for word selection and difficulty."""
+
+import random
+import unittest
+
+from word_garden import words
+
+
+class TestWordList(unittest.TestCase):
+    """Test the word list."""
+
+    def test_words_is_list_of_10(self):
+        """The WORDS list should contain exactly 10 uppercase words."""
+        self.assertEqual(len(words.WORDS), 10)
+        for word in words.WORDS:
+            self.assertIsInstance(word, str)
+            self.assertEqual(word, word.upper())
+            self.assertTrue(word.isalpha())
+
+    def test_words_are_uppercase(self):
+        """All words in WORDS should be uppercase."""
+        for word in words.WORDS:
+            self.assertEqual(word, word.upper())
+
+
+class TestWaterFor(unittest.TestCase):
+    """Test the water_for function."""
+
+    def test_water_for_easy(self):
+        """Easy difficulty should return 8 water."""
+        self.assertEqual(words.water_for("easy"), 8)
+
+    def test_water_for_normal(self):
+        """Normal difficulty should return 6 water."""
+        self.assertEqual(words.water_for("normal"), 6)
+
+    def test_water_for_hard(self):
+        """Hard difficulty should return 4 water."""
+        self.assertEqual(words.water_for("hard"), 4)
+
+    def test_water_for_default_is_normal(self):
+        """Default difficulty should be normal (6 water)."""
+        self.assertEqual(words.water_for(), 6)
+
+    def test_water_for_unknown_difficulty(self):
+        """Unknown difficulty should raise ValueError."""
+        with self.assertRaises(ValueError):
+            words.water_for("impossible")
+
+
+class TestSelectWord(unittest.TestCase):
+    """Test the select_word function."""
+
+    def test_select_word_easy(self):
+        """Easy mode should return words of length 4-6."""
+        rng = random.Random(42)
+        for _ in range(20):
+            word = words.select_word("easy", rng=rng)
+            self.assertIn(word, words.WORDS)
+            self.assertGreaterEqual(len(word), 4)
+            self.assertLessEqual(len(word), 6)
+
+    def test_select_word_normal(self):
+        """Normal mode should return words of length 5-8."""
+        rng = random.Random(42)
+        for _ in range(20):
+            word = words.select_word("normal", rng=rng)
+            self.assertIn(word, words.WORDS)
+            self.assertGreaterEqual(len(word), 5)
+            self.assertLessEqual(len(word), 8)
+
+    def test_select_word_hard(self):
+        """Hard mode should return words of length 7+."""
+        rng = random.Random(42)
+        for _ in range(20):
+            word = words.select_word("hard", rng=rng)
+            self.assertIn(word, words.WORDS)
+            self.assertGreaterEqual(len(word), 7)
+
+    def test_select_word_default_is_normal(self):
+        """Default difficulty should be normal."""
+        rng = random.Random(42)
+        word = words.select_word(rng=rng)
+        self.assertIn(word, words.WORDS)
+        self.assertGreaterEqual(len(word), 5)
+        self.assertLessEqual(len(word), 8)
+
+    def test_select_word_uses_rng(self):
+        """Providing the same RNG seed should give the same word."""
+        word1 = words.select_word(rng=random.Random(123))
+        word2 = words.select_word(rng=random.Random(123))
+        self.assertEqual(word1, word2)
+
+    def test_select_word_without_rng(self):
+        """select_word without rng should use module-level random."""
+        word = words.select_word()
+        self.assertIn(word, words.WORDS)
+
+    def test_select_word_unknown_difficulty(self):
+        """Unknown difficulty should raise ValueError."""
+        with self.assertRaises(ValueError):
+            words.select_word("unknown")
+
+
+if __name__ == "__main__":
+    unittest.main()
