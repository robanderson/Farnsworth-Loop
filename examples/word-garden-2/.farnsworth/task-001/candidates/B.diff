+"""Tests for game logic."""
+
+import random
+import unittest
+
+from word_garden import game, words
+
+
+class TestGameState(unittest.TestCase):
+    """Test GameState initialization and fields."""
+
+    def test_gamestate_fields(self):
+        """GameState should have all required fields."""
+        state = game.GameState(
+            secret_word="TEST",
+            guessed_letters={"T"},
+            remaining_water=5,
+            weed_count=1,
+            max_water=6,
+            status_message="Test",
+            game_over=False,
+            won=False,
+        )
+        self.assertEqual(state.secret_word, "TEST")
+        self.assertEqual(state.guessed_letters, {"T"})
+        self.assertEqual(state.remaining_water, 5)
+        self.assertEqual(state.weed_count, 1)
+        self.assertEqual(state.max_water, 6)
+        self.assertEqual(state.status_message, "Test")
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_gamestate_defaults(self):
+        """GameState should have sensible defaults."""
+        state = game.GameState(secret_word="TEST", remaining_water=6, max_water=6)
+        self.assertEqual(state.guessed_letters, set())
+        self.assertEqual(state.status_message, "")
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+
+class TestNewGame(unittest.TestCase):
+    """Test game creation."""
+
+    def test_new_game_default(self):
+        """new_game() should create a normal difficulty game."""
+        rng = random.Random(42)
+        state = game.new_game(rng=rng)
+        self.assertIn(state.secret_word, words.WORDS)
+        self.assertEqual(state.guessed_letters, set())
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(state.max_water, 6)
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_new_game_easy(self):
+        """new_game("easy") should start with 8 water."""
+        rng = random.Random(42)
+        state = game.new_game("easy", rng=rng)
+        self.assertEqual(state.remaining_water, 8)
+        self.assertEqual(state.max_water, 8)
+
+    def test_new_game_hard(self):
+        """new_game("hard") should start with 4 water."""
+        rng = random.Random(42)
+        state = game.new_game("hard", rng=rng)
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.max_water, 4)
+
+    def test_new_game_uses_rng(self):
+        """Providing the same RNG seed should give the same word."""
+        state1 = game.new_game(rng=random.Random(99))
+        state2 = game.new_game(rng=random.Random(99))
+        self.assertEqual(state1.secret_word, state2.secret_word)
+
+
+class TestValidateGuess(unittest.TestCase):
+    """Test input validation."""
+
+    def test_valid_single_letter_lowercase(self):
+        """Lowercase letter should be accepted and converted to uppercase."""
+        letter, msg = game.validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_valid_single_letter_uppercase(self):
+        """Uppercase letter should be accepted."""
+        letter, msg = game.validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+    def test_valid_with_whitespace(self):
+        """Whitespace should be trimmed."""
+        letter, msg = game.validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(msg, "")
+
+    def test_invalid_empty(self):
+        """Empty input should be rejected."""
+        letter, msg = game.validate_guess("")
+        self.assertIsNone(letter)
+        self.assertIn("single letter", msg.lower())
+
+    def test_invalid_multiple_characters(self):
+        """Multiple characters should be rejected."""
+        letter, msg = game.validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertIn("single letter", msg.lower())
+
+    def test_invalid_digit(self):
+        """Digit should be rejected."""
+        letter, msg = game.validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertIn("not a letter", msg.lower())
+
+    def test_invalid_symbol(self):
+        """Symbol should be rejected."""
+        letter, msg = game.validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertIn("not a letter", msg.lower())
+
+    def test_invalid_whitespace_only(self):
+        """Whitespace-only input should be rejected."""
+        letter, msg = game.validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertIn("single letter", msg.lower())
+
+
+class TestDisplayWord(unittest.TestCase):
+    """Test display_word function."""
+
+    def test_display_word_no_guesses(self):
+        """Unguessed word should show all blanks."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        display = game.display_word(state)
+        self.assertEqual(display, "_ _ _ _ _ _")
+
+    def test_display_word_partial_guesses(self):
+        """Partial guesses should reveal some letters."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "E", "N"},
+            remaining_water=6,
+            max_water=6,
+        )
+        display = game.display_word(state)
+        self.assertEqual(display, "G A _ _ E N")
+
+    def test_display_word_all_guesses(self):
+        """All guessed letters should show the complete word."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            max_water=6,
+        )
+        display = game.display_word(state)
+        self.assertEqual(display, "G A R D E N")
+
+    def test_display_word_with_duplicate_letters(self):
+        """Letters appearing multiple times should all be revealed."""
+        state = game.GameState(
+            secret_word="COFFEE",
+            guessed_letters={"C", "O", "F", "E"},
+            remaining_water=6,
+            max_water=6,
+        )
+        display = game.display_word(state)
+        self.assertEqual(display, "C O F F E E")
+
+
+class TestIsWon(unittest.TestCase):
+    """Test win detection."""
+
+    def test_is_won_false_no_guesses(self):
+        """Unguessed word should not be a win."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        self.assertFalse(game.is_won(state))
+
+    def test_is_won_false_partial_guesses(self):
+        """Partially guessed word should not be a win."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A"},
+            remaining_water=6,
+            max_water=6,
+        )
+        self.assertFalse(game.is_won(state))
+
+    def test_is_won_true_all_letters(self):
+        """All letters guessed should be a win."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=6,
+            max_water=6,
+        )
+        self.assertTrue(game.is_won(state))
+
+    def test_is_won_true_with_extra_letters(self):
+        """Guessing all letters (and extras) should be a win."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N", "Z", "X"},
+            remaining_water=6,
+            max_water=6,
+        )
+        self.assertTrue(game.is_won(state))
+
+
+class TestIsLost(unittest.TestCase):
+    """Test loss detection."""
+
+    def test_is_lost_false_water_remaining(self):
+        """With water remaining, should not be a loss."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        self.assertFalse(game.is_lost(state))
+
+    def test_is_lost_false_won_before_zero(self):
+        """Win before running out of water should not be a loss."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=1,
+            max_water=6,
+        )
+        self.assertFalse(game.is_lost(state))
+
+    def test_is_lost_true_water_zero_word_unguessed(self):
+        """Water at 0 with unguessed letters should be a loss."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G"},
+            remaining_water=0,
+            max_water=6,
+        )
+        self.assertTrue(game.is_lost(state))
+
+    def test_is_lost_true_water_negative(self):
+        """Water below 0 with unguessed letters should be a loss."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=-1,
+            max_water=6,
+        )
+        self.assertTrue(game.is_lost(state))
+
+
+class TestApplyGuess(unittest.TestCase):
+    """Test applying guesses to game state."""
+
+    def test_correct_guess_reveals_letters(self):
+        """Correct guess should add letter to guessed set."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "G")
+        self.assertIn("G", new_state.guessed_letters)
+        self.assertEqual(new_state.status_message, "Good guess! The garden grows.")
+
+    def test_correct_guess_no_water_cost(self):
+        """Correct guess should not reduce water."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "G")
+        self.assertEqual(new_state.remaining_water, 6)
+
+    def test_correct_guess_no_weeds(self):
+        """Correct guess should not increase weeds."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+            weed_count=0,
+        )
+        new_state = game.apply_guess(state, "G")
+        self.assertEqual(new_state.weed_count, 0)
+
+    def test_wrong_guess_reduces_water(self):
+        """Wrong guess should reduce water by exactly 1."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "Z")
+        self.assertEqual(new_state.remaining_water, 5)
+
+    def test_wrong_guess_increases_weeds(self):
+        """Wrong guess should increase weeds by exactly 1."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+            weed_count=0,
+        )
+        new_state = game.apply_guess(state, "Z")
+        self.assertEqual(new_state.weed_count, 1)
+
+    def test_wrong_guess_records_letter(self):
+        """Wrong guess should add letter to guessed set."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "Z")
+        self.assertIn("Z", new_state.guessed_letters)
+
+    def test_wrong_guess_friendly_message(self):
+        """Wrong guess should have a friendly message."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "Z")
+        self.assertEqual(new_state.status_message, "No match. A weed appears.")
+
+    def test_repeated_guess_no_water_change(self):
+        """Repeated guess should not change water."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"A"},
+            remaining_water=6,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "A")
+        self.assertEqual(new_state.remaining_water, 6)
+
+    def test_repeated_guess_no_weed_change(self):
+        """Repeated guess should not change weeds."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"A"},
+            remaining_water=6,
+            max_water=6,
+            weed_count=2,
+        )
+        new_state = game.apply_guess(state, "A")
+        self.assertEqual(new_state.weed_count, 2)
+
+    def test_repeated_guess_message(self):
+        """Repeated guess should have a specific message."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"A"},
+            remaining_water=6,
+            max_water=6,
+        )
+        new_state = game.apply_guess(state, "A")
+        self.assertIn("already guessed", new_state.status_message.lower())
+        self.assertIn("A", new_state.status_message)
+
+    def test_win_detection_sets_flags(self):
+        """Guessing the last letter should set game_over and won."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E"},
+            remaining_water=6,
+            max_water=6,
+            game_over=False,
+            won=False,
+        )
+        new_state = game.apply_guess(state, "N")
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+
+    def test_loss_detection_sets_flags(self):
+        """Running out of water should set game_over and won=False."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"Z"},
+            remaining_water=1,
+            max_water=6,
+            game_over=False,
+            won=False,
+        )
+        new_state = game.apply_guess(state, "X")
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+
+    def test_guess_after_game_over_is_noop(self):
+        """Guessing after game over should not change state."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters={"G", "A", "R", "D", "E", "N"},
+            remaining_water=3,
+            max_water=6,
+            game_over=True,
+            won=True,
+        )
+        new_state = game.apply_guess(state, "Z")
+        self.assertEqual(new_state.remaining_water, 3)
+        self.assertEqual(new_state.weed_count, state.weed_count)
+        self.assertIn("game is over", new_state.status_message.lower())
+
+    def test_multiple_correct_guesses(self):
+        """Multiple correct guesses should accumulate letters."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+        )
+        state = game.apply_guess(state, "G")
+        state = game.apply_guess(state, "A")
+        state = game.apply_guess(state, "R")
+        self.assertEqual(state.guessed_letters, {"G", "A", "R"})
+        self.assertEqual(state.remaining_water, 6)
+
+    def test_mixed_guesses(self):
+        """Mix of correct and wrong guesses should be tracked correctly."""
+        state = game.GameState(
+            secret_word="GARDEN",
+            guessed_letters=set(),
+            remaining_water=6,
+            max_water=6,
+            weed_count=0,
+        )
+        state = game.apply_guess(state, "G")  # Correct
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+
+        state = game.apply_guess(state, "Z")  # Wrong
+        self.assertEqual(state.remaining_water, 5)
+        self.assertEqual(state.weed_count, 1)
+
+        state = game.apply_guess(state, "A")  # Correct
+        self.assertEqual(state.remaining_water, 5)
+        self.assertEqual(state.weed_count, 1)
+
+        state = game.apply_guess(state, "X")  # Wrong
+        self.assertEqual(state.remaining_water, 4)
+        self.assertEqual(state.weed_count, 2)
+
+
+class TestIntegration(unittest.TestCase):
+    """Integration tests for game scenarios."""
+
+    def test_full_game_win(self):
+        """Play a full game to winning."""
+        rng = random.Random(42)
+        state = game.new_game("easy", rng=rng)
+
+        # Get the word and guess all letters
+        word = state.secret_word
+        for letter in word:
+            state = game.apply_guess(state, letter)
+
+        self.assertTrue(state.game_over)
+        self.assertTrue(state.won)
+        self.assertEqual(game.display_word(state), " ".join(word))
+
+    def test_full_game_loss(self):
+        """Play a game leading to loss."""
+        rng = random.Random(42)
+        state = game.new_game("hard", rng=rng)
+        initial_water = state.remaining_water
+
+        # Make wrong guesses until water runs out
+        # Use enough wrong guesses to deplete water
+        wrong_letters = "ZXCVBNMQWERTYUIOPASDFGHJKL"
+        for i, letter in enumerate(wrong_letters):
+            if not state.game_over:
+                # Check if letter is in the word
+                if letter not in state.secret_word:
+                    state = game.apply_guess(state, letter)
+                    if state.remaining_water <= 0:
+                        break
+
+        self.assertTrue(state.game_over)
+        self.assertFalse(state.won)
+        self.assertLessEqual(state.remaining_water, 0)
+
+
+if __name__ == "__main__":
+    unittest.main()
