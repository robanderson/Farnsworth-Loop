+"""Core game logic for Word Garden."""
+
+from dataclasses import dataclass, field
+from typing import Optional
+
+from word_garden.words import select_word, water_for
+
+
+@dataclass
+class GameState:
+    """Complete game state per SPEC.md section 12."""
+
+    secret_word: str
+    guessed_letters: set
+    remaining_water: int
+    weed_count: int
+    max_water: int
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng=None) -> GameState:
+    """Create a fresh GameState for the given difficulty.
+
+    Selects a word via words.select_word, uppercases it, fills water, zeroes weeds.
+    rng is an optional random.Random instance for deterministic tests.
+    """
+    word = select_word(difficulty=difficulty, rng=rng).upper()
+    water = water_for(difficulty=difficulty)
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+def validate_guess(input_text) -> tuple:
+    """Validate raw user input and return (letter, error_message).
+
+    Returns (letter, "") for valid input: trimmed, uppercased, exactly one
+    alphabetic character.
+    Returns (None, message) for invalid input with a specific, helpful message.
+
+    Validation does NOT consult game state; repeated-guess detection belongs
+    to apply_guess.
+    """
+    if input_text is None:
+        return (None, "Please enter a single letter.")
+
+    text = str(input_text).strip()
+
+    if len(text) == 0:
+        return (None, "Please enter a single letter.")
+
+    if len(text) > 1:
+        return (None, "Please enter a single letter.")
+
+    if not text.isalpha():
+        return (None, "That is not a letter.")
+
+    return (text.upper(), "")
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply an already-validated uppercase letter to the game state.
+
+    Handles correct guess, wrong guess, repeated guess, and post-game no-op.
+    Returns a new GameState (the original is not mutated).
+
+    Per SPEC.md sections 6.3-6.5:
+    - Correct guess: reveals letter, no water/weed change.
+    - Wrong guess: -1 water, +1 weed.
+    - Repeated guess: no changes, message says already guessed.
+    - Guessing after game_over: no-op with a message.
+    """
+    # If game is already over, return state with a message but no changes
+    if state.game_over:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=set(state.guessed_letters),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message="The game is already over.",
+            game_over=state.game_over,
+            won=state.won,
+        )
+
+    # Check for repeated guess
+    if letter in state.guessed_letters:
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=set(state.guessed_letters),
+            remaining_water=state.remaining_water,
+            weed_count=state.weed_count,
+            max_water=state.max_water,
+            status_message=f"You already guessed {letter}. Try another letter.",
+            game_over=False,
+            won=False,
+        )
+
+    # Record the guess
+    new_guessed = set(state.guessed_letters) | {letter}
+
+    if letter in state.secret_word:
+        # Correct guess
+        new_water = state.remaining_water
+        new_weeds = state.weed_count
+        # Check win condition: all letters in secret word are now guessed
+        if all(ch in new_guessed for ch in state.secret_word):
+            return GameState(
+                secret_word=state.secret_word,
+                guessed_letters=new_guessed,
+                remaining_water=new_water,
+                weed_count=new_weeds,
+                max_water=state.max_water,
+                status_message=f"You guessed the word: {state.secret_word}! The garden is thriving.",
+                game_over=True,
+                won=True,
+            )
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_water,
+            weed_count=new_weeds,
+            max_water=state.max_water,
+            status_message="Good guess! The garden grows.",
+            game_over=False,
+            won=False,
+        )
+    else:
+        # Wrong guess
+        new_water = state.remaining_water - 1
+        new_weeds = state.weed_count + 1
+        # Check loss condition
+        if new_water <= 0:
+            return GameState(
+                secret_word=state.secret_word,
+                guessed_letters=new_guessed,
+                remaining_water=0,
+                weed_count=new_weeds,
+                max_water=state.max_water,
+                status_message=f"The garden ran out of water. The word was: {state.secret_word}.",
+                game_over=True,
+                won=False,
+            )
+        return GameState(
+            secret_word=state.secret_word,
+            guessed_letters=new_guessed,
+            remaining_water=new_water,
+            weed_count=new_weeds,
+            max_water=state.max_water,
+            status_message="No match. A weed appears.",
+            game_over=False,
+            won=False,
+        )
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word with space-separated characters.
+
+    Guessed letters are shown; unguessed letters are shown as '_'.
+    Example: 'G _ R _ E _'
+    """
+    return " ".join(
+        ch if ch in state.guessed_letters else "_"
+        for ch in state.secret_word
+    )
+
+
+def is_won(state: GameState) -> bool:
+    """Return True if all letters of the secret word have been guessed."""
+    return all(ch in state.guessed_letters for ch in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Return True if water reached zero before the word was revealed."""
+    return state.remaining_water <= 0 and not is_won(state)
