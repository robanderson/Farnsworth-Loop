+"""Word list and word selection for Word Garden."""
+
+import random as _random
+
+# 10-word list from SPEC.md section 8, uppercase
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty configuration per SPEC.md section 7
+_DIFFICULTY_CONFIG = {
+    "easy":   {"water": 8, "min_len": 4, "max_len": 6},
+    "normal": {"water": 6, "min_len": 5, "max_len": 8},
+    "hard":   {"water": 4, "min_len": 7, "max_len": None},
+}
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return starting water level for the given difficulty.
+
+    Raises ValueError for unknown difficulty names.
+    """
+    difficulty = difficulty.lower()
+    if difficulty not in _DIFFICULTY_CONFIG:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose from: {', '.join(_DIFFICULTY_CONFIG)}"
+        )
+    return _DIFFICULTY_CONFIG[difficulty]["water"]
+
+
+def select_word(difficulty: str = "normal", rng=None) -> str:
+    """Return a random word filtered by difficulty length constraints.
+
+    difficulty: "easy" (4-6 letters), "normal" (5-8 letters), "hard" (7+).
+    rng: optional random.Random instance for deterministic selection;
+         defaults to the module-level random functions.
+
+    Raises ValueError for unknown difficulty names.
+    """
+    difficulty = difficulty.lower()
+    if difficulty not in _DIFFICULTY_CONFIG:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose from: {', '.join(_DIFFICULTY_CONFIG)}"
+        )
+
+    config = _DIFFICULTY_CONFIG[difficulty]
+    min_len = config["min_len"]
+    max_len = config["max_len"]
+
+    candidates = [
+        w for w in WORDS
+        if len(w) >= min_len and (max_len is None or len(w) <= max_len)
+    ]
+
+    if not candidates:
+        raise ValueError(
+            f"No words available for difficulty {difficulty!r}."
+        )
+
+    if rng is not None:
+        return rng.choice(candidates)
+    return _random.choice(candidates)
