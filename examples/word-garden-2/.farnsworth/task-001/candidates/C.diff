+"""Tests for word_garden/game.py — covers all SPEC section 16 cases."""
+
+import random
+import unittest
+
+from word_garden.game import (
+    GameState,
+    apply_guess,
+    display_word,
+    is_lost,
+    is_won,
+    new_game,
+    validate_guess,
+)
+
+
+def _make_state(word="GARDEN", water=6, guessed=None, weeds=0,
+                game_over=False, won=False, status_message=""):
+    """Helper: construct a GameState with sensible defaults."""
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(guessed or []),
+        remaining_water=water,
+        weed_count=weeds,
+        max_water=water,
+        status_message=status_message,
+        game_over=game_over,
+        won=won,
+    )
+
+
+class TestNewGame(unittest.TestCase):
+    """Tests for new_game()."""
+
+    def test_new_game_returns_gamestate(self):
+        rng = random.Random(0)
+        state = new_game(rng=rng)
+        self.assertIsInstance(state, GameState)
+
+    def test_new_game_word_is_uppercase(self):
+        rng = random.Random(0)
+        state = new_game(rng=rng)
+        self.assertEqual(state.secret_word, state.secret_word.upper())
+
+    def test_new_game_starts_with_zero_weeds(self):
+        rng = random.Random(0)
+        state = new_game(rng=rng)
+        self.assertEqual(state.weed_count, 0)
+
+    def test_new_game_full_water_normal(self):
+        rng = random.Random(0)
+        state = new_game(difficulty="normal", rng=rng)
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.max_water, 6)
+
+    def test_new_game_full_water_easy(self):
+        rng = random.Random(0)
+        state = new_game(difficulty="easy", rng=rng)
+        self.assertEqual(state.remaining_water, 8)
+
+    def test_new_game_full_water_hard(self):
+        rng = random.Random(0)
+        state = new_game(difficulty="hard", rng=rng)
+        self.assertEqual(state.remaining_water, 4)
+
+    def test_new_game_no_guessed_letters(self):
+        rng = random.Random(0)
+        state = new_game(rng=rng)
+        self.assertEqual(len(state.guessed_letters), 0)
+
+    def test_new_game_not_over(self):
+        rng = random.Random(0)
+        state = new_game(rng=rng)
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+
+class TestCorrectGuess(unittest.TestCase):
+    """SPEC section 16 case 1: a correct guess reveals matching letters."""
+
+    def test_correct_guess_adds_letter_to_guessed(self):
+        state = _make_state(word="GARDEN", water=6)
+        new_state = apply_guess(state, "G")
+        self.assertIn("G", new_state.guessed_letters)
+
+    def test_correct_guess_does_not_reduce_water(self):
+        state = _make_state(word="GARDEN", water=6)
+        new_state = apply_guess(state, "G")
+        self.assertEqual(new_state.remaining_water, 6)
+
+    def test_correct_guess_does_not_increase_weeds(self):
+        state = _make_state(word="GARDEN", water=6)
+        new_state = apply_guess(state, "G")
+        self.assertEqual(new_state.weed_count, 0)
+
+    def test_correct_guess_positive_message(self):
+        state = _make_state(word="GARDEN", water=6)
+        new_state = apply_guess(state, "G")
+        self.assertIn("Good", new_state.status_message)
+
+
+class TestIncorrectGuess(unittest.TestCase):
+    """SPEC section 16 cases 2 & 3: wrong guess -1 water, +1 weed."""
+
+    def test_wrong_guess_reduces_water_by_one(self):
+        state = _make_state(word="GARDEN", water=6)
+        new_state = apply_guess(state, "Z")
+        self.assertEqual(new_state.remaining_water, 5)
+
+    def test_wrong_guess_increases_weed_count_by_one(self):
+        state = _make_state(word="GARDEN", water=6)
+        new_state = apply_guess(state, "Z")
+        self.assertEqual(new_state.weed_count, 1)
+
+    def test_wrong_guess_records_letter(self):
+        state = _make_state(word="GARDEN", water=6)
+        new_state = apply_guess(state, "Z")
+        self.assertIn("Z", new_state.guessed_letters)
+
+    def test_wrong_guess_gentle_message(self):
+        state = _make_state(word="GARDEN", water=6)
+        new_state = apply_guess(state, "Z")
+        self.assertIn("weed", new_state.status_message.lower())
+
+    def test_wrong_guess_all_three_together(self):
+        """Positive assertion: water down by 1, weeds up by 1, letter recorded."""
+        state = _make_state(word="GARDEN", water=6, weeds=0)
+        new_state = apply_guess(state, "X")
+        self.assertEqual(new_state.remaining_water, state.remaining_water - 1)
+        self.assertEqual(new_state.weed_count, state.weed_count + 1)
+        self.assertIn("X", new_state.guessed_letters)
+
+
+class TestRepeatedGuess(unittest.TestCase):
+    """SPEC section 16 case 4: repeated guesses do not reduce water."""
+
+    def test_repeated_guess_no_water_change(self):
+        state = _make_state(word="GARDEN", water=6, guessed={"A"})
+        new_state = apply_guess(state, "A")
+        self.assertEqual(new_state.remaining_water, 6)
+
+    def test_repeated_guess_no_weed_change(self):
+        state = _make_state(word="GARDEN", water=6, guessed={"A"}, weeds=1)
+        new_state = apply_guess(state, "A")
+        self.assertEqual(new_state.weed_count, 1)
+
+    def test_repeated_guess_message_mentions_letter(self):
+        state = _make_state(word="GARDEN", water=6, guessed={"A"})
+        new_state = apply_guess(state, "A")
+        self.assertIn("A", new_state.status_message)
+        self.assertIn("already", new_state.status_message.lower())
+
+
+class TestValidateGuess(unittest.TestCase):
+    """SPEC section 16 cases 5 & 6: input validation and normalisation."""
+
+    def test_valid_lowercase_returns_uppercase(self):
+        """Case 6: lowercase input is normalised."""
+        letter, msg = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_valid_uppercase_returned_as_is(self):
+        letter, msg = validate_guess("Z")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+    def test_valid_with_whitespace_stripped(self):
+        letter, msg = validate_guess("  b  ")
+        self.assertEqual(letter, "B")
+        self.assertEqual(msg, "")
+
+    def test_empty_string_rejected(self):
+        """Case 5: invalid input is rejected."""
+        letter, msg = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_none_rejected(self):
+        letter, msg = validate_guess(None)
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_multiple_characters_rejected(self):
+        letter, msg = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertIn("single", msg.lower())
+
+    def test_digit_rejected(self):
+        letter, msg = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_symbol_rejected(self):
+        letter, msg = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_invalid_input_does_not_mutate_state(self):
+        """Validation does not consult or mutate game state."""
+        state = _make_state(word="GARDEN", water=6)
+        letter, msg = validate_guess("99")
+        self.assertIsNone(letter)
+        # State fields unchanged (validate_guess doesn't touch state)
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+
+
+class TestWinDetection(unittest.TestCase):
+    """SPEC section 16 case 7: win detection."""
+
+    def test_is_won_when_all_letters_guessed(self):
+        # All unique letters in FLOWER: F, L, O, W, E, R
+        state = _make_state(word="FLOWER", guessed={"F", "L", "O", "W", "E", "R"})
+        self.assertTrue(is_won(state))
+
+    def test_is_won_false_when_not_all_guessed(self):
+        state = _make_state(word="FLOWER", guessed={"F", "L"})
+        self.assertFalse(is_won(state))
+
+    def test_apply_guess_sets_game_over_on_win(self):
+        # One letter away from winning PYTHON: P,Y,T,H,O,N — guess final N
+        state = _make_state(word="PYTHON", guessed={"P", "Y", "T", "H", "O"})
+        new_state = apply_guess(state, "N")
+        self.assertTrue(new_state.game_over)
+        self.assertTrue(new_state.won)
+
+    def test_win_message_contains_word(self):
+        state = _make_state(word="PYTHON", guessed={"P", "Y", "T", "H", "O"})
+        new_state = apply_guess(state, "N")
+        self.assertIn("PYTHON", new_state.status_message)
+
+
+class TestLossDetection(unittest.TestCase):
+    """SPEC section 16 case 8: loss detection."""
+
+    def test_is_lost_when_water_zero(self):
+        state = _make_state(word="GARDEN", water=0, guessed={"Z", "X"})
+        self.assertTrue(is_lost(state))
+
+    def test_is_lost_false_when_water_remains(self):
+        state = _make_state(word="GARDEN", water=3)
+        self.assertFalse(is_lost(state))
+
+    def test_apply_guess_sets_game_over_on_loss(self):
+        # 1 water left, wrong guess should cause loss
+        state = _make_state(word="GARDEN", water=1, guessed={"Z"})
+        new_state = apply_guess(state, "X")
+        self.assertTrue(new_state.game_over)
+        self.assertFalse(new_state.won)
+        self.assertEqual(new_state.remaining_water, 0)
+
+    def test_loss_message_contains_word(self):
+        state = _make_state(word="GARDEN", water=1, guessed={"Z"})
+        new_state = apply_guess(state, "X")
+        self.assertIn("GARDEN", new_state.status_message)
+
+
+class TestDisplayWord(unittest.TestCase):
+    """SPEC section 16 case 9: display_word masks unguessed letters."""
+
+    def test_all_blanks_at_start(self):
+        state = _make_state(word="GARDEN", guessed=set())
+        result = display_word(state)
+        self.assertEqual(result, "_ _ _ _ _ _")
+
+    def test_partially_revealed(self):
+        state = _make_state(word="GARDEN", guessed={"G", "R"})
+        result = display_word(state)
+        self.assertEqual(result, "G _ R _ _ _")
+
+    def test_fully_revealed(self):
+        state = _make_state(word="GARDEN", guessed={"G", "A", "R", "D", "E", "N"})
+        result = display_word(state)
+        self.assertEqual(result, "G A R D E N")
+
+    def test_space_separated(self):
+        """Each character separated by a single space."""
+        state = _make_state(word="HI", guessed={"H"})
+        result = display_word(state)
+        self.assertEqual(result, "H _")
+
+    def test_repeated_letters_revealed(self):
+        """If a letter appears multiple times, all instances are revealed."""
+        state = _make_state(word="SEEDLING", guessed={"E"})
+        result = display_word(state)
+        # SEEDLING: S E E D L I N G — positions 1 and 2 (0-indexed) are E
+        self.assertEqual(result, "_ E E _ _ _ _ _")
+
+
+class TestGuessAfterGameOver(unittest.TestCase):
+    """Guessing after game_over is a no-op with a message."""
+
+    def test_guess_after_win_noop(self):
+        state = _make_state(word="HI", guessed={"H", "I"}, water=6,
+                            game_over=True, won=True)
+        new_state = apply_guess(state, "A")
+        self.assertEqual(new_state.remaining_water, 6)
+        self.assertEqual(new_state.weed_count, 0)
+        self.assertGreater(len(new_state.status_message), 0)
+
+    def test_guess_after_loss_noop(self):
+        state = _make_state(word="GARDEN", water=0, guessed={"Z"},
+                            game_over=True, won=False)
+        new_state = apply_guess(state, "A")
+        self.assertEqual(new_state.remaining_water, 0)
+        self.assertFalse(new_state.won)
+        self.assertGreater(len(new_state.status_message), 0)
+
+
+class TestIsWonIsLost(unittest.TestCase):
+    """Extra tests for is_won / is_lost edge cases."""
+
+    def test_win_not_lost_simultaneously(self):
+        """A won game is not also a lost game."""
+        state = _make_state(word="HI", guessed={"H", "I"}, water=0)
+        # Even at 0 water, if all letters guessed, is_won takes precedence
+        self.assertTrue(is_won(state))
+        self.assertFalse(is_lost(state))
+
+    def test_fresh_game_neither_won_nor_lost(self):
+        rng = random.Random(1)
+        state = new_game(rng=rng)
+        self.assertFalse(is_won(state))
+        self.assertFalse(is_lost(state))
+
+
+if __name__ == "__main__":
+    unittest.main()
