+"""Tests for word_garden/words.py."""
+
+import random
+import unittest
+
+from word_garden.words import WORDS, select_word, water_for
+
+
+class TestWordList(unittest.TestCase):
+    """Tests for the WORDS constant."""
+
+    def test_words_is_nonempty(self):
+        self.assertGreater(len(WORDS), 0)
+
+    def test_words_are_uppercase(self):
+        for word in WORDS:
+            self.assertEqual(word, word.upper(), f"{word!r} is not uppercase")
+
+    def test_words_contains_expected_entries(self):
+        # All ten words from SPEC.md section 8 must be present
+        expected = {
+            "GARDEN", "FLOWER", "PLANET", "PYTHON", "TERMINAL",
+            "MEADOW", "ORCHARD", "VINEYARD", "SEEDLING", "HARVEST",
+        }
+        self.assertEqual(expected, set(WORDS))
+
+
+class TestWaterFor(unittest.TestCase):
+    """Tests for water_for()."""
+
+    def test_easy_water(self):
+        self.assertEqual(water_for("easy"), 8)
+
+    def test_normal_water(self):
+        self.assertEqual(water_for("normal"), 6)
+
+    def test_hard_water(self):
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            water_for("extreme")
+
+    def test_case_insensitive(self):
+        self.assertEqual(water_for("NORMAL"), 6)
+        self.assertEqual(water_for("Easy"), 8)
+
+
+class TestSelectWord(unittest.TestCase):
+    """Tests for select_word() — SPEC section 16 case 10."""
+
+    def _make_rng(self, seed=42):
+        return random.Random(seed)
+
+    def test_returns_string(self):
+        rng = self._make_rng()
+        result = select_word(rng=rng)
+        self.assertIsInstance(result, str)
+
+    def test_returns_uppercase(self):
+        rng = self._make_rng()
+        result = select_word(rng=rng)
+        self.assertEqual(result, result.upper())
+
+    def test_result_in_word_list(self):
+        rng = self._make_rng()
+        result = select_word(rng=rng)
+        self.assertIn(result, WORDS)
+
+    def test_easy_word_length(self):
+        """Easy difficulty: word length 4-6."""
+        rng = self._make_rng()
+        for _ in range(20):
+            word = select_word(difficulty="easy", rng=rng)
+            self.assertGreaterEqual(len(word), 4)
+            self.assertLessEqual(len(word), 6)
+
+    def test_normal_word_length(self):
+        """Normal difficulty: word length 5-8."""
+        rng = self._make_rng()
+        for _ in range(20):
+            word = select_word(difficulty="normal", rng=rng)
+            self.assertGreaterEqual(len(word), 5)
+            self.assertLessEqual(len(word), 8)
+
+    def test_hard_word_length(self):
+        """Hard difficulty: word length 7+."""
+        rng = self._make_rng()
+        for _ in range(20):
+            word = select_word(difficulty="hard", rng=rng)
+            self.assertGreaterEqual(len(word), 7)
+
+    def test_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            select_word(difficulty="legendary")
+
+    def test_deterministic_with_rng(self):
+        """Same seed produces same word."""
+        word1 = select_word(rng=random.Random(123))
+        word2 = select_word(rng=random.Random(123))
+        self.assertEqual(word1, word2)
+
+    def test_default_rng_returns_valid_word(self):
+        """select_word with no rng argument still returns a valid word."""
+        result = select_word()
+        self.assertIn(result, WORDS)
+
+
+if __name__ == "__main__":
+    unittest.main()
