+"""Tests for word_garden.words — covers SPEC.md section 16 case 10."""
+
+import random
+import unittest
+from word_garden.words import WORDS, select_word, water_for
+
+
+class TestWordList(unittest.TestCase):
+    """Basic sanity checks on the WORDS constant."""
+
+    def test_word_list_has_ten_entries(self):
+        self.assertEqual(len(WORDS), 10)
+
+    def test_all_words_are_uppercase(self):
+        for word in WORDS:
+            self.assertEqual(word, word.upper(), f"{word!r} is not uppercase")
+
+    def test_all_words_are_alphabetic(self):
+        for word in WORDS:
+            self.assertTrue(word.isalpha(), f"{word!r} contains non-alpha characters")
+
+
+class TestSelectWord(unittest.TestCase):
+    """Case 10 — The word selector returns a valid word."""
+
+    def test_select_word_easy_is_in_words(self):
+        rng = random.Random(1)
+        word = select_word(difficulty="easy", rng=rng)
+        self.assertIn(word, WORDS)
+
+    def test_select_word_normal_is_in_words(self):
+        rng = random.Random(2)
+        word = select_word(difficulty="normal", rng=rng)
+        self.assertIn(word, WORDS)
+
+    def test_select_word_hard_is_in_words(self):
+        rng = random.Random(3)
+        word = select_word(difficulty="hard", rng=rng)
+        self.assertIn(word, WORDS)
+
+    def test_select_word_easy_length_constraint(self):
+        # Easy: word length 4–6
+        rng = random.Random(0)
+        for _ in range(20):
+            word = select_word(difficulty="easy", rng=rng)
+            self.assertGreaterEqual(len(word), 4)
+            self.assertLessEqual(len(word), 6)
+
+    def test_select_word_normal_length_constraint(self):
+        # Normal: word length 5–8
+        rng = random.Random(0)
+        for _ in range(20):
+            word = select_word(difficulty="normal", rng=rng)
+            self.assertGreaterEqual(len(word), 5)
+            self.assertLessEqual(len(word), 8)
+
+    def test_select_word_hard_length_constraint(self):
+        # Hard: word length 7+
+        rng = random.Random(0)
+        for _ in range(20):
+            word = select_word(difficulty="hard", rng=rng)
+            self.assertGreaterEqual(len(word), 7)
+
+    def test_select_word_unknown_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            select_word(difficulty="extreme")
+
+    def test_select_word_case_insensitive_difficulty(self):
+        rng = random.Random(5)
+        word = select_word(difficulty="EASY", rng=rng)
+        self.assertIn(word, WORDS)
+
+    def test_select_word_deterministic_with_rng(self):
+        rng1 = random.Random(77)
+        rng2 = random.Random(77)
+        word1 = select_word(difficulty="normal", rng=rng1)
+        word2 = select_word(difficulty="normal", rng=rng2)
+        self.assertEqual(word1, word2)
+
+    def test_select_word_default_rng(self):
+        # Should not raise; returns a word from the list
+        word = select_word()
+        self.assertIn(word, WORDS)
+
+
+class TestWaterFor(unittest.TestCase):
+    """water_for returns correct starting water per difficulty."""
+
+    def test_water_for_easy(self):
+        self.assertEqual(water_for("easy"), 8)
+
+    def test_water_for_normal(self):
+        self.assertEqual(water_for("normal"), 6)
+
+    def test_water_for_hard(self):
+        self.assertEqual(water_for("hard"), 4)
+
+    def test_water_for_case_insensitive(self):
+        self.assertEqual(water_for("NORMAL"), 6)
+        self.assertEqual(water_for("Easy"), 8)
+
+    def test_water_for_unknown_raises(self):
+        with self.assertRaises(ValueError):
+            water_for("impossible")
+
+
+if __name__ == "__main__":
+    unittest.main()
