+"""Core game logic for Word Garden.
+
+Pure logic — no stdin/stdout, no UI.
+"""
+
+from __future__ import annotations
+
+import random
+from dataclasses import dataclass, field
+
+from word_garden import words as _words
+
+
+@dataclass
+class GameState:
+    """Complete mutable state for one Word Garden session."""
+
+    secret_word: str
+    guessed_letters: set[str]
+    remaining_water: int
+    weed_count: int
+    max_water: int
+    status_message: str = ""
+    game_over: bool = False
+    won: bool = False
+
+
+def new_game(difficulty: str = "normal", rng: random.Random | None = None) -> GameState:
+    """Start a fresh game.
+
+    Selects a word via words.select_word, uppercases it, and returns a
+    GameState with full water and zero weeds.
+    """
+    word = _words.select_word(difficulty=difficulty, rng=rng).upper()
+    water = _words.water_for(difficulty=difficulty)
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+        status_message="",
+        game_over=False,
+        won=False,
+    )
+
+
+def validate_guess(input_text: str) -> tuple[str | None, str]:
+    """Validate raw player input.
+
+    Returns (letter, "") when input is valid — trimmed, uppercased, exactly
+    one alphabetic character.
+    Returns (None, message) with a specific helpful message when input is
+    invalid.
+
+    Does NOT consult game state; repeated-guess detection is in apply_guess.
+    """
+    stripped = input_text.strip()
+
+    if len(stripped) == 0:
+        return None, "Please enter a single letter."
+
+    if len(stripped) > 1:
+        return None, "Please enter a single letter."
+
+    char = stripped.upper()
+
+    if not char.isalpha():
+        return None, "That is not a letter."
+
+    return char, ""
+
+
+def apply_guess(state: GameState, letter: str) -> GameState:
+    """Apply a single already-validated uppercase letter to the game state.
+
+    Rules (SPEC sections 6.3–6.5):
+    - If game is already over: no-op with a message.
+    - Repeated guess: no water/weed change, message says already guessed.
+    - Correct guess: reveal letters, no water/weed change, positive message.
+    - Wrong guess: water -1, weeds +1, gentle warning message.
+    Updates game_over/won when the guess ends the game.
+    """
+    if state.game_over:
+        state.status_message = "The game is already over."
+        return state
+
+    # Repeated guess check
+    if letter in state.guessed_letters:
+        state.status_message = f"You already guessed {letter}. Try another letter."
+        return state
+
+    # Record the guess
+    state.guessed_letters.add(letter)
+
+    if letter in state.secret_word:
+        # Correct guess
+        state.status_message = "Good guess! The garden grows."
+    else:
+        # Wrong guess
+        state.remaining_water -= 1
+        state.weed_count += 1
+        state.status_message = "No match. A weed appears."
+
+    # Check end conditions
+    if is_won(state):
+        state.game_over = True
+        state.won = True
+        state.status_message = f"Bloom! You guessed the word: {state.secret_word}"
+    elif is_lost(state):
+        state.game_over = True
+        state.won = False
+        state.status_message = (
+            f"The garden ran out of water. The word was: {state.secret_word}"
+        )
+
+    return state
+
+
+def display_word(state: GameState) -> str:
+    """Return the masked word with guessed letters revealed.
+
+    Unguessed positions are shown as '_'. Letters are space-separated.
+    Example: 'G _ R _ E _'
+    """
+    return " ".join(
+        ch if ch in state.guessed_letters else "_"
+        for ch in state.secret_word
+    )
+
+
+def is_won(state: GameState) -> bool:
+    """Return True when all letters of the secret word have been guessed."""
+    return all(ch in state.guessed_letters for ch in state.secret_word)
+
+
+def is_lost(state: GameState) -> bool:
+    """Return True when water has reached zero and the word is not yet won."""
+    return state.remaining_water <= 0 and not is_won(state)
