+"""Tests for word_garden.game — covers SPEC.md section 16 cases 1–9."""
+
+import unittest
+from word_garden.game import (
+    GameState,
+    new_game,
+    validate_guess,
+    apply_guess,
+    display_word,
+    is_won,
+    is_lost,
+)
+
+
+def _state_with_word(word: str, water: int = 6) -> GameState:
+    """Helper: build a fresh GameState for a known word."""
+    return GameState(
+        secret_word=word,
+        guessed_letters=set(),
+        remaining_water=water,
+        weed_count=0,
+        max_water=water,
+    )
+
+
+class TestCorrectGuess(unittest.TestCase):
+    """Case 1 — A correct guess reveals matching letters."""
+
+    def test_correct_guess_reveals_letters(self):
+        state = _state_with_word("GARDEN")
+        state = apply_guess(state, "A")
+        self.assertIn("A", state.guessed_letters)
+
+    def test_correct_guess_does_not_reduce_water(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "G")
+        self.assertEqual(state.remaining_water, 6)
+
+    def test_correct_guess_does_not_add_weed(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "G")
+        self.assertEqual(state.weed_count, 0)
+
+    def test_correct_guess_positive_message(self):
+        state = _state_with_word("GARDEN")
+        state = apply_guess(state, "G")
+        self.assertIn("garden", state.status_message.lower())
+
+
+class TestIncorrectGuessWater(unittest.TestCase):
+    """Case 2 — An incorrect guess reduces water by one."""
+
+    def test_wrong_guess_water_decreases_by_one(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, 5)
+
+
+class TestIncorrectGuessWeeds(unittest.TestCase):
+    """Case 3 — An incorrect guess increases weed count by one."""
+
+    def test_wrong_guess_weed_increases_by_one(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "Z")
+        self.assertEqual(state.weed_count, 1)
+
+    def test_wrong_guess_records_letter(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "Z")
+        self.assertIn("Z", state.guessed_letters)
+
+    def test_wrong_guess_friendly_message(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "Z")
+        self.assertIn("weed", state.status_message.lower())
+
+
+class TestRepeatedGuess(unittest.TestCase):
+    """Case 4 — Repeated guesses do not reduce water."""
+
+    def test_repeated_guess_no_water_change(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "Z")          # wrong first time
+        water_after_first = state.remaining_water
+        state = apply_guess(state, "Z")          # repeated
+        self.assertEqual(state.remaining_water, water_after_first)
+
+    def test_repeated_guess_no_weed_change(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "Z")
+        weed_after_first = state.weed_count
+        state = apply_guess(state, "Z")
+        self.assertEqual(state.weed_count, weed_after_first)
+
+    def test_repeated_guess_message_mentions_letter(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "A")
+        state = apply_guess(state, "A")
+        self.assertIn("A", state.status_message)
+
+    def test_repeated_correct_guess_no_extra_water_loss(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "G")          # correct first time
+        state = apply_guess(state, "G")          # repeated
+        self.assertEqual(state.remaining_water, 6)
+        self.assertEqual(state.weed_count, 0)
+
+
+class TestInvalidInput(unittest.TestCase):
+    """Case 5 — Invalid input is rejected."""
+
+    def test_empty_input_returns_none(self):
+        letter, msg = validate_guess("")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_whitespace_only_returns_none(self):
+        letter, msg = validate_guess("   ")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_number_input_returns_none(self):
+        letter, msg = validate_guess("7")
+        self.assertIsNone(letter)
+        self.assertIn("letter", msg.lower())
+
+    def test_symbol_input_returns_none(self):
+        letter, msg = validate_guess("!")
+        self.assertIsNone(letter)
+        self.assertIn("letter", msg.lower())
+
+    def test_multiple_characters_returns_none(self):
+        letter, msg = validate_guess("apple")
+        self.assertIsNone(letter)
+        self.assertGreater(len(msg), 0)
+
+    def test_invalid_input_does_not_mutate_state(self):
+        state = _state_with_word("GARDEN", water=6)
+        water_before = state.remaining_water
+        weeds_before = state.weed_count
+        # validate_guess does not touch state; ensure state unchanged
+        letter, msg = validate_guess("99")
+        self.assertIsNone(letter)
+        self.assertEqual(state.remaining_water, water_before)
+        self.assertEqual(state.weed_count, weeds_before)
+
+
+class TestLowercaseNormalization(unittest.TestCase):
+    """Case 6 — Lowercase input is normalized."""
+
+    def test_lowercase_letter_normalized_to_upper(self):
+        letter, msg = validate_guess("a")
+        self.assertEqual(letter, "A")
+        self.assertEqual(msg, "")
+
+    def test_lowercase_with_spaces_normalized(self):
+        letter, msg = validate_guess("  z  ")
+        self.assertEqual(letter, "Z")
+        self.assertEqual(msg, "")
+
+
+class TestWinDetection(unittest.TestCase):
+    """Case 7 — The game detects a win."""
+
+    def test_win_detected_when_all_letters_guessed(self):
+        state = _state_with_word("CAT", water=6)
+        state = apply_guess(state, "C")
+        state = apply_guess(state, "A")
+        state = apply_guess(state, "T")
+        self.assertTrue(state.game_over)
+        self.assertTrue(state.won)
+
+    def test_is_won_helper(self):
+        state = _state_with_word("CAT", water=6)
+        state.guessed_letters = {"C", "A", "T"}
+        self.assertTrue(is_won(state))
+
+    def test_win_sets_game_over(self):
+        state = _state_with_word("GO", water=4)
+        state = apply_guess(state, "G")
+        state = apply_guess(state, "O")
+        self.assertTrue(state.game_over)
+        self.assertTrue(state.won)
+
+    def test_win_message_includes_word(self):
+        state = _state_with_word("GO", water=4)
+        state = apply_guess(state, "G")
+        state = apply_guess(state, "O")
+        self.assertIn("GO", state.status_message)
+
+    def test_no_win_when_letters_remain(self):
+        state = _state_with_word("CAT", water=6)
+        state = apply_guess(state, "C")
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+
+
+class TestLossDetection(unittest.TestCase):
+    """Case 8 — The game detects a loss."""
+
+    def test_loss_detected_when_water_runs_out(self):
+        state = _state_with_word("GARDEN", water=2)
+        state = apply_guess(state, "Z")  # wrong -1 water
+        state = apply_guess(state, "Q")  # wrong -1 water -> 0
+        self.assertTrue(state.game_over)
+        self.assertFalse(state.won)
+
+    def test_is_lost_helper(self):
+        state = _state_with_word("GARDEN", water=0)
+        self.assertTrue(is_lost(state))
+
+    def test_not_lost_when_water_remains(self):
+        state = _state_with_word("GARDEN", water=6)
+        state = apply_guess(state, "Z")
+        self.assertFalse(state.game_over)
+
+    def test_loss_message_includes_word(self):
+        state = _state_with_word("GARDEN", water=2)
+        state = apply_guess(state, "Z")
+        state = apply_guess(state, "Q")
+        self.assertIn("GARDEN", state.status_message)
+
+    def test_no_further_change_after_loss(self):
+        state = _state_with_word("XY", water=1)
+        state = apply_guess(state, "Z")    # wrong -> water 0 -> game over
+        water_at_loss = state.remaining_water
+        state = apply_guess(state, "Q")    # after game over: no-op
+        self.assertEqual(state.remaining_water, water_at_loss)
+
+
+class TestDisplayWord(unittest.TestCase):
+    """Case 9 — The displayed word masks unguessed letters."""
+
+    def test_fully_masked_at_start(self):
+        state = _state_with_word("GARDEN")
+        self.assertEqual(display_word(state), "_ _ _ _ _ _")
+
+    def test_correct_guess_reveals_letter(self):
+        state = _state_with_word("GARDEN")
+        state.guessed_letters = {"G", "R"}
+        self.assertEqual(display_word(state), "G _ R _ _ _")
+
+    def test_fully_revealed_when_all_guessed(self):
+        state = _state_with_word("GARDEN")
+        state.guessed_letters = set("GARDEN")
+        self.assertEqual(display_word(state), "G A R D E N")
+
+    def test_repeated_letter_revealed_in_all_positions(self):
+        state = _state_with_word("LEVEL")
+        state.guessed_letters = {"L"}
+        self.assertEqual(display_word(state), "L _ _ _ L")
+
+
+class TestGameOverNoOp(unittest.TestCase):
+    """Guessing after game_over is a no-op."""
+
+    def test_guess_after_win_is_noop(self):
+        state = _state_with_word("GO", water=4)
+        state = apply_guess(state, "G")
+        state = apply_guess(state, "O")
+        self.assertTrue(state.game_over)
+        water_before = state.remaining_water
+        state = apply_guess(state, "Z")
+        self.assertEqual(state.remaining_water, water_before)
+
+    def test_guess_after_loss_is_noop(self):
+        state = _state_with_word("GARDEN", water=1)
+        state = apply_guess(state, "Z")  # wrong -> game over
+        self.assertTrue(state.game_over)
+        state = apply_guess(state, "Q")
+        self.assertFalse(state.won)
+        self.assertTrue(state.game_over)
+
+
+class TestNewGame(unittest.TestCase):
+    """new_game should produce a valid initial state."""
+
+    def test_new_game_normal_difficulty(self):
+        import random
+        rng = random.Random(42)
+        state = new_game(difficulty="normal", rng=rng)
+        self.assertIsInstance(state, GameState)
+        self.assertFalse(state.game_over)
+        self.assertFalse(state.won)
+        self.assertEqual(state.weed_count, 0)
+        self.assertEqual(len(state.guessed_letters), 0)
+        self.assertEqual(state.remaining_water, state.max_water)
+
+    def test_new_game_water_matches_difficulty(self):
+        import random
+        from word_garden.words import water_for
+        rng = random.Random(0)
+        state = new_game(difficulty="easy", rng=rng)
+        self.assertEqual(state.max_water, water_for("easy"))
+
+    def test_new_game_word_is_uppercase(self):
+        import random
+        rng = random.Random(99)
+        state = new_game(rng=rng)
+        self.assertEqual(state.secret_word, state.secret_word.upper())
+
+    def test_new_game_invalid_difficulty_raises(self):
+        with self.assertRaises(ValueError):
+            new_game(difficulty="ultra")
+
+
+if __name__ == "__main__":
+    unittest.main()
