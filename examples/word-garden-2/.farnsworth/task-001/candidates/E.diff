+"""Word list and word selection logic for Word Garden."""
+
+import random as _random
+
+# The canonical 10-word list from SPEC.md section 8 (all uppercase)
+WORDS = [
+    "GARDEN",
+    "FLOWER",
+    "PLANET",
+    "PYTHON",
+    "TERMINAL",
+    "MEADOW",
+    "ORCHARD",
+    "VINEYARD",
+    "SEEDLING",
+    "HARVEST",
+]
+
+# Difficulty table from SPEC.md section 7
+_DIFFICULTY_TABLE = {
+    "easy":   {"water": 8, "min_len": 4, "max_len": 6},
+    "normal": {"water": 6, "min_len": 5, "max_len": 8},
+    "hard":   {"water": 4, "min_len": 7, "max_len": None},
+}
+
+
+def water_for(difficulty: str = "normal") -> int:
+    """Return starting water count for the given difficulty level.
+
+    Raises ValueError for unknown difficulty strings.
+    """
+    difficulty = difficulty.lower()
+    if difficulty not in _DIFFICULTY_TABLE:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose one of: {', '.join(_DIFFICULTY_TABLE)}"
+        )
+    return _DIFFICULTY_TABLE[difficulty]["water"]
+
+
+def select_word(difficulty: str = "normal", rng: _random.Random | None = None) -> str:
+    """Return a randomly selected word filtered by difficulty.
+
+    difficulty: "easy", "normal", or "hard"
+    rng: optional random.Random instance for deterministic selection;
+         if None, the module-level random functions are used.
+
+    Raises ValueError for unknown difficulty.
+    """
+    difficulty = difficulty.lower()
+    if difficulty not in _DIFFICULTY_TABLE:
+        raise ValueError(
+            f"Unknown difficulty {difficulty!r}. "
+            f"Choose one of: {', '.join(_DIFFICULTY_TABLE)}"
+        )
+
+    settings = _DIFFICULTY_TABLE[difficulty]
+    min_len = settings["min_len"]
+    max_len = settings["max_len"]
+
+    candidates = [
+        w for w in WORDS
